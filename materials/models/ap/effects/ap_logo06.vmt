UnLitTwoTexture
{
	$basetexture "models/ap/effects/ap_logo06"
	$texture2 "models/effects/cappoint_beam_lines_n"
	$additive 1
	$model 1
	
	Proxies
	{
		TextureScroll
		{
			texturescrollvar $texture2transform
			texturescrollrate .1
			texturescrollangle 90
		}
		Sine
		{
			Sineperiod 2
			SineMax 1
			SineMin ".7"
			resultVar $color
		}
	}
}
