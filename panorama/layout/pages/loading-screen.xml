<root>
	<styles>
		<include src="file://{resources}/styles/main.scss" />
		<include src="file://{resources}/styles/pages/loading-screen.scss" />
	</styles>
	<scripts>
		<include src="file://{scripts}/common/dev.ts" />
		<include src="file://{scripts}/pages/loading-screen.ts" />
	</scripts>

	<Panel class="loadingscreen">
		<Image
			id="BackgroundMapImage1"
			class="loadingscreen__background loadingscreen__background-image1"
			src=""
			scaling="stretch-to-cover-preserve-aspect"
		/>
		<Image
			id="BackgroundMapImage2"
			class="loadingscreen__background loadingscreen__background-image2"
			src=""
			scaling="stretch-to-cover-preserve-aspect"
		/>
		<Image
			id="BackgroundMapImage3"
			class="loadingscreen__background loadingscreen__background-image3"
			src=""
			scaling="stretch-to-cover-preserve-aspect"
		/>
		<Image
			id="BackgroundMapImage4"
			class="loadingscreen__background loadingscreen__background-image4"
			src=""
			scaling="stretch-to-cover-preserve-aspect"
		/>

		<!-- todo: set the logo dynamically -->
		<!-- Pivot (26/11/2025): Re-enabling this in the hopes that custom campaigns will be able to override this -->
		<Panel class="loadingscreen__logo">
			<AnimatedImageStrip
				animating="true"
				defaultframe="0"
				frametime="125ms"
				src=""
				defaultsrc="file://{images}/menu/p2ce/spinner_strip.tga"
				scaling="stretch-to-cover-preserve-aspect"
			/>
			<Image
				id="Logo"
				src="file://{images}/archipelago/portalpelago_v2.png"
				scaling="stretch-to-fit-preserve-aspect"
				hittest="false"
			/>
		</Panel>

		<Panel class="loadingscreen__fade--dark" />
		<Panel id="LoadingScreenContents" class="loadingscreen__contents" />

		<Panel id="" class="full-width full-height">
		</Panel>

		<Panel class="loadingscreen__progress-panel">
			<Panel class="loadingscreen__grid1" hittest="false" />
			<Panel class="loadingscreen__grid2" hittest="false" />
			<Panel class="full-width flow-down vertical-align-center">
				<Panel class="full-width">
					<Label id="ProgressStatusText" class="loadingscreen__details" text="Progress" />
					<Label id="PercentText" class="loadingscreen__percentage-label" text="{d:percent}%" />
				</Panel>
				<ProgressBar id="ProgressBar" class="progressbar loadingscreen__progressbar" />
			</Panel>
		</Panel>
	</Panel>
</root>
