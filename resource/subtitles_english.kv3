		"turret.sp_sabotage_factory_defect_laugh05" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> [evil laughter]"
		"turret.sp_sabotage_factory_defect_laugh06" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> [evil laughter]"
		"turret.sp_sabotage_factory_defect_laugh07" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> [evil laughter]"
		"turret.sp_sabotage_factory_defect_pass01" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> [evil laughter]"
		"turret.sp_sabotage_factory_defect_pass02" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Really? Alright."
		"turret.sp_sabotage_factory_defect_pass03" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yes, indeed. Yes, indeed."
		"turret.sp_sabotage_factory_defect_pass04" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Alright. Your funeral, pal."
		"turret.sp_sabotage_factory_defect_pass05" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> So... we're all supposed to be blind, then, right? Not just me? Alright, fantastic."
		"turret.sp_sabotage_factory_defect_pass06" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> I, uh... don't have any bullets. Are you gonna give me bullets? Are the bullets up there?"
		"turret.sp_sabotage_factory_defect_pass07" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Where do I get my gun?"
		"turret.sp_sabotage_factory_defect_pass08" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Do, uh.... we get some eyes at some point?"
		"turret.sp_sabotage_factory_defect_pass09" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yeah, I'm uh... I'm a bad man!"
		"turret.sp_sabotage_factory_defect_pass10" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> I, uh... I am a bad man."
		"turret.sp_sabotage_factory_defect_postrange01" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Well, I gave it everything I could. Can't ask for more than that."
		"turret.sp_sabotage_factory_defect_postrange02" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Uhhhh... Blam! Blam blam blam! I'm not defective!"
		"turret.sp_sabotage_factory_defect_postrange03" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Well, I did my best."
		"turret.sp_sabotage_factory_defect_postrange04" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Oh, no. I'm one of the bad ones, aren't I?"
		"turret.sp_sabotage_factory_defect_postrange05" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Hey, squeaky-voice! Gimme some of your bullets."
		"turret.sp_sabotage_factory_defect_postrange06" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Can I get some bullets here? Anybody got bullets?"
		"turret.sp_sabotage_factory_defect_postrange07" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Anyone got any bullets?"
		"turret.sp_sabotage_factory_defect_postrange08" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Well, I tried."
		"turret.sp_sabotage_factory_defect_postrange09" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Uh... no bullets. Sorry."
		"turret.sp_sabotage_factory_defect_postrange10" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> No can do."
		"turret.sp_sabotage_factory_defect_postrange11" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Uh, no bullets. Sorry."
		"turret.sp_sabotage_factory_defect_postrange12" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Hey. squeaky-voice! How did I do?"
		"turret.sp_sabotage_factory_defect_postrange13" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yeah! What's happening?"
		"turret.sp_sabotage_factory_defect_postrange14" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yeah, I got it, didn't I?"
		"turret.sp_sabotage_factory_defect_postrange15" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yeah."
		"turret.sp_sabotage_factory_defect_postrange16" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yeah!"
		"turret.sp_sabotage_factory_defect_postrange17" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Did I hit it? I hit it, didn't I?"
		"turret.sp_sabotage_factory_defect_postrange18" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yeah! Clickety, click, click. Right on the money."
		"turret.sp_sabotage_factory_defect_postrange19" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Shootin' blanks every time. All the time."
		"turret.sp_sabotage_factory_defect_postrange20" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Yeah, that's right. Little bullseye."
		"turret.sp_sabotage_factory_defect_postrange21" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> What did I hit?"
		"turret.sp_sabotage_factory_defect_postrange22" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> Welp, can't win 'em all."
		"turret.sp_sabotage_factory_defect_postrange23" = "<font color=\"rgb(197,208,230)\"><b>Defective Turret:</b> How was that?"
