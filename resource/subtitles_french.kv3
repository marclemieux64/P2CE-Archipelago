		"ep_01.al_stalk_getemoff06" = "<font color=\"rgb(255,212,255)\">Oh, mon Dieu."
		"ep_01.al_stalk_getemoff07" = "<font color=\"rgb(255,212,255)\">Gordon, à l'aide! S'il vous plaît!"
		"ep_01.al_stalk_getemoff08" = "<font color=\"rgb(255,212,255)\">À l'aide, s'il vous plaît!"
