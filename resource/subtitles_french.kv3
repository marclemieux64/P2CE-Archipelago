		"ep1_citizen.cit_alert_antlions12_male" = "Avant, les défenses du Cartel les tenaient à distance."
		"ep1_citizen.cit_alert_antlions13_male" = "Les fourmis-lions n'entraient jamais dans la ville avant... enfin, la semaine dernière."
		"ep1_citizen.cit_alert_antlions14_male" = "Au moins, les fourmis-lions nous détestent autant que le Cartel."
		"ep1_citizen.cit_alert_antlions15_male" = "D'abord le Cartel... puis ça!"
		"ep1_citizen.cit_alert_antlions16_male" = "Bouchez-moi ces trous!"
		"ep1_citizen.cit_alert_antlions17_male" = "Elles viennent par ces trous!"
		"ep1_citizen.cit_alert_antlions18_male" = "Sales bestioles!"
		"ep1_citizen.cit_alert_gunship01_male" = "Attention, il va tirer!"
		"ep1_citizen.cit_alert_gunship02_male" = "Il vient vers nous!"
		"ep1_citizen.cit_alert_gunship03_male" = "Abattez-le!"
		"ep1_citizen.cit_alert_gunship04_male" = "Il faut le descendre!"
		"ep1_citizen.cit_alert_gunship05_male" = "Détruisez-le avant qu'il revienne!"
		"ep1_citizen.cit_alert_gunship06_male" = "Il va nous déchiqueter!"
		"ep1_citizen.cit_alert_gunship07_male" = "Cette chose va nous dévorer!"
		"ep1_citizen.cit_alert_gunship08_male" = "On en vient presque à regretter les crabes de têtes."
		"ep1_citizen.cit_alert_head01_male" = "Des crabes de têtes!"
		"ep1_citizen.cit_alert_head02_male" = "C'est ça, un crabe de tête... aahhh..."
		"ep1_citizen.cit_alert_head03_male" = "Enlevez-moi ça! Enlevez-le!"
		"ep1_citizen.cit_alert_head03a_male" = "Enlevez-moi ça! Enlevez-le!"
		"ep1_citizen.cit_alert_head04_male" = "Enlevez-le-moi!"
		"ep1_citizen.cit_alert_head05_male" = "Bwaaah!"
		"ep1_citizen.cit_alert_head06_male" = "Merde!"
		"ep1_citizen.cit_alert_head07_male" = "C'est quoi, ça?"
		"ep1_citizen.cit_alert_head08_male" = "Ne le laissez pas vous sauter à la tête!"
		"ep1_citizen.cit_alert_rollers01_male" = "Des lamineurs!"
		"ep1_citizen.cit_alert_rollers02_male" = "Les laissez pas s'approcher!"
		"ep1_citizen.cit_alert_rollers03_male" = "Restez éloignés!"
		"ep1_citizen.cit_alert_rollers04_male" = "À l'aide!"
		"ep1_citizen.cit_alert_soldier_above_male" = "Ils viennent d'en haut!"
		"ep1_citizen.cit_alert_soldier01_male" = "On est que des cibles maintenant pour eux."
		"ep1_citizen.cit_alert_soldier02_male" = "Mais pourquoi sont-ils encore là?"
		"ep1_citizen.cit_alert_soldier03_male" = "Leur leader est parti! Mais pourquoi est-ce qu'ils restent?"
		"ep1_citizen.cit_alert_soldier04_male" = "Des soldats!"
		"ep1_citizen.cit_alert_soldier05_male" = "C'est la milice!"
		"ep1_citizen.cit_alert_soldier06_male" = "Pourquoi ils ne sont pas partis avec le reste du Cartel?"
		"ep1_citizen.cit_alert_soldier07_male" = "Traîtres!"
		"ep1_citizen.cit_alert_zombie01_male" = "Des zombies!"
		"ep1_citizen.cit_alert_zombie02_male" = "C'est quoi... un zombie?"
		"ep1_citizen.cit_alert_zombie03_male" = "C'est quoi ça?"
		"ep1_citizen.cit_alert_zombie04_male" = "Tuez-le!"
		"ep1_citizen.cit_alert_zombie05_male" = "Mon Dieu, qu'est-ce que c'est que ça?"
		"ep1_citizen.cit_alert_zombie06_male" = "Tuez-les!"
		"ep1_citizen.cit_alert_zombie07_male" = "Visez la tête!"
		"ep1_citizen.cit_alert_zombie08_male" = "Merde! Je crois que je connais ce gars!"
		"ep1_citizen.cit_alert_zombie09_male" = "Tuez-le!"
		"ep1_citizen.cit_buddykilled01_male" = "Ça va?"
		"ep1_citizen.cit_buddykilled02_male" = "Mon Dieu... je vais y passer... j'en suis sûr."
		"ep1_citizen.cit_buddykilled03_male" = "Non!"
		"ep1_citizen.cit_buddykilled04_male" = "Mon Dieu!"
		"ep1_citizen.cit_buddykilled05_male" = "Debout!"
		"ep1_citizen.cit_buddykilled06_male" = "Avancez!"
		"ep1_citizen.cit_buddykilled07_male" = "Oh, merde!"
		"ep1_citizen.cit_buddykilled08_male" = "Homme à terre!"
		"ep1_citizen.cit_buddykilled09_male" = "Pourquoi?"
		"ep1_citizen.cit_buddykilled10_male" = "On a fait une erreur terrible..."
		"ep1_citizen.cit_buddykilled11_male" = "On va tous mourir!"
		"ep1_citizen.cit_buddykilled12_male" = "Ça y est... je suis énervé!"
		"ep1_citizen.cit_buddykilled13_male" = "Ils ont tué le nouveau!"
		"ep1_citizen.cit_comehere_male" = "Par ici!"
		"ep1_citizen.cit_denytrain01_male" = "Pas vous, Freeman! Vous avez du travail."
		"ep1_citizen.cit_denytrain02_male" = "En arrière, Doc... Je suis sûr que vous voulez aider les autres à embarquer d'abord."
		"ep1_citizen.cit_denytrain03_male" = "Vous êtes supposé attendre que tout le monde soit à bord."
		"ep1_citizen.cit_denytrain04_male" = "Hé, Freeman. Allez donc aider les autres."
		"ep1_citizen.cit_evac_casualty01_male" = "Vous pouvez faire mieux que ça!"
		"ep1_citizen.cit_evac_casualty02_male" = "Ils sont tous en train de mourir."
		"ep1_citizen.cit_evac_casualty03_male" = "On en a perdu un autre!"
		"ep1_citizen.cit_evac_casualty04_male" = "N'en perdez pas un autre, Freeman!"
		"ep1_citizen.cit_evac_casualty05_male" = "On n'y arrivera jamais comme ça!"
		"ep1_citizen.cit_evac_casualty06_male" = "C'est pas passé loin!"
		"ep1_citizen.cit_evac_casualty07_male" = "Je croyais que vous deviez nous aider!"
		"ep1_citizen.cit_evac_casualty08_male" = "À l'aaaiiide!"
		"ep1_citizen.cit_evac_casualty09_male" = "C'est, c'est sans espoir!"
		"ep1_citizen.cit_evac_casualty10_male" = "Autant abandonner..."
		"ep1_citizen.cit_evac_casualty11_male" = "Nom de Dieu... Au secours!"
		"ep1_citizen.cit_evac_defendus01_male" = "Vous êtes supposé nous protéger!"
		"ep1_citizen.cit_evac_defendus02_male" = "Défendez-nous, Freeman!"
		"ep1_citizen.cit_evac_defendus03_male" = "Mais couvrez-nous, Freeman!"
		"ep1_citizen.cit_evac_defendus04_male" = "Nous dépendons de vous, Freeman!"
		"ep1_citizen.cit_evac_defendus05_male" = "Où est-ce qu'on doit aller, déjà?"
		"ep1_citizen.cit_evac_defendus06_male" = "Faut sortir d'ici!"
		"ep1_citizen.cit_evac_defendus07_male" = "Vers les trains!"
		"ep1_citizen.cit_evac_defendus08_male" = "J'aurais jamais cru être aussi heureux de revoir ces trains."
		"ep1_citizen.cit_evac_defendus09_male" = "On a besoin d'aide ici, Freeman."
		"ep1_citizen.cit_evac_defendusvance_male" = "On a besoin d'aide ici, Vance."
		"ep1_citizen.cit_evac_enemies01_male" = "Ils arrivent!"
		"ep1_citizen.cit_evac_enemies02_male" = "Ils sont partout!"
		"ep1_citizen.cit_evac_no01_male" = "On suivra dès qu'on pourra."
		"ep1_citizen.cit_evac_no02_male" = "On reste pour voir si on peut aider quelqu'un à partir."
		"ep1_citizen.cit_evac_no03_male" = "S'il reste des gens dans la ville, on va essayer de les sauver."
		"ep1_citizen.cit_evac_no04_male" = "Partez sans nous. On a du boulot."
		"ep1_citizen.cit_evac_ok01_male" = "Bien sûr qu'on est avec vous!"
		"ep1_citizen.cit_evac_ok02_male" = "Nous venons avec vous."
		"ep1_citizen.cit_evac_ok03_male" = "Nous sortons le plus vite possible!"
		"ep1_citizen.cit_evac_ok04_male" = "Faut pas me le demander deux fois. Partons."
		"ep1_citizen.cit_evac_thanks01_male" = "Merci, Freeman!"
		"ep1_citizen.cit_evac_thanks02_male" = "On a réussi, grâce à vous!"
		"ep1_citizen.cit_evac_thanks03_male" = "C'est pas passé loin."
		"ep1_citizen.cit_evac_thanks04_male" = "Je pensais qu'on n'y arriverait pas."
		"ep1_citizen.cit_evac_thanks05_male" = "Pfff, j'ai bien cru qu'on s'en sortirait pas!"
		"ep1_citizen.cit_evac_thanksalyx_male" = "Merci, Alyx."
		"ep1_citizen.cit_getaboard01_male" = "Venez citoyens."
		"ep1_citizen.cit_getaboard02_male" = "Embarquez!"
		"ep1_citizen.cit_getaboard03_male" = "Foutons le camp!"
		"ep1_citizen.cit_getaboard04_male" = "Montez par ici!"
		"ep1_citizen.cit_getaboard05_male" = "À l'intérieur, vite!"
		"ep1_citizen.cit_getoffstreet_male" = "Vite! Partez d'ici! Le Cartel arrive dans cette zone."
		"ep1_citizen.cit_greatshot_male" = "Bien joué, Doc!"
		"ep1_citizen.cit_greet_alyx01_male" = "Hé! Vous êtes Alyx Vance!"
		"ep1_citizen.cit_greet_alyx02_male" = "Je vous connais!"
		"ep1_citizen.cit_greet_alyx03_male" = "Alyx Vance et Gordon Freeman! Vous êtes restés derrière pour nous protéger, c'est ça?"
		"ep1_citizen.cit_greet_alyx04_male" = "Qui êtes-vous déjà?"
		"ep1_citizen.cit_greet_alyx05_male" = "J'espère que vous allez nous aider."
		"ep1_citizen.cit_greet_alyx06_male" = "Vous êtes la fille de Kleiner?"
		"ep1_citizen.cit_greet_alyx07_male" = "Oui, oui, ravi de vous voir. Où est Chien?"
		"ep1_citizen.cit_greet_alyx08_male" = "Alyx, mon Dieu, où est Freeman? Ah, il est ici..."
		"ep1_citizen.cit_greet_alyx09_male" = "Bonjour, Freeman. Et voici Madame, je suppose?"
		"ep1_citizen.cit_greet_alyx10_male" = "Alyx, Gordon. Vous y êtes arrivés!"
		"ep1_citizen.cit_greet_alyx11_male" = "Alyx, franchement, vous croyez qu'on a une chance?"
		"ep1_citizen.cit_greet_alyx12_male" = "Bla, bla, bla, bla... pourquoi vous laissez pas Freeman parler pour une fois?"
		"ep1_citizen.cit_greet_alyx13_male" = "Bonjour, Freeman... Et voici Mademoiselle, je suppose?"
		"ep1_citizen.cit_gunship_male" = "Oh non, un hélico! Courez!"
		"ep1_citizen.cit_heyoverhere_male" = "Hé! Par ici!"
		"ep1_citizen.cit_hurryup_male" = "Dépêchez-vous!"
		"ep1_citizen.cit_itsaraid_male" = "C'est un raid!"
		"ep1_citizen.cit_jump_male" = "Sautez!"
		"ep1_citizen.cit_kill01_male" = "Ouais!"
		"ep1_citizen.cit_kill02_male" = "Et un de moins."
		"ep1_citizen.cit_kill03_male" = "Et encore un."
		"ep1_citizen.cit_kill04_male" = "Ça, c'est du bon travail."
		"ep1_citizen.cit_kill05_male" = "Quelqu'un connaît une prière?"
		"ep1_citizen.cit_kill06_male" = "Vous avez vu ça?"
		"ep1_citizen.cit_kill07_male" = "De mieux en mieux."
		"ep1_citizen.cit_kill08_male" = "Bingo!"
		"ep1_citizen.cit_kill09_male" = "Prends ça!"
		"ep1_citizen.cit_kill10_male" = "Prends ça!"
		"ep1_citizen.cit_kill11_male" = "Ouais."
		"ep1_citizen.cit_kill12_male" = "Ouais."
		"ep1_citizen.cit_kill13_male" = "Bouffe ça!"
		"ep1_citizen.cit_kill14_male" = "Crève!"
		"ep1_citizen.cit_kill15_male" = "Un pour la résistance!"
		"ep1_citizen.cit_kill16_male" = "Brûlez en Enfer! Enfin, si vous y croyez."
		"ep1_citizen.cit_kill17_male" = "Crève en Enfer!"
		"ep1_citizen.cit_kill18_male" = "C'est comme ça que vous faites, hein Freeman?"
		"ep1_citizen.cit_kill19_male" = "Regardez ce que je viens de faire!"
		"ep1_citizen.cit_kill20_male" = "[rire d'exultation]"
		"ep1_citizen.cit_letyouthru_male" = "Ok, on vous laisse passer."
		"ep1_citizen.cit_notice_gravgunkill01_male" = "Ouah! Bien joué, Dr Freeman."
		"ep1_citizen.cit_notice_gravgunkill02_male" = "Ça c'était quelque chose, Doc!"
		"ep1_citizen.cit_notice_gravgunkill03_male" = "Qu'est-ce que vous avez fait, là?"
		"ep1_citizen.cit_notice_gravgunkill04_male" = "Un jour vous me montrerez comment vous faites."
		"ep1_citizen.cit_pain01_male" = "[cri de douleur]"
		"ep1_citizen.cit_pain02_male" = "[cri de douleur]"
		"ep1_citizen.cit_pain03_male" = "[cri de douleur]"
		"ep1_citizen.cit_pain04_male" = "[cri de douleur]"
		"ep1_citizen.cit_pain05_male" = "[cri de douleur]"
		"ep1_citizen.cit_pain06_male" = "[cri de douleur]"
