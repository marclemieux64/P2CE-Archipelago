		"ep_02.eli_launch_pain06" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_pain07" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_pain08" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
