		"ep_02.al_launch_gethug" = "<font color=\"rgb(255,212,255)\">Ouah, j'ai cru qu'il allait vous embrasser."
		"ep_02.al_launch_getmoving01" = "<font color=\"rgb(255,212,255)\">Lancez la fusée, Gordon! "
		"ep_02.al_launch_getmoving02" = "<font color=\"rgb(255,212,255)\">Il faut qu'on parte."
		"ep_02.al_launch_gonnamissit" = "<font color=\"rgb(255,212,255)\">Vous êtes où? Vous allez tout rater!"
		"ep_02.al_launch_gonnawork" = "<font color=\"rgb(255,212,255)\">Ça va marcher, hein?"
		"ep_02.al_launch_goonin" = "<font color=\"rgb(255,212,255)\">Montez."
		"ep_02.al_launch_hailingfreq01" = "<font color=\"rgb(255,212,255)\">Je crois, oui."
		"ep_02.al_launch_hailingfreq02" = "<font color=\"rgb(255,212,255)\">Le Dr Kleiner nous a donné les coordonnées du Borealis. "
		"ep_02.al_launch_hailingfreq03" = "<font color=\"rgb(255,212,255)\">On surveillera la fréquence radio de l'hélico, au cas où Judith essaierait de nous joindre."
		"ep_02.al_launch_herewecome01" = "<font color=\"rgb(255,212,255)\">Bon, Gordon,"
		"ep_02.al_launch_herewecome02" = "<font color=\"rgb(255,212,255)\">J'espère que votre combi est bien chaude, parce que"
		"ep_02.al_launch_herewecome03" = "<font color=\"rgb(255,212,255)\">Borealis,"
		"ep_02.al_launch_herewecome04" = "<font color=\"rgb(255,212,255)\">nous voilà."
