		"ep_02.al_launch_dambutton" = "<font color=\"rgb(255,212,255)\">Appuyez sur ce foutu bouton, Gordon!"
		"ep_02.al_launch_damnit" = "<font color=\"rgb(255,212,255)\">Mais bon sang, lâchez-le!"
		"ep_02.al_launch_dogspot_alt1" = "<font color=\"rgb(255,212,255)\">Chien!"
		"ep_02.al_launch_dogspot_alt2" = "<font color=\"rgb(255,212,255)\">Chien!"
		"ep_02.al_launch_dogspot01" = "<font color=\"rgb(255,212,255)\">Ah."
		"ep_02.al_launch_dogspot02" = "<font color=\"rgb(255,212,255)\">Chien!"
