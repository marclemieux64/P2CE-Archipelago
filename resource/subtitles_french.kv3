		"ep_02.al_barn_sorry02" = "<font color=\"rgb(255,212,255)\">[oumph]"
		"ep_02.al_barn_thereagain" = "<font color=\"rgb(255,212,255)\">Là encore!"
		"ep_02.al_barn_thereitisagain" = "<font color=\"rgb(255,212,255)\">Ça recommence..."
		"ep_02.al_barn_therewego" = "<font color=\"rgb(255,212,255)\">Et voilà."
		"ep_02.al_barn_thereyoug02" = "<font color=\"rgb(255,212,255)\">Et voilà."
		"ep_02.al_barn_thereyougo" = "<font color=\"rgb(255,212,255)\">Et voilà."
		"ep_02.al_barn_uhgordon" = "<font color=\"rgb(255,212,255)\">Euh, Gordon..."
		"ep_02.al_barn_uhmygod" = "<font color=\"rgb(255,212,255)\">Oh... mon Dieu...  "
		"ep_02.al_barn_umwhatsgoingon01" = "<font color=\"rgb(255,212,255)\">Hum..."
		"ep_02.al_barn_umwhatsgoingon02" = "<font color=\"rgb(255,212,255)\">Que se passe-t-il?"
		"ep_02.al_barn_wakes" = "<font color=\"rgb(255,212,255)\">Il faut le tuer!"
		"ep_02.al_barn_wellenough_loud01" = "<font color=\"rgb(255,212,255)\">On aurait dû laisser ce truc tranquille. "
		"ep_02.al_barn_wellenough_loud02" = "<font color=\"rgb(255,212,255)\">On ne l'a pas achevé et du coup ils savent où nous sommes."
		"ep_02.al_barn_wellenough01" = "<font color=\"rgb(255,212,255)\">On aurait dû laisser ce truc tranquille. "
		"ep_02.al_barn_wellenough02" = "<font color=\"rgb(255,212,255)\">On ne l'a pas achevé et du coup ils savent où nous sommes."
		"ep_02.al_barn_whatsitdoing01" = "<font color=\"rgb(255,212,255)\">Ouh."
		"ep_02.al_barn_whatsitdoing02" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'il fait?"
		"ep_02.al_barn_whatsthat" = "<font color=\"rgb(255,212,255)\">Ouah, c'est quoi?"
		"ep_02.al_barn_whatwasthat" = "<font color=\"rgb(255,212,255)\">Allô?"
		"ep_02.al_barn_wwcd" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que le Cartel trouve à un endroit comme ça."
		"ep_02.al_barn_youdiditshutdown" = "<font color=\"rgb(255,212,255)\">Bravo! Ça marche!"
		"ep_02.al_barn_youfeltitdidntyou" = "<font color=\"rgb(255,212,255)\">Vous avez senti aussi, hein?"
		"ep_02.al_barn_youokay" = "<font color=\"rgb(255,212,255)\">Ça va? "
		"ep_02.al_barn_youokay02" = "<font color=\"rgb(255,212,255)\">Ici..."
		"ep_02.al_bridge_almostcar01" = "<font color=\"rgb(255,212,255)\">Bien joué! Vous êtes presque à la voiture!"
		"ep_02.al_bridge_almostcar02" = "<font color=\"rgb(255,212,255)\">Vous y êtes presque!"
		"ep_02.al_bridge_better" = "<font color=\"rgb(255,212,255)\">Eh, je me sens bien mieux, moi."
		"ep_02.al_bridge_bye01" = "<font color=\"rgb(255,212,255)\">Prudence."
		"ep_02.al_bridge_careful" = "<font color=\"rgb(255,212,255)\">Soyez prudent."
		"ep_02.al_bridge_cartalk01" = "<font color=\"rgb(255,212,255)\">Quelle épave."
		"ep_02.al_bridge_cartalk02" = "<font color=\"rgb(255,212,255)\">On aura de la chance si elle nous amène jusqu'à la base."
		"ep_02.al_bridge_cartalk03" = "<font color=\"rgb(255,212,255)\">Laissez tomber White Forest."
		"ep_02.al_bridge_cartalk04" = "<font color=\"rgb(255,212,255)\">On aura de la chance si elle nous amène jusqu'au bout de la rue."
		"ep_02.al_bridge_coveryou" = "<font color=\"rgb(255,212,255)\">Je vous couvre d'ici."
		"ep_02.al_bridge_deadgun" = "<font color=\"rgb(255,212,255)\">Bon, OK. Si vous pouviez m'aider à l'allumer."
		"ep_02.al_bridge_found01" = "<font color=\"rgb(255,212,255)\">Oh, mon Dieu. "
		"ep_02.al_bridge_found02" = "<font color=\"rgb(255,212,255)\">Le Cartel ne les a pas loupés."
		"ep_02.al_bridge_gooddrive" = "<font color=\"rgb(255,212,255)\">Un vrai as du volant, ce Gordon."
		"ep_02.al_bridge_goodhunt" = "<font color=\"rgb(255,212,255)\">Bonne chasse"
		"ep_02.al_bridge_gotback" = "<font color=\"rgb(255,212,255)\">Je couvre vos arrières, Gordon!"
		"ep_02.al_bridge_hopeokay" = "<font color=\"rgb(255,212,255)\">OK. Gordon notre sort est entre vos mains."
		"ep_02.al_bridge_iseeyou" = "<font color=\"rgb(255,212,255)\">Te voilà!"
		"ep_02.al_bridge_jumpback" = "<font color=\"rgb(255,212,255)\">S'ils l'ont fait passer de ce côté-là, on peut bien la faire sauter de ce côté-ci."
		"ep_02.al_bridge_keeplookout" = "<font color=\"rgb(255,212,255)\">On restera sur nos gardes."
		"ep_02.al_bridge_leavecarfornow" = "<font color=\"rgb(255,212,255)\">Laissez la voiture pour le moment!"
		"ep_02.al_bridge_lookcar01" = "<font color=\"rgb(255,212,255)\">Hé, regardez!"
		"ep_02.al_bridge_lookcar02" = "<font color=\"rgb(255,212,255)\">Sur le pont..."
		"ep_02.al_bridge_lookcar03" = "<font color=\"rgb(255,212,255)\">Je vois la voiture dont vous parliez."
		"ep_02.al_bridge_missyou" = "<font color=\"rgb(255,212,255)\">Vous allez me manquer."
		"ep_02.al_bridge_okayhere" = "<font color=\"rgb(255,212,255)\">Ça va aller ici?"
		"ep_02.al_bridge_openthisdoor" = "<font color=\"rgb(255,212,255)\">Vous pouvez essayer d'ouvrir cette porte?"
		"ep_02.al_bridge_openway01" = "<font color=\"rgb(255,212,255)\">Ouais, on peut faire ça."
		"ep_02.al_bridge_openway02" = "<font color=\"rgb(255,212,255)\">Bon, je vais désactiver ce champ."
		"ep_02.al_bridge_openway03" = "<font color=\"rgb(255,212,255)\">Bonne chance, Gordon."
		"ep_02.al_bridge_openway04" = "<font color=\"rgb(255,212,255)\">Pour arriver à White Forest avant le Cartel, il faudra vous dépêcher."
		"ep_02.al_bridge_roofclear" = "<font color=\"rgb(255,212,255)\">Nettoyez ce toit pour que je puisse tirer!"
		"ep_02.al_bridge_seecaryet" = "<font color=\"rgb(255,212,255)\">Gordon! Vous pouvez voir la voiture?"
		"ep_02.al_bridge_shotgun" = "<font color=\"rgb(255,212,255)\">En voiture!"
		"ep_02.al_bridge_startcar01" = "<font color=\"rgb(255,212,255)\">Montez, Gordon! "
		"ep_02.al_bridge_startcar02" = "<font color=\"rgb(255,212,255)\">En route!"
		"ep_02.al_bridge_startcar03" = "<font color=\"rgb(255,212,255)\">Montez!"
		"ep_02.al_bridge_tanks01" = "<font color=\"rgb(255,212,255)\">Eh, Gordon! "
		"ep_02.al_bridge_tanks02" = "<font color=\"rgb(255,212,255)\">Regardez! Ouais!"
		"ep_02.al_bridge_thankful" = "<font color=\"rgb(255,212,255)\">Je suis tellement reconnaissante."
		"ep_02.al_bridge_unbelievable" = "<font color=\"rgb(255,212,255)\">C'était incroyable. "
		"ep_02.al_bridge_unlessyou" = "<font color=\"rgb(255,212,255)\">Oh... sauf si vous y tenez."
		"ep_02.al_bridge_vortcharge01" = "<font color=\"rgb(255,212,255)\">Eh, on a chargé le fusil."
		"ep_02.al_bridge_waytojump" = "<font color=\"rgb(255,212,255)\">On doit pouvoir sauter par-dessus!"
		"ep_02.al_bridge_wescored01" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu..."
		"ep_02.al_bridge_wescored02" = "<font color=\"rgb(255,212,255)\">Oh, c'est bon!"
		"ep_02.al_bridge_wescored03" = "<font color=\"rgb(255,212,255)\">Quelle voiture!"
		"ep_02.al_bridge_wescored04" = "<font color=\"rgb(255,212,255)\">C'est la classe pour aller à White Forest."
		"ep_02.al_cache_cool" = "<font color=\"rgb(255,212,255)\">Super."
		"ep_02.al_cache1_clearedup" = "<font color=\"rgb(255,212,255)\">Bon, vous avez réglé ce petit problème."
		"ep_02.al_cache1_cratetype" = "<font color=\"rgb(255,212,255)\">C'est une de ces balises radio qu'on voit sur le radar."
		"ep_02.al_cache1_pickup" = "<font color=\"rgb(255,212,255)\">Hé! Le radar a repéré une cache de munitions."
		"ep_02.al_cache1_stopcar01" = "<font color=\"rgb(255,212,255)\">Arrêtez-vous, Gordon."
		"ep_02.al_cache1_stopcar02" = "<font color=\"rgb(255,212,255)\">D'après le radar, il y a des munitions par ici. "
		"ep_02.al_cache1_stopcar03" = "<font color=\"rgb(255,212,255)\">Ça doit être le fourgon."
		"ep_02.al_canyon_army" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu. Le Cartel est en route. "
		"ep_02.al_canyon_defenseless01" = "<font color=\"rgb(255,212,255)\">Le nord? "
		"ep_02.al_canyon_defenseless02" = "<font color=\"rgb(255,212,255)\">White Forest! "
		"ep_02.al_canyon_defenseless03" = "<font color=\"rgb(255,212,255)\">Il faut arriver avant eux!"
		"ep_02.al_canyon_eggs01" = "<font color=\"rgb(255,212,255)\">Vous avez touché à ses oeufs?"
		"ep_02.al_canyon_eggs02" = "<font color=\"rgb(255,212,255)\">Oh, pas étonnant alors."
		"ep_02.al_canyon_heaven" = "<font color=\"rgb(255,212,255)\">Ah, des fourmis-lions... Preuve que je ne suis pas encore au paradis."
		"ep_02.al_canyon_hell" = "<font color=\"rgb(255,212,255)\">Ah, des fourmis-lions... Vous êtes sûr que je ne suis pas déjà en enfer?"
		"ep_02.al_canyon_pissitoff01" = "<font color=\"rgb(255,212,255)\">Wow! "
		"ep_02.al_canyon_pissitoff02" = "<font color=\"rgb(255,212,255)\">C'était un gardien!"
		"ep_02.al_canyon_pissitoff03" = "<font color=\"rgb(255,212,255)\">Quelqu'un a dû faire quelque chose qui l'a énervé!"
		"ep_02.al_canyon_sawincit01" = "<font color=\"rgb(255,212,255)\">C'était donc ça qu'on a vu à la Citadelle. "
		"ep_02.al_canyon_sawincit02" = "<font color=\"rgb(255,212,255)\">Pour être pressés, ils sont pressés. "
		"ep_02.al_canyon_thinkcomb" = "<font color=\"rgb(255,212,255)\">Le Cartel les aurait trouvés?"
		"ep_02.al_canyon_waiting" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'on attend? "
		"ep_02.al_canyon_walkonmyown01" = "<font color=\"rgb(255,212,255)\">Je peux marcher seule à présent...  "
		"ep_02.al_canyon_walkonmyown02" = "<font color=\"rgb(255,212,255)\">Attendez, j'essaie."
		"ep_02.al_canyon_walkonmyown03" = "<font color=\"rgb(255,212,255)\">Hmmm, ouais, c'est un peu raide mais..."
		"ep_02.al_canyon_walkonmyown04" = "<font color=\"rgb(255,212,255)\">Ça va aller."
		"ep_02.al_car_beatsonfoot" = "<font color=\"rgb(255,212,255)\">C'est quand même plus rapide qu'à pied."
		"ep_02.al_car_beenawhile" = "<font color=\"rgb(255,212,255)\">Euh, vous n'avez pas conduit depuis longtemps, hein?"
		"ep_02.al_car_callback01" = "<font color=\"rgb(255,212,255)\">Gordon, allons-y!"
		"ep_02.al_car_callback02" = "<font color=\"rgb(255,212,255)\">En route!"
		"ep_02.al_car_callback03" = "<font color=\"rgb(255,212,255)\">Il faut y aller, là!"
		"ep_02.al_car_callback04" = "<font color=\"rgb(255,212,255)\">Revenez, Gordon!"
		"ep_02.al_car_catchup01" = "<font color=\"rgb(255,212,255)\">Merci d'avoir attendu."
		"ep_02.al_car_catchup02" = "<font color=\"rgb(255,212,255)\">Ne m'attendez pas surtout."
		"ep_02.al_car_catchup03" = "<font color=\"rgb(255,212,255)\">Vous me déposez?"
		"ep_02.al_car_catchup04" = "<font color=\"rgb(255,212,255)\">On croirait presque que vous voulez vous débarrasser de moi..."
		"ep_02.al_car_clutch" = "<font color=\"rgb(255,212,255)\">Eh. Doucement sur l'embrayage."
		"ep_02.al_car_comments01" = "<font color=\"rgb(255,212,255)\">Alors avant, c'est, c'est là qu'on mettait les gants?"
		"ep_02.al_car_comments02" = "<font color=\"rgb(255,212,255)\">Un éléphant, ça trompe, ça trompe... Désolée."
		"ep_02.al_car_comments03" = "<font color=\"rgb(255,212,255)\">Heureusement que je n'ai pas le mal des transports..."
		"ep_02.al_car_crash01" = "<font color=\"rgb(255,212,255)\">Aw!"
		"ep_02.al_car_crash02" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_02.al_car_crash03" = "<font color=\"rgb(255,212,255)\">Ouah..."
		"ep_02.al_car_crash04" = "<font color=\"rgb(255,212,255)\">[surprise]"
		"ep_02.al_car_crash05" = "<font color=\"rgb(255,212,255)\">[surprise]"
		"ep_02.al_car_crash06" = "<font color=\"rgb(255,212,255)\">[surprise]"
		"ep_02.al_car_crash07" = "<font color=\"rgb(255,212,255)\">[surprise]"
		"ep_02.al_car_crazy01" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_crazy02" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_02.al_car_crazy03" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_car_crazy04" = "<font color=\"rgb(255,212,255)\">Doucement!"
		"ep_02.al_car_crazy05" = "<font color=\"rgb(255,212,255)\">Mince!"
		"ep_02.al_car_crazy06" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_car_crazy07" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_car_crazy08" = "<font color=\"rgb(255,212,255)\">OK!"
		"ep_02.al_car_getgoing01" = "<font color=\"rgb(255,212,255)\">Faites-lui sa fête!"
		"ep_02.al_car_getgoing02" = "<font color=\"rgb(255,212,255)\">Allez-y!"
		"ep_02.al_car_getgoing03" = "<font color=\"rgb(255,212,255)\">Foncez! "
		"ep_02.al_car_getgoing04" = "<font color=\"rgb(255,212,255)\">Allons-y!"
		"ep_02.al_car_hitit" = "<font color=\"rgb(255,212,255)\">Allez-y!"
		"ep_02.al_car_jumpyell01" = "<font color=\"rgb(255,212,255)\">Allez!"
		"ep_02.al_car_jumpyell02" = "<font color=\"rgb(255,212,255)\">Ah ah!"
		"ep_02.al_car_jumpyell03" = "<font color=\"rgb(255,212,255)\">Wouuuu!"
		"ep_02.al_car_jumpyell04" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_car_jumpyell05" = "<font color=\"rgb(255,212,255)\">Wouhou, ouais!"
		"ep_02.al_car_jumpyell06" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_car_kickoff01" = "<font color=\"rgb(255,212,255)\">Ugh!"
		"ep_02.al_car_kickoff02" = "<font color=\"rgb(255,212,255)\">Dégage!"
		"ep_02.al_car_kickoff03" = "<font color=\"rgb(255,212,255)\">Allez, dégage."
		"ep_02.al_car_kickoff04" = "<font color=\"rgb(255,212,255)\">Dégage!"
		"ep_02.al_car_killit02" = "<font color=\"rgb(255,212,255)\">On est sur la route là!"
		"ep_02.al_car_killit03" = "<font color=\"rgb(255,212,255)\">Splatch!"
		"ep_02.al_car_killit04" = "<font color=\"rgb(255,212,255)\">Boum!"
		"ep_02.al_car_killit05" = "<font color=\"rgb(255,212,255)\">Oh, dégoûtant."
		"ep_02.al_car_killit06" = "<font color=\"rgb(255,212,255)\">Beurk!"
		"ep_02.al_car_killit07" = "<font color=\"rgb(255,212,255)\">Oh! Un cadavre..."
		"ep_02.al_car_killit08" = "<font color=\"rgb(255,212,255)\">Les piétons dangereux seront punis."
		"ep_02.al_car_killit09" = "<font color=\"rgb(255,212,255)\">Hé! La peinture!"
		"ep_02.al_car_laughing01" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing02" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing03" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing04" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing05" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing06" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing07" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing08" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing09" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing10" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing11" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing12" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing13" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_laughing14" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_car_nearmiss01" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_car_nearmiss02" = "<font color=\"rgb(255,212,255)\">Hé!"
		"ep_02.al_car_nearmiss03" = "<font color=\"rgb(255,212,255)\">On a eu chaud!"
		"ep_02.al_car_nearmiss04" = "<font color=\"rgb(255,212,255)\">On n'est pas passé loin, Gordon!"
		"ep_02.al_car_playerout01" = "<font color=\"rgb(255,212,255)\">Eh, n'allez pas trop loin, hein?"
		"ep_02.al_car_playerout02" = "<font color=\"rgb(255,212,255)\">Je reste ici."
		"ep_02.al_car_playerout03" = "<font color=\"rgb(255,212,255)\">Je garde la voiture."
		"ep_02.al_car_playerout04" = "<font color=\"rgb(255,212,255)\">N'allez pas trop loin."
		"ep_02.al_car_playerout05" = "<font color=\"rgb(255,212,255)\">Faites attention!"
		"ep_02.al_car_playerout06" = "<font color=\"rgb(255,212,255)\">Réveillez-moi à votre retour."
		"ep_02.al_car_rolled01a" = "<font color=\"rgb(255,212,255)\">Wow! "
		"ep_02.al_car_rolled01b" = "<font color=\"rgb(255,212,255)\">Un tonneau!"
		"ep_02.al_car_rolled02" = "<font color=\"rgb(255,212,255)\">On peut dire que c'est du solide, hein?"
		"ep_02.al_car_rolled03" = "<font color=\"rgb(255,212,255)\">Elle ne craint pas grand-chose, cette voiture."
		"ep_02.al_car_rolled04" = "<font color=\"rgb(255,212,255)\">Wow, ça tourne..."
		"ep_02.al_car_rolled05" = "<font color=\"rgb(255,212,255)\">Bon, d'accord..."
		"ep_02.al_car_rolled06" = "<font color=\"rgb(255,212,255)\">Gordon. Vous n'avez rien remarqué?"
		"ep_02.al_car_rolled07" = "<font color=\"rgb(255,212,255)\">Eh, Gordon, vous n'allez pas abandonner une fille en détresse, non?"
		"ep_02.al_car_runafter01" = "<font color=\"rgb(255,212,255)\">Attendez!"
		"ep_02.al_car_runafter02" = "<font color=\"rgb(255,212,255)\">Attendez-moi!"
		"ep_02.al_car_runafter03" = "<font color=\"rgb(255,212,255)\">Attends!"
		"ep_02.al_car_runafter04" = "<font color=\"rgb(255,212,255)\">Pas si vite!"
		"ep_02.al_car_runafter05" = "<font color=\"rgb(255,212,255)\">Gordon! Attendez-moi!"
		"ep_02.al_car_runitover" = "<font color=\"rgb(255,212,255)\">Écrasez-le!"
		"ep_02.al_car_startle01" = "<font color=\"rgb(255,212,255)\">[souffle coupé]"
		"ep_02.al_car_startle02" = "<font color=\"rgb(255,212,255)\">[souffle coupé]"
		"ep_02.al_car_startle03" = "<font color=\"rgb(255,212,255)\">[souffle coupé]"
		"ep_02.al_car_startle04" = "<font color=\"rgb(255,212,255)\">Mais qu'est-ce que...!"
		"ep_02.al_car_stayincar01" = "<font color=\"rgb(255,212,255)\">Je reste ici."
		"ep_02.al_car_stayincar02" = "<font color=\"rgb(255,212,255)\">J'attends ici."
		"ep_02.al_car_stayincar03" = "<font color=\"rgb(255,212,255)\">Je vais me reposer ici."
		"ep_02.al_car_stayincar04" = "<font color=\"rgb(255,212,255)\">Allez-y."
		"ep_02.al_car_stayincar05" = "<font color=\"rgb(255,212,255)\">Je reste dans la voiture."
		"ep_02.al_car_stayincar06" = "<font color=\"rgb(255,212,255)\">Je garde la voiture."
		"ep_02.al_car_stayincar07" = "<font color=\"rgb(255,212,255)\">Ça vous dérange si je reste ici?"
		"ep_02.al_car_stuckup01" = "<font color=\"rgb(255,212,255)\">Vous croyez qu'on va en sortir indemnes?"
		"ep_02.al_car_stuckup02" = "<font color=\"rgb(255,212,255)\">On pourrait peut-être... redescendre sur terre?"
		"ep_02.al_car_stuckup03" = "<font color=\"rgb(255,212,255)\">Beau travail."
		"ep_02.al_car_stuckup04" = "<font color=\"rgb(255,212,255)\">C'est mieux."
		"ep_02.al_chop_alwaysgame01" = "<font color=\"rgb(255,212,255)\">Oh, il est toujours partant."
		"ep_02.al_chop_alwaysgame02" = "<font color=\"rgb(255,212,255)\">Pas vrai?"
		"ep_02.al_chop_anytools01" = "<font color=\"rgb(255,212,255)\">Il faut reprendre la route, mais le moteur est foutu. "
		"ep_02.al_chop_anytools02" = "<font color=\"rgb(255,212,255)\">Vous n'auriez pas des outils pour la voiture, par hasard?"
		"ep_02.al_chop_bonus" = "<font color=\"rgb(255,212,255)\">Ils m'ont aidée à réparer la voiture et nous offrent un bonus."
		"ep_02.al_chop_cache01" = "<font color=\"rgb(255,212,255)\">Gordon! "
		"ep_02.al_chop_cache02" = "<font color=\"rgb(255,212,255)\">J'ai trouvé des trousses de secours!"
		"ep_02.al_chop_cache03" = "<font color=\"rgb(255,212,255)\">Tenez, une trousse de secours."
		"ep_02.al_chop_carready01" = "<font color=\"rgb(255,212,255)\">Eh, Gordon!"
		"ep_02.al_chop_carready02" = "<font color=\"rgb(255,212,255)\">La voiture nous attend."
		"ep_02.al_chop_carready03" = "<font color=\"rgb(255,212,255)\">Revenez et partons vite."
		"ep_02.al_chop_cheers01" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_chop_cheers02" = "<font color=\"rgb(255,212,255)\">Génial Gordon."
		"ep_02.al_chop_cheers03" = "<font color=\"rgb(255,212,255)\">Beau travail!"
		"ep_02.al_chop_cheers04" = "<font color=\"rgb(255,212,255)\">Wow! Hé!"
		"ep_02.al_chop_clearup01" = "<font color=\"rgb(255,212,255)\">Hmmm..."
		"ep_02.al_chop_clearup02" = "<font color=\"rgb(255,212,255)\">Qu'en pensez-vous, Gordon?"
		"ep_02.al_chop_clearup03" = "<font color=\"rgb(255,212,255)\">Pendant que je répare la voiture, essayez de dégager le barrage."
		"ep_02.al_chop_craptheengine01" = "<font color=\"rgb(255,212,255)\">C'est pas vrai! Le moteur! "
		"ep_02.al_chop_craptheengine02" = "<font color=\"rgb(255,212,255)\">Il faudra peut-être laisser tomber la voiture!"
		"ep_02.al_chop_enginefire01" = "<font color=\"rgb(255,212,255)\">Wow! Hé!"
		"ep_02.al_chop_enginefire02" = "<font color=\"rgb(255,212,255)\">C'est pas vrai!"
		"ep_02.al_chop_fewsoldiers01" = "<font color=\"rgb(255,212,255)\">Gordon, occupez-vous de cette arme."
		"ep_02.al_chop_fewsoldiers02" = "<font color=\"rgb(255,212,255)\">Il faut absolument que je répare cette voiture, si on veut devancer le Cartel."
		"ep_02.al_chop_findmedkits01" = "<font color=\"rgb(255,212,255)\">Ça craint ici. "
		"ep_02.al_chop_findmedkits02" = "<font color=\"rgb(255,212,255)\">Si vous commenciez à tirer sur cet hélico je pourrais rechercher des trousses de secours."
		"ep_02.al_chop_getinthere" = "<font color=\"rgb(255,212,255)\">Entrons là-dedans."
		"ep_02.al_chop_gladguys" = "<font color=\"rgb(255,212,255)\">Contente de vous voir les gars."
		"ep_02.al_chop_goahead" = "<font color=\"rgb(255,212,255)\">Passez devant...  Je cherche des munitions."
		"ep_02.al_chop_gunnags01" = "<font color=\"rgb(255,212,255)\">Je vois. "
		"ep_02.al_chop_gunnags02" = "<font color=\"rgb(255,212,255)\">Ouais, ça a l'air bien sympa..."
		"ep_02.al_chop_gunnags03" = "<font color=\"rgb(255,212,255)\">Regardez, Gordon."
		"ep_02.al_chop_inhere" = "<font color=\"rgb(255,212,255)\">Gordon! Par ici!"
		"ep_02.al_chop_mydad01" = "<font color=\"rgb(255,212,255)\">Ouais."
		"ep_02.al_chop_mydad02" = "<font color=\"rgb(255,212,255)\">Mon père est là-bas."
		"ep_02.al_chop_mydad03" = "<font color=\"rgb(255,212,255)\">Eli Vance."
		"ep_02.al_chop_nagdoor01" = "<font color=\"rgb(255,212,255)\">Allez-y. Gordon, il faut vraiment y aller."
		"ep_02.al_chop_nagdoor02" = "<font color=\"rgb(255,212,255)\">Il a dit que la trappe était là."
		"ep_02.al_chop_nags01" = "<font color=\"rgb(255,212,255)\">Allez, Gordon"
		"ep_02.al_chop_nags02" = "<font color=\"rgb(255,212,255)\">Il va bien falloir descendre cet hélico..."
		"ep_02.al_chop_nags03" = "<font color=\"rgb(255,212,255)\">Descendez l'hélico!"
		"ep_02.al_chop_nokidding01" = "<font color=\"rgb(255,212,255)\">[Rire]"
		"ep_02.al_chop_nokidding02" = "<font color=\"rgb(255,212,255)\">C'était pas de la blague! "
		"ep_02.al_chop_nokidding03" = "<font color=\"rgb(255,212,255)\">On va vite reprendre la route."
		"ep_02.al_chop_pleasure" = "<font color=\"rgb(255,212,255)\">Oh avec plaisir."
		"ep_02.al_chop_reason01" = "<font color=\"rgb(255,212,255)\">Eh, vous savez si on peut passer un message à la base de White Forest d'ici?"
		"ep_02.al_chop_thanksguys01" = "<font color=\"rgb(255,212,255)\">Je vous expliquerai en route, Gordon. "
		"ep_02.al_chop_thanksguys02" = "<font color=\"rgb(255,212,255)\">Merci encore les gars!"
		"ep_02.al_chop_thx" = "<font color=\"rgb(255,212,255)\">Ça,  Merci."
		"ep_02.al_chop_waving" = "<font color=\"rgb(255,212,255)\">Eh, on nous fait signe."
		"ep_02.al_combat_grim_01" = "<font color=\"rgb(255,212,255)\">Joli coup!"
		"ep_02.al_combat_grim_02" = "<font color=\"rgb(255,212,255)\">Bien visé!"
		"ep_02.al_combat_grim_03" = "<font color=\"rgb(255,212,255)\">Excellent!"
		"ep_02.al_combat_grim_04" = "<font color=\"rgb(255,212,255)\">Joli!"
		"ep_02.al_combat_grim_05" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_combat_grim_06" = "<font color=\"rgb(255,212,255)\">Bien joué, Gordon!"
		"ep_02.al_combat_grim_07" = "<font color=\"rgb(255,212,255)\">C'est parti!"
		"ep_02.al_combat_grim_08" = "<font color=\"rgb(255,212,255)\">C'est parti!"
		"ep_02.al_combat_grim_09" = "<font color=\"rgb(255,212,255)\">Faut les supprimer!"
		"ep_02.al_combat_grim_10" = "<font color=\"rgb(255,212,255)\">Allons-y!"
		"ep_02.al_combat_grim_11" = "<font color=\"rgb(255,212,255)\">Je m'en occupe!"
		"ep_02.al_combat_panic01" = "<font color=\"rgb(255,212,255)\">Ils sont partout!"
		"ep_02.al_combat_panic02" = "<font color=\"rgb(255,212,255)\">Il y en a partout!"
		"ep_02.al_guard_itsaguardian" = "<font color=\"rgb(255,212,255)\">C'est un gardien!"
		"ep_02.al_guard_keepmoving01" = "<font color=\"rgb(255,212,255)\">Continuons notre chemin."
		"ep_02.al_guard_keepmoving02" = "<font color=\"rgb(255,212,255)\">Fonçons au prochain marteleur!"
		"ep_02.al_guard_keepmoving03" = "<font color=\"rgb(255,212,255)\">Courez jusqu'au marteleur, Gordon. Je vous suis!"
		"ep_02.al_guard_keepmoving04" = "<font color=\"rgb(255,212,255)\">Gordon, continuez! Je vous suivrai!"
		"ep_02.al_guard_keepmoving05" = "<font color=\"rgb(255,212,255)\">Je me sens faible, mais je peux suivre!"
		"ep_02.al_guard_keepmoving06" = "<font color=\"rgb(255,212,255)\">Je vous couvre d'ici."
		"ep_02.al_guard_nevergetpast" = "<font color=\"rgb(255,212,255)\">On ne pourra pas passer. Il faut se débarrasser de ces trucs."
		"ep_02.al_guard_nicework" = "<font color=\"rgb(255,212,255)\">Bien joué, Gordon. Je n'ai pas été d'une grande utilité,  désolée."
		"ep_02.al_guard_stucklift01" = "<font color=\"rgb(255,212,255)\">L'ascenseur a l'air bloqué là-haut."
		"ep_02.al_guard_stucklift02" = "<font color=\"rgb(255,212,255)\">Essayez de le faire descendre, Gordon."
		"ep_02.al_guard_stucklift03" = "<font color=\"rgb(255,212,255)\">Merci, Gordon!"
		"ep_02.al_guard_stucklift04" = "<font color=\"rgb(255,212,255)\">Bien joué, Gordon."
		"ep_02.al_guard_takecareguardians" = "<font color=\"rgb(255,212,255)\">Il va falloir se débarrasser de ces gardes, Gordon."
		"ep_02.al_guard_thanksg" = "<font color=\"rgb(255,212,255)\">Merci, Gordon!"
		"ep_02.al_hunter_heyworking" = "<font color=\"rgb(255,212,255)\">Eh, ça marche!"
		"ep_02.al_hunter_hititagain" = "<font color=\"rgb(255,212,255)\">Frappez-le encore!"
		"ep_02.al_hunter_howmanymore" = "<font color=\"rgb(255,212,255)\">Mais, il y en a encore combien?"
		"ep_02.al_hunter_ihate" = "<font color=\"rgb(255,212,255)\">J'ai horreur de ces trucs."
		"ep_02.al_hunter_itshurtinggord" = "<font color=\"rgb(255,212,255)\">Ah, ça lui fait mal, Gordon!"
		"ep_02.al_hunter_keepafterit" = "<font color=\"rgb(255,212,255)\">Continuez!"
		"ep_02.al_hunter_nicethrow" = "<font color=\"rgb(255,212,255)\">Bien joué!"
		"ep_02.al_hunter_shootit" = "<font color=\"rgb(255,212,255)\">Tirez!"
		"ep_02.al_hunter_shootitnowgord" = "<font color=\"rgb(255,212,255)\">Tirez dessus, Gordon!"
		"ep_02.al_hunter_thatsit" = "<font color=\"rgb(255,212,255)\">Voilà!"
		"ep_02.al_hunter_thatsworking" = "<font color=\"rgb(255,212,255)\">Ça marche!"
		"ep_02.al_hunter_wedidit" = "<font color=\"rgb(255,212,255)\">On a réussi!"
		"ep_02.al_hunter_weregettingit" = "<font color=\"rgb(255,212,255)\">Ouais, ça vient!"
		"ep_02.al_hunter_yeah01" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_hunter_yeah02" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_hunter_yeah03" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_hunter_yeahwedidit" = "<font color=\"rgb(255,212,255)\">Ouais, on a réussi!"
		"ep_02.al_inn_getinside" = "<font color=\"rgb(255,212,255)\">Gordon, entrez! Rentrez!"
		"ep_02.al_inn_gocomeon" = "<font color=\"rgb(255,212,255)\">On y va, allez!"
		"ep_02.al_inn_roadblock01" = "<font color=\"rgb(255,212,255)\">Merde. Un barrage. "
		"ep_02.al_inn_roadblock02" = "<font color=\"rgb(255,212,255)\">Vous savez quoi faire!"
