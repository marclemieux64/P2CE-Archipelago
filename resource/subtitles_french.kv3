		"ep_01.al_pbox_nicejobandgun02" = "<font color=\"rgb(255,212,255)\">Vous avez même trouvé un pistolet."
		"ep_01.al_pbox_padlock01" = "<font color=\"rgb(255,212,255)\">Super!"
		"ep_01.al_pbox_padlock02" = "<font color=\"rgb(255,212,255)\">Ouaouh, vous avez vraiment pulvérisé ce cadenas."
		"ep_01.al_peoplelistening" = "<font color=\"rgb(255,212,255)\">J'espère que les gens écoutent."
		"ep_01.al_peopletohelp" = "<font color=\"rgb(255,212,255)\">On pourrait aider ces gens!"
		"ep_01.al_plaza_view01" = "<font color=\"rgb(255,212,255)\">Enfin, de l'air fr..."
		"ep_01.al_plaza_view02" = "<font color=\"rgb(255,212,255)\">Oh, mon Dieu..."
		"ep_01.al_plaza_view03" = "<font color=\"rgb(255,212,255)\">Les striders ont vraiment tout détruit ici..."
		"ep_01.al_pzombie_covered" = "<font color=\"rgb(255,212,255)\">Celui-là est couvert de crabes venimeux."
		"ep_01.al_pzombie_hate" = "<font color=\"rgb(255,212,255)\">Euhhh! Des crabes venimeux. Je déteste ça!"
		"ep_01.al_pzombie_ohno" = "<font color=\"rgb(255,212,255)\">Oh, non... pas un de ces trucs !"
		"ep_01.al_rappel_hearthat" = "<font color=\"rgb(255,212,255)\">Vous entendez?"
		"ep_01.al_rappel_hearthat_loud" = "<font color=\"rgb(255,212,255)\">Vous entendez?"
		"ep_01.al_rappel_hoping" = "<font color=\"rgb(255,212,255)\">J'espérais prendre un peu plus d'avance avant qu'ils ne nous repèrent."
		"ep_01.al_rappel_looking01" = "<font color=\"rgb(255,212,255)\">Ils cherchent quelque chose."
		"ep_01.al_rappel_looking02" = "<font color=\"rgb(255,212,255)\">Certainement nous."
		"ep_01.al_rappel_rooftops" = "<font color=\"rgb(255,212,255)\">Ca vient des toits!"
		"ep_01.al_rappel_rooftops_loud" = "<font color=\"rgb(255,212,255)\">Ca vient des toits!"
		"ep_01.al_rappel_scanners" = "<font color=\"rgb(255,212,255)\">Des scanners!"
		"ep_01.al_rappel_spotted" = "<font color=\"rgb(255,212,255)\">On est repérés."
		"ep_01.al_safehouse_separate01" = "<font color=\"rgb(255,212,255)\">Gordon et moi pouvons prendre deux routes différentes pour détourner l'attention du Cartel."
		"ep_01.al_safehouse_separate02" = "<font color=\"rgb(255,212,255)\">Ca vous laisse le temps de remplir les trains avant qu'on arrive."
		"ep_01.al_safehouse_stoleinfo01" = "<font color=\"rgb(255,212,255)\">On a volé des informations dans la Citadelle."
		"ep_01.al_safehouse_stoleinfo02" = "<font color=\"rgb(255,212,255)\">Je ne sais pas encore ce que c'est,"
		"ep_01.al_safehouse_stoleinfo03" = "<font color=\"rgb(255,212,255)\">mais ça doit être important pour qu'ils nous pourchassent jusqu'ici."
		"ep_01.al_safehouse_vorthand01" = "<font color=\"rgb(255,212,255)\">On n'est pas tout à fait sûrs."
		"ep_01.al_safehouse_vorthand02" = "<font color=\"rgb(255,212,255)\">Les Vorts y sont pour quelque chose."
		"ep_01.al_safehouse_vorthand03" = "<font color=\"rgb(255,212,255)\">C'est tout ce que je sais."
		"ep_01.al_safehouse_vortsomething01" = "<font color=\"rgb(255,212,255)\">On n'est pas tout à fait sûrs."
		"ep_01.al_safehouse_vortsomething02" = "<font color=\"rgb(255,212,255)\">Mais les Vorts y sont pour quelque chose,"
		"ep_01.al_safehouse_whataboutyou" = "<font color=\"rgb(255,212,255)\">Mais, et vous, Barney?"
		"ep_01.al_safehouse_yeah_new" = "<font color=\"rgb(255,212,255)\">Ouais."
		"ep_01.al_sniper_climbup" = "<font color=\"rgb(255,212,255)\">Je vais grimper et voir un peu ce qui nous attend."
		"ep_01.al_sniper_fort" = "<font color=\"rgb(255,212,255)\">Oh oh. La route est fortifiée par-là."
		"ep_01.al_sniper_headoff01" = "<font color=\"rgb(255,212,255)\">Joli lancer, Gordon!"
		"ep_01.al_sniper_headoff02" = "<font color=\"rgb(255,212,255)\">Ce sniper a failli me décapiter!"
		"ep_01.al_sniper_runpoint_new01" = "<font color=\"rgb(255,212,255)\">Vous ouvrez le chemin, OK?"
		"ep_01.al_sniper_runpoint_new02" = "<font color=\"rgb(255,212,255)\">Je vous couvre jusqu'à ce que vous arriviez à l'autre bout."
		"ep_01.al_sniper_runpoint_new03" = "<font color=\"rgb(255,212,255)\">Dès que la voie est libre, je vous rattrape."
		"ep_01.al_sniper_runpoint_new04" = "<font color=\"rgb(255,212,255)\">D'accord?"
