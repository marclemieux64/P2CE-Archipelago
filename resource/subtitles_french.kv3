		"ep_01.al_train_ride02" = "<font color=\"rgb(255,212,255)\">Il dit qu'il m'a emmenée une fois, mais je ne m'en rappelle plus."
		"ep_01.al_tunnel_catchbreath01" = "<font color=\"rgb(255,212,255)\">Je..."
