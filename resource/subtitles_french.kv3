		"ep_02.sheckley_moreat1breach" = "<font color=\"rgb(251,218,194)\">D'autres à la brèche!"
		"ep_02.sheckley_moreat24" = "<font color=\"rgb(251,218,194)\">D'autres sur le 24!"
		"ep_02.sheckley_moreat36" = "<font color=\"rgb(251,218,194)\">D'autres sur le 36!"
		"ep_02.sheckley_needagun" = "<font color=\"rgb(251,218,194)\">Hé, Doc, s'il vous faut une arme, il y en a par ici."
		"ep_02.sheckley_needsomehelp" = "<font color=\"rgb(251,218,194)\">Je vais avoir besoin d'aide ce coup-là."
		"ep_02.sheckley_nestbigger" = "<font color=\"rgb(251,218,194)\">Ce nid doit être plus gros qu'on ne le pensait."
		"ep_02.sheckley_neverseen" = "<font color=\"rgb(251,218,194)\">Je n'en ai jamais vu autant en même temps."
