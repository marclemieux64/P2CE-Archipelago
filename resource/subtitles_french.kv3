		"ep_02.reb_shootmag06" = "Tirez sur le Magnusson!"
		"ep_02.reb_shootmag07" = "Détruisez-le!"
		"ep_02.reb_shootmag08" = "Faites sauter ce truc!"
		"ep_02.reb_silo_bailout" = "Wow! Quand je vais dire aux autres que j'ai sauvé la mise à Gordon Freeman! (calmant son enthousiasme) Ok, je la ferme."
		"ep_02.reb_silo_evacuee" = "Eh Doc, je voulais vous remercier. J'étais dans le train que vous avez fait évacuer de Cité 17."
		"ep_02.reb_silo_extrahands" = "Eh! Vous venez pour le coup de main!"
