		"ep_02.al_launch_findus01" = "<font color=\"rgb(255,212,255)\">OK, je vous prends au mot. "
		"ep_02.al_launch_findus02" = "<font color=\"rgb(255,212,255)\">Vous aussi, Dr Magnusson. "
