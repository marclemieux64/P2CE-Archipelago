		"ep_01.al_core_parting" = "<font color=\"rgb(255,212,255)\">Dépêchez-vous."
		"ep_01.al_core_saybye01" = "<font color=\"rgb(255,212,255)\">Gordon, ce..."
		"ep_01.al_core_saybye02" = "<font color=\"rgb(255,212,255)\">Ce n'est pas un adieu."
		"ep_01.al_dropship_getback01" = "<font color=\"rgb(255,212,255)\">Gordon."
		"ep_01.al_dropship_getback02" = "<font color=\"rgb(255,212,255)\">Faites gaffe!"
