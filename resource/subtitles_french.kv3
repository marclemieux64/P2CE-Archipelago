		"ep_01.al_lift_moving" = "<font color=\"rgb(255,212,255)\">Ca y est, c'est parti..."
		"ep_01.al_lift_nearmiss01" = "<font color=\"rgb(255,212,255)\">Ouah!"
		"ep_01.al_lift_nearmiss02" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_lift_nearmiss03" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_lift_nearmiss04" = "<font color=\"rgb(255,212,255)\">Ouh, c'est pas passé loin!"
		"ep_01.al_lift_nearmiss05" = "<font color=\"rgb(255,212,255)\">Ah, merde!"
		"ep_01.al_lift_powerout" = "<font color=\"rgb(255,212,255)\">Pourquoi il ne fonctionne pas... Il ne doit plus y avoir de courant."
		"ep_01.al_lift_run" = "<font color=\"rgb(255,212,255)\">Vite, courez!"
		"ep_01.al_lift_stall01" = "<font color=\"rgb(255,212,255)\">Ah non, encore?"
		"ep_01.al_lift_stall02" = "<font color=\"rgb(255,212,255)\">On s'arrête encore."
		"ep_01.al_lift_stall03" = "<font color=\"rgb(255,212,255)\">Mais pourquoi on s'arrête?"
		"ep_01.al_lift_stall04" = "<font color=\"rgb(255,212,255)\">Il va s'arrêter à tous les étages?"
		"ep_01.al_lift_stall05" = "<font color=\"rgb(255,212,255)\">Hhhh, ça ne se passe pas si bien que ça."
		"ep_01.al_lift_stalled" = "<font color=\"rgb(255,212,255)\">On s'est arrêtés. Essayez de nous faire repartir."
		"ep_01.al_lift_startagain" = "<font color=\"rgb(255,212,255)\">Faites-le repartir. Faites comme la dernière fois, Gordon."
		"ep_01.al_lift_stop" = "<font color=\"rgb(255,212,255)\">On descend là! Préparez-vous!"
		"ep_01.al_lift_tocore" = "<font color=\"rgb(255,212,255)\">On dirait que ce monte-charge va jusqu'au noyau."
		"ep_01.al_lift_tryagain" = "<font color=\"rgb(255,212,255)\">Essayez."
		"ep_01.al_lift_tryagaingord" = "<font color=\"rgb(255,212,255)\">Oh, non. Essayez encore."
		"ep_01.al_lift_vulnerable" = "<font color=\"rgb(255,212,255)\">On est vulnérables ici. Il faut le faire marcher."
		"ep_01.al_lift_warns01" = "<font color=\"rgb(255,212,255)\">Là-haut! Attention! "
		"ep_01.al_lift_warns02" = "<font color=\"rgb(255,212,255)\">Virez ce truc avant qu'il ne nous touche."
		"ep_01.al_lift_warns03" = "<font color=\"rgb(255,212,255)\">Virez ce truc avant qu'il ne nous touche."
		"ep_01.al_lift_warns04" = "<font color=\"rgb(255,212,255)\">Il ne doit pas nous toucher."
		"ep_01.al_lift_warns05" = "<font color=\"rgb(255,212,255)\">En voilà d'autres."
		"ep_01.al_lift_warns06" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_lift_warns07" = "<font color=\"rgb(255,212,255)\">Là-haut!"
		"ep_01.al_lift_warns08" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_lift_warns09" = "<font color=\"rgb(255,212,255)\">Eloignez-le!"
		"ep_01.al_lift_warns10" = "<font color=\"rgb(255,212,255)\">En voilà un gros."
		"ep_01.al_lift_warns11" = "<font color=\"rgb(255,212,255)\">En voilà un autre."
		"ep_01.al_lift_warns12" = "<font color=\"rgb(255,212,255)\">Un autre!"
		"ep_01.al_lift_warns13" = "<font color=\"rgb(255,212,255)\">Là-haut!"
		"ep_01.al_lift_warns14" = "<font color=\"rgb(255,212,255)\">Bon sang! "
		"ep_01.al_lift_watchout" = "<font color=\"rgb(255,212,255)\">Attention! "
		"ep_01.al_light_antlion" = "<font color=\"rgb(255,212,255)\">Éclairez cette fourmi-lion."
		"ep_01.al_light_barnacle01" = "<font color=\"rgb(255,212,255)\">Éclairez ce bernacle."
		"ep_01.al_light_barnacle02" = "<font color=\"rgb(255,212,255)\">Éclairez bien le bernacle."
		"ep_01.al_light_blind01" = "<font color=\"rgb(255,212,255)\">Je ne vois rien."
		"ep_01.al_light_blind02" = "<font color=\"rgb(255,212,255)\">Je ne vois rien sans votre lampe torche."
		"ep_01.al_light_blind03" = "<font color=\"rgb(255,212,255)\">Je ne vois pas où je mets les pieds."
		"ep_01.al_light_blind04" = "<font color=\"rgb(255,212,255)\">Attention, je ne vois rien du tout."
		"ep_01.al_light_blind05" = "<font color=\"rgb(255,212,255)\">Il fait trop noir."
		"ep_01.al_light_blind06" = "<font color=\"rgb(255,212,255)\">Il fait trop noir."
		"ep_01.al_light_generic01" = "<font color=\"rgb(255,212,255)\">Éclairez-moi ça."
		"ep_01.al_light_generic02" = "<font color=\"rgb(255,212,255)\">Mais, éclairez-moi ce truc."
		"ep_01.al_light_generic03" = "<font color=\"rgb(255,212,255)\">Mais, éclairez-moi ça."
		"ep_01.al_light_ok01" = "<font color=\"rgb(255,212,255)\">Ah, c'est mieux."
		"ep_01.al_light_ok02" = "<font color=\"rgb(255,212,255)\">Éclairez par là."
		"ep_01.al_light_ok03" = "<font color=\"rgb(255,212,255)\">Merci."
		"ep_01.al_light_ok04" = "<font color=\"rgb(255,212,255)\">Et la lumière fut."
		"ep_01.al_light_recharge01" = "<font color=\"rgb(255,212,255)\">Bon sang, il faut la recharger?"
		"ep_01.al_light_recharge02" = "<font color=\"rgb(255,212,255)\">Rehargeons-la, je vous attends."
		"ep_01.al_light_recharge03" = "<font color=\"rgb(255,212,255)\">Ah... vous chargez encore votre lampe?"
		"ep_01.al_light_recharge04" = "<font color=\"rgb(255,212,255)\">Je sais très bien que vous ne l'avez pas fait exprès, Gordon. Mais... c'est vraiment agaçant."
		"ep_01.al_light_recharge05" = "<font color=\"rgb(255,212,255)\">Il faut vraiment demander au Dr Kleiner une nouvelle batterie pour la lampe torche."
		"ep_01.al_light_recharge06" = "<font color=\"rgb(255,212,255)\">Rechargez votre lampe torche. Je vais avoir besoin de temps pour faire marcher ce truc."
		"ep_01.al_light_recharge07" = "<font color=\"rgb(255,212,255)\">Attendons pendant qu'elle se charge."
		"ep_01.al_light_turnon01" = "<font color=\"rgb(255,212,255)\">Allumez votre lampe torche!"
		"ep_01.al_light_turnon02" = "<font color=\"rgb(255,212,255)\">Éclairez par là."
		"ep_01.al_light_turnon03" = "<font color=\"rgb(255,212,255)\">J'ai besoin de lumière."
		"ep_01.al_light_turnon04" = "<font color=\"rgb(255,212,255)\">Allumez la lampe de la combi."
		"ep_01.al_light_zombie" = "<font color=\"rgb(255,212,255)\">Éclairez ce zombie!"
		"ep_01.al_lookatgravgun" = "<font color=\"rgb(255,212,255)\">Regardez le pistolet! Mais qu'est-ce qui se passe?"
		"ep_01.al_lookatthem" = "<font color=\"rgb(255,212,255)\">Regardez-les. Je me demande s'ils essaient de s'échapper ou s'ils ne comprennent pas ce qui se passe."
		"ep_01.al_lookout01" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_lookoutforvan" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_lookslikeundercontrol" = "<font color=\"rgb(255,212,255)\">On dirait que vous avez la situation en main."
		"ep_01.al_lowerbridge" = "<font color=\"rgb(255,212,255)\">Quoi encore?"
		"ep_01.al_madedamnthings" = "<font color=\"rgb(255,212,255)\">C'est là qu'ils ont dû fabriquer ces trucs."
		"ep_01.al_missyoutoo" = "<font color=\"rgb(255,212,255)\">Tu vas me manquer."
		"ep_01.al_monsterbehindplayer01" = "<font color=\"rgb(255,212,255)\">Derrière vous!"
		"ep_01.al_monsterbehindplayer02" = "<font color=\"rgb(255,212,255)\">Derrière vous!"
		"ep_01.al_monsterbehindplayer03" = "<font color=\"rgb(255,212,255)\">Attention, Gordon!"
		"ep_01.al_monsterbehindplayer04" = "<font color=\"rgb(255,212,255)\">Retournez-vous!"
		"ep_01.al_morerollers" = "<font color=\"rgb(255,212,255)\">Balançons plus de lamineurs."
		"ep_01.al_moretime" = "<font color=\"rgb(255,212,255)\">Ca nous laissera plus de temps pour sortir de la ville. J'ai beaucoup d'informations pour mon père et le Dr Kleiner."
		"ep_01.al_mostwanted" = "<font color=\"rgb(255,212,255)\">Le nom de mon père! Ca doit être la liste noire du Cartel."
		"ep_01.al_movecar" = "<font color=\"rgb(255,212,255)\">Déplacez cette voiture pour qu'on passe!"
		"ep_01.al_movejunk" = "<font color=\"rgb(255,212,255)\">Enlevez-moi ça d'abord."
		"ep_01.al_moveouttogether" = "<font color=\"rgb(255,212,255)\">On y va ensemble."
		"ep_01.al_museum01" = "<font color=\"rgb(255,212,255)\">Quelqu'un a dû aménager un musée secret ici. C'est des trésors de l'humanité, ça."
		"ep_01.al_museum02" = "<font color=\"rgb(255,212,255)\">Et maintenant, c'est de l'histoire ancienne."
		"ep_01.al_mustbeit" = "<font color=\"rgb(255,212,255)\">Je crois que c'est par là."
		"ep_01.al_nag_keepmoving01" = "<font color=\"rgb(255,212,255)\">Allez, on continue."
		"ep_01.al_nag_keepmoving02" = "<font color=\"rgb(255,212,255)\">On doit continuer."
		"ep_01.al_nag_keepmoving03" = "<font color=\"rgb(255,212,255)\">On se dépêche."
		"ep_01.al_nag_stalkcar01" = "<font color=\"rgb(255,212,255)\">Montez, Gordon."
		"ep_01.al_nag_stalkcar02" = "<font color=\"rgb(255,212,255)\">Allez."
		"ep_01.al_nag_station01" = "<font color=\"rgb(255,212,255)\">Vite, montez dans le train."
		"ep_01.al_nag_station02" = "<font color=\"rgb(255,212,255)\">Montez, le dernier train part!"
		"ep_01.al_nag_station03" = "<font color=\"rgb(255,212,255)\">On va les repousser. Vous, vous devez quitter la ville tout de suite! "
		"ep_01.al_nag_station04" = "<font color=\"rgb(255,212,255)\">Allez! C'est votre dernière chance!"
		"ep_01.al_needtokeepmoving" = "<font color=\"rgb(255,212,255)\">Allez, Gordon, il faut continuer."
		"ep_01.al_nextfloor" = "<font color=\"rgb(255,212,255)\">La sortie est peut-être à l'étage du dessous."
		"ep_01.al_nicestrider" = "<font color=\"rgb(255,212,255)\">Bien joué avec le strider!"
		"ep_01.al_noelevator" = "<font color=\"rgb(255,212,255)\">Normalement, il y a un ascenseur ici. Bon sang. Il va falloir trouver un autre chemin."
		"ep_01.al_noelevator01" = "<font color=\"rgb(255,212,255)\">Normalement, il y a un ascenseur ici."
		"ep_01.al_noelevator02" = "<font color=\"rgb(255,212,255)\">Mince."
		"ep_01.al_noelevator03" = "<font color=\"rgb(255,212,255)\">Il va falloir trouver un autre chemin."
		"ep_01.al_noseatbelts" = "<font color=\"rgb(255,212,255)\">Hmm... Préparez-vous, Gordon."
		"ep_01.al_notanymore" = "<font color=\"rgb(255,212,255)\">Plus maintenant."
		"ep_01.al_notgonnawork" = "<font color=\"rgb(255,212,255)\">Hmm, ça, ça ne va pas marcher."
		"ep_01.al_nothangaround" = "<font color=\"rgb(255,212,255)\">Bien joué, Gordon. Ne restons pas ici. Le Dr Kleiner a dit que ça se réchaufferait bientôt."
		"ep_01.al_nothangaround01" = "<font color=\"rgb(255,212,255)\">Bien joué, Gordon."
		"ep_01.al_nothangaround02" = "<font color=\"rgb(255,212,255)\">Ne restons pas ici."
		"ep_01.al_nottimetoplay" = "<font color=\"rgb(255,212,255)\">C'est pas le moment de jouer!"
		"ep_01.al_notyourfault" = "<font color=\"rgb(255,212,255)\">Pas de problème, ce n'est pas de ta faute."
		"ep_01.al_nowgoboy" = "<font color=\"rgb(255,212,255)\">Allez, mon chien, vas-y. Ça va aller, il faut..."
		"ep_01.al_offscale" = "<font color=\"rgb(255,212,255)\">Waouh, ces mesures sont vraiment très élevées."
		"ep_01.al_offyourback" = "<font color=\"rgb(255,212,255)\">Barney! On les a retenus autant que possible."
		"ep_01.al_ohgordon" = "<font color=\"rgb(255,212,255)\">Oh, Gordon!"
		"ep_01.al_ohnoapc" = "<font color=\"rgb(255,212,255)\">Oh non, un blindé!"
		"ep_01.al_okdownthere" = "<font color=\"rgb(255,212,255)\">Ça va, en bas?"
		"ep_01.al_okletsgo01" = "<font color=\"rgb(255,212,255)\">OK, on y va!"
		"ep_01.al_omg01" = "<font color=\"rgb(255,212,255)\">Bon sang..."
		"ep_01.al_omg02" = "<font color=\"rgb(255,212,255)\">Oh, bon sang..."
		"ep_01.al_omgdog01" = "<font color=\"rgb(255,212,255)\">Bon sang! Chien!"
		"ep_01.al_omgdog02" = "<font color=\"rgb(255,212,255)\">Chien!"
		"ep_01.al_omgdog03" = "<font color=\"rgb(255,212,255)\">Chien, ça va?"
		"ep_01.al_onceacross" = "<font color=\"rgb(255,212,255)\">Chien, quand on sera passés, je veux que tu sortes d'ici. Tu ne pourras pas nous suivre, alors va chercher Papa. Comme ça, je saurai où te retrouver, OK?"
		"ep_01.al_onceacross02" = "<font color=\"rgb(255,212,255)\">Va chercher Papa."
		"ep_01.al_onceacross03" = "<font color=\"rgb(255,212,255)\">On te retrouvera, ne t'en fais pas."
		"ep_01.al_onedeadstrider" = "<font color=\"rgb(255,212,255)\">Chaud devant, un strider, un."
		"ep_01.al_onfoot" = "<font color=\"rgb(255,212,255)\">Il faut continuer à pied."
		"ep_01.al_onhistrail" = "<font color=\"rgb(255,212,255)\">Pas tout à fait, Papa, mais on l'a trouvé!"
		"ep_01.al_onlywaytocore" = "<font color=\"rgb(255,212,255)\">On doit traverser. C'est le seul chemin pour aller au noyau."
		"ep_01.al_outcontact" = "<font color=\"rgb(255,212,255)\">On sera peut-être coupés quand vous serez dedans, au moins jusqu'à la destruction du noyau."
		"ep_01.al_outofbullets" = "<font color=\"rgb(255,212,255)\">Ils sont à cours de munitions."
		"ep_01.al_overtoyou" = "<font color=\"rgb(255,212,255)\">A vous, Gordon."
		"ep_01.al_packupdog" = "<font color=\"rgb(255,212,255)\">Remballe ça et rejoins-nous sur la partie la plus éloignée."
		"ep_01.al_pb_anotherlock" = "<font color=\"rgb(255,212,255)\">Oh, non... un autre verrou électrique."
		"ep_01.al_pb_antlions01" = "<font color=\"rgb(255,212,255)\">Je ne peux pas faire ça avec des fourmis-lions à nos trousses! On ne peut pas les arrêter?"
		"ep_01.al_pb_antlions02" = "<font color=\"rgb(255,212,255)\">Si on pouvait seulement empêcher les fourmis-lions d'entrer..."
		"ep_01.al_pb_antlions03" = "<font color=\"rgb(255,212,255)\">Je n'y arriverai jamais avec toutes ces fourmis-lions autour de moi!"
		"ep_01.al_pb_awayout" = "<font color=\"rgb(255,212,255)\">Ah, enfin une sortie."
		"ep_01.al_pb_buildcharge" = "<font color=\"rgb(255,212,255)\">Attendez. Je vais poser une charge."
		"ep_01.al_pb_chargetofull" = "<font color=\"rgb(255,212,255)\">Vous devriez charger complètement votre lampe torche."
		"ep_01.al_pb_crossfingers" = "<font color=\"rgb(255,212,255)\">Croisez les doigts."
		"ep_01.al_pb_cycleup" = "<font color=\"rgb(255,212,255)\">Il faut que j'attende la fin du cycle."
		"ep_01.al_pb_damnpowerlock01" = "<font color=\"rgb(255,212,255)\">Mince. Un verrou électrique."
		"ep_01.al_pb_damnpowerlock02" = "<font color=\"rgb(255,212,255)\">Comment on va ouvrir ça?"
		"ep_01.al_pb_didit" = "<font color=\"rgb(255,212,255)\">Ah, ça a marché!"
		"ep_01.al_pb_findapb" = "<font color=\"rgb(255,212,255)\">Il faut trouver le générateur."
		"ep_01.al_pb_followcable" = "<font color=\"rgb(255,212,255)\">Suivez ce câble et voyez où il mène."
		"ep_01.al_pb_gettingbetter" = "<font color=\"rgb(255,212,255)\">Je crois que je m'améliore."
		"ep_01.al_pb_givemelight" = "<font color=\"rgb(255,212,255)\">Éclairez-moi et je verrai ce que je peux faire."
		"ep_01.al_pb_gottabekidding" = "<font color=\"rgb(255,212,255)\">Oh, c'est pas vrai... un autre verrou électrique."
		"ep_01.al_pb_hatetosay" = "<font color=\"rgb(255,212,255)\">Désolée de vous dire ça, mais on va devoir trouver un autre générateur."
		"ep_01.al_pb_herewego" = "<font color=\"rgb(255,212,255)\">Ça y est..."
		"ep_01.al_pb_heyimgood" = "<font color=\"rgb(255,212,255)\">Hé! Pas mal!"
		"ep_01.al_pb_knowthedrill" = "<font color=\"rgb(255,212,255)\">Vous connaissez la suite."
		"ep_01.al_pb_messtakelonger" = "<font color=\"rgb(255,212,255)\">Quelle fouillis! Pour celui-là, ça prendra certainement plus de temps."
		"ep_01.al_pb_mightgivejolt" = "<font color=\"rgb(255,212,255)\">Hmmm. On dirait que je peux envoyer une décharge. Du moins, ça suffira pour ouvrir la porte."
		"ep_01.al_pb_mightwork" = "<font color=\"rgb(255,212,255)\">Ca peut peut-être marcher."
		"ep_01.al_pb_notbad" = "<font color=\"rgb(255,212,255)\">Pas mal, pas mal."
		"ep_01.al_pb_readyforjolt" = "<font color=\"rgb(255,212,255)\">Prêt pour la décharge?"
		"ep_01.al_pb_reminders01" = "<font color=\"rgb(255,212,255)\">On charge le générateur et on sort d'ici. "
		"ep_01.al_pb_reminders02" = "<font color=\"rgb(255,212,255)\">Trouvons le générateur pour pouvoir sortir."
		"ep_01.al_pb_reminders03" = "<font color=\"rgb(255,212,255)\">On n'en a pas fini avec ce générateur."
		"ep_01.al_pb_reminders04" = "<font color=\"rgb(255,212,255)\">Finissons-en avec ce générateur."
		"ep_01.al_pb_reminders05" = "<font color=\"rgb(255,212,255)\">Il faut que je m'occupe de ce générateur."
		"ep_01.al_pb_sofarsogood" = "<font color=\"rgb(255,212,255)\">Bon, jusqu'ici, tout va bien."
		"ep_01.al_pb_sorry01" = "<font color=\"rgb(255,212,255)\">Désolée pour les lampes, Gordon."
		"ep_01.al_pb_sorry02" = "<font color=\"rgb(255,212,255)\">Euh... Je suis vraiment désolée d'avoir grillé les lampes."
		"ep_01.al_pb_sorry03" = "<font color=\"rgb(255,212,255)\">Est-ce que je vous ai dit que j'étais désolée pour les lampes?"
		"ep_01.al_pb_startagain01" = "<font color=\"rgb(255,212,255)\">Je dois recommencer."
		"ep_01.al_pb_startagain02" = "<font color=\"rgb(255,212,255)\">Bon sang, je dois recommencer."
		"ep_01.al_pb_startagain03" = "<font color=\"rgb(255,212,255)\">Hhhh, on recommence."
		"ep_01.al_pb_startagain04" = "<font color=\"rgb(255,212,255)\">Il faut tout recommencer."
		"ep_01.al_pb_thereitis" = "<font color=\"rgb(255,212,255)\">Ah, le voilà."
		"ep_01.al_pb1_afterall" = "<font color=\"rgb(255,212,255)\">Finalement, on va avoir besoin de la lampe torche."
		"ep_01.al_pb1_guessthatwasntit" = "<font color=\"rgb(255,212,255)\">Ah non, c'est raté."
		"ep_01.al_pb1_hm" = "<font color=\"rgb(255,212,255)\">Hmmmm..."
		"ep_01.al_pb1_isee" = "<font color=\"rgb(255,212,255)\">OK, je comprends. Je crois qu'il suffit de... hmmm..."
		"ep_01.al_pb1_lettherebelight01" = "<font color=\"rgb(255,212,255)\">Et que la lumière..."
		"ep_01.al_pb1_lettherebelight02" = "<font color=\"rgb(255,212,255)\">... soit??"
		"ep_01.al_pb1_morelight" = "<font color=\"rgb(255,212,255)\">Je peux avoir un peu plus de lumière, Gordon?"
		"ep_01.al_pb1_nicenottorely" = "<font color=\"rgb(255,212,255)\">Ce serait bien de pouvoir se passer de cette lampe torche."
		"ep_01.al_pb1_noreasonicant" = "<font color=\"rgb(255,212,255)\">Si je peux faire fonctionner le générateur, on devrait pouvoir allumer les lampes de tout le secteur. Alors les portes se débloqueront."
		"ep_01.al_pb1_oh" = "<font color=\"rgb(255,212,255)\">Oh! "
		"ep_01.al_pb1_ohgreat" = "<font color=\"rgb(255,212,255)\">Oh, super."
		"ep_01.al_pb1_ready" = "<font color=\"rgb(255,212,255)\">Prêt?"
		"ep_01.al_pb1_therewego" = "<font color=\"rgb(255,212,255)\">C'est bon!"
		"ep_01.al_pb1_thisinstead" = "<font color=\"rgb(255,212,255)\">Hmm. Essayons plutôt ça."
		"ep_01.al_pb1_toomuchpower" = "<font color=\"rgb(255,212,255)\">J'ai utilisé un petit peu trop de courant cette fois-ci."
		"ep_01.al_pb1_whatididwrong" = "<font color=\"rgb(255,212,255)\">Ah, je comprends mon erreur... On n'aura pas de lumière, mais je pourrai ouvrir la porte."
		"ep_01.al_pb1_whatsthis" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que c'est?"
		"ep_01.al_placecomingapart01" = "<font color=\"rgb(255,212,255)\">Bon sang. Cet endroit est vraiment en train de s'écrouler."
		"ep_01.al_placecomingapart02" = "<font color=\"rgb(255,212,255)\">Il faut se dépêcher."
		"ep_01.al_plantbounce" = "<font color=\"rgb(255,212,255)\">Essayez de poser des grenades..."
		"ep_01.al_player_goodshot01" = "<font color=\"rgb(255,212,255)\">Bien joué."
		"ep_01.al_player_goodshot02" = "<font color=\"rgb(255,212,255)\">Hé, bien joué."
		"ep_01.al_player_goodshot03" = "<font color=\"rgb(255,212,255)\">Pas mal."
		"ep_01.al_player_goodshot04" = "<font color=\"rgb(255,212,255)\">Hé, pas mal."
		"ep_01.al_player_healthlow01" = "<font color=\"rgb(255,212,255)\">Vous n'avez pas l'air en forme."
		"ep_01.al_player_healthlow02" = "<font color=\"rgb(255,212,255)\">Il faut trouver une trousse de secours."
		"ep_01.al_player_healthlow03" = "<font color=\"rgb(255,212,255)\">Vous n'avez pas l'air d'être en forme."
		"ep_01.al_player_healthlow04" = "<font color=\"rgb(255,212,255)\">Gordon, vous n'avez pas l'air d'aller bien."
		"ep_01.al_player_healthlow05" = "<font color=\"rgb(255,212,255)\">Cherchez des trousses de secours."
		"ep_01.al_player_newweapon01" = "<font color=\"rgb(255,212,255)\">On dirait que vous savez l'utiliser."
		"ep_01.al_player_newweapon02" = "<font color=\"rgb(255,212,255)\">Ca a l'air d'être votre style d'arme."
		"ep_01.al_player_newweapon03" = "<font color=\"rgb(255,212,255)\">Cette arme est faite pour vous."
		"ep_01.al_player_newweapon04" = "<font color=\"rgb(255,212,255)\">Je vois que vous avez l'habitude."
		"ep_01.al_playerdeath01" = "<font color=\"rgb(255,212,255)\">Oh, non!"
		"ep_01.al_playerdeath02" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_01.al_playerdeath03" = "<font color=\"rgb(255,212,255)\">Non, Gordon!"
		"ep_01.al_playerdeath04" = "<font color=\"rgb(255,212,255)\">Mon Dieu!"
		"ep_01.al_playerfalls01" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_01.al_playerfalls02" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_playerfalls03" = "<font color=\"rgb(255,212,255)\">Noooon!"
		"ep_01.al_playerreload01" = "<font color=\"rgb(255,212,255)\">Eh, rechargez tant qu'il est temps."
		"ep_01.al_playerreload02" = "<font color=\"rgb(255,212,255)\">N'oubliez pas de recharger."
		"ep_01.al_playerreload03" = "<font color=\"rgb(255,212,255)\">Vérifiez vos munitions."
		"ep_01.al_playerseesmonster01" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que c'est?... Ohhhh!"
		"ep_01.al_playerseesmonster02" = "<font color=\"rgb(255,212,255)\">Quoi?"
		"ep_01.al_playerseesmonster03" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'il y a, Gordon?"
		"ep_01.al_playerstare01" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'il y a?"
		"ep_01.al_playerstare02" = "<font color=\"rgb(255,212,255)\">Hmmm?"
		"ep_01.al_playerstare03" = "<font color=\"rgb(255,212,255)\">Il vous faut quelque chose?"
		"ep_01.al_playerstare04" = "<font color=\"rgb(255,212,255)\">Ça va?"
		"ep_01.al_pod_lookout" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_powerball01" = "<font color=\"rgb(255,212,255)\">Pas mal!"
		"ep_01.al_powerball02" = "<font color=\"rgb(255,212,255)\">Pas mal!"
		"ep_01.al_powertobridge" = "<font color=\"rgb(255,212,255)\">Il faut mettre le générateur du pont sous tension. Mais comment?"
		"ep_01.al_pushcarback" = "<font color=\"rgb(255,212,255)\">Remettez la voiture. Ca pourrait les ralentir."
		"ep_01.al_pushitout" = "<font color=\"rgb(255,212,255)\">Jetez-le dans le champ magnétique."
		"ep_01.al_putdown" = "<font color=\"rgb(255,212,255)\">Laisse tomber ce que tu fais et viens m'aider."
		"ep_01.al_putdown01" = "<font color=\"rgb(255,212,255)\">Je crois que j'ai trouvé un truc."
		"ep_01.al_putdown02" = "<font color=\"rgb(255,212,255)\">Laisse tomber ça, viens. Viens ici..."
		"ep_01.al_putdown03" = "<font color=\"rgb(255,212,255)\">[halètement]"
		"ep_01.al_putdown04" = "<font color=\"rgb(255,212,255)\">Bon sang!"
		"ep_01.al_quitgoofing" = "<font color=\"rgb(255,212,255)\">J'essaie de trouver une solution, arrête de faire l'imbécile."
		"ep_01.al_rattrap" = "<font color=\"rgb(255,212,255)\">Bon sang... Ils ont été piégés comme des rats..."
		"ep_01.al_rearguard" = "<font color=\"rgb(255,212,255)\">Ils ont laissé une arrière-garde."
		"ep_01.al_reload01" = "<font color=\"rgb(255,212,255)\">Je recharge!"
		"ep_01.al_reload02" = "<font color=\"rgb(255,212,255)\">Plus de munitions."
		"ep_01.al_reload03" = "<font color=\"rgb(255,212,255)\">Je recharge!"
		"ep_01.al_reload04" = "<font color=\"rgb(255,212,255)\">Je recharge!"
		"ep_01.al_reload05" = "<font color=\"rgb(255,212,255)\">Je recharge!"
		"ep_01.al_reload06" = "<font color=\"rgb(255,212,255)\">Je recharge!"
		"ep_01.al_right" = "<font color=\"rgb(255,212,255)\">OK."
		"ep_01.al_roll_bring" = "<font color=\"rgb(255,212,255)\">Attrapez un des lamineurs, Gordon."
		"ep_01.al_roll_grab01" = "<font color=\"rgb(255,212,255)\">Prenez l'un de ces lamineurs."
		"ep_01.al_roll_gravgun" = "<font color=\"rgb(255,212,255)\">Prenez-le avec le pistolet."
		"ep_01.al_roll_holdout01" = "<font color=\"rgb(255,212,255)\">Donnez-le moi."
		"ep_01.al_roll_holdout02" = "<font color=\"rgb(255,212,255)\">Donnez-le moi."
		"ep_01.al_roll_icanhack" = "<font color=\"rgb(255,212,255)\">Je vais le pirater et l'envoyer contre les soldats du Cartel."
		"ep_01.al_roll_letgo01" = "<font color=\"rgb(255,212,255)\">OK, lâchez-le."
		"ep_01.al_roll_shortlive" = "<font color=\"rgb(255,212,255)\">J'ai tellement trafiqué ses circuits qu'il va griller rapidement, mais il devrait faire des dégâts avant."
		"ep_01.al_roll_steady01" = "<font color=\"rgb(255,212,255)\">On y va. OK. Tenez-le."
		"ep_01.al_rolleragain" = "<font color=\"rgb(255,212,255)\">Hmmm, il y en a plein en bas. On dirait qu'ils voulaient se servir de ce train."
		"ep_01.al_safeforme" = "<font color=\"rgb(255,212,255)\">Super, vous avez réussi. Maintenant, je peux venir."
		"ep_01.al_safeforme01" = "<font color=\"rgb(255,212,255)\">Super, vous avez réussi."
		"ep_01.al_safeforme02" = "<font color=\"rgb(255,212,255)\">Maintenant, je peux venir."
		"ep_01.al_safehouse_clearout" = "<font color=\"rgb(255,212,255)\">Mais qu'est-ce vous faites encore là? Tout le monde doit quitter la ville."
		"ep_01.al_safehouse_soundgood" = "<font color=\"rgb(255,212,255)\">Ca a l'air bon. Allons-y."
		"ep_01.al_safehouse_takeus" = "<font color=\"rgb(255,212,255)\">Vous pouvez nous emmener?"
		"ep_01.al_safehouse_tellus" = "<font color=\"rgb(255,212,255)\">Dites-nous où on doit aller."
		"ep_01.al_safehouse_yeah" = "<font color=\"rgb(255,212,255)\">Ouais."
		"ep_01.al_safetillheats" = "<font color=\"rgb(255,212,255)\">Je pense que ça va si je viens. Au moins, jusqu'au réchauffement."
		"ep_01.al_sameaslast_bridge" = "<font color=\"rgb(255,212,255)\">OK, Gordon. Même chose que la dernière fois: on met en marche le pont."
		"ep_01.al_sameaslasttime" = "<font color=\"rgb(255,212,255)\">Même chose que la dernière fois: on active le pont."
		"ep_01.al_sameideaasus" = "<font color=\"rgb(255,212,255)\">On dirait qu'ils ont eu la même idée que nous."
		"ep_01.al_seats" = "<font color=\"rgb(255,212,255)\">Je crois qu'on va se battre pour s'asseoir."
		"ep_01.al_seeforyourself" = "<font color=\"rgb(255,212,255)\">La Citadelle est très instable. On aura à peine le temps de sortir."
		"ep_01.al_seemanyfoe01" = "<font color=\"rgb(255,212,255)\">Eh, regardez-les."
		"ep_01.al_seemanyfoe02" = "<font color=\"rgb(255,212,255)\">Allons-y!"
		"ep_01.al_seemanyfoe03" = "<font color=\"rgb(255,212,255)\">C'est parti!"
		"ep_01.al_seemanyfoe04" = "<font color=\"rgb(255,212,255)\">Hmmm, ça risque d'être intéressant."
		"ep_01.al_seemanyfoe05" = "<font color=\"rgb(255,212,255)\">Oh, là là..."
		"ep_01.al_seemanyfoe06" = "<font color=\"rgb(255,212,255)\">C'est parti..."
		"ep_01.al_seemanyfoe07" = "<font color=\"rgb(255,212,255)\">Allons-y, Gordon..."
		"ep_01.al_seemanyfoe08" = "<font color=\"rgb(255,212,255)\">Ils ne font pas le poids!"
		"ep_01.al_seemanyfoe09" = "<font color=\"rgb(255,212,255)\">Ils sortent de partout."
		"ep_01.al_seemanyfoe10" = "<font color=\"rgb(255,212,255)\">Oh, super."
		"ep_01.al_seewhaticanget" = "<font color=\"rgb(255,212,255)\">Oh. Voyons si je peux trouver des infos."
		"ep_01.al_seeyousoon01" = "<font color=\"rgb(255,212,255)\">On se revoit bientôt..."
		"ep_01.al_seeyousoon02" = "<font color=\"rgb(255,212,255)\">Ne t'en fais pas."
		"ep_01.al_self_healthlow01" = "<font color=\"rgb(255,212,255)\">Je dois trouver des trousses de secours."
		"ep_01.al_self_healthlow02" = "<font color=\"rgb(255,212,255)\">Je suis blessée."
		"ep_01.al_shallwe" = "<font color=\"rgb(255,212,255)\">On y va?"
		"ep_01.al_shortwork" = "<font color=\"rgb(255,212,255)\">On va les avoir en moins de deux avec les tourelles!"
		"ep_01.al_shotathacking" = "<font color=\"rgb(255,212,255)\">Pendant que vous êtes ici, je vais essayer de pirater leur réseau."
		"ep_01.al_shouldevac" = "<font color=\"rgb(255,212,255)\">Mais qu'est-ce que vous faites là? Vous auriez déjà dû partir!"
		"ep_01.al_shutitoff" = "<font color=\"rgb(255,212,255)\">Maintenant je peux le désactiver."
		"ep_01.al_snipe_close01" = "<font color=\"rgb(255,212,255)\">C'est pas passé loin."
		"ep_01.al_snipe_close02" = "<font color=\"rgb(255,212,255)\">Passons par là."
		"ep_01.al_snipe_gunner" = "<font color=\"rgb(255,212,255)\">Je ne vois pas bien cet artilleur... Vous pouvez ouvrir une ligne de tir?"
		"ep_01.al_snipe_ladder01" = "<font color=\"rgb(255,212,255)\">OK, je peux vous descendre cette échelle. Je vais tirer sur le loquet."
		"ep_01.al_snipe_ladder02" = "<font color=\"rgb(255,212,255)\">J'ai peut-être perdu la main avec ce fusil..."
		"ep_01.al_snipe_ladder03" = "<font color=\"rgb(255,212,255)\">Ah! Non, finalement, ça va."
		"ep_01.al_snipe_lure01" = "<font color=\"rgb(255,212,255)\">Faites-les sortir, Gordon!"
		"ep_01.al_snipe_lure02" = "<font color=\"rgb(255,212,255)\">Faites-les sortir pour que je les vise bien."
		"ep_01.al_snipe_lure03" = "<font color=\"rgb(255,212,255)\">Il faut que je les vise bien, Gordon."
		"ep_01.al_snipe_lure04" = "<font color=\"rgb(255,212,255)\">Je m'occupe de ça."
		"ep_01.al_snipe_openandcover01" = "<font color=\"rgb(255,212,255)\">Ouvrez le portail!"
		"ep_01.al_snipe_openandcover02" = "<font color=\"rgb(255,212,255)\">Couvrez-moi pendant que je vous rattrape."
		"ep_01.al_snipe_post" = "<font color=\"rgb(255,212,255)\">OK, je vais prendre la place du sniper et vous couvrir."
		"ep_01.al_snipe_rollers" = "<font color=\"rgb(255,212,255)\">Encore des lamineurs! On va les faire fonctionner."
		"ep_01.al_snipe_runforit01" = "<font color=\"rgb(255,212,255)\">Vous voyez cette barricade?"
		"ep_01.al_snipe_runforit02" = "<font color=\"rgb(255,212,255)\">Vous pouvez courir jusque là-bas?"
		"ep_01.al_snipe_runforit03" = "<font color=\"rgb(255,212,255)\">Je vous couvre, ensuite vous ouvrez la porte et vous me couvrez pendant que je vous rejoins."
		"ep_01.al_snipe_toss" = "<font color=\"rgb(255,212,255)\">Jetez-en un sur les snipers."
		"ep_01.al_sogladtoseeyou" = "<font color=\"rgb(255,212,255)\">Je suis tellement contente de vous voir."
		"ep_01.al_soldiersbusy" = "<font color=\"rgb(255,212,255)\">Oh, des soldats! Ils sont tellement pressés de sortir qu'ils ne s'occupent même pas de nous."
		"ep_01.al_someonefiring" = "<font color=\"rgb(255,212,255)\">Quelqu'un tire."
		"ep_01.al_somethingisaid" = "<font color=\"rgb(255,212,255)\">J'ai dit quelque chose de mal?"
		"ep_01.al_somewayacrossgap" = "<font color=\"rgb(255,212,255)\">Si seulement on pouvait traverser ce gouffre..."
		"ep_01.al_soworried" = "<font color=\"rgb(255,212,255)\">J'étais si inquiète..."
		"ep_01.al_stabilize" = "<font color=\"rgb(255,212,255)\">Vous devez stabiliser le noyau niveau par niveau."
		"ep_01.al_stalk_coveritup" = "<font color=\"rgb(255,212,255)\">Ah. Gordon, couvrez-le, s'il vous plaît!"
		"ep_01.al_stalk_makestop01" = "<font color=\"rgb(255,212,255)\">Non! Arrêtez-le!"
		"ep_01.al_stalk_makestop02" = "<font color=\"rgb(255,212,255)\">Couvrez ses yeux!"
		"ep_01.al_stalk_makestop03" = "<font color=\"rgb(255,212,255)\">Couvrez-le!"
		"ep_01.al_stalk_notalone" = "<font color=\"rgb(255,212,255)\">Je ne pourrais pas rester toute seule ici."
		"ep_01.al_stalk_ohno" = "<font color=\"rgb(255,212,255)\">Oh non! Des stalkers! Je ne peux pas... on ne peut pas rester dans cette voiture."
		"ep_01.al_stalk_story01" = "<font color=\"rgb(255,212,255)\">[Soupir]"
		"ep_01.al_stalk_story02" = "<font color=\"rgb(255,212,255)\">Je suis désolée, Gordon. Je n'ai pas le courage."
		"ep_01.al_stalk_story03" = "<font color=\"rgb(255,212,255)\">Chacun d'entre eux a combattu le Cartel."
		"ep_01.al_stalk_story04" = "<font color=\"rgb(255,212,255)\">J'espère qu'ils ne se rappellent pas qui ils étaient."
		"ep_01.al_stalk_story05" = "<font color=\"rgb(255,212,255)\">Moi aussi..."
		"ep_01.al_stalk_story06" = "<font color=\"rgb(255,212,255)\">Je risque de finir comme ça..."
		"ep_01.al_stalk_train" = "<font color=\"rgb(255,212,255)\">Il faut qu'on prenne ce train. Il n'y en aura peut-être pas d'autre."
		"ep_01.al_stalker_gasp" = "<font color=\"rgb(255,212,255)\">Des stalkers!"
		"ep_01.al_stalkeromg" = "<font color=\"rgb(255,212,255)\">Bon sang. Des stalkers."
		"ep_01.al_stalkersagain" = "<font color=\"rgb(255,212,255)\">Encore des stalkers. Mais qu'est-ce qu'ils manigancent?"
		"ep_01.al_startcombat01" = "<font color=\"rgb(255,212,255)\">C'est reparti."
		"ep_01.al_startcombat02" = "<font color=\"rgb(255,212,255)\">Faites gaffe."
		"ep_01.al_startcombat03" = "<font color=\"rgb(255,212,255)\">Allons-y."
		"ep_01.al_startcombat04" = "<font color=\"rgb(255,212,255)\">Oh, super!"
		"ep_01.al_startingtoflarehurry" = "<font color=\"rgb(255,212,255)\">La Citadelle est en alerte. Il faut se dépêcher!"
		"ep_01.al_staycloseboy01" = "<font color=\"rgb(255,212,255)\">Ah vous êtes là. Vous m'avez fait peur."
		"ep_01.al_staycloseboy02" = "<font color=\"rgb(255,212,255)\">Reste avec nous, mon chien."
		"ep_01.al_stayclosedog01" = "<font color=\"rgb(255,212,255)\">Chien, tu restes avec nous"
		"ep_01.al_stillcrank" = "<font color=\"rgb(255,212,255)\">Vous avez toujours la manivelle?"
		"ep_01.al_stilldontknow" = "<font color=\"rgb(255,212,255)\">D'accord, Papa. Déjà, je ne sais pas comment il est sorti."
		"ep_01.al_stilldontknow01" = "<font color=\"rgb(255,212,255)\">D'accord, Papa."
		"ep_01.al_stilldontknow02" = "<font color=\"rgb(255,212,255)\">Déjà, je ne sais pas comment il est sorti."
		"ep_01.al_stillnotsure" = "<font color=\"rgb(255,212,255)\">Je ne sais plus comment on a fait pour descendre. Tout est confus dans mon esprit. Bref, il faut continuer."
		"ep_01.al_stopclowning" = "<font color=\"rgb(255,212,255)\">Chien, arrête de faire le clown."
		"ep_01.al_stopgoofing" = "<font color=\"rgb(255,212,255)\">Chien, attention à ce que tu fais. Et puis, arrête de faire l'imbécile."
		"ep_01.al_storingpods" = "<font color=\"rgb(255,212,255)\">On dirait qu'ils stockent quelque chose dans les cellules. Comme si elles servaient à charger des trucs."
		"ep_01.al_streaming" = "<font color=\"rgb(255,212,255)\">Il y a une vraie masse d'informations. Le Dr Kleiner va s'en donner à coeur joie!"
		"ep_01.al_strider_berightback" = "<font color=\"rgb(255,212,255)\">Je reviens, Gordon."
		"ep_01.al_strider_keephammering" = "<font color=\"rgb(255,212,255)\">Je ne vais pas vous être très utile pour le strider mais je peux trouver une sortie. Tenez bon et continuez à tirer sur ce truc. Je reviens dès que possible."
		"ep_01.al_strider_whoa" = "<font color=\"rgb(255,212,255)\">Waouh!"
		"ep_01.al_strippedforparts01" = "<font color=\"rgb(255,212,255)\">Alors, ils sont où tes copains, hein?"
		"ep_01.al_strippedforparts02" = "<font color=\"rgb(255,212,255)\">Ils ont pris ce qu'ils voulaient et t'ont laissé mourir?"
		"ep_01.al_strippedforparts03" = "<font color=\"rgb(255,212,255)\">Mais qu'est-ce que tu croyais?"
		"ep_01.al_strippedforparts04" = "<font color=\"rgb(255,212,255)\">Ils ne sont pas plus humains que toi."
		"ep_01.al_sublevelcut" = "<font color=\"rgb(255,212,255)\">On dirait que le Cartel a coupé par les souterrains. Je me demande à quelle profondeur on se trouve."
		"ep_01.al_surround01" = "<font color=\"rgb(255,212,255)\">Je suis cernée!"
		"ep_01.al_surround02" = "<font color=\"rgb(255,212,255)\">Il y en a partout!"
		"ep_01.al_survivors" = "<font color=\"rgb(255,212,255)\">Cherchez les survivants, les gens qui se cachent."
		"ep_01.al_swamped01" = "<font color=\"rgb(255,212,255)\">On est encerclés."
		"ep_01.al_swamped02" = "<font color=\"rgb(255,212,255)\">Il y en a partout."
		"ep_01.al_swamped03" = "<font color=\"rgb(255,212,255)\">Aidez-moi."
		"ep_01.al_swamped04" = "<font color=\"rgb(255,212,255)\">Vous me donnez un coup de main?"
		"ep_01.al_swamped05" = "<font color=\"rgb(255,212,255)\">Vous venez m'aider?"
		"ep_01.al_swamped06" = "<font color=\"rgb(255,212,255)\">Ouh là!"
		"ep_01.al_swamped07" = "<font color=\"rgb(255,212,255)\">Ouuuh!"
		"ep_01.al_swamped08" = "<font color=\"rgb(255,212,255)\">Mais ils viennent-d'où?"
		"ep_01.al_swamped09" = "<font color=\"rgb(255,212,255)\">Merde!"
		"ep_01.al_swamped10" = "<font color=\"rgb(255,212,255)\">Mince!"
		"ep_01.al_swamped11" = "<font color=\"rgb(255,212,255)\">Ah!"
		"ep_01.al_swamped12" = "<font color=\"rgb(255,212,255)\">Merde!"
		"ep_01.al_swamped13" = "<font color=\"rgb(255,212,255)\">Oh!"
		"ep_01.al_takeammo" = "<font color=\"rgb(255,212,255)\">Prenez quelques munitions."
		"ep_01.al_takeoutstalker" = "<font color=\"rgb(255,212,255)\">Liquidez le stalker, s'il le faut. On doit avancer."
		"ep_01.al_takethemwithit" = "<font color=\"rgb(255,212,255)\">Au moins, quand la Citadelle explosera, ils sauteront aussi."
		"ep_01.al_takeusoutcity" = "<font color=\"rgb(255,212,255)\">Hhh... Apparemment, on sort de la ville."
		"ep_01.al_terminalaround" = "<font color=\"rgb(255,212,255)\">Il doit bien y avoir un terminal quelque part, ici."
		"ep_01.al_terminalexplode" = "<font color=\"rgb(255,212,255)\">Ah... Merde."
		"ep_01.al_thankgod" = "<font color=\"rgb(255,212,255)\">Dieu merci!"
