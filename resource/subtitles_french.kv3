		"ep_02.al_barn_advis" = "<font color=\"rgb(255,212,255)\">Un conseiller..."
		"ep_02.al_barn_agh01" = "<font color=\"rgb(255,212,255)\">Euh..."
		"ep_02.al_barn_agh02" = "<font color=\"rgb(255,212,255)\">Agh!"
		"ep_02.al_barn_aghno" = "<font color=\"rgb(255,212,255)\">Ah, non!"
		"ep_02.al_barn_awesome" = "<font color=\"rgb(255,212,255)\">Génial."
		"ep_02.al_barn_back" = "<font color=\"rgb(255,212,255)\">Les revoilà!"
		"ep_02.al_barn_backattower01" = "<font color=\"rgb(255,212,255)\">C'est donc pour ça qu'il n'y a personne ici."
		"ep_02.al_barn_backattower02" = "<font color=\"rgb(255,212,255)\">Ils sont en train de nous chercher au pylône de radio."
		"ep_02.al_barn_backsoon01" = "<font color=\"rgb(255,212,255)\">Ils vont bientôt revenir."
		"ep_02.al_barn_backsoon02" = "<font color=\"rgb(255,212,255)\">Allez, dépêchons-nous."
		"ep_02.al_barn_body01" = "<font color=\"rgb(255,212,255)\">Oouh!"
		"ep_02.al_barn_body02" = "<font color=\"rgb(255,212,255)\">On n'est pas les premiers dans cet endroit."
		"ep_02.al_barn_checkotherbldg01" = "<font color=\"rgb(255,212,255)\">Rien là-dedans. "
		"ep_02.al_barn_checkotherbldg02" = "<font color=\"rgb(255,212,255)\">Fouillons l'autre bâtiment."
		"ep_02.al_barn_combaround01" = "<font color=\"rgb(255,212,255)\">Le Cartel a dû trouver cet endroit."
		"ep_02.al_barn_combaround02" = "<font color=\"rgb(255,212,255)\">Ils sont peut-être encore là."
		"ep_02.al_barn_explode01" = "<font color=\"rgb(255,212,255)\">Ah !"
		"ep_02.al_barn_explode02" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu !"
		"ep_02.al_barn_explode03" = "<font color=\"rgb(255,212,255)\">Ma tête!"
		"ep_02.al_barn_explode04" = "<font color=\"rgb(255,212,255)\">Oouh!"
		"ep_02.al_barn_fishout01" = "<font color=\"rgb(255,212,255)\">Ce truc n'avait pas l'air d'être dans son élément."
		"ep_02.al_barn_fishout02" = "<font color=\"rgb(255,212,255)\">Il devait chercher sa combi spatiale..."
		"ep_02.al_barn_fishout03" = "<font color=\"rgb(255,212,255)\">ou terrestre..."
		"ep_02.al_barn_fishout04" = "<font color=\"rgb(255,212,255)\">Peu importe."
		"ep_02.al_barn_fishout05" = "<font color=\"rgb(255,212,255)\">Partons d'ici avant que ça revienne."
		"ep_02.al_barn_followtracks" = "<font color=\"rgb(255,212,255)\">Si on les suit, on se rapprochera de White Forest."
		"ep_02.al_barn_foundadvisor01" = "<font color=\"rgb(255,212,255)\">Je crois qu'on a trouvé notre conseiller. "
		"ep_02.al_barn_foundadvisor02" = "<font color=\"rgb(255,212,255)\">Le Vort a dit de les tuer avant l'éclosion."
		"ep_02.al_barn_friends_loud01" = "<font color=\"rgb(255,212,255)\">Oh-oh..."
		"ep_02.al_barn_friends_loud02" = "<font color=\"rgb(255,212,255)\">On dirait qu'il a appelé ses amis."
		"ep_02.al_barn_friends01" = "<font color=\"rgb(255,212,255)\">Oh-oh..."
		"ep_02.al_barn_friends02" = "<font color=\"rgb(255,212,255)\">On dirait qu'il a appelé ses amis."
		"ep_02.al_barn_getback" = "<font color=\"rgb(255,212,255)\">Reculez!"
		"ep_02.al_barn_getcar" = "<font color=\"rgb(255,212,255)\">Allons à la voiture."
		"ep_02.al_barn_gettingaway" = "<font color=\"rgb(255,212,255)\">Il s'en va."
		"ep_02.al_barn_gloomy" = "<font color=\"rgb(255,212,255)\">C'est bien lugubre ici."
		"ep_02.al_barn_handy" = "<font color=\"rgb(255,212,255)\">Voyons ce qu'on peut trouver ici."
		"ep_02.al_barn_lambda01" = "<font color=\"rgb(255,212,255)\">Eh, un symbole lambda! "
		"ep_02.al_barn_lambda02" = "<font color=\"rgb(255,212,255)\">C'est bon signe."
		"ep_02.al_barn_letgoofhim01" = "<font color=\"rgb(255,212,255)\">Non! "
		"ep_02.al_barn_letgoofhim02" = "<font color=\"rgb(255,212,255)\">Lâchez-le!"
		"ep_02.al_barn_letgoofhim03" = "<font color=\"rgb(255,212,255)\">Gordon! Pousse-toi!"
		"ep_02.al_barn_letmedown" = "<font color=\"rgb(255,212,255)\">Argh. Laissez-moi !"
		"ep_02.al_barn_letsgetout" = "<font color=\"rgb(255,212,255)\">Fichons le camp d'ici!"
		"ep_02.al_barn_lifesuppnags01" = "<font color=\"rgb(255,212,255)\">Allez, éliminez-moi ce truc."
		"ep_02.al_barn_lifesuppnags02" = "<font color=\"rgb(255,212,255)\">Vous pouvez utiliser le pistolet ici, Gordon?"
		"ep_02.al_barn_lifesupport01" = "<font color=\"rgb(255,212,255)\">Ah..."
		"ep_02.al_barn_lifesupport02" = "<font color=\"rgb(255,212,255)\">Assistance vitale."
		"ep_02.al_barn_likeincitadel01" = "<font color=\"rgb(255,212,255)\">C'est comme... à la Citadelle,  "
		"ep_02.al_barn_likeincitadel02" = "<font color=\"rgb(255,212,255)\">ces choses qu'on a vues..."
		"ep_02.al_barn_likeincitadel03" = "<font color=\"rgb(255,212,255)\">Des conseillers."
		"ep_02.al_barn_locked01" = "<font color=\"rgb(255,212,255)\">C'est verrouillé."
		"ep_02.al_barn_locked02" = "<font color=\"rgb(255,212,255)\">Je voudrais bien y jeter un oeil."
		"ep_02.al_barn_lockup01" = "<font color=\"rgb(255,212,255)\">C'est parti. "
		"ep_02.al_barn_lockup02" = "<font color=\"rgb(255,212,255)\">Ils s'en sont donné du mal pour verrouiller cet endroit."
		"ep_02.al_barn_lockup03" = "<font color=\"rgb(255,212,255)\">Raison de plus pour y regarder de plus près."
		"ep_02.al_barn_lookinbarn" = "<font color=\"rgb(255,212,255)\">Fouillons la grange, Gordon."
		"ep_02.al_barn_no" = "<font color=\"rgb(255,212,255)\">Non."
		"ep_02.al_barn_noplug01" = "<font color=\"rgb(255,212,255)\">Hmmm..."
		"ep_02.al_barn_noplug02" = "<font color=\"rgb(255,212,255)\">Je peux peut-être ouvrir ça..."
		"ep_02.al_barn_ohmygod" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu."
		"ep_02.al_barn_oldoutpost01" = "<font color=\"rgb(255,212,255)\">On dirait un ancien poste de la résistance. "
		"ep_02.al_barn_oldoutpost02" = "<font color=\"rgb(255,212,255)\">Il y a peut-être des munitions."
		"ep_02.al_barn_onearoundhere" = "<font color=\"rgb(255,212,255)\">Vous croyez qu'il y en a un par ici?"
		"ep_02.al_barn_oneofthose01" = "<font color=\"rgb(255,212,255)\">C'est..."
		"ep_02.al_barn_oneofthose02" = "<font color=\"rgb(255,212,255)\">C'est l'un d'entre eux."
		"ep_02.al_barn_oof" = "<font color=\"rgb(255,212,255)\">Oouh!"
		"ep_02.al_barn_oof02" = "<font color=\"rgb(255,212,255)\">Oouh!"
		"ep_02.al_barn_overtoyou" = "<font color=\"rgb(255,212,255)\">C'est à vous, Gordon."
		"ep_02.al_barn_peakview01" = "<font color=\"rgb(255,212,255)\">Eh, je connais ce sommet! On le voit de White Forest! "
		"ep_02.al_barn_peakview02" = "<font color=\"rgb(255,212,255)\">On est sur la bonne route!"
		"ep_02.al_barn_podslaunched01" = "<font color=\"rgb(255,212,255)\">Hé!"
		"ep_02.al_barn_podslaunched02" = "<font color=\"rgb(255,212,255)\">Ça doit être l'un de ces incubateurs de conseiller!"
		"ep_02.al_barn_podslaunched03" = "<font color=\"rgb(255,212,255)\">Ouais."
		"ep_02.al_barn_podslaunched04" = "<font color=\"rgb(255,212,255)\">Il y a un conseiller par ici."
		"ep_02.al_barn_powerdown01" = "<font color=\"rgb(255,212,255)\">Ça devrait..."
		"ep_02.al_barn_powerdown02" = "<font color=\"rgb(255,212,255)\">s'éteindre..."
		"ep_02.al_barn_powerdown03" = "<font color=\"rgb(255,212,255)\">Oh oh."
		"ep_02.al_barn_pullplug01" = "<font color=\"rgb(255,212,255)\">Qu'en dites-vous Gordon?"
		"ep_02.al_barn_pullplug02" = "<font color=\"rgb(255,212,255)\">On débranche?"
		"ep_02.al_barn_pulsewhat" = "<font color=\"rgb(255,212,255)\">Euh, c'était...c'était quoi ça?"
		"ep_02.al_barn_putusdown01" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_barn_putusdown02" = "<font color=\"rgb(255,212,255)\">Hé!"
		"ep_02.al_barn_putusdown03" = "<font color=\"rgb(255,212,255)\">Arrêtez!"
		"ep_02.al_barn_putusdown04" = "<font color=\"rgb(255,212,255)\">Lâchez-nous!"
		"ep_02.al_barn_putusdown05" = "<font color=\"rgb(255,212,255)\">Hé! Arrêtez!"
		"ep_02.al_barn_questionhow01" = "<font color=\"rgb(255,212,255)\">La question c'est..."
		"ep_02.al_barn_questionhow02" = "<font color=\"rgb(255,212,255)\">Comment?"
		"ep_02.al_barn_railbed" = "<font color=\"rgb(255,212,255)\">J'ai cru voir des rails plus bas."
		"ep_02.al_barn_realtrouble01" = "<font color=\"rgb(255,212,255)\">[soupir]"
		"ep_02.al_barn_realtrouble02" = "<font color=\"rgb(255,212,255)\">Pendant un moment, j'ai cru que c'était fichu pour vous."
		"ep_02.al_barn_rebels" = "<font color=\"rgb(255,212,255)\">Ça doit faire longtemps que les rebelles sont partis."
		"ep_02.al_barn_recent" = "<font color=\"rgb(255,212,255)\">Quelqu'un est venu ici récemment... mais qui?"
		"ep_02.al_barn_recon01" = "<font color=\"rgb(255,212,255)\">Une petite reconnaissance s'impose."
		"ep_02.al_barn_recon02" = "<font color=\"rgb(255,212,255)\">Je me demande ce qu'ils mijotent."
		"ep_02.al_barn_samething01" = "<font color=\"rgb(255,212,255)\">Vous avez senti?"
		"ep_02.al_barn_shutdownwhoa" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_barn_soldiers01" = "<font color=\"rgb(255,212,255)\">Des soldats!"
		"ep_02.al_barn_soldiers02" = "<font color=\"rgb(255,212,255)\">Il faut sortir d'ici!"
