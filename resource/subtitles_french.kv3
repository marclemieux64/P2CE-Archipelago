		"ep_01.al_stalk_crushed02" = "<font color=\"rgb(255,212,255)\">ils m'écrasent."
		"ep_01.al_stalk_derail_omg" = "<font color=\"rgb(255,212,255)\">Mon Dieu!"
		"ep_01.al_stalk_getemoff01" = "<font color=\"rgb(255,212,255)\">Gordon"
		"ep_01.al_stalk_getemoff02" = "<font color=\"rgb(255,212,255)\">À l'aide!"
		"ep_01.al_stalk_getemoff03" = "<font color=\"rgb(255,212,255)\">À l'aide!"
		"ep_01.al_stalk_getemoff04" = "<font color=\"rgb(255,212,255)\">Pitié..."
