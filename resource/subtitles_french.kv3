		"ep_02.eli_launch_pain12" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_pain13" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_pain14" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_portalyes01" = "<font color=\"rgb(255,208,172)\">Oui!"
		"ep_02.eli_launch_portalyes02" = "<font color=\"rgb(255,208,172)\">Oui!"
		"ep_02.eli_launch_portalyes03" = "<font color=\"rgb(255,208,172)\">Oui!"
		"ep_02.eli_launch_promiseme" = "<font color=\"rgb(255,208,172)\">Détruisez-le!"
		"ep_02.eli_launch_promiseme_alt" = "<font color=\"rgb(255,208,172)\">Détruisez-le!"
		"ep_02.eli_launch_promiseme01" = "<font color=\"rgb(255,208,172)\">Bien, je..."
		"ep_02.eli_launch_promiseme02" = "<font color=\"rgb(255,208,172)\">Promettez-moi"
		"ep_02.eli_launch_promiseme03" = "<font color=\"rgb(255,208,172)\">que vous serez prudents."
		"ep_02.eli_launch_pulleditoff01" = "<font color=\"rgb(255,208,172)\">Ouais."
		"ep_02.eli_launch_pulleditoff02" = "<font color=\"rgb(255,208,172)\">Magnusson s'en est bien sorti, hein?"
		"ep_02.eli_launch_pulleditoff03" = "<font color=\"rgb(255,208,172)\">Eh bien, comme ça, le Cartel aura compris à qui il a affaire."
		"ep_02.eli_launch_pulleditoff04" = "<font color=\"rgb(255,208,172)\">On n'est pas encore libres..."
		"ep_02.eli_launch_pulleditoff05" = "<font color=\"rgb(255,208,172)\">Mais si on obtient une signature des données que tu as ramenées,"
		"ep_02.eli_launch_pulleditoff06" = "<font color=\"rgb(255,208,172)\">on pourra les bloquer pour de bon."
		"ep_02.eli_launch_pulleditoff07" = "<font color=\"rgb(255,208,172)\">Je suis sûr que quand"
		"ep_02.eli_launch_pulleditoff08" = "<font color=\"rgb(255,208,172)\">Judith..."
		"ep_02.eli_launch_remember01" = "<font color=\"rgb(255,208,172)\">Détruis le vaisseau!"
		"ep_02.eli_launch_remember02" = "<font color=\"rgb(255,208,172)\">Coûte que coûte!"
		"ep_02.eli_launch_soundplan" = "<font color=\"rgb(255,208,172)\">C'est une idée."
		"ep_02.eli_launch_sureashell" = "<font color=\"rgb(255,208,172)\">Et comment!"
		"ep_02.eli_launch_takecarenow" = "<font color=\"rgb(255,208,172)\">A bientôt!"
		"ep_02.eli_launch_talk01" = "<font color=\"rgb(255,208,172)\">Ce message de notre ami commun."
		"ep_02.eli_launch_talk01_alt" = "<font color=\"rgb(255,208,172)\">Plus j'y pense, plus je crois qu'il y a un rapport avec le Borealis."
		"ep_02.eli_launch_talk02" = "<font color=\"rgb(255,208,172)\">Il y a forcément un lien avec le Borealis."
		"ep_02.eli_launch_talk03" = "<font color=\"rgb(255,208,172)\">Ne vous y trompez pas."
		"ep_02.eli_launch_talk04" = "<font color=\"rgb(255,208,172)\">Ce vaisseau ne doit jamais être utilisé."
		"ep_02.eli_launch_talk05" = "<font color=\"rgb(255,208,172)\">Vous devez le détruire."
		"ep_02.eli_launch_talk06" = "<font color=\"rgb(255,208,172)\">Coûte que coûte."
		"ep_02.eli_launch_terrific" = "<font color=\"rgb(255,208,172)\">Fantastique!"
		"ep_02.eli_launch_thanksforeverything01" = "<font color=\"rgb(255,208,172)\">Gordon... "
		"ep_02.eli_launch_thanksforeverything02" = "<font color=\"rgb(255,208,172)\">Merci pour tout."
		"ep_02.eli_launch_thanksforeverything03" = "<font color=\"rgb(255,208,172)\">Pour Alyx."
		"ep_02.eli_launch_thanksforeverything04" = "<font color=\"rgb(255,208,172)\">Pour nous tous."
		"ep_02.eli_launch_thanksforeverything05" = "<font color=\"rgb(255,208,172)\">Je ne pourrais être plus fier de vous..."
		"ep_02.eli_launch_thanksg01" = "<font color=\"rgb(255,208,172)\">Merci Gordon."
		"ep_02.eli_launch_thanksg02" = "<font color=\"rgb(255,208,172)\">Merci pour tout."
		"ep_02.eli_launch_uhizzy" = "<font color=\"rgb(255,208,172)\">Euh, Izzy"
		"ep_02.eli_launch_use01" = "<font color=\"rgb(255,208,172)\">Ça va, ça va."
		"ep_02.eli_launch_use02" = "<font color=\"rgb(255,208,172)\">OK, Gordon."
		"ep_02.eli_launch_use03" = "<font color=\"rgb(255,208,172)\">Hein?"
		"ep_02.eli_launch_use04" = "<font color=\"rgb(255,208,172)\">C'est un grand jour, hein Gordon?"
		"ep_02.eli_launch_use05" = "<font color=\"rgb(255,208,172)\">Il faudra attendre la fin du lancement."
		"ep_02.eli_launch_wesuredid" = "<font color=\"rgb(255,208,172)\">Et comment!"
		"ep_02.eli_launch_whenyougetback" = "<font color=\"rgb(255,208,172)\">A votre retour, nous aurons beaucoup à nous dire."
		"ep_02.eli_launch_wontifyou" = "<font color=\"rgb(255,208,172)\">Je ne fais rien si vous ne faites rien."
		"ep_02.eli_launch_yeah" = "<font color=\"rgb(255,208,172)\">Ouais!"
		"ep_02.eli_launch_youtwo" = "<font color=\"rgb(255,208,172)\">Je crois que vous devriez vraiment y aller."
		"ep_02.eli_silo_amazing" = "<font color=\"rgb(255,208,172)\">Formidable, non?"
		"ep_02.eli_silo_atitagain" = "<font color=\"rgb(255,208,172)\">Oh, c'est pas vrai, ils remettent ça!"
		"ep_02.eli_silo_barrier" = "<font color=\"rgb(255,208,172)\">Une barrière autour de la planète."
		"ep_02.eli_silo_believe" = "<font color=\"rgb(255,208,172)\">Gordon, c'est en place depuis que vous avez envoyé le dernier satellite depuis Black Mesa."
		"ep_02.eli_silo_blame" = "<font color=\"rgb(255,208,172)\">Quoi? Je n'ai pas le droit d'espérer être grand-père?"
		"ep_02.eli_silo_bootstrap01" = "<font color=\"rgb(255,208,172)\">Oui."
		"ep_02.eli_silo_bootstrap02" = "<font color=\"rgb(255,208,172)\">On dirait qu'il y en a encore."
		"ep_02.eli_silo_bootstrap03" = "<font color=\"rgb(255,208,172)\">Mais si"
		"ep_02.eli_silo_bootstrap04" = "<font color=\"rgb(255,208,172)\">le Cartel en a "
		"ep_02.eli_silo_bootstrap05" = "<font color=\"rgb(255,208,172)\">pris possession..."
		"ep_02.eli_silo_catchingup01" = "<font color=\"rgb(255,208,172)\">OK...Oui, oui on devrait."
		"ep_02.eli_silo_catchingup02" = "<font color=\"rgb(255,208,172)\">Il sera content de pouvoir enfin sortir du silo. "
		"ep_02.eli_silo_catchingup03" = "<font color=\"rgb(255,208,172)\">Quand on voit comment il se dispute avec Magnusson, on croirait qu'ils se battent encore pour obtenir des subventions."
		"ep_02.eli_silo_chuckles01" = "<font color=\"rgb(255,208,172)\">[rire]"
		"ep_02.eli_silo_chuckles02" = "<font color=\"rgb(255,208,172)\">[rire]"
		"ep_02.eli_silo_chuckles03" = "<font color=\"rgb(255,208,172)\">[rire]"
		"ep_02.eli_silo_chuckles04" = "<font color=\"rgb(255,208,172)\">[rire]"
		"ep_02.eli_silo_comehereg01" = "<font color=\"rgb(255,208,172)\">Gordon... "
		"ep_02.eli_silo_comehereg02" = "<font color=\"rgb(255,208,172)\">Gordon, venez."
		"ep_02.eli_silo_comehereg03" = "<font color=\"rgb(255,208,172)\">Par ici, Gordon."
		"ep_02.eli_silo_cuedup01" = "<font color=\"rgb(255,208,172)\"><i>Très bien."
		"ep_02.eli_silo_cuedup02" = "<font color=\"rgb(255,208,172)\"><i>Nous allons regarder la transmission de Judith."
		"ep_02.eli_silo_cuedup03" = "<font color=\"rgb(255,208,172)\"><i>Kleiner a tout préparé."
		"ep_02.eli_silo_dofavor01" = "<norepeat:10><font color=\"rgb(255,208,172)\">[respiration]"
		"ep_02.eli_silo_dofavor02" = "<font color=\"rgb(255,208,172)\">Eh bien, Alyx... Ça te dérangerait d'aller me chercher une tasse de thé?"
		"ep_02.eli_silo_dofavor03" = "<font color=\"rgb(255,208,172)\">Il y a une plaque chauffante dans la salle des employés."
		"ep_02.eli_silo_dofavor04" = "<norepeat:10><font color=\"rgb(255,208,172)\">[respiration]"
		"ep_02.eli_silo_doneenough01" = "<font color=\"rgb(255,208,172)\">Je ne peux pas vous demander de faire ça..."
		"ep_02.eli_silo_doneenough02" = "<font color=\"rgb(255,208,172)\">Vous en avez déjà assez fait..."
		"ep_02.eli_silo_donerunning01" = "<font color=\"rgb(255,208,172)\">Très bien."
		"ep_02.eli_silo_donerunning02" = "<font color=\"rgb(255,208,172)\">Nous avons assez fui."
		"ep_02.eli_silo_donerunning03" = "<font color=\"rgb(255,208,172)\">Il est temps de récupérer notre monde."
		"ep_02.eli_silo_extracther01" = "<font color=\"rgb(255,208,172)\">Je ne prendrai pas ce risque."
		"ep_02.eli_silo_extracther02" = "<font color=\"rgb(255,208,172)\">Je vais la chercher."
		"ep_02.eli_silo_feelfree" = "<font color=\"rgb(255,208,172)\">N'hésitez pas à jeter un coup d'oeil, Gordon."
		"ep_02.eli_silo_findherizzy01" = "<font color=\"rgb(255,208,172)\">Retrouve-la, Izzy, c'est tout."
		"ep_02.eli_silo_findherizzy02" = "<font color=\"rgb(255,208,172)\">Nous devons la retrouver."
		"ep_02.eli_silo_fineinaminute01" = "<font color=\"rgb(255,208,172)\">[soupir]"
		"ep_02.eli_silo_fineinaminute02" = "<font color=\"rgb(255,208,172)\">Merci, ma chérie."
		"ep_02.eli_silo_fineinaminute03" = "<font color=\"rgb(255,208,172)\">Ça ira mieux..."
		"ep_02.eli_silo_fineinaminute04" = "<font color=\"rgb(255,208,172)\">dans quelques instants."
		"ep_02.eli_silo_fineinaminute05" = "<norepeat:10><font color=\"rgb(255,208,172)\">[respiration]"
		"ep_02.eli_silo_fromjudith01" = "<font color=\"rgb(255,208,172)\">Une transmission?"
		"ep_02.eli_silo_fromjudith02" = "<font color=\"rgb(255,208,172)\">De Judith?"
		"ep_02.eli_silo_gettingclose01" = "<font color=\"rgb(255,208,172)\">On n'est pas sûrs."
		"ep_02.eli_silo_gettingclose02" = "<font color=\"rgb(255,208,172)\">On surveille ça."
		"ep_02.eli_silo_good" = "<font color=\"rgb(255,208,172)\">Bien."
		"ep_02.eli_silo_goodback" = "<font color=\"rgb(255,208,172)\">C'est bon de te revoir, mon ange."
		"ep_02.eli_silo_goodback01" = "<font color=\"rgb(255,208,172)\">Ne t'en fais pas, on va y arriver."
		"ep_02.eli_silo_goodback02" = "<font color=\"rgb(255,208,172)\">Je suis tellement content de te revoir."
		"ep_02.eli_silo_goodgod" = "<font color=\"rgb(255,208,172)\">Mon Dieu!"
		"ep_02.eli_silo_goodgod01" = "<font color=\"rgb(255,208,172)\">Mon Dieu!"
		"ep_02.eli_silo_goodgod02" = "<font color=\"rgb(255,208,172)\">C'est pire que ce que je pensais."
		"ep_02.eli_silo_goodman01" = "<font color=\"rgb(255,208,172)\">Regardez-moi ça!"
		"ep_02.eli_silo_goodman02" = "<font color=\"rgb(255,208,172)\">Je savais que si vous restiez ensemble, rien ne vous arrêterait!"
		"ep_02.eli_silo_goodman03" = "<font color=\"rgb(255,208,172)\">Je savais que si vous restiez ensemble, rien ne vous arrêterait!"
		"ep_02.eli_silo_hadalook01" = "<font color=\"rgb(255,208,172)\">Euh, oui."
		"ep_02.eli_silo_hadalook02" = "<font color=\"rgb(255,208,172)\">Gordon... "
		"ep_02.eli_silo_hadalook03" = "<font color=\"rgb(255,208,172)\">Si ça ne vous dérange pas, ça me rassurerait que vous y jetiez un coup d'oeil."
		"ep_02.eli_silo_happeningagain01" = "<font color=\"rgb(255,208,172)\">Oh non."
		"ep_02.eli_silo_happeningagain02" = "<font color=\"rgb(255,208,172)\">Je ne peux pas laisser l'histoire se répéter."
		"ep_02.eli_silo_happeningagain03" = "<font color=\"rgb(255,208,172)\">Pas un autre Black Mesa."
		"ep_02.eli_silo_heardclose01" = "<font color=\"rgb(255,208,172)\">Hé!"
		"ep_02.eli_silo_heardclose02" = "<font color=\"rgb(255,208,172)\">Gordon!"
		"ep_02.eli_silo_heardclose02_alt" = "<font color=\"rgb(255,208,172)\">Gordon!"
		"ep_02.eli_silo_heardclose03" = "<font color=\"rgb(255,208,172)\">Vous avez réussi!"
		"ep_02.eli_silo_helpingout" = "<font color=\"rgb(255,208,172)\">Merci pour votre aide, Gordon!"
		"ep_02.eli_silo_holdyou" = "<font color=\"rgb(255,208,172)\">Oh, Alyx!"
		"ep_02.eli_silo_hurry" = "<font color=\"rgb(255,208,172)\">Dépêchez-vous, bon sang."
		"ep_02.eli_silo_hurryizzy" = "<font color=\"rgb(255,208,172)\">Izzy!"
		"ep_02.eli_silo_iknow" = "<font color=\"rgb(255,208,172)\">Je sais, je sais."
		"ep_02.eli_silo_iknowiknow" = "<font color=\"rgb(255,208,172)\">Je sais, je sais."
		"ep_02.eli_silo_intercomok01" = "<font color=\"rgb(255,208,172)\"><i>Oui, Alyx, tout se passe bien?"
		"ep_02.eli_silo_intercomok02" = "<font color=\"rgb(255,208,172)\"><i>Gordon va bien?"
		"ep_02.eli_silo_itsallrighthoney" = "<font color=\"rgb(255,208,172)\">Ça va, ma chérie."
		"ep_02.eli_silo_justgothere" = "<font color=\"rgb(255,208,172)\">Ne t'en fais pas, Izzy. Ils viennent d'arriver."
		"ep_02.eli_silo_keepmoving01" = "<font color=\"rgb(255,208,172)\">Eh bien, on devrait continuer."
		"ep_02.eli_silo_keepmoving02" = "<font color=\"rgb(255,208,172)\">Nous n'avons pas beaucoup de temps. Allons-y."
		"ep_02.eli_silo_littletime01" = "<font color=\"rgb(255,208,172)\">On a réussi..."
		"ep_02.eli_silo_littletime02" = "<font color=\"rgb(255,208,172)\">et grâce à votre avertissement, nous serons prêts quand ils arriveront."
		"ep_02.eli_silo_littletime03" = "<font color=\"rgb(255,208,172)\">Combien de temps reste-t-il?"
		"ep_02.eli_silo_lostforever" = "<font color=\"rgb(255,208,172)\">On le croyait perdu à jamais."
		"ep_02.eli_silo_neverlether" = "<font color=\"rgb(255,208,172)\">Je n'aurais jamais dû la laisser partir."
		"ep_02.eli_silo_nocontrol01" = "<font color=\"rgb(255,208,172)\">Vous n'avez donc pas retenu la leçon de Black Mesa?"
		"ep_02.eli_silo_nocontrol02" = "<font color=\"rgb(255,208,172)\">On ne peut pas contrôler ce genre de force."
		"ep_02.eli_silo_nonemeanthing01" = "<font color=\"rgb(255,208,172)\">Tout cela ne"
		"ep_02.eli_silo_nonemeanthing02" = "<font color=\"rgb(255,208,172)\">signifiera rien si..."
		"ep_02.eli_silo_notword" = "<font color=\"rgb(255,208,172)\">Ce n'est pas le mot que j'emploierais."
		"ep_02.eli_silo_nowayyou01" = "<font color=\"rgb(255,208,172)\">Non, non, ça va ma chérie."
		"ep_02.eli_silo_nowayyou02" = "<font color=\"rgb(255,208,172)\">Tu ne pouvais pas savoir."
		"ep_02.eli_silo_ohalyx" = "<font color=\"rgb(255,208,172)\">Oh!"
		"ep_02.eli_silo_ohbrother" = "<font color=\"rgb(255,208,172)\">Oh, bon sang."
		"ep_02.eli_silo_onething" = "<font color=\"rgb(255,208,172)\">Une chose à la fois, Izzy"
		"ep_02.eli_silo_perfect01" = "<font color=\"rgb(255,208,172)\">Merci, ma chérie."
		"ep_02.eli_silo_perfect02" = "<font color=\"rgb(255,208,172)\">Hmmmmm"
		"ep_02.eli_silo_perfect03" = "<font color=\"rgb(255,208,172)\">C'est parfait."
		"ep_02.eli_silo_perfect04" = "<font color=\"rgb(255,208,172)\">Hmmmmm..."
		"ep_02.eli_silo_quick" = "<font color=\"rgb(255,208,172)\">C'est du rapide."
		"ep_02.eli_silo_quicklyg01" = "<font color=\"rgb(255,208,172)\">Gordon, vite!"
		"ep_02.eli_silo_quicklyg02" = "<font color=\"rgb(255,208,172)\">Allez-y, faites votre possible pour l'aider."
		"ep_02.eli_silo_raceclock01" = "<font color=\"rgb(255,208,172)\">Ça va être juste."
		"ep_02.eli_silo_raceclock02" = "<font color=\"rgb(255,208,172)\">Il suffirait d'un seul strider pour détruire notre fusée."
		"ep_02.eli_silo_raceclock03" = "<font color=\"rgb(255,208,172)\">Mais on est prêts à les recevoir."
		"ep_02.eli_silo_remember01" = "<font color=\"rgb(255,208,172)\">Je n'ai pas besoin de vous présenter Gordon Freeman."
		"ep_02.eli_silo_rememberalyx" = "<font color=\"rgb(255,208,172)\">Vous vous souvenez d'Alyx, n'est-ce pas?"
		"ep_02.eli_silo_rightaway" = "<font color=\"rgb(255,208,172)\">Il faut voir ça tout de suite."
		"ep_02.eli_silo_sendgordon01" = "<font color=\"rgb(255,208,172)\">Ouvre la porte, Isaac."
		"ep_02.eli_silo_sendgordon02" = "<font color=\"rgb(255,208,172)\">On va l'y envoyer."
		"ep_02.eli_silo_stillalive01" = "<font color=\"rgb(255,208,172)\">Eh bien, ça veut dire qu'elle est toujours en vie, là-haut."
		"ep_02.eli_silo_stillalive02" = "<font color=\"rgb(255,208,172)\">Mais si le Cartel la capture,"
		"ep_02.eli_silo_stillalive03" = "<font color=\"rgb(255,208,172)\">ils lui arracheront tout ce qu'elle sait."
		"ep_02.eli_silo_stillalive04" = "<font color=\"rgb(255,208,172)\">Il ne restera rien d'elle."
		"ep_02.eli_silo_stoprightthere01" = "<font color=\"rgb(255,208,172)\">Arrête-toi, mon ange."
		"ep_02.eli_silo_stoprightthere02" = "<font color=\"rgb(255,208,172)\">C'est moi qui suis responsable de son rapprochement avec Breen."
		"ep_02.eli_silo_stoprightthere03" = "<font color=\"rgb(255,208,172)\">Elle voulait rester avec nous mais j'avais besoin qu'elle le surveille."
		"ep_02.eli_silo_stoprightthere04" = "<font color=\"rgb(255,208,172)\">J'ai eu tort de sous-estimer son talent de persuasion."
		"ep_02.eli_silo_stoprightthere05" = "<font color=\"rgb(255,208,172)\">Judith a fait de graves erreurs."
		"ep_02.eli_silo_stoprightthere06" = "<font color=\"rgb(255,208,172)\">Mais elle a en payé le prix."
		"ep_02.eli_silo_stoprightthere07" = "<font color=\"rgb(255,208,172)\">Elle a besoin de nous, Alyx"
		"ep_02.eli_silo_stoprightthere08" = "<font color=\"rgb(255,208,172)\">et j'ai besoin d'elle."
		"ep_02.eli_silo_swoon" = "<font color=\"rgb(255,208,172)\">[gémissement puis évanouissement]"
		"ep_02.eli_silo_talk01" = "<font color=\"rgb(255,208,172)\">Des conséquences imprévues..."
		"ep_02.eli_silo_talk02" = "<font color=\"rgb(255,208,172)\">[rire]"
		"ep_02.eli_silo_talk03" = "<font color=\"rgb(255,208,172)\">La dernière fois que j'ai entendu ces mots, c'était à Black Mesa."
		"ep_02.eli_silo_talk04" = "<font color=\"rgb(255,208,172)\">Vous veniez d'entrer dans la chambre d'essai"
		"ep_02.eli_silo_talk05" = "<font color=\"rgb(255,208,172)\">quand il m'a murmuré ces mots."
		"ep_02.eli_silo_talk06" = "<font color=\"rgb(255,208,172)\">Vous savez de qui je veux parler."
		"ep_02.eli_silo_talk07" = "<font color=\"rgb(255,208,172)\">Notre ami commun."
		"ep_02.eli_silo_talk08" = "<font color=\"rgb(255,208,172)\">Quand il a apporté ce cristal, je le savais... "
		"ep_02.eli_silo_talk09" = "<font color=\"rgb(255,208,172)\">j'aurais dû interrompre le test, mais"
		"ep_02.eli_silo_talk10" = "<font color=\"rgb(255,208,172)\">je n'ai rien fait."
		"ep_02.eli_silo_talk11" = "<font color=\"rgb(255,208,172)\">Le monde a complètement basculé ce jour-là."
		"ep_02.eli_silo_talk12" = "<font color=\"rgb(255,208,172)\">Et maintenant..."
		"ep_02.eli_silo_talk13" = "<font color=\"rgb(255,208,172)\">Il se sert de ma fille..."
		"ep_02.eli_silo_talk14" = "<font color=\"rgb(255,208,172)\">lui fait dire des choses."
		"ep_02.eli_silo_talk15" = "<font color=\"rgb(255,208,172)\">Oh, bon sang!"
		"ep_02.eli_silo_talk16" = "<font color=\"rgb(255,208,172)\">J'aurais dû le savoir qu'il l'avait sauvée pour servir ses propres intérêts!"
		"ep_02.eli_silo_talk17" = "<font color=\"rgb(255,208,172)\">Gordon... "
		"ep_02.eli_silo_talk18" = "<font color=\"rgb(255,208,172)\">Ah, j'ai tant de choses à vous dire."
		"ep_02.eli_silo_talk19" = "<font color=\"rgb(255,208,172)\">On aura peut-être enfin la chance de..."
		"ep_02.eli_silo_talk20" = "<font color=\"rgb(255,208,172)\">Qu'a-t-il encore en tête?"
		"ep_02.eli_silo_talk21" = "<font color=\"rgb(255,208,172)\">Il y tant de choses."
		"ep_02.eli_silo_thankyou01" = "<norepeat:10><font color=\"rgb(255,208,172)\">[respiration]"
		"ep_02.eli_silo_thankyou02" = "<font color=\"rgb(255,208,172)\">Merci, ma chérie."
		"ep_02.eli_silo_thankyou03" = "<font color=\"rgb(255,208,172)\">Merci."
		"ep_02.eli_silo_thankyou04" = "<font color=\"rgb(255,208,172)\">On ne bouge pas d'ici."
		"ep_02.eli_silo_thankyou05" = "<norepeat:10><font color=\"rgb(255,208,172)\">[respiration]"
		"ep_02.eli_silo_there01" = "<font color=\"rgb(255,208,172)\">Je suis là, ma chérie. Nous sommes enfin réunis."
		"ep_02.eli_silo_there02" = "<font color=\"rgb(255,208,172)\">C'est tout ce qui compte."
		"ep_02.eli_silo_theygoagain" = "<font color=\"rgb(255,208,172)\">Et c'est reparti."
		"ep_02.eli_silo_thiswayg01" = "<font color=\"rgb(255,208,172)\">Par ici, Gordon."
		"ep_02.eli_silo_thiswayg02" = "<font color=\"rgb(255,208,172)\">Venez."
		"ep_02.eli_silo_uh" = "<font color=\"rgb(255,208,172)\">Ça va, mon ange."
		"ep_02.eli_silo_underwraps01" = "<font color=\"rgb(255,208,172)\">C'est mieux que prévu."
		"ep_02.eli_silo_underwraps02" = "<font color=\"rgb(255,208,172)\">Magnusson a fait un travail remarquable."
		"ep_02.eli_silo_underwraps03" = "<font color=\"rgb(255,208,172)\">Nous sommes sur le point de placer notre premier pion."
		"ep_02.eli_silo_underwraps04" = "<font color=\"rgb(255,208,172)\">Le Cartel ne va pas comprendre ce qui lui tombe dessus."
		"ep_02.eli_silo_useit01" = "<font color=\"rgb(255,208,172)\">L'utiliser?"
		"ep_02.eli_silo_useit02" = "<font color=\"rgb(255,208,172)\">La meilleure chose à faire, c'est le détruire!"
		"ep_02.eli_silo_welltalklater" = "<font color=\"rgb(255,208,172)\">Nous parlerons plus tard, Gordon."
		"ep_02.eli_silo_whahappen" = "<font color=\"rgb(255,208,172)\">Que... Qu'est-ce qui t'est arrivé?"
		"ep_02.eli_silo_whatisit" = "<font color=\"rgb(255,208,172)\">Izzy? qu'est-ce qui se passe?"
		"ep_02.eli_silo_whatsay" = "<font color=\"rgb(255,208,172)\">Qu'est-ce que tu as dit?"
		"ep_02.eli_silo_wheresalyx01" = "<font color=\"rgb(255,208,172)\">Mais où est Alyx?"
		"ep_02.eli_silo_wheresalyx02" = "<font color=\"rgb(255,208,172)\">Alyx!"
		"ep_02.eli_silo_youheardkleiner01" = "<font color=\"rgb(255,208,172)\">Je suis ravi de l'entendre, parce que..."
		"ep_02.eli_silo_youheardkleiner02" = "<font color=\"rgb(255,208,172)\">maintenant que le champ de suppression est désactivé,"
		"ep_02.eli_silo_youheardkleiner03" = "<font color=\"rgb(255,208,172)\">il faudra que chacun fasse ce qu'il a à faire..."
		"ep_02.eli_silo_yousure01" = "<font color=\"rgb(255,208,172)\">Tu es sûre? "
		"ep_02.eli_silo_yousure02" = "<font color=\"rgb(255,208,172)\">On devrait t'examiner."
		"ep_02.eli_transmit_believe01" = "<font color=\"rgb(255,208,172)\"><i>Alyx! "
		"ep_02.eli_transmit_believe02" = "<font color=\"rgb(255,208,172)\"><i>Dieu merci! "
		"ep_02.eli_transmit_believe03" = "<font color=\"rgb(255,208,172)\"><i>Je n'arrive pas à y croire. "
		"ep_02.eli_transmit_crawl01" = "<font color=\"rgb(255,208,172)\"><i>Il s'agit du Cartel. "
		"ep_02.eli_transmit_crawl02" = "<font color=\"rgb(255,208,172)\"><i>Leurs unités tentent d'ouvrir une autre passerelle. "
		"ep_02.eli_transmit_goodgod" = "<font color=\"rgb(255,208,172)\"><i>Mon Dieu. "
		"ep_02.eli_transmit_rash01" = "<font color=\"rgb(255,208,172)\"><i>Venez aussi vite que possible. "
		"ep_02.eli_transmit_rash02" = "<font color=\"rgb(255,208,172)\"><i>Mais surtout, faites attention. "
		"ep_02.eli_transmit_rash03" = "<font color=\"rgb(255,208,172)\"><i>Je vous attendrai. "
		"ep_02.eli_transmit_rash04" = "<font color=\"rgb(255,208,172)\"><i>J'ai hâte de vous voir."
		"ep_02.eli_transmit_sevenminutes01" = "<font color=\"rgb(255,208,172)\"><i>Ce sera de nouveau la Guerre des sept heures. "
		"ep_02.eli_transmit_sevenminutes02" = "<font color=\"rgb(255,208,172)\"><i>Sauf que cette fois, on ne tiendra pas plus de sept minutes. "
		"ep_02.gman_har" = "Ah... Ah..."
		"ep_02.gman_mono01" = "Docteur Freeman! "
		"ep_02.gman_mono02" = "Je sais bien que ce moment n'est pas vraiment propice à une discussion sincère,"
		"ep_02.gman_mono03" = "mais je devais attendre que vos amis soient occupés à autre chose. "
		"ep_02.gman_mono04" = "Hmmm... "
		"ep_02.gman_mono05" = "Il fut un temps où ils ne se souciaient pas de Mlle Vance..."
		"ep_02.gman_mono06" = "où leur seul contact avec l'humanité était un pied-de-biche s'approchant vers eux du fond d'un couloir d'acier. "
		"ep_02.gman_mono07" = "Il semble qu'ils commencent à l'estimer autant que moi."
		"ep_02.gman_mono08" = "Lorsque je l'ai arrachée de Black Mesa, j'ai dû aller à l'encontre de ceux qui la considéraient comme une enfant et disaient qu'elle ne serait d'aucune utilité. "
		"ep_02.gman_mono09" = "J'ai appris à ignorer ces opposants systématiques lorsqu'il était hors de question de les arrêter. "
		"ep_02.gman_mono10" = "[respiration]"
		"ep_02.gman_mono11" = "Pourtant, je n'ai pas pour habitude de gaspiller mes investissements..."
		"ep_02.gman_mono12" = "et je reste certain qu'elle vaut bien plus que ma première..."
		"ep_02.gman_mono13" = "évaluation. "
		"ep_02.gman_mono14" = "C'est pourquoi je dois maintenant "
		"ep_02.gman_mono15" = "exiger "
		"ep_02.gman_mono16" = "de vous "
		"ep_02.gman_mono17" = "une petite contrepartie en échange de votre survie. "
		"ep_02.gman_mono18" = "Je ne vous demande rien allant à l'encontre de votre nature,"
		"ep_02.gman_mono19" = "juste de la protéger en permanence"
		"ep_02.gman_mono20" = "puisqu'elle"
		"ep_02.gman_mono21" = "véhicule un message d'une certaine importance."
		"ep_02.gman_mono22" = "Accompagnez-la jusqu'à White Forest, Docteur Freeman. "
		"ep_02.gman_mono23" = "Il faudra peut-être prendre soin d'elle plus qu'auparavant."
		"ep_02.gman_mono24" = "[respiration]"
		"ep_02.gman_mono25" = "Je voudrais pouvoir faire plus que simplement vous surveiller,"
		"ep_02.gman_mono26" = "mais j'ai accepté de me soumettre à certaines... "
		"ep_02.gman_mono27" = "restrictions. "
		"ep_02.gman_mono28" = "Hmmmmm"
		"ep_02.gman_mono29" = "Bon..."
		"ep_02.gman_mono30" = "Maintenant..."
		"ep_02.gman_mono31" = "écoutez-moi bien, ma chère."
		"ep_02.gman_mono32" = "Lorsque vous verrez votre père "
		"ep_02.gman_mono33" = "transmettez-lui ces mots:"
		"ep_02.gman_mono34" = "Préparez-vous à des conséquences imprévues. "
		"ep_02.griggs_12crazy" = "<font color=\"rgb(255,216,150)\">Le 12 pète un plomb!"
		"ep_02.griggs_24lit" = "<font color=\"rgb(255,216,150)\">Le 24 est en ébullition!"
		"ep_02.griggs_24swarm" = "<font color=\"rgb(255,216,150)\">Invasion au 24!"
		"ep_02.griggs_36again" = "<font color=\"rgb(255,216,150)\">Le 36 encore!"
		"ep_02.griggs_36majorswarm" = "<font color=\"rgb(255,216,150)\">Invasion majeure"
		"ep_02.griggs_36overthere" = "<font color=\"rgb(255,216,150)\">Là-bas."
		"ep_02.griggs_afteralyx" = "<font color=\"rgb(255,216,150)\">Elles poursuivent Alyx!"
		"ep_02.griggs_ahcrap" = "<font color=\"rgb(255,216,150)\">Ahh merde!"
		"ep_02.griggs_altvortarrive" = "<font color=\"rgb(255,216,150)\">Prêts, oh merde, prêts, trois feux, ça va être terrible..."
		"ep_02.griggs_and12" = "<font color=\"rgb(255,216,150)\">Et le 12!"
		"ep_02.griggs_and24" = "<font color=\"rgb(255,216,150)\">Et le 24!"
		"ep_02.griggs_and36" = "<font color=\"rgb(255,216,150)\">Et le 36!"
		"ep_02.griggs_andbreach" = "<font color=\"rgb(255,216,150)\">Et la brèche!"
		"ep_02.griggs_at12" = "<font color=\"rgb(255,216,150)\">Elles sont au 12!"
		"ep_02.griggs_at12again" = "<font color=\"rgb(255,216,150)\">Elles sont de nouveau au 12!"
		"ep_02.griggs_atbreach" = "<font color=\"rgb(255,216,150)\">Elles sont à la brèche!"
		"ep_02.griggs_awayfromvort" = "<font color=\"rgb(255,216,150)\">Eloignez-les du Vort!"
		"ep_02.griggs_badturret" = "<font color=\"rgb(255,216,150)\">Pardon. On aurait vous avertir pour cette tourelle."
		"ep_02.griggs_beadequate" = "<font color=\"rgb(255,216,150)\">OK Freeman! Soyez à la hauteur!"
		"ep_02.griggs_betweenwave_01" = "<font color=\"rgb(255,216,150)\">Freeman, vous avez évité les larves en arrivant ici, hein?"
		"ep_02.griggs_betweenwave_02" = "<font color=\"rgb(255,216,150)\">Freeman, vous avez marché sur combien de larves?"
		"ep_02.griggs_betweenwave_03" = "<font color=\"rgb(255,216,150)\">Je n'étais même pas censé être ici."
		"ep_02.griggs_betweenwave_04" = "<font color=\"rgb(255,216,150)\">Ne le prenez pas mal, Freeman mais c'était plutôt calme avant votre arrivée."
		"ep_02.griggs_betweenwave_05" = "<font color=\"rgb(255,216,150)\">Ce n'était pas le dernier."
		"ep_02.griggs_betweenwave_06" = "<font color=\"rgb(255,216,150)\">Ça ira tant qu'ils sortent d'un seul tunnel."
		"ep_02.griggs_betweenwave_07" = "<font color=\"rgb(255,216,150)\">S'ils sortent de plusieurs tunnels, on est foutus!"
		"ep_02.griggs_betweenwave_08" = "<font color=\"rgb(255,216,150)\">Prêt, Freeman?"
		"ep_02.griggs_betweenwave_09" = "<font color=\"rgb(255,216,150)\">On va y arriver, hein, les gars? Mais oui, on va y arriver."
		"ep_02.griggs_betweenwave_conver1_01" = "<font color=\"rgb(255,216,150)\">J'en ai eu dix!"
		"ep_02.griggs_betweenwave_conver2_01" = "<font color=\"rgb(255,216,150)\">Sheckley!"
		"ep_02.griggs_betweenwave_conver2_02" = "<font color=\"rgb(255,216,150)\">Sheckley!"
		"ep_02.griggs_betweenwave_conver2_03" = "<font color=\"rgb(255,216,150)\">Non, rien..."
		"ep_02.griggs_betweenwave_conver3_01" = "<font color=\"rgb(255,216,150)\">Ah, il ne doit pas y en avoir beaucoup plus."
		"ep_02.griggs_betweenwave_conver4_01" = "<font color=\"rgb(255,216,150)\">Je ne l'ai pas vu."
		"ep_02.griggs_breachagain" = "<font color=\"rgb(255,216,150)\">Encore la brèche!"
		"ep_02.griggs_bye01" = "<font color=\"rgb(255,216,150)\">A plus! "
		"ep_02.griggs_bye02" = "<font color=\"rgb(255,216,150)\">Bonne chance pour là-bas."
		"ep_02.griggs_calvary" = "<font color=\"rgb(255,216,150)\">Le calvaire arrive!"
		"ep_02.griggs_cantholdout" = "<font color=\"rgb(255,216,150)\">On va pas pouvoir tenir beaucoup plus longtemps."
		"ep_02.griggs_coming01" = "<font color=\"rgb(255,216,150)\">Ils arrivent!"
		"ep_02.griggs_coming02" = "<font color=\"rgb(255,216,150)\">Un feu..."
		"ep_02.griggs_comingfrom24" = "<font color=\"rgb(255,216,150)\">Elles viennent encore du 24!"
		"ep_02.griggs_cover12" = "<font color=\"rgb(255,216,150)\">Couvrez le 12!"
		"ep_02.griggs_cover24" = "<font color=\"rgb(255,216,150)\">Couvrez le 24!"
		"ep_02.griggs_cover36" = "<font color=\"rgb(255,216,150)\">Couvrez le 36!"
		"ep_02.griggs_covervort" = "<font color=\"rgb(255,216,150)\">Couvrez le Vort!"
		"ep_02.griggs_dochelpvort" = "<font color=\"rgb(255,216,150)\">Doc, aidez le Vort!"
		"ep_02.griggs_doctorin" = "<font color=\"rgb(255,216,150)\">Ah oui ! En bas, à côté du Vort, il y a tout ce qu'il faut pour se soigner."
		"ep_02.griggs_everywhere" = "<font color=\"rgb(255,216,150)\">Oh mon Dieu, elles viennent de partout!"
		"ep_02.griggs_fightlion_01" = "<font color=\"rgb(255,216,150)\">Ahhhhhhh!"
		"ep_02.griggs_fightlion_02" = "<font color=\"rgb(255,216,150)\">Couvre-moi, Schek!"
		"ep_02.griggs_fightlion_03" = "<font color=\"rgb(255,216,150)\">Attention, Sheckley!"
		"ep_02.griggs_fightlion_04" = "<font color=\"rgb(255,216,150)\">Attention, Sheck!"
		"ep_02.griggs_fightlion_05" = "<font color=\"rgb(255,216,150)\">Ah. Ah. Ah! Ah! Ah!"
		"ep_02.griggs_followed01" = "<font color=\"rgb(255,216,150)\">Hé, Doc"
		"ep_02.griggs_followed02" = "<font color=\"rgb(255,216,150)\">en venant ici...  "
		"ep_02.griggs_followed03" = "<font color=\"rgb(255,216,150)\">on ne vous a pas suivi, hein?"
		"ep_02.griggs_following01" = "<font color=\"rgb(255,216,150)\">Je suis là, je suis là."
		"ep_02.griggs_following02" = "<font color=\"rgb(255,216,150)\">J'arrive, j'arrive."
		"ep_02.griggs_following03" = "<font color=\"rgb(255,216,150)\">Je suis juste derrière vous."
		"ep_02.griggs_following04" = "<font color=\"rgb(255,216,150)\">On reste ici."
		"ep_02.griggs_followme01" = "<font color=\"rgb(255,216,150)\">Allez, Sheckley, on bouge."
		"ep_02.griggs_followme02" = "<font color=\"rgb(255,216,150)\">On y va, Sheck."
		"ep_02.griggs_followme03" = "<font color=\"rgb(255,216,150)\">Par ici, Sheckley."
		"ep_02.griggs_followvortnag_01" = "<font color=\"rgb(255,216,150)\">Faut se bouger, Doc. Suivez le Vort."
		"ep_02.griggs_followvortnag_02" = "<font color=\"rgb(255,216,150)\">Sérieusement, Freeman, il faut y aller."
		"ep_02.griggs_followvortnag_03" = "<font color=\"rgb(255,216,150)\">Mademoiselle Vance est mal en point, Doc. Dépêchez-vous de suivre le Vort."
		"ep_02.griggs_followvortnag_04" = "<font color=\"rgb(255,216,150)\">On est tous crevés, Freeman, mais vous ne pouvez pas rester sans rien faire. Suivez le Vort!"
		"ep_02.griggs_gohelpvort" = "<font color=\"rgb(255,216,150)\">Freeman, allez aider le Vort!"
		"ep_02.griggs_gosheckley" = "<font color=\"rgb(255,216,150)\">Pas mal, Sheckley!"
		"ep_02.griggs_grubs" = "<font color=\"rgb(255,216,150)\">Le Vort dit que tant que l'on ne marche pas sur leurs larves, si loin du nid, ils ne nous entendent pas..."
		"ep_02.griggs_gunnags01" = "<font color=\"rgb(255,216,150)\">Hé, Doc! Il y a une arme supplémentaire, si vous voulez."
		"ep_02.griggs_gunnags02" = "<font color=\"rgb(255,216,150)\">Hé Doc, il y a une arme par terre, à côté du Vort!"
		"ep_02.griggs_gunnags03" = "<font color=\"rgb(255,216,150)\">Hé, Doc, si vous voulez une arme, il y en a une à côté de l'ascenseur. Il y en a pour tout le monde!"
		"ep_02.griggs_incom36" = "<font color=\"rgb(255,216,150)\">Elles arrivent au 36! "
		"ep_02.griggs_junc_extrahand" = "<font color=\"rgb(255,216,150)\">Hé, merci les Vorts! On est très contents pour le coup de main!"
		"ep_02.griggs_junc_freemanlaughed" = "<font color=\"rgb(255,216,150)\">Ah, Freeman a ri. Je l'ai vu."
		"ep_02.griggs_kaput" = "<font color=\"rgb(255,216,150)\">Oh non! La tourelle! Elle est kaput!"
		"ep_02.griggs_keepeye" = "<font color=\"rgb(255,216,150)\">Freeman! Regardez bien les feux!"
		"ep_02.griggs_killlion_01" = "<font color=\"rgb(255,216,150)\">Hé Sheck, tu vas m'aider à les tuer ou quoi?"
		"ep_02.griggs_killlion_02" = "<font color=\"rgb(255,216,150)\">Ouais!"
		"ep_02.griggs_killlion_03" = "<font color=\"rgb(255,216,150)\">Ouais!"
		"ep_02.griggs_killlion_04" = "<font color=\"rgb(255,216,150)\">Saloperies d'insectes!"
		"ep_02.griggs_lookalive" = "<font color=\"rgb(255,216,150)\">Soyez vif!"
		"ep_02.griggs_moreat12" = "<font color=\"rgb(255,216,150)\">D'autres sur le 12!"
		"ep_02.griggs_moreat24" = "<font color=\"rgb(255,216,150)\">D'autres sur le 24!"
		"ep_02.griggs_moreat36" = "<font color=\"rgb(255,216,150)\">D'autres sur le 36!"
		"ep_02.griggs_moreatbreach" = "<font color=\"rgb(255,216,150)\">D'autres à la brèche!"
		"ep_02.griggs_needagun" = "<font color=\"rgb(255,216,150)\">Hé, Doc, s'il vous faut une arme, il y en a par ici."
		"ep_02.griggs_needsomehelp" = "<font color=\"rgb(255,216,150)\">Je vais avoir besoin d'aide ce coup-là."
		"ep_02.griggs_nestbigger" = "<font color=\"rgb(255,216,150)\">Ce nid doit être plus gros qu'on ne le pensait."
		"ep_02.griggs_neverseen" = "<font color=\"rgb(255,216,150)\">Je n'en ai jamais vu autant en même temps."
		"ep_02.griggs_onelight" = "<font color=\"rgb(255,216,150)\">Un feu!"
		"ep_02.griggs_onenoproblem" = "<font color=\"rgb(255,216,150)\">Pas de problème."
		"ep_02.griggs_pickturretup" = "<font color=\"rgb(255,216,150)\">Ramassez votre tourelle!"
		"ep_02.griggs_protectvort" = "<font color=\"rgb(255,216,150)\">Protégez le Vort!"
		"ep_02.griggs_rightturret" = "<font color=\"rgb(255,216,150)\">Redressez cette tourelle!"
		"ep_02.griggs_samediff" = "<font color=\"rgb(255,216,150)\">Il y a une différence?"
		"ep_02.griggs_sparegun" = "<font color=\"rgb(255,216,150)\">Vous aurez peut-être besoin de cette arme, Doc!"
		"ep_02.griggs_swarmatbreach" = "<font color=\"rgb(255,216,150)\">Invasion à la brèche!"
		"ep_02.griggs_thosevortswant" = "<font color=\"rgb(255,216,150)\">Me regardez pas, je sais pas ce qu'ils veulent ces Vorts."
		"ep_02.griggs_threelights" = "<font color=\"rgb(255,216,150)\">Trois feux! On a trois feux!"
		"ep_02.griggs_threeomg" = "<font color=\"rgb(255,216,150)\">Oh mon Dieu!"
		"ep_02.griggs_threeswarm" = "<font color=\"rgb(255,216,150)\">Invasion!"
		"ep_02.griggs_thrubreach" = "<font color=\"rgb(255,216,150)\">Ils viennent par la brèche!"
		"ep_02.griggs_toomany" = "<font color=\"rgb(255,216,150)\">Y en a trop!"
		"ep_02.griggs_tryingtoscare" = "<font color=\"rgb(255,216,150)\">Oui, oui, je le savais. J'essayais juste de te faire peur, Sheck."
		"ep_02.griggs_tunnelpanic_01" = "<font color=\"rgb(255,216,150)\">Oh, merde. Tout est allumé. Prenez un tunnel!"
		"ep_02.griggs_tunnelpanic_02" = "<font color=\"rgb(255,216,150)\">Tout est allumé. Prenez un tunnel!"
		"ep_02.griggs_turretdown01" = "<font color=\"rgb(255,216,150)\">Une tourelle en moins!"
		"ep_02.griggs_turretdown02" = "<font color=\"rgb(255,216,150)\">La tourelle, Doc!"
		"ep_02.griggs_turretfeet" = "<font color=\"rgb(255,216,150)\">Il faut redresser ces tourelles!"
		"ep_02.griggs_turretsturrets" = "<font color=\"rgb(255,216,150)\">Des tourelles! Des tourelles!"
		"ep_02.griggs_twolights" = "<font color=\"rgb(255,216,150)\">Deux feux."
		"ep_02.griggs_twothatmeans" = "<font color=\"rgb(255,216,150)\">Ça veut dire deux ou trois, hein?"
		"ep_02.griggs_underest" = "<font color=\"rgb(255,216,150)\">Je crois qu'on s'est trompés."
		"ep_02.griggs_vortintrouble" = "<font color=\"rgb(255,216,150)\">Il faut aider le Vort!"
		"ep_02.griggs_vortscalling" = "<font color=\"rgb(255,216,150)\">Les Vorts vous appellent."
		"ep_02.griggs_vortswantyou" = "<font color=\"rgb(255,216,150)\">Les Vorts veulent que vous descendiez."
		"ep_02.griggs_vortswouldsay" = "<font color=\"rgb(255,216,150)\">Ah, je ne sais pas, c'est la façon de parler des Vorts."
		"ep_02.griggs_watchall" = "<font color=\"rgb(255,216,150)\">Il faut surveiller tous les tunnels, Freeman!"
		"ep_02.griggs_watchvorts_01" = "<font color=\"rgb(255,216,150)\">Sheck! Recule, laisse de la place aux Vorts!"
		"ep_02.griggs_watchvorts_02" = "<font color=\"rgb(255,216,150)\">Les Vorts les réduisent en miettes!"
		"ep_02.griggs_watchvorts_03" = "<font color=\"rgb(255,216,150)\">Il ne fallait pas leur chercher des noises!"
		"ep_02.griggs_watchvorts_04" = "<font color=\"rgb(255,216,150)\">Bon sang, je n'ai jamais vu les Vorts dans un état pareil!"
		"ep_02.griggs_wecandothis" = "<font color=\"rgb(255,216,150)\">Encore des feux, on peut le faire."
		"ep_02.griggs_wegot_12_01" = "<font color=\"rgb(255,216,150)\">On a le 12!"
		"ep_02.griggs_wegot_12_02" = "<font color=\"rgb(255,216,150)\">On va prendre le 12!"
		"ep_02.griggs_wegot_24_01" = "<font color=\"rgb(255,216,150)\">On a le 24!"
		"ep_02.griggs_wegot_24_02" = "<font color=\"rgb(255,216,150)\">On va prendre le 24!"
		"ep_02.griggs_wegot_36_01" = "<font color=\"rgb(255,216,150)\">On a le 36!"
		"ep_02.griggs_wegot_36_02" = "<font color=\"rgb(255,216,150)\">On va prendre le 36!"
		"ep_02.griggs_wegot_breach01" = "<font color=\"rgb(255,216,150)\">On a la brèche!"
		"ep_02.griggs_wegot_breach02" = "<font color=\"rgb(255,216,150)\">On va prendre la brèche!"
		"ep_02.griggs_wegotantlions01" = "<font color=\"rgb(255,216,150)\">Sheckley!"
		"ep_02.griggs_wegotantlions02" = "<font color=\"rgb(255,216,150)\">On a des fourmis-lions!"
		"ep_02.griggs_whysomany" = "<font color=\"rgb(255,216,150)\">Pourquoi y en a-t-il tant?"
		"ep_02.griggs_wronghole" = "<font color=\"rgb(255,216,150)\">Qu'est-ce qu'il a ce trou?"
		"ep_02.griggs_youtake_12_01" = "<font color=\"rgb(255,216,150)\">Hé Doc, couvrez le 12!"
		"ep_02.griggs_youtake_12_02" = "<font color=\"rgb(255,216,150)\">Vous gérez le 12, Doc!"
		"ep_02.griggs_youtake_24_01" = "<font color=\"rgb(255,216,150)\">Hé Doc, couvrez le 24!"
		"ep_02.griggs_youtake_24_02" = "<font color=\"rgb(255,216,150)\">Vous gérez le 24, Doc!"
		"ep_02.griggs_youtake_36_01" = "<font color=\"rgb(255,216,150)\">Hé Doc, couvrez le 36!"
		"ep_02.griggs_youtake_36_02" = "<font color=\"rgb(255,216,150)\">Vous gérez le 36, Doc!"
		"ep_02.griggs_youtake_breach_01" = "<font color=\"rgb(255,216,150)\">Hé Doc, couvrez la brèche!"
		"ep_02.griggs_youtake_breach_02" = "<font color=\"rgb(255,216,150)\">Vous gérez la brèche, Doc!"
		"ep_02.griggs_youturrets" = "<font color=\"rgb(255,216,150)\">Dr Freeman, vous vous occupez de ces tourelles."
		"ep_02.kl_launch_1" = "<font color=\"rgb(255,255,200)\">Un..."
		"ep_02.kl_launch_10" = "<font color=\"rgb(255,255,200)\">Lancement dans 10..."
		"ep_02.kl_launch_2" = "<font color=\"rgb(255,255,200)\">Deux..."
		"ep_02.kl_launch_3" = "<font color=\"rgb(255,255,200)\">Trois..."
		"ep_02.kl_launch_4" = "<font color=\"rgb(255,255,200)\">Quatre..."
		"ep_02.kl_launch_5" = "<font color=\"rgb(255,255,200)\">Cinq..."
		"ep_02.kl_launch_6" = "<font color=\"rgb(255,255,200)\">Six..."
		"ep_02.kl_launch_7" = "<font color=\"rgb(255,255,200)\">Sept..."
		"ep_02.kl_launch_8" = "<font color=\"rgb(255,255,200)\">Huit..."
		"ep_02.kl_launch_9" = "<font color=\"rgb(255,255,200)\">Neuf..."
		"ep_02.kl_launch_anomaly01" = "<font color=\"rgb(255,255,200)\">Attendez..."
		"ep_02.kl_launch_anomaly02" = "<font color=\"rgb(255,255,200)\">La charge utile présente un surpoids d'environ 4 kilos."
		"ep_02.kl_launch_atlast" = "<font color=\"rgb(255,255,200)\">Enfin!"
		"ep_02.kl_launch_awe01" = "<font color=\"rgb(255,255,200)\">[Soupir de respect et d'admiration]"
		"ep_02.kl_launch_awe02" = "<font color=\"rgb(255,255,200)\">Bon Dieu!"
		"ep_02.kl_launch_awe03" = "<font color=\"rgb(255,255,200)\">Regardez-moi ça!"
		"ep_02.kl_launch_awe04" = "<font color=\"rgb(255,255,200)\">Oui!"
		"ep_02.kl_launch_awe05" = "<font color=\"rgb(255,255,200)\">Oui!"
		"ep_02.kl_launch_awe06" = "<font color=\"rgb(255,255,200)\">[Soupir de respect et d'admiration]"
		"ep_02.kl_launch_awe07" = "<font color=\"rgb(255,255,200)\">Regardez!"
		"ep_02.kl_launch_awe08" = "<font color=\"rgb(255,255,200)\">Regardez!"
		"ep_02.kl_launch_awe09" = "<font color=\"rgb(255,255,200)\">Vole, bel oiseau!"
		"ep_02.kl_launch_awe10" = "<font color=\"rgb(255,255,200)\">Euh..."
		"ep_02.kl_launch_awe11" = "<font color=\"rgb(255,255,200)\">C'est parti..."
		"ep_02.kl_launch_awe12" = "<font color=\"rgb(255,255,200)\">C'est parti!"
		"ep_02.kl_launch_awe13" = "<font color=\"rgb(255,255,200)\">Oui."
		"ep_02.kl_launch_awe14" = "<font color=\"rgb(255,255,200)\">Oui."
		"ep_02.kl_launch_bestofluck01" = "<font color=\"rgb(255,255,200)\">Bien sûr."
		"ep_02.kl_launch_bestofluck02" = "<font color=\"rgb(255,255,200)\">Bonne chance, vous deux."
		"ep_02.kl_launch_button01" = "<font color=\"rgb(255,255,200)\">Le bouton, Gordon? "
		"ep_02.kl_launch_button02" = "<font color=\"rgb(255,255,200)\">Euh...  "
		"ep_02.kl_launch_button03" = "<font color=\"rgb(255,255,200)\">Si ça ne vous dérange pas."
		"ep_02.kl_launch_check01a" = "<font color=\"rgb(255,255,200)\"><i>Testés et opérationnels."
		"ep_02.kl_launch_check01b" = "<font color=\"rgb(255,255,200)\"><i>Quoi? «Système SGM... vérifier les liens avec les champs de sauvegarde des sites de sécurité?»"
		"ep_02.kl_launch_check02" = "<font color=\"rgb(255,255,200)\"><i>Alignement avant le vol terminé."
		"ep_02.kl_launch_check03" = "<font color=\"rgb(255,255,200)\"><i>Vérifié."
		"ep_02.kl_launch_check04" = "<font color=\"rgb(255,255,200)\"><i>Vérifié. Vérifié. Vérifié."
		"ep_02.kl_launch_check05" = "<font color=\"rgb(255,255,200)\"><i>Vous avez fait ça?"
		"ep_02.kl_launch_check06" = "<font color=\"rgb(255,255,200)\"><i>Terminé, bien sûr."
		"ep_02.kl_launch_check07" = "<font color=\"rgb(255,255,200)\"><i>Eh bien, la précision de ces mesures n'est pas telle que je l'aurais souhaitée mais nous devrons faire avec."
		"ep_02.kl_launch_check08" = "<font color=\"rgb(255,255,200)\"><i>Rapports OK."
		"ep_02.kl_launch_check09" = "<font color=\"rgb(255,255,200)\"><i>Bien sûr, c'est déjà fait."
		"ep_02.kl_launch_check10" = "<font color=\"rgb(255,255,200)\"><i>Bien sûr."
		"ep_02.kl_launch_check11" = "<font color=\"rgb(255,255,200)\"><i>Mais non, bien sûr que non."
		"ep_02.kl_launch_check12" = "<font color=\"rgb(255,255,200)\"><i>Oui, oui."
		"ep_02.kl_launch_congrats01" = "<font color=\"rgb(255,255,200)\"><i>Attention, votre attention s'il vous plaît. Félicitations au personnel et aux habitants de White Forest,"
		"ep_02.kl_launch_congrats02" = "<font color=\"rgb(255,255,200)\"><i>à l'exception des créatures des bois."
		"ep_02.kl_launch_curtail01" = "<font color=\"rgb(255,255,200)\"><i>Nous regrettons d'avoir à écourter ces festivités spontanées et d'interférer avec cette ambiance de fête,"
		"ep_02.kl_launch_curtail02" = "<font color=\"rgb(255,255,200)\"><i>mais nous devons demander à tout le personnel de s'abriter afin de s'assurer que les environs sont dégagés pour le lancement."
		"ep_02.kl_launch_curtail03" = "<font color=\"rgb(255,255,200)\"><i>En effet, les manifestations naturelles de bonne volonté seraient certainement freinées si l'un de nos fidèles partisans finissait rôti par les flammes brûlantes de ce glorieux lancement."
		"ep_02.kl_launch_excuseme01" = "<font color=\"rgb(255,255,200)\">Pardon."
		"ep_02.kl_launch_excuseme02" = "<font color=\"rgb(255,255,200)\">Pardon."
		"ep_02.kl_launch_excuseme03" = "<font color=\"rgb(255,255,200)\">Pardon, Gordon."
		"ep_02.kl_launch_fever01" = "<font color=\"rgb(255,255,200)\">Je crois que je viens juste de comprendre ce qu'on appelle une «attente fébrile»."
		"ep_02.kl_launch_fever02" = "<font color=\"rgb(255,255,200)\">Je pensais qu'il s'agissait d'une figure de style..."
		"ep_02.kl_launch_fever03" = "<font color=\"rgb(255,255,200)\">mais soudain, j'ai"
		"ep_02.kl_launch_fever04" = "<font color=\"rgb(255,255,200)\">assez chaud."
		"ep_02.kl_launch_finger" = "<font color=\"rgb(255,255,200)\">Nous n'attendons plus qu'un doigt expérimenté appuie sur le bouton."
		"ep_02.kl_launch_fruition01" = "<font color=\"rgb(255,255,200)\">Vos nombreuses années de service et de dévouement sont sur le point de connaître leur apogée."
		"ep_02.kl_launch_fruition02" = "<font color=\"rgb(255,255,200)\">Nous nous attendons à ce que ce moment soit pleinement glorieux et transcendant pour la civilisation humaine."
		"ep_02.kl_launch_high5a" = "<font color=\"rgb(255,255,200)\">Eh bien, je... oh"
		"ep_02.kl_launch_high5b" = "<font color=\"rgb(255,255,200)\">Euh, oui"
		"ep_02.kl_launch_high5c" = "<font color=\"rgb(255,255,200)\">très joli"
		"ep_02.kl_launch_high5d" = "<font color=\"rgb(255,255,200)\">Je pense que ceci illustre bien l'idée d'un renforcement physique du lien intellectuel."
		"ep_02.kl_launch_high5e" = "<font color=\"rgb(255,255,200)\">[reniflement]"
		"ep_02.kl_launch_lamarr01" = "<font color=\"rgb(255,255,200)\">Euh... hmmm...  "
		"ep_02.kl_launch_lamarr02" = "<font color=\"rgb(255,255,200)\">Quelqu'un aurait-il vu Lamarr?"
		"ep_02.kl_launch_lookup01" = "<font color=\"rgb(255,255,200)\"><i>Eli! Gordon! Alyx! Regardez le portail!"
		"ep_02.kl_launch_lookup02" = "<font color=\"rgb(255,255,200)\"><i>Nous avons activé le résonateur."
		"ep_02.kl_launch_lookup03" = "<font color=\"rgb(255,255,200)\"><i>Ça y est! "
		"ep_02.kl_launch_morelamarr01" = "<font color=\"rgb(255,255,200)\">Lamarr?"
		"ep_02.kl_launch_morelamarr02" = "<font color=\"rgb(255,255,200)\">Lamarr?"
		"ep_02.kl_launch_morelamarr03" = "<font color=\"rgb(255,255,200)\">Lamarr?"
		"ep_02.kl_launch_morelamarr04" = "<font color=\"rgb(255,255,200)\">Bon sang, où es-tu donc allé?"
		"ep_02.kl_launch_morelamarr05" = "<font color=\"rgb(255,255,200)\">Hedy?"
		"ep_02.kl_launch_morelamarr06" = "<font color=\"rgb(255,255,200)\">Oh la la..."
		"ep_02.kl_launch_morelamarr07" = "<font color=\"rgb(255,255,200)\">Quelqu'un aurait-il vu Lamarr?"
		"ep_02.kl_launch_neverfear01" = "<font color=\"rgb(255,255,200)\">Dès que j'en ai fini avec ça."
		"ep_02.kl_launch_neverfear02" = "<font color=\"rgb(255,255,200)\">Je ne vous laisserais jamais partir sans vous dire au revoir."
		"ep_02.kl_launch_palamarr" = "<font color=\"rgb(255,255,200)\">A tout le personnel. Votre attention s'il vous plaît. Quelqu'un aurait-il vu Lamarr?"
		"ep_02.kl_launch_permorbit01" = "<font color=\"rgb(255,255,200)\">La capsule elle-même n'entrera en orbite permanente que bien plus tard."
		"ep_02.kl_launch_permorbit02" = "<font color=\"rgb(255,255,200)\">ici."
		"ep_02.kl_launch_permorbit03" = "<font color=\"rgb(255,255,200)\">C'est là que nous pourrons tester la stabilité du système."
		"ep_02.kl_launch_permorbit04" = "<font color=\"rgb(255,255,200)\">Cependant, les premiers effets devraient être immédiats."
		"ep_02.kl_launch_portalclosing01" = "<font color=\"rgb(255,255,200)\"><i>Bon sang..."
		"ep_02.kl_launch_portalclosing02" = "<font color=\"rgb(255,255,200)\"><i>Oh, regardez ça!"
		"ep_02.kl_launch_portalclosing03" = "<font color=\"rgb(255,255,200)\"><i>Le résonateur... Il commence à fonctionner."
		"ep_02.kl_launch_portalclosing04" = "<font color=\"rgb(255,255,200)\"><i>Le portail a été neutralisé."
		"ep_02.kl_launch_portalclosing05" = "<font color=\"rgb(255,255,200)\"><i>C'est spectaculaire!"
		"ep_02.kl_launch_portalclosing06" = "<font color=\"rgb(255,255,200)\"><i>Quel soulagement!"
		"ep_02.kl_launch_portalclosing07" = "<font color=\"rgb(255,255,200)\"><i>Merveilleux!"
		"ep_02.kl_launch_portalclosing08" = "<font color=\"rgb(255,255,200)\"><i>Eh, bien, ça dépasse l'entendement!"
		"ep_02.kl_launch_portalclosing09" = "<font color=\"rgb(255,255,200)\"><i>Comme quoi, il faut garder espoir."
		"ep_02.kl_launch_portalclosing10" = "<font color=\"rgb(255,255,200)\"><i>Nous sommes en sécurité... pour le moment."
		"ep_02.kl_launch_portalclosing11" = "<font color=\"rgb(255,255,200)\"><i>Je dois l'admettre... j'avais des doutes."
		"ep_02.kl_launch_portalclosing12" = "<font color=\"rgb(255,255,200)\"><i>Oui, oui, nous pouvons être contents de nos efforts..."
		"ep_02.kl_launch_portalclosing13" = "<font color=\"rgb(255,255,200)\"><i>Alors, Magnusson..."
		"ep_02.kl_launch_right01" = "<font color=\"rgb(255,255,200)\">Tout à fait. "
		"ep_02.kl_launch_right02" = "<font color=\"rgb(255,255,200)\">S'il vous plaît."
		"ep_02.kl_launch_shortly01" = "<font color=\"rgb(255,255,200)\">Je suis sûr qu'il va arriver bientôt."
		"ep_02.kl_launch_shortly02" = "<font color=\"rgb(255,255,200)\">Ça ne lui ressemble pas."
		"ep_02.kl_launch_show01" = "<font color=\"rgb(255,255,200)\">Quand la fusée sera à portée du portail, on pourra allumer le résonateur à Xenium. "
		"ep_02.kl_launch_show02" = "<font color=\"rgb(255,255,200)\">Ça va être spectaculaire. Malheureusement, je ne peux pas venir."
		"ep_02.kl_launch_show03" = "<font color=\"rgb(255,255,200)\">Magnusson et moi devons surveiller la trajectoire de la fusée."
		"ep_02.kl_launch_show04" = "<font color=\"rgb(255,255,200)\">On peut voir"
		"ep_02.kl_launch_show05" = "<font color=\"rgb(255,255,200)\">ici"
		"ep_02.kl_launch_show06" = "<font color=\"rgb(255,255,200)\">que lorsqu'on aura pris de l'altitude, les antennes se réactiveront."
		"ep_02.kl_launch_sigh" = "<font color=\"rgb(255,255,200)\">[soupir]"
		"ep_02.kl_launch_signoff01" = "<font color=\"rgb(255,255,200)\">Très bien, laissez-nous sécuriser nos instruments et nous vous dirons ensuite au revoir."
		"ep_02.kl_launch_signoff02" = "<font color=\"rgb(255,255,200)\">Merci à tous. C'est terminé."
		"ep_02.kl_launch_skyawe01" = "<font color=\"rgb(255,255,200)\">Oh!"
		"ep_02.kl_launch_skyawe02" = "<font color=\"rgb(255,255,200)\">Merveilleux!"
		"ep_02.kl_launch_skyawe03" = "<font color=\"rgb(255,255,200)\">Magnifique!"
		"ep_02.kl_launch_skyawe04" = "<font color=\"rgb(255,255,200)\">Ah, spectaculaire!"
		"ep_02.kl_launch_skyawe05" = "<font color=\"rgb(255,255,200)\">Oh, j'espère que Lamarr voit ça."
		"ep_02.kl_launch_skyawe06" = "<font color=\"rgb(255,255,200)\">Euh..."
		"ep_02.kl_launch_skyawe07" = "<font color=\"rgb(255,255,200)\">Superbe!"
		"ep_02.kl_launch_skyawe08" = "<font color=\"rgb(255,255,200)\">Splendide! Magnifique!"
		"ep_02.kl_launch_skyawe09" = "<font color=\"rgb(255,255,200)\">Oh, la couronne!"
		"ep_02.kl_launch_theirsuccess" = "<font color=\"rgb(255,255,200)\">Oui, eh bien je pense que Gordon y est peut-être pour quelque chose dans cet exploit."
		"ep_02.kl_launch_ticking01" = "<font color=\"rgb(255,255,200)\">Tout à fait! "
		"ep_02.kl_launch_ticking02" = "<font color=\"rgb(255,255,200)\">L'heure tourne!"
		"ep_02.kl_launch_use01" = "<font color=\"rgb(255,255,200)\">Je n'ai pas de temps à perdre."
		"ep_02.kl_launch_use02" = "<font color=\"rgb(255,255,200)\">Vous devrez attendre la fin du lancement."
		"ep_02.kl_launch_valiant01" = "<font color=\"rgb(255,255,200)\">Je suis tout à fait d'accord."
		"ep_02.kl_launch_valiant02" = "<font color=\"rgb(255,255,200)\">Le lancement n'aurait jamais pu se faire sans ses courageux efforts."
		"ep_02.kl_launch_waxing01" = "<font color=\"rgb(255,255,200)\">[reniflement]"
		"ep_02.kl_launch_waxing02" = "<font color=\"rgb(255,255,200)\">Juste ciel!"
		"ep_02.kl_launch_wedidit" = "<font color=\"rgb(255,255,200)\">On a réussi!"
		"ep_02.kl_launch_wogordon" = "<font color=\"rgb(255,255,200)\">Mais, on ne peut pas continuer sans Gordon."
		"ep_02.kl_silo_agreed01" = "<font color=\"rgb(255,255,200)\">D'accord!"
		"ep_02.kl_silo_agreed02" = "<font color=\"rgb(255,255,200)\">Le Cartel envahit."
		"ep_02.kl_silo_arrived" = "<font color=\"rgb(255,255,200)\">Ciel! Eli! Pourquoi ne pas m'avoir dit qu'ils étaient arrivés?"
		"ep_02.kl_silo_auxil" = "<font color=\"rgb(255,255,200)\">On pourra le voir de la salle de contrôle auxiliaire."
		"ep_02.kl_silo_auxil02" = "<font color=\"rgb(255,255,200)\">On pourra le voir de la salle de contrôle auxiliaire."
		"ep_02.kl_silo_berightthere" = "<font color=\"rgb(255,255,200)\">Je me dépêche, Magnusson."
		"ep_02.kl_silo_auxil01" = "<font color=\"rgb(255,255,200)\">Laissez-moi initier le décodage."
		"ep_02.kl_silo_comein" = "<font color=\"rgb(255,255,200)\">Eli, Eli,  tu es là?"
		"ep_02.kl_silo_delight" = "<font color=\"rgb(255,255,200)\">Ma chère, quel soulagement mais aussi quel plaisir de vous revoir enfin ici. "
		"ep_02.kl_silo_devised01" = "<font color=\"rgb(255,255,200)\">Oui, en effet."
		"ep_02.kl_silo_devised02" = "<font color=\"rgb(255,255,200)\">Magnusson a conçu un résonateur à Xenium qui, en orbite, activera les antennes et les transformera en bouclier"
		"ep_02.kl_silo_devised03" = "<font color=\"rgb(255,255,200)\">de nature sub-dimensionnelle."
		"ep_02.kl_silo_emergency01" = "<font color=\"rgb(255,255,200)\">Oh, mince. Finalement, je crois que vous ne devriez pas envoyer Gordon tout de suite."
		"ep_02.kl_silo_emergency02" = "<font color=\"rgb(255,255,200)\">Comment?"
		"ep_02.kl_silo_emergency03" = "<font color=\"rgb(255,255,200)\">Eh bien, je ne peux pas le laisser entrer."
		"ep_02.kl_silo_emergency04" = "<font color=\"rgb(255,255,200)\">Les portes de secours seront condamnées."
		"ep_02.kl_silo_emergency05" = "<font color=\"rgb(255,255,200)\">Oh, non!"
		"ep_02.kl_silo_emergency06" = "<font color=\"rgb(255,255,200)\">Il y a une infiltration."
		"ep_02.kl_silo_emergency07" = "<font color=\"rgb(255,255,200)\">J'espère que Magnusson a prévu cette éventualité."
		"ep_02.kl_silo_fiethecode01" = "<font color=\"rgb(255,255,200)\">Oh non, le code.   "
		"ep_02.kl_silo_fiethecode02" = "<font color=\"rgb(255,255,200)\">Oui, Magnusson, j'ai besoin d'un peu plus de temps. "
		"ep_02.kl_silo_findus" = "<font color=\"rgb(255,255,200)\">Nous serons dans la salle de contrôle auxiliaire."
		"ep_02.kl_silo_fond01" = "<font color=\"rgb(255,255,200)\">Comme vous ne manquez pas de le souligner,"
		"ep_02.kl_silo_fond02" = "<font color=\"rgb(255,255,200)\">vous en êtes arrivé là sans nous."
		"ep_02.kl_silo_givenup01" = "<font color=\"rgb(255,255,200)\">Oh oui, il est bien réel malgré sa réputation légendaire. "
		"ep_02.kl_silo_givenup02" = "<font color=\"rgb(255,255,200)\">Nos collègues d'Aperture Science travaillaient sur un projet prometteur, mais dans leur chasse aux subventions afin de battre Black Mesa, ils ont dû prendre énormément de risques. Nous avons entendu que leur vaisseau de recherche avait simplement disparu. Disparu, corps et biens! Et même avec une partie de la cale sèche!"
		"ep_02.kl_silo_givenup03" = "<font color=\"rgb(255,255,200)\">Peu pensaient qu'on en reverrait les restes un jour..."
		"ep_02.kl_silo_goingover01" = "<font color=\"rgb(255,255,200)\">Oui, je regarderai ça de plus près quand j'aurai le temps, mais avant..."
		"ep_02.kl_silo_goingover02" = "<font color=\"rgb(255,255,200)\">laissez-moi trouver la transmission"
		"ep_02.kl_silo_goldmine01" = "<font color=\"rgb(255,255,200)\">Euh, oui, il y a toujours un risque, Eli."
		"ep_02.kl_silo_goldmine01a" = "<font color=\"rgb(255,255,200)\">Bon..."
		"ep_02.kl_silo_goldmine01b" = "<font color=\"rgb(255,255,200)\">Oui..."
		"ep_02.kl_silo_goldmine01c" = "<font color=\"rgb(255,255,200)\">Il y a toujours un risque, Eli."
		"ep_02.kl_silo_goldmine02" = "<font color=\"rgb(255,255,200)\">Bon sang, nous avons les coordonnées... les plans... les fréquences radio...  "
		"ep_02.kl_silo_goldmine03" = "<font color=\"rgb(255,255,200)\">Le Docteur Mossman a été bien inspirée de les cacher dans l'onde porteuse."
		"ep_02.kl_silo_headway01" = "<font color=\"rgb(255,255,200)\">Eh bien, ça ne fait aucun doute qu'elle a trouvé le Borealis."
		"ep_02.kl_silo_headway02" = "<font color=\"rgb(255,255,200)\">Ce vaisseau est de l'Aperture Science tout craché."
		"ep_02.kl_silo_headway03" = "<font color=\"rgb(255,255,200)\">Cependant, je n'ai fait que très peu de progrès avec les données en elles-mêmes."
		"ep_02.kl_silo_headway04" = "<font color=\"rgb(255,255,200)\">Si je peux vous l'emprunter, Gordon pourrait m'aider."
		"ep_02.kl_silo_hev" = "<font color=\"rgb(255,255,200)\">Vous aussi Gordon. Je vois que vous avez pris soin de la combinaison CEH, et inversement."
		"ep_02.kl_silo_hm" = "<font color=\"rgb(255,255,200)\">Hmmm..."
		"ep_02.kl_silo_idontbelieveit01" = "<font color=\"rgb(255,255,200)\">[Etonnement] C'est... le Borealis! "
		"ep_02.kl_silo_incredible" = "<font color=\"rgb(255,255,200)\">Incroyable!"
		"ep_02.kl_silo_inorder01" = "<font color=\"rgb(255,255,200)\">Tout semble être en ordre. "
		"ep_02.kl_silo_inorder02" = "<font color=\"rgb(255,255,200)\">Je me demande juste..."
		"ep_02.kl_silo_ionlymeant" = "<font color=\"rgb(255,255,200)\">Bon sang, je voulais juste dire qu'ils..."
		"ep_02.kl_silo_ireally" = "<font color=\"rgb(255,255,200)\">Mais nous ne sommes pas certains que..."
		"ep_02.kl_silo_keeponthis" = "<font color=\"rgb(255,255,200)\">Je reviens dès que j'ai fini."
		"ep_02.kl_silo_least" = "<font color=\"rgb(255,255,200)\">La moindre des choses, c'est de dire bonjour."
		"ep_02.kl_silo_lookaround01" = "<font color=\"rgb(255,255,200)\">On dirait que Gordon veut examiner le soi-disant missile pointu."
		"ep_02.kl_silo_lookaround02" = "<font color=\"rgb(255,255,200)\">Eh bien! Son enthousiasme incarne l'essence même de la démarche scientifique."
		"ep_02.kl_silo_lookaround03" = "<font color=\"rgb(255,255,200)\">Il me rappelle comment j'étais à son âge."
		"ep_02.kl_silo_neverfear01" = "<font color=\"rgb(255,255,200)\">Alors, allons-y."
		"ep_02.kl_silo_neverfear02" = "<font color=\"rgb(255,255,200)\">Je retourne travailler sur l'analyse."
		"ep_02.kl_silo_nevermind" = "<font color=\"rgb(255,255,200)\">Ne faites pas attention à lui."
		"ep_02.kl_silo_nostoppingher" = "<font color=\"rgb(255,255,200)\">On n'aurait pas pu l'arrêter, Eli."
		"ep_02.kl_silo_noweli01" = "<font color=\"rgb(255,255,200)\">Eli... Le pire qui puisse nous arriver à part la capture de Judith serait que tu sois capturé à ton tour. Elle connaît peut-être certaines choses sur le Borealis, mais toi... tu connais tout sur la résistance!"
		"ep_02.kl_silo_nowfound" = "<font color=\"rgb(255,255,200)\">Maintenant que nous l'avons trouvé, nous pouvons l'utiliser contre le Cartel."
		"ep_02.kl_silo_nowmag" = "<font color=\"rgb(255,255,200)\">Écoutez bien Magnusson. Il est inutile de faire des commentaires désobligeants."
		"ep_02.kl_silo_nowmag01" = "<font color=\"rgb(255,255,200)\">Écoutez bien Magnusson."
		"ep_02.kl_silo_nowmag02" = "<font color=\"rgb(255,255,200)\">Il est inutile de faire des commentaires désobligeants."
		"ep_02.kl_silo_nownow01" = "<font color=\"rgb(255,255,200)\">Ne t'en fais pas, Eli."
		"ep_02.kl_silo_nownow02" = "<font color=\"rgb(255,255,200)\">Je suis sûr que le Dr Mossman va bien."
		"ep_02.kl_silo_nownow03" = "<font color=\"rgb(255,255,200)\">Elle est très ingénieuse."
		"ep_02.kl_silo_onceinplace01" = "<font color=\"rgb(255,255,200)\">Une fois en place, il bloquera l'accès du Cartel à la Terre, même s'ils parviennent à restaurer leur réseau de portails,"
		"ep_02.kl_silo_onceinplace02" = "<font color=\"rgb(255,255,200)\">ce qui semble de plus en plus probable."
		"ep_02.kl_silo_rawtrans01" = "<font color=\"rgb(255,255,200)\">Eh bien... Même un fragment de transmission nous donnerait un aperçu pénétrant dans"
		"ep_02.kl_silo_rawtrans02" = "<font color=\"rgb(255,255,200)\">Eh bien, c'est inimaginable."
		"ep_02.kl_silo_rawtrans03" = "<font color=\"rgb(255,255,200)\">Et vous pensez que ça va, ici?"
		"ep_02.kl_silo_reunion01" = "<font color=\"rgb(255,255,200)\">Je n'en reviens pas."
		"ep_02.kl_silo_reunion02" = "<font color=\"rgb(255,255,200)\">C'est comme si nous avions réuni de nouveau l'ancienne équipe scientifique de Black Mesa."
		"ep_02.kl_silo_reunion03" = "<font color=\"rgb(255,255,200)\">Enfin sans un ou deux membres titulaires que nous ne regretterons pas."
		"ep_02.kl_silo_samearray01" = "<font color=\"rgb(255,255,200)\">Oui, les antennes ont été abandonnées depuis que vous avez éliminé Nihilanth."
		"ep_02.kl_silo_samearray02" = "<font color=\"rgb(255,255,200)\">Nous avons cependant récemment mis au point un plan pour inverser la polarité du portail."
		"ep_02.kl_silo_sayinghello01" = "<font color=\"rgb(255,255,200)\">Ça va, ça va. "
		"ep_02.kl_silo_sayinghello02" = "<font color=\"rgb(255,255,200)\">Je ne faisais que saluer Alyx et Gordon."
		"ep_02.kl_silo_sendhim" = "<font color=\"rgb(255,255,200)\">Allez-y, faites-le traverser."
		"ep_02.kl_silo_shoulddoit" = "<font color=\"rgb(255,255,200)\">Ah, ça devrait faire l'affaire."
		"ep_02.kl_silo_signature01" = "<font color=\"rgb(255,255,200)\">Malheureusement, on ne peut que deviner la signature spécifique du portail,"
		"ep_02.kl_silo_signature02" = "<font color=\"rgb(255,255,200)\">du moins, jusqu'à la reconnexion avec le Monde supérieur du Cartel."
		"ep_02.kl_silo_signature03" = "<font color=\"rgb(255,255,200)\">Après quoi il sera trop tard pour empêcher une nouvelle invasion."
		"ep_02.kl_silo_signature04" = "<font color=\"rgb(255,255,200)\">Si l'on connaissait la nature du signal, on pourrait bloquer l'accès du Cartel tout en nous téléportant librement."
		"ep_02.kl_silo_signature05" = "<font color=\"rgb(255,255,200)\">Mais la probabilité est si faible"
		"ep_02.kl_silo_signature06" = "<font color=\"rgb(255,255,200)\">qu'on ne peut pas compter dessus."
		"ep_02.kl_silo_smallcrew" = "<font color=\"rgb(255,255,200)\">Elle est partie au Nord avec quelques hommes... peu de temps après notre départ pour White Forest."
		"ep_02.kl_silo_somethingelse01" = "<font color=\"rgb(255,255,200)\">Attendez..."
		"ep_02.kl_silo_somethingelse02" = "<font color=\"rgb(255,255,200)\">Il y a quelque chose d'autre, ici."
		"ep_02.kl_silor_superb" = "<font color=\"rgb(255,255,200)\">Bravo à vous deux pour le retardement de la réaction du noyau! Ça a dû être passionnant."
		"ep_02.kl_silo_thereweare" = "<font color=\"rgb(255,255,200)\">On y est."
		"ep_02.kl_silo_tour" = "<font color=\"rgb(255,255,200)\">Vous pourrez le faire visiter plus tard, Magnusson."
		"ep_02.kl_silo_trove01" = "<font color=\"rgb(255,255,200)\">Eh bien, c'est une véritable mine d'or."
		"ep_02.kl_silo_trove02" = "<font color=\"rgb(255,255,200)\">On dirait que vous avez pillé la mine de données de la Citadelle comme deux pirates des temps modernes."
		"ep_02.kl_silo_trove02_alt" = "<font color=\"rgb(255,255,200)\">On dirait que vous avez pillé la mine de données de la Citadelle comme"
		"ep_02.kl_silo_waste01" = "<font color=\"rgb(255,255,200)\">Mais pense un peu aux bienfaits pour l'humanité! Nous ne pouvons pas laisser échapper cette opportunité. "
		"ep_02.kl_silo_wellseeyou" = "<font color=\"rgb(255,255,200)\">On se revoit dans la salle de contrôle auxiliaire."
		"ep_02.kl_silo_whatmean" = "<font color=\"rgb(255,255,200)\">Que voulez-vous dire, ma chère?"
		"ep_02.kl_silo_whatsthis" = "<font color=\"rgb(255,255,200)\">Qu'est-ce que c'est?"
		"ep_02.kl_silo_wheredata01" = "<font color=\"rgb(255,255,200)\">Oh, ne faites pas attention à lui."
		"ep_02.kl_silo_wheredata02" = "<font color=\"rgb(255,255,200)\">Eh bien, ma chère, où sont ces données que vous avez rapportées? "
		"ep_02.kl_silo_wheredata03" = "<font color=\"rgb(255,255,200)\">Si je retarde encore, on n'a pas fini de l'entendre."
		"ep_02.kl_transmit_callmag01" = "<font color=\"rgb(255,255,200)\"><i>Magnusson, vous avez entendu? "
		"ep_02.kl_transmit_callmag02" = "<font color=\"rgb(255,255,200)\"><i>Ça doit être le code du portail du Cartel. "
		"ep_02.kl_transmit_data" = "<font color=\"rgb(255,255,200)\"><i>Des données? De la Citadelle? "
		"ep_02.kl_transmit_goodness" = "<font color=\"rgb(255,255,200)\"><i>Alyx, mon Dieu, c'est vraiment vous? "
		"ep_02.kl_transmit_monitor" = "<font color=\"rgb(255,255,200)\"><i>Oui, nous avons suivi la situation attentivement. L'implosion du noyau a donné naissance à un faisceau cohérent d'énergie de portail. "
		"ep_02.kl_transmit_neversaid" = "<font color=\"rgb(255,255,200)\"><i>Oui, je le sais mais je n'ai jamais dit que... "
		"ep_02.kl_transmit_superportal01" = "<font color=\"rgb(255,255,200)\"><i>Oui. Vous avez sous les yeux l'ébauche d'un superportail. "
		"ep_02.kl_transmit_superportal02" = "<font color=\"rgb(255,255,200)\"><i>S'il atteint sa puissance maximale... "
		"ep_02.kl_silo_yesyes" = "<font color=\"rgb(255,255,200)\">Oui, oui,  Bien sûr!"
		"ep_02.kl_silo_resume" = "<font color=\"rgb(255,255,200)\">On peut reprendre?"
		"ep_02.mag_aband_apex01" = "<font color=\"rgb(209,178,178)\"><i>Freeman"
		"ep_02.mag_aband_apex02" = "<font color=\"rgb(209,178,178)\"><i>Freeman, vous m'entendez?"
		"ep_02.mag_aband_apex03" = "<font color=\"rgb(209,178,178)\"><i>La base sera vulnérable tant que vous n'aurez pas trouvé les commandes et fermé la porte supérieure."
		"ep_02.mag_aband_assume01" = "<font color=\"rgb(209,178,178)\"><i>Freeman..."
		"ep_02.mag_aband_assume02" = "<font color=\"rgb(209,178,178)\"><i>Freeman, en supposant que vous êtes dans le silo secondaire et que vous m'entendez..."
		"ep_02.mag_aband_assume03" = "<font color=\"rgb(209,178,178)\"><i>J'ai déterminé que l'infiltration provient de la porte de lancement supérieure."
		"ep_02.mag_aband_assume04" = "<font color=\"rgb(209,178,178)\"><i>Déplacez-vous vers le haut du tube de lancement et faites le nécessaire pour condamner la zone."
		"ep_02.mag_aband_critical" = "<font color=\"rgb(209,178,178)\"><i>Attention Freeman! Il faut absolument condamner les portes supérieures du silo et arrêter l'infiltration!"
		"ep_02.mag_aband_dearbreach" = "<font color=\"rgb(209,178,178)\"><i>Quelle horreur! Bon sang. C'est une brèche,  c'est une brèche!"
		"ep_02.mag_aband_decom01" = "<font color=\"rgb(209,178,178)\"><i>Freeman! Il y a une brèche dans le silo secondaire. Le problème vient des portes de lancement supérieures."
		"ep_02.mag_aband_decom02" = "<font color=\"rgb(209,178,178)\"><i>Vous devez condamner les portes du silo."
		"ep_02.mag_aband_dontanswer" = "<font color=\"rgb(209,178,178)\"><i>Sinon... ne répondez pas."
		"ep_02.mag_aband_fiends01" = "<font color=\"rgb(209,178,178)\"><i>Ces démons à plumes sont les plus tenaces que j'aie jamais...  "
		"ep_02.mag_aband_fiends02" = "<font color=\"rgb(209,178,178)\"><i>Attendez... Qu'est-ce que c'est?"
		"ep_02.mag_aband_forgordsake" = "<font color=\"rgb(209,178,178)\"><i>Freeman, si vous m'entendez, vous devez fermer les portes supérieures du silo."
		"ep_02.mag_aband_freeman" = "<font color=\"rgb(209,178,178)\"><i>Freeman? Freeman, j'espère que vous m'entendez. Ici le Dr. Magnusson."
		"ep_02.mag_aband_notcrows" = "<font color=\"rgb(209,178,178)\"><i>Pas des corbeaux! Le Cartel!"
		"ep_02.mag_aband_ominous" = "<font color=\"rgb(209,178,178)\"><i>J'ai peur que quelque chose de plus dangereux que des corbeaux soit impliqué..."
		"ep_02.mag_aband_onceagain01" = "<font color=\"rgb(209,178,178)\"><i>Freeman!"
		"ep_02.mag_aband_onceagain02" = "<font color=\"rgb(209,178,178)\"><i>Freeman! Vous avez entendu ce que j'ai dit? "
		"ep_02.mag_aband_onceagain03" = "<font color=\"rgb(209,178,178)\"><i>C'est à vous de condamner les portes de lancement!"
		"ep_02.mag_aband_pinpoint" = "<font color=\"rgb(209,178,178)\"><i>Votre attention! Annonce au personnel! Ici le Dr. Magnusson. Nous subissons une brèche des défenses internes de la base. Veuillez patienter pendant que nous localisons le problème. "
		"ep_02.mag_aband_pleased" = "<font color=\"rgb(209,178,178)\"><i>Ici le Dr. Magnusson. Et... je suis heureux de vous annoncer que le silo secondaire a été condamné. Allez! Au travail!"
		"ep_02.mag_aband_popular01" = "<font color=\"rgb(209,178,178)\"><i>Annonce au personnel!"
		"ep_02.mag_aband_popular02" = "<font color=\"rgb(209,178,178)\"><i>Ici le Dr. Magnusson!"
		"ep_02.mag_aband_popular03" = "<font color=\"rgb(209,178,178)\"><i>Puisque l'équipe du silo secondaire semble incapable de résoudre son petit problème de corbeaux, vous serez heureux d'apprendre que nous avons demandé au Dr Freeman de s'en charger. Nous attendons ses résultats avec impatience. "
		"ep_02.mag_aband_popular04" = "<font color=\"rgb(209,178,178)\"><i>Je suis par ailleurs curieux de connaître les raisons pour lesquelles le personnel n'a pas réussi à s'en charger."
		"ep_02.mag_aband_popular05" = "<font color=\"rgb(209,178,178)\"><i>Merci pour votre patience."
		"ep_02.mag_aband_racket" = "<font color=\"rgb(209,178,178)\"><i>Bon sang, Freeman, vous en mettez du temps! Oh, mais je ne peux pas me concentrer avec tout ce raffut!"
		"ep_02.mag_aband_stillalive" = "<font color=\"rgb(209,178,178)\"><i>Il y a quelqu'un de vivant là-dedans?"
		"ep_02.mag_aband_stillthere" = "<font color=\"rgb(209,178,178)\"><i>Freeman! Vous êtes encore dans le silo secondaire?"
		"ep_02.mag_launch_check01" = "<font color=\"rgb(209,178,178)\"><i>Liens de données télémétriques."
		"ep_02.mag_launch_check02" = "<font color=\"rgb(209,178,178)\"><i>Il doit s'agir d'une vieille entrée. Il n'y a pas de site secondaire. Si nous échouons, il faut espérer que la fusée tombe directement sur l'ennemi. Bien... Systèmes de navigation par inertie."
		"ep_02.mag_launch_check03" = "<font color=\"rgb(209,178,178)\"><i>Balise de suivi... Ça aussi, on peut le laisser de côté. Équipement d'assistance éteint."
		"ep_02.mag_launch_check04" = "<font color=\"rgb(209,178,178)\"><i>Système de télécommunication prêt..."
		"ep_02.mag_launch_check05" = "<font color=\"rgb(209,178,178)\"><i>Contrôle d'équipement d'assistance de lancement OK."
		"ep_02.mag_launch_check06" = "<font color=\"rgb(209,178,178)\"><i>Test de sécurité du SGM..."
		"ep_02.mag_launch_check07" = "<font color=\"rgb(209,178,178)\"><i>Vents au sol et en haute altitude..."
		"ep_02.mag_launch_check08" = "<font color=\"rgb(209,178,178)\"><i>Courant et tension de l'ordinateur de guidage..."
		"ep_02.mag_launch_check09" = "<font color=\"rgb(209,178,178)\"><i>Passage du SGM sur alimentation interne."
		"ep_02.mag_launch_check10" = "<font color=\"rgb(209,178,178)\"><i>Armé?"
		"ep_02.mag_launch_check11" = "<font color=\"rgb(209,178,178)\"><i>Ne dites pas «Bien sûr». On n'est jamais sûrs de rien!"
		"ep_02.mag_launch_check12a" = "<font color=\"rgb(209,178,178)\"><i>[Soupir]"
		"ep_02.mag_launch_check12b" = "<font color=\"rgb(209,178,178)\"><i>Avionique vers alimentation?"
		"ep_02.mag_launch_chitchat01" = "<font color=\"rgb(209,178,178)\">Hmmm... Assez parlé. "
		"ep_02.mag_launch_chitchat02" = "<font color=\"rgb(209,178,178)\">J'ai une fusée à lancer. "
		"ep_02.mag_launch_cutclose" = "<font color=\"rgb(209,178,178)\"><i>Même si on l'avait voulu, on n'aurait pas pu être aussi limites. "
		"ep_02.mag_launch_doitmyself" = "<font color=\"rgb(209,178,178)\"><i>Dépêchez-vous ou je le fais moi-même! "
		"ep_02.mag_launch_flawless01" = "<font color=\"rgb(209,178,178)\">Ah, Freeman. "
		"ep_02.mag_launch_flawless02" = "<font color=\"rgb(209,178,178)\">Le dispositif Magnusson a donc parfaitement fonctionné. "
		"ep_02.mag_launch_forgetmd01" = "<font color=\"rgb(209,178,178)\">N'oublions pas que grâce au dispositif Magnusson, ces striders se détruisent pratiquement tout seuls. "
		"ep_02.mag_launch_haventseenhim" = "<font color=\"rgb(209,178,178)\"><i>Non, non, je ne l'ai pas vu. "
		"ep_02.mag_launch_holdon" = "<font color=\"rgb(209,178,178)\">Une seconde, Kleiner. "
		"ep_02.mag_launch_indeed" = "<font color=\"rgb(209,178,178)\"><i>Certainement. "
		"ep_02.mag_launch_launchsequence01" = "<font color=\"rgb(209,178,178)\"><i>Silo ouvert. "
		"ep_02.mag_launch_launchsequence02" = "<font color=\"rgb(209,178,178)\"><i>Tout le monde en place. "
		"ep_02.mag_launch_launchsequence03" = "<font color=\"rgb(209,178,178)\"><i>Alimentation aux propulseurs. "
		"ep_02.mag_launch_launchsequence04" = "<font color=\"rgb(209,178,178)\"><i>Préparez-vous. "
		"ep_02.mag_launch_launchsequence05" = "<font color=\"rgb(209,178,178)\"><i>Lancement "
		"ep_02.mag_launch_launchsequence06" = "<font color=\"rgb(209,178,178)\"><i>Doucement, doucement. "
		"ep_02.mag_launch_launchsequence07" = "<font color=\"rgb(209,178,178)\"><i>Elle... elle... a décollé. "
		"ep_02.mag_launch_launchsequence08a" = "<font color=\"rgb(209,178,178)\"><i>Elle a décollé. "
		"ep_02.mag_launch_launchsequence08b" = "<font color=\"rgb(209,178,178)\"><i>Décollé! "
		"ep_02.mag_launch_launchsequence08c" = "<font color=\"rgb(209,178,178)\"><i>Elle a décollé. Oh! "
		"ep_02.mag_launch_launchsequence08d" = "<font color=\"rgb(209,178,178)\"><i>Oh, oh, je dois me reprendre. Il faut que je respire profondément, doucement, ahhh."
		"ep_02.mag_launch_launchsequence09a" = "<font color=\"rgb(209,178,178)\"><i>Oh, ma fusée! Ma fusée fonctionne! Ah... "
		"ep_02.mag_launch_launchsequence09b" = "<font color=\"rgb(209,178,178)\"><i>Je suis un génie! "
		"ep_02.mag_launch_launchsequence09c" = "<font color=\"rgb(209,178,178)\"><i>Je vous avais dit que ça marcherait! Je le savais! "
		"ep_02.mag_launch_launchsequence09d" = "<font color=\"rgb(209,178,178)\"><i>Merci, Freeman. "
		"ep_02.mag_launch_onlyabutton" = "<font color=\"rgb(209,178,178)\"><i>Oh, bon sang, ce n'est qu'un bouton. Appuyez dessus, c'est tout ce que je vous demande. "
		"ep_02.mag_launch_portalresponse01" = "<font color=\"rgb(209,178,178)\">"
		"ep_02.mag_launch_portalresponse02" = "<font color=\"rgb(209,178,178)\">"
		"ep_02.mag_launch_portalresponse03" = "<font color=\"rgb(209,178,178)\">"
		"ep_02.mag_launch_portalresponse04" = "<font color=\"rgb(209,178,178)\">"
		"ep_02.mag_launch_premature01" = "<font color=\"rgb(209,178,178)\"><i>Bien... il est encore trop tôt pour sauter de joie. "
		"ep_02.mag_launch_premature02" = "<font color=\"rgb(209,178,178)\"><i>Nous devons prendre de l'altitude et transmettre le signal. "
		"ep_02.mag_launch_premature03" = "<font color=\"rgb(209,178,178)\"><i>Si tant est que Kleiner l'ait décodé correctement. "
		"ep_02.mag_launch_pushingit" = "<font color=\"rgb(209,178,178)\"><i>Bon, ça suffit. Je vais le faire moi-même. "
		"ep_02.mag_launch_readytostartauto" = "<font color=\"rgb(209,178,178)\"><i>Nous sommes prêts à initier l'autoséquence. "
		"ep_02.mag_launch_solong01" = "<font color=\"rgb(209,178,178)\"><i>Pourquoi met-il autant de temps? "
		"ep_02.mag_launch_solong02" = "<font color=\"rgb(209,178,178)\"><i>Où est-il donc passé? "
		"ep_02.mag_launch_standaround" = "<font color=\"rgb(209,178,178)\"><i>Vous n'avez rien de mieux à faire que de rester là, les bras croisés? "
		"ep_02.mag_launch_startauto01" = "<font color=\"rgb(209,178,178)\"><i>Début autoséquence prêt. "
		"ep_02.mag_launch_startauto02" = "<font color=\"rgb(209,178,178)\"><i>Je propose que nous continuions cette cérémonie de félicitations après le lancement de la fusée. "
		"ep_02.mag_launch_thankyou01" = "<font color=\"rgb(209,178,178)\">Je me sens obligé de vous remercier, personnellement, d'avoir sauvé ma fusée. "
		"ep_02.mag_launch_thankyou02" = "<font color=\"rgb(209,178,178)\">Alors, euh... "
		"ep_02.mag_launch_thankyou03" = "<font color=\"rgb(209,178,178)\">Merci. "
		"ep_02.mag_launch_tolerance01" = "<font color=\"rgb(209,178,178)\"><i>Oh... Ça reste acceptable... Ça ne vaut certainement pas la peine de retarder... "
		"ep_02.mag_launch_tolerance02" = "<font color=\"rgb(209,178,178)\"><i>Ah, Gordon Freeman! "
		"ep_02.mag_launch_what" = "<font color=\"rgb(209,178,178)\"><i>Quoi? "
		"ep_02.mag_launch_wherewerewe" = "<font color=\"rgb(209,178,178)\"><i>Alors... Où en étions-nous? "
		"ep_02.mag_launch_whose" = "<font color=\"rgb(209,178,178)\"><i>Mais allez-y bon sang! "
		"ep_02.mag_post_pa01" = "<font color=\"rgb(209,178,178)\"><i>Ça y est! Le dernier strider a été éliminé."
		"ep_02.mag_post_pa02" = "<font color=\"rgb(209,178,178)\"><i>Les sbires du Cartel ont été repoussés!"
		"ep_02.mag_post_pa03" = "<font color=\"rgb(209,178,178)\"><i>Retournez tous à la base! Je répète! Tout le personnel à la base immédiatement! Nous devons lancer cette fusée!"
		"ep_02.mag_post_pa04" = "<font color=\"rgb(209,178,178)\"><i>Evacuation! A tout le personnel de White Forest! Evacuez la zone!"
		"ep_02.mag_post_pa05" = "<font color=\"rgb(209,178,178)\"><i>Evacuation! A tout le personnel, retournez à la base ou abritez-vous immédiatement. Il faut libérer la zone pour le lancement."
		"ep_02.mag_post_pa06" = "<font color=\"rgb(209,178,178)\"><i>Freeman, si vous m'entendez, revenez tout de suite à la base!"
		"ep_02.mag_post_pa07a" = "<font color=\"rgb(209,178,178)\"><i>Retour à la base pour tout le personnel! "
		"ep_02.mag_post_pa07b" = "<font color=\"rgb(209,178,178)\"><i>Et si vous croisez Gordon Freeman, dites-lui de ramener ses fesses ici et que ça saute!"
		"ep_02.mag_rad_expectedyou01" = "<font color=\"rgb(209,178,178)\"><i>Alyx? "
		"ep_02.mag_rad_expectedyou02" = "<font color=\"rgb(209,178,178)\"><i>Alyx Vance? "
		"ep_02.mag_rad_expectedyou03" = "<font color=\"rgb(209,178,178)\"><i>Où êtes-vous? "
		"ep_02.mag_rad_expectedyou04" = "<font color=\"rgb(209,178,178)\"><i>Ça fait des heures que je vous attends. "
		"ep_02.mag_rad_gravity01" = "<font color=\"rgb(209,178,178)\"><i>Avez-vous conscience de la gravité de la situation? "
		"ep_02.mag_rad_gravity02" = "<font color=\"rgb(209,178,178)\"><i>La survie de la Terre dépend des données que vous transportez. "
		"ep_02.mag_rad_hopeso01" = "<font color=\"rgb(209,178,178)\"><i>Quoi? Quoi? "
		"ep_02.mag_rad_hopeso02" = "<font color=\"rgb(209,178,178)\"><i>Vous avancez vers nous? Mais j'espère bien! "
		"ep_02.mag_rad_hopeso03" = "<font color=\"rgb(209,178,178)\"><i>Quoi? Allô? "
		"ep_02.mag_rad_hopeso04" = "<font color=\"rgb(209,178,178)\"><i>Oh? "
		"ep_02.mag_rad_hopeso05" = "<font color=\"rgb(209,178,178)\"><i>Je vous entends mal, Alyx. "
		"ep_02.mag_rad_hopeso06" = "<font color=\"rgb(209,178,178)\"><i>Je ne vous entends pas. "
		"ep_02.mag_rad_whatwhat01" = "<font color=\"rgb(209,178,178)\"><i>Quoi? "
		"ep_02.mag_rad_whatwhat02" = "<font color=\"rgb(209,178,178)\"><i>Quoi? "
		"ep_02.mag_silo_backtowork01" = "<font color=\"rgb(209,178,178)\"><i>Allez! Tout le monde au travail! "
		"ep_02.mag_silo_backtowork02" = "<font color=\"rgb(209,178,178)\"><i>C'est rien de plus qu'une nouvelle fausse alerte dans le silo secondaire."
		"ep_02.mag_silo_changeplans01" = "<font color=\"rgb(209,178,178)\">OK. Changement de programme. "
		"ep_02.mag_silo_changeplans02" = "<font color=\"rgb(209,178,178)\">On ne pourra pas effectuer de lancement tant que les striders... "
		"ep_02.mag_silo_datapeople" = "<font color=\"rgb(209,178,178)\">Les données! Bon sang, les données! "
		"ep_02.mag_silo_excuseme01" = "<font color=\"rgb(209,178,178)\">Oh, excusez-moi si je vous dérange pendant votre pause café! "
		"ep_02.mag_silo_excuseme02" = "<font color=\"rgb(209,178,178)\">Je reviendrai quand vous aurez fini, si vous préférez. "
		"ep_02.mag_silo_falsealarms01" = "<font color=\"rgb(209,178,178)\">Hou-hou! "
		"ep_02.mag_silo_falsealarms02" = "<font color=\"rgb(209,178,178)\">Hou-hou, il y a quelqu'un? "
		"ep_02.mag_silo_falsealarms03" = "<font color=\"rgb(209,178,178)\">Il y a quelqu'un? "
		"ep_02.mag_silo_falsealarms04" = "<font color=\"rgb(209,178,178)\">Des fausses alarmes toute la journée. Ces foutus corbeaux nichent sur les rails. Je ne sais même pas comment je peux me concentrer avec tout ce raffut. "
		"ep_02.mag_silo_follownags01" = "<font color=\"rgb(209,178,178)\">Suivez-moi. "
		"ep_02.mag_silo_follownags02" = "<font color=\"rgb(209,178,178)\">Freeman! "
		"ep_02.mag_silo_follownags03" = "<font color=\"rgb(209,178,178)\">Suivez-moi. "
		"ep_02.mag_silo_follownags04" = "<font color=\"rgb(209,178,178)\">Suivez-moi, Freeman. "
		"ep_02.mag_silo_follownags05" = "<font color=\"rgb(209,178,178)\">Freeman! "
		"ep_02.mag_silo_follownags06" = "<font color=\"rgb(209,178,178)\">Freeman, suivez-moi, dépêchez-vous! "
		"ep_02.mag_silo_follownags07" = "<font color=\"rgb(209,178,178)\">Freeman! Bon sang, où êtes-vous? "
		"ep_02.mag_silo_followquick01" = "<font color=\"rgb(209,178,178)\">Eh bien, Freeman,"
		"ep_02.mag_silo_followquick02" = "<font color=\"rgb(209,178,178)\">j'ai trouvé une tâche parfaite pour vous."
		"ep_02.mag_silo_followquick03" = "<font color=\"rgb(209,178,178)\">Suivez-moi. "
		"ep_02.mag_silo_followquick04" = "<font color=\"rgb(209,178,178)\">Vite."
		"ep_02.mag_silo_goahead" = "<font color=\"rgb(209,178,178)\"><i>Si vous attendez le signal du Cartel, ils seront bientôt là pour vous le donner de vive voix. "
		"ep_02.mag_silo_guarant" = "<font color=\"rgb(209,178,178)\">Vous pouvez me faire confiance! "
		"ep_02.mag_silo_kleinercert01" = "<font color=\"rgb(209,178,178)\">Demander l'approbation de Kleiner, c'est bien la dernière chose qui me serait venue à l'esprit. "
		"ep_02.mag_silo_kleinercert02" = "<font color=\"rgb(209,178,178)\">Les problèmes que nous avons rencontrés résultent uniquement du manque de personnel et de moyens. "
		"ep_02.mag_silo_laddernags01" = "<font color=\"rgb(209,178,178)\">Prenez l'échelle. "
		"ep_02.mag_silo_laddernags02" = "<font color=\"rgb(209,178,178)\">L'échelle. Vite. "
		"ep_02.mag_silo_laddernags03" = "<font color=\"rgb(209,178,178)\">Vite, descendez par cette échelle. "
		"ep_02.mag_silo_laddernags04" = "<font color=\"rgb(209,178,178)\">L'échelle est ici. "
		"ep_02.mag_silo_lamarr" = "<font color=\"rgb(209,178,178)\">Et sortez votre parasite cranio-conjugal du nez de ma fusée! "
		"ep_02.mag_silo_makeuseful" = "<font color=\"rgb(209,178,178)\">Freeman, ne restez pas là à rien faire. Rendez-vous utile, allez voir ce qui se passe là-dedans. "
		"ep_02.mag_silo_needahand01" = "<font color=\"rgb(209,178,178)\"><i>Kleiner, où êtes-vous? "
		"ep_02.mag_silo_needahand02" = "<font color=\"rgb(209,178,178)\"><i>Pourquoi le décodage n'est-il pas terminé? "
		"ep_02.mag_silo_needyouhere" = "<font color=\"rgb(209,178,178)\"><i>J'ai besoin de vous ici."
		"ep_02.mag_silo_notagain" = "<font color=\"rgb(209,178,178)\">Oh non, encore! Mais qu'est-ce qui se passe dans le silo secondaire? "
		"ep_02.mag_silo_parade01" = "<font color=\"rgb(209,178,178)\">Oh non. Allez, le festival des interruptions continue. "
		"ep_02.mag_silo_redcarpet" = "<font color=\"rgb(209,178,178)\">Oh, magnifique. Moi, je n'ai pas un moment pour souffler, mais je vous en prie, déroulez le tapis rouge. "
		"ep_02.mag_silo_reunion" = "<font color=\"rgb(209,178,178)\">Kleiner, vous allez synchroniser le satellite ou je dois attendre la fin de votre réunion de famille pour effectuer le lancement ?"
		"ep_02.mag_silo_sendtosecondsilo01" = "<font color=\"rgb(209,178,178)\">J'ouvre la trappe et vous descendez. "
		"ep_02.mag_silo_sendtosecondsilo02" = "<font color=\"rgb(209,178,178)\">Les portes anti-déflagration se sont fermées lors de l'alerte. Allez au fond du tube de lancement. "
		"ep_02.mag_silo_sendtosecondsilo03" = "<font color=\"rgb(209,178,178)\">Quand serez au fond, Uriah vous fera entrer dans le silo secondaire. "
		"ep_02.mag_silo_thisway" = "<font color=\"rgb(209,178,178)\">Par là, Freeman. "
		"ep_02.mag_silo_waitingforhug01" = "<font color=\"rgb(209,178,178)\">Vous attendez quoi Freeman, mes encouragements? "
		"ep_02.mag_silo_waitingforhug02" = "<font color=\"rgb(209,178,178)\">Le problème ne va pas se résoudre tout seul! "
		"ep_02.mag_silo_wheregoing" = "<font color=\"rgb(209,178,178)\">Où croyez-vous aller, Freeman? "
		"ep_02.mag_transmit_linchpin" = "<font color=\"rgb(209,178,178)\"><i>Bien sûr qu'ils nous pourchassent. Vous voyez, Kleiner, c'est tout l'intérêt de leur visite! "
		"ep_02.mag_transmit_nodoubt01" = "<font color=\"rgb(209,178,178)\"><i>Si je ne me trompe pas, et je n'ai aucun doute là-dessus, vous êtes en possession du code que le Dr Mossman voulait récupérer. "
		"ep_02.mag_transmit_nodoubt02" = "<font color=\"rgb(209,178,178)\"><i>Quand pensez-vous arriver? "
		"ep_02.mag_transmit_nowaste01" = "<font color=\"rgb(209,178,178)\"><i>Il n'y a pas de temps à perdre. "
		"ep_02.mag_transmit_nowaste02" = "<font color=\"rgb(209,178,178)\"><i>Accélérons le planning du lancement. "
		"ep_02.mag_transmit_nowaste03" = "<font color=\"rgb(209,178,178)\"><i>Dès que vous arriverez avec les données de signature, nous encoderons le satellite et le mettrons en orbite. "
		"ep_02.mag_transmit_sequence01" = "<font color=\"rgb(209,178,178)\"><i>Quelque part dans cette séquence, ils ont dû établir une connexion avec le côté opposé. "
		"ep_02.mag_transmit_sequence02" = "<font color=\"rgb(209,178,178)\"><i>Ce que vous avez là, jeune fille, est le code de contact pour le Monde supérieur du Cartel. "
		"ep_02.mag_transmit_whatnow" = "<font color=\"rgb(209,178,178)\"><i>Oui, oui, je ne suis pas sourd. "
		"ep_02.mag_tutor_aimforcarap" = "<font color=\"rgb(209,178,178)\">Visez la carapace. "
		"ep_02.mag_tutor_aimforupperbody" = "<font color=\"rgb(209,178,178)\">Visez le haut du corps, bon sang. "
		"ep_02.mag_tutor_amplesupply" = "<font color=\"rgb(209,178,178)\">Chaque immeuble de la vallée a son propre port de distribution. Vous disposez d'énormes réserves d'explosifs. "
		"ep_02.mag_tutor_anothermiss" = "<font color=\"rgb(209,178,178)\">Et... encore raté. "
		"ep_02.mag_tutor_attach" = "<font color=\"rgb(209,178,178)\">Pas besoin d'en coller plus d'un. "
		"ep_02.mag_tutor_backtorocket" = "<font color=\"rgb(209,178,178)\">Je dois retourner travailler sur ma fusée. "
		"ep_02.mag_tutor_bitmore" = "<font color=\"rgb(209,178,178)\">C'est un peu plus difficile à cette distance. "
		"ep_02.mag_tutor_brawn01" = "<font color=\"rgb(209,178,178)\">Vous vous êtes montré à la hauteur et le personnel semble vous respecter. Je vous charge donc de défendre White Forest et place ma nouvelle arme révolutionnaire entre vos mains. "
		"ep_02.mag_tutor_carapfreeman" = "<font color=\"rgb(209,178,178)\">La carapace, Freeman. "
		"ep_02.mag_tutor_darelaunch01" = "<font color=\"rgb(209,178,178)\">Freeman, les striders arrivent. "
		"ep_02.mag_tutor_darelaunch02" = "<font color=\"rgb(209,178,178)\">Un seul d'entre eux pourrait réduire notre fusée en miettes. "
		"ep_02.mag_tutor_darelaunch03" = "<font color=\"rgb(209,178,178)\">Pas de lancement tant que tous les striders ne sont pas détruits. "
		"ep_02.mag_tutor_debacle" = "<font color=\"rgb(209,178,178)\">Oh, Freeman! Si vous réussissez, je pourrai peut-être vous pardonner le fiasco de Black Mesa. Vous voyez ce que je veux dire... cette histoire de plat au micro-ondes. "
		"ep_02.mag_tutor_debacle_dist" = "<font color=\"rgb(209,178,178)\">Oh, Freeman! Si vous réussissez, je pourrai peut-être vous pardonner le fiasco de Black Mesa. Vous voyez ce que je veux dire... cette histoire de plat au micro-ondes. "
		"ep_02.mag_tutor_exprop" = "<font color=\"rgb(209,178,178)\">Je propose de donner la combi CEH au Dr Mossman. Peut-être qu'on va m'écouter, maintenant. "
		"ep_02.mag_tutor_fartarget" = "<font color=\"rgb(209,178,178)\">Uriah, envoyez la cible tout au bout des rails. "
		"ep_02.mag_tutor_figuratively" = "<font color=\"rgb(209,178,178)\">Quand je disais qu'avec le dispositif Magnusson, les striders se détruiraient tout seuls, c'était une image. "
		"ep_02.mag_tutor_finally" = "<font color=\"rgb(209,178,178)\">Enfin... "
		"ep_02.mag_tutor_firearm" = "<font color=\"rgb(209,178,178)\">Bien. Maintenant, choisissez une arme à feu et tirez sur le dispositif. "
		"ep_02.mag_tutor_fragile" = "<font color=\"rgb(209,178,178)\">Comme vous pouvez le voir, le Magnusson est une arme fragile. Il se détruit immédiatement s'il n'atteint pas son but. "
		"ep_02.mag_tutor_fueled" = "<font color=\"rgb(209,178,178)\">Le plein est fait, votre voiture est prête. "
		"ep_02.mag_tutor_getinpractice" = "<font color=\"rgb(209,178,178)\">Venez. Vous vous entraînerez tant que nous avons encore du temps. "
		"ep_02.mag_tutor_giveitathrow" = "<font color=\"rgb(209,178,178)\">Lancez-le. "
		"ep_02.mag_tutor_gravitygun01" = "<font color=\"rgb(209,178,178)\">Hmmm? Le pistolet anti-gravité? "
		"ep_02.mag_tutor_gravitygun02" = "<font color=\"rgb(209,178,178)\">C'est ce que ces tire-au-flanc appellent un pistolet anti-gravité. "
		"ep_02.mag_tutor_hadenough" = "<font color=\"rgb(209,178,178)\">C'est bon? "
		"ep_02.mag_tutor_homing" = "<font color=\"rgb(209,178,178)\">Ce dispositif possède une fonction à tête chercheuse... si vous êtes proche du strider, il parcourt la distance restante et se colle à la carapace. "
		"ep_02.mag_tutor_impaling" = "<font color=\"rgb(209,178,178)\">Ne vous en faites pas Freeman. Les jours de cet embrocheur d'humains qui a massacré vos amis sont désormais comptés. "
		"ep_02.mag_tutor_longasyoulike" = "<font color=\"rgb(209,178,178)\">Entraînez-vous tant que vous voulez. "
		"ep_02.mag_tutor_looklively" = "<font color=\"rgb(209,178,178)\">Remuez-vous là-dedans. Allumez le port de distribution. "
		"ep_02.mag_tutor_magdevice01" = "<font color=\"rgb(209,178,178)\">Il s'agit du dispositif Magnusson. "
		"ep_02.mag_tutor_magdevice02" = "<font color=\"rgb(209,178,178)\">Ce n'est pas moi qui ai choisi le nom, mais il semble plaire au personnel. "
		"ep_02.mag_tutor_magnif" = "<font color=\"rgb(209,178,178)\">Magnifique dispositif, n'est-ce pas? "
		"ep_02.mag_tutor_miss01" = "<font color=\"rgb(209,178,178)\">Manqué. "
		"ep_02.mag_tutor_miss02" = "<font color=\"rgb(209,178,178)\">Manqué! "
		"ep_02.mag_tutor_miss03" = "<font color=\"rgb(209,178,178)\">Manqué! "
		"ep_02.mag_tutor_moveon" = "<font color=\"rgb(209,178,178)\">Essayons quelque chose de plus difficile. "
		"ep_02.mag_tutor_noisaidcarap" = "<font color=\"rgb(209,178,178)\">Non, je vous ai dit la... carapace! "
		"ep_02.mag_tutor_notshot" = "<font color=\"rgb(209,178,178)\">Vous avez démontré ce qui se passe lorsqu'on ne tire pas sur le dispositif. Tirez dessus maintenant. "
		"ep_02.mag_tutor_nottoohard01" = "<font color=\"rgb(209,178,178)\">Et voilà. "
		"ep_02.mag_tutor_nottoohard02" = "<font color=\"rgb(209,178,178)\">C'est du gâteau à cette distance. Mais c'est déjà plus difficile quand le strider avance et vous tire dessus. "
		"ep_02.mag_tutor_onedevice01" = "<font color=\"rgb(209,178,178)\">Un dispositif à la fois suffit, Freeman. "
		"ep_02.mag_tutor_onedevice02" = "<font color=\"rgb(209,178,178)\">Ne les gaspillez pas. Chacun d'eux est une véritable oeuvre d'art."
		"ep_02.mag_tutor_outinfield" = "<font color=\"rgb(209,178,178)\">Bon. Sur le terrain, vous disposerez de tous les dispositifs Magnusson nécessaires via des ports de distribution comme celui-ci. "
		"ep_02.mag_tutor_overhere" = "<font color=\"rgb(209,178,178)\">Passez me voir quand vous serez prêt à partir. "
		"ep_02.mag_tutor_perfect" = "<font color=\"rgb(209,178,178)\">Très honorable. "
		"ep_02.mag_tutor_rdu01" = "<font color=\"rgb(209,178,178)\">Il s'agit d'une bombe collante, bien plus élaborée que cette définition ne le laisse entendre. "
		"ep_02.mag_tutor_rdu02" = "<font color=\"rgb(209,178,178)\">Il vous suffit de lancer le dispositif sur la carapace du strider, puis de le faire exploser. "
		"ep_02.mag_tutor_rdu03" = "<font color=\"rgb(209,178,178)\">J'ai eu du mal à mettre au point le dispositif de lancement, mais... votre manipulateur de champs énergétiques point zéro devrait résoudre le problème. "
		"ep_02.mag_tutor_rocketsci" = "<font color=\"rgb(209,178,178)\">Pas besoin d'être un génie là... Ça, c'est plus mon domaine pour être honnête. Il suffit de tirer sur le dispositif. "
		"ep_02.mag_tutor_settarget" = "<font color=\"rgb(209,178,178)\">Uriah, préparez la cible pour une courte distance. "
		"ep_02.mag_tutor_shell" = "<font color=\"rgb(209,178,178)\">Bon sang. «La carapace», vous savez ce que ça veut dire? Visez-la donc! "
		"ep_02.mag_tutor_shootthemagdev" = "<font color=\"rgb(209,178,178)\">Tirez- sur-le Magnusson. Magnusson! "
		"ep_02.mag_tutor_squander" = "<font color=\"rgb(209,178,178)\">Ne me faites pas douter de vous... et ne gaspillez pas mes Magnussons! "
		"ep_02.mag_tutor_takeoutdevice" = "<font color=\"rgb(209,178,178)\">Prenez un dispositif dans le distributeur. "
		"ep_02.mag_tutor_takeyourtime" = "<font color=\"rgb(209,178,178)\">Les unités du Cartel sont presque au-dessus de nous. Mais allez-y... prenez votre temps. "
		"ep_02.mag_tutor_thatsright" = "<font color=\"rgb(209,178,178)\">Très bien. "
		"ep_02.mag_tutor_thereuare" = "<font color=\"rgb(209,178,178)\">Et voilà."
		"ep_02.mag_tutor_timeforrealthing" = "<font color=\"rgb(209,178,178)\">Allez-y. On passe aux choses sérieuses. "
		"ep_02.mag_tutor_tossatbody" = "<font color=\"rgb(209,178,178)\">Très bien. Maintenant, jetez-le sur la coque du strider. "
		"ep_02.mag_tutor_unless" = "<font color=\"rgb(209,178,178)\">Eh bien, je crois que nous avons fait le tour... "
		"ep_02.mag_tutor_verywell" = "<font color=\"rgb(209,178,178)\">Très bien, Freeman. Essayez-le maintenant. "
		"ep_02.mag_tutor_wanttousegravgun" = "<font color=\"rgb(209,178,178)\">Utilisez votre pistolet anti-gravité pour le lancer. "
		"ep_02.mag_tutor_welldone" = "<font color=\"rgb(209,178,178)\">Pas mal. "
		"ep_02.mag_tutor_wearedoomed" = "<font color=\"rgb(209,178,178)\">Nous sommes perdus. "
		"MISSING" = "<font color=\"rgb(188,241,174)\">Ennemi indigne!"
		"ep_02.mirt_battle_anomalies01" = "<i>Mouvements anormaux de troupes détectés...  "
		"ep_02.mirt_battle_anomalies02" = "<i>J'arrive pas à les cibler.   C'est peut-être, euh..."
		"ep_02.mirt_battle_anomalies03" = "<i>Bon, restez à l'écoute."
		"ep_02.mirt_battle_keepalert" = "<i>Restez vigilant."
		"ep_02.mirt_battle_northbreach" = "<i>Votre attention! Brèche périmètre nord! Un strider s'approche, il vient de la zone des grues!"
		"ep_02.mirt_battle_periclear" = "<i>Le périmètre est libre. Aucun signal d'incursion."
		"ep_02.mirt_brief_keepyoucurrent01" = "Je reste ici pour surveiller et envoyer des mises à jour. "
		"ep_02.mirt_brief_keepyoucurrent02" = "Bonne chance!"
		"ep_02.mirt_brief_mapquicklook01" = "Regardez cette carte. "
		"ep_02.mirt_brief_mapquicklook02" = "Nous sommes ici, tout au sud de la vallée. "
		"ep_02.mirt_brief_mapquicklook03" = "Le reste de l'équipe est au nord près de l'ancienne scierie, là. "
		"ep_02.mirt_brief_mapquicklook04" = "Mettez cap au nord et ils vous brieferont sur les plans d'attaque."
		"ep_02.mirt_brief_overhere01" = "Le Dr Freeman, par ici! "
		"ep_02.mirt_brief_overhere02" = "J'ai pris quelques libertés avec votre voiture."
		"ep_02.mirt_brief_ports01" = "J'ai bidouillé votre radar pour faire apparaître le Cartel en rouge sur le tableau de bord. "
		"ep_02.mirt_brief_ports02" = "En plus, il envoie un signal à votre combi CEH, si vous êtes loin de la voiture. "
		"ep_02.mirt_brief_ports03" = "Ne me remerciez pas."
		"ep_02.mirt_brief_yanktrunk01" = "Venez voir."
		"ep_02.mirt_brief_yanktrunk02" = "J'ai ajouté un rack à l'arrière pour les Magnusson."
		"ep_02.mirt_post_waytogo01" = "Bien joué, Freeman! Le Cartel se replie. "
		"ep_02.mirt_post_waytogo02" = "Je ne dirais pas qu'il se débine, mais c'est un bon début!"
		"ep_02.mirt_silo_dogpatrol" = "Ça vous dérange si on laisse Chien ici?"
		"ep_02.mirt_silo_eliknows01" = "Eli ne sait pas que vous êtes là."
		"ep_02.mirt_silo_eliknows02" = "Il est dans l'unité d'accès au silo 1. C'est par ici."
		"ep_02.mirt_silo_overhere" = "Alyx ! Dr Freeman ! Vous avez réussi."
		"ep_02.mirt_silo_trouble01" = "Oui, on a entendu que vous avez eu des soucis là-bas. "
		"ep_02.mirt_silo_trouble02" = "Le Cartel essaye de rentrer par la grande porte. "
		"ep_02.mirt_silo_trouble03" = "Ça leur a servi de leçon. "
		"ep_02.mirt_silo_walk" = "OK, Chien. On va se promener!"
		"ep_02.over_barn" = "<font color=\"rgb(255,73,24)\"><i>VOIX MILICE: ALERTE VITALE. UNITES AUTONOMES SUBSUMEES. CONFORMITE OBLIGATOIRE AVEC TOUS PRINCIPES DE LOI D'ASSISTANCE D'ALERTE. AJUSTEMENT NIVEAU MENACE. SONDER. ELIMINER."
		"ep_02.over_camp" = "<font color=\"rgb(255,73,24)\"><i>VOIX MILICE: NETTOYAGE SECTEUR EN COURS. BIOTIQUES CONFIRMES. CONTINUER NETTOYAGE SURFACE SECTEUR. CONFORMISATION A DISTANCE. EXTERMINER. CHERCHER EMPREINTE SIGNATURE PASSIVE. MANDATER RESTRICTIONS DE SOUS-NIVEAU."
		"ep_02.over_inne" = "<font color=\"rgb(255,73,24)\"><i>VOIX MILICE: ALERTE. ANTI-CITOYEN UN ENGAGE. SOUS-PRINCIPAL VANCE ENGAGE.   ELIMINER. MANDATER SUPPRESSION EMPREINTE SIGNATURE ACTIVE. CAUTERISER ET ELIMINER."
		"ep_02.over_vista" = "<font color=\"rgb(255,73,24)\"><i>VOIX MILICE: TOUTES UNITES AUTONOMES: ACCEPTER ASSIMILATION SECTEUR OBLIGATOIRE. RESSERREMENT COORDONNE EN COURS. DEBRIDER ET CAUTERISER. ENTREE PHASE NEUF. CONFORMITE AMELIOREE. DEPLOYER CONTRÔLE D'ALERTE ET SURVEILLANCE. SOUMETTRE ET SE SUBSUMER."
		"ep_02.cit_loudspeaker_01" = "<i>Un strider arrive par les grues."
		"ep_02.cit_loudspeaker_02" = "<i>Strider à la scierie."
		"ep_02.cit_loudspeaker_03" = "<i>Un autre strider se dirige vers la scierie."
		"ep_02.cit_loudspeaker_04" = "<i>Un strider a été repéré près des grues."
		"ep_02.cit_loudspeaker_05" = "<i>Un autre strider se dirige vers les ruines de la scierie."
		"ep_02.cit_loudspeaker_06" = "<i>Un strider arrive en provenance du château d'eau."
		"ep_02.cit_loudspeaker_07" = "<i>Strider repéré près des grues."
		"ep_02.cit_loudspeaker_08" = "<i>Un autre strider venant du château d'eau."
		"ep_02.cit_loudspeaker_09" = "<i>Un strider arrive du secteur des grues."
		"ep_02.cit_loudspeaker_10" = "<i>Maintenant, il y en a un à la scierie."
		"ep_02.cit_loudspeaker_11" = "<i>Il en sort de partout. Strider repéré au château d'eau."
		"ep_02.cit_loudspeaker_12" = "<i>Du nerf, y a encore du boulot. Un autre strider a été localisé à la scierie."
		"ep_02.cit_loudspeaker_13" = "<i>Un autre près des grues!"
		"ep_02.cit_loudspeaker_atbase" = "<i>Strider au silo! Strider à la base!"
		"ep_02.cit_loudspeaker_closetobase" = "<i>Alerte! Un strider s'approche de la base!"
		"ep_02.cit_loudspeaker_dropships" = "<i>On dirait que c'était le dernier... Attendez! Tout le monde en position! Des vaisseaux amènent un nouveau bataillon de striders! Une minute avant contact. A vos postes! Il faut frapper fort si on veut en finir."
		"ep_02.cit_loudspeaker_failure01" = "<i>Non!"
		"ep_02.cit_loudspeaker_failure02" = "<i>Oh mon Dieu !"
		"ep_02.cit_loudspeaker_failure03" = "<i>Le bunkerest touché!"
		"ep_02.cit_loudspeaker_failure04" = "<i>La fusée est détruite!"
		"ep_02.cit_loudspeaker_failure05" = "<i>On est foutus..."
		"ep_02.cit_loudspeaker_failure06" = "<i>Oh, c'est pas vrai, noooon..."
		"ep_02.cit_loudspeaker_failure07" = "<i>Bon sang."
		"ep_02.cit_loudspeaker_failure08" = "<i>Oh, c'est la fin."
		"ep_02.cit_loudspeaker_failure09" = "<i>Désolé Dr. Magnusson. Nous avons échoué."
		"ep_02.cit_loudspeaker_failure10" = "<i>Bon sang... Magnusson va être furax!"
		"ep_02.cit_loudspeaker_fewleft" = "<i>Continuez comme ça! Il en reste plus beaucoup!"
		"ep_02.cit_loudspeaker_hereyougo" = "<i>Je crois... euh, à vos ordres, Dr. Magnusson. Et voilà."
		"ep_02.cit_loudspeaker_packs" = "<i>Ouvrez l'oeil. Il y a des chasseurs avec les striders. Ils se déplacent en meutes!"
		"ep_02.cit_loudspeaker_returntobase01" = "<i>Des striders  Aux abords du silo! "
		"ep_02.cit_loudspeaker_returntobase02" = "<i>Repliez-vous et défendez le silo!"
		"ep_02.cit_loudspeaker_returntobase03" = "<i>Ils sont beaucoup trop près du silo!"
		"ep_02.cit_loudspeaker_returntobase04" = "<i>Il nous faut du renfort au silo!"
		"ep_02.cit_loudspeaker_returntobase05" = "<i>Ils approchent du silo! Repoussez-les!"
		"ep_02.cit_loudspeaker_returntobase06" = "<i>Repliez-vous! Tout le monde à la base! Protégez le silo!"
		"ep_02.cit_loudspeaker_returntobase07" = "<i>A tout le personnel! A tout le personnel! Rendez-vous à la base! Le silo est pris d'assaut!"
		"ep_02.cit_loudspeaker_returntobase08" = "<i>C'est l'alarme de la base! Repliez-vous et défendez le silo!"
		"ep_02.cit_loudspeaker_victory" = "<i>Votre attention! Votre attention! Les striders ont été éliminés! Retour immédiat à la base pour tout le personnel! Je répète. Retour immédiat à la base pour tout le personnel!"
		"ep_02.cit_loudspeaker_wedidit" = "<i>On a réussi! On les a repoussés! Bien joué les gars!"
		"ep_02.cit_loudspeakeralt_05" = "<i>Un autre strider aux abords des ruines de la scierie."
		"ep_02.cit_tothesawmill_01" = "La scierie est au bout de la vallée!"
		"ep_02.cit_tothesawmill_02" = "La scierie est par là. Ils vous attendent."
		"ep_02.cit_tothesawmill_03" = "Ils vous attendent à la scierie. C'est par là!"
		"ep_02.cit_tothesawmill_04" = "Si vous cherchez la scierie, c'est par là!"
		"ep_02.reb_1stwave01" = "Ça y est? C'est fini? Ahhh, dites-moi qu'il n'y en a pas d'autres..."
		"ep_02.reb_1stwave02" = "Je crois bien que c'en est fini du Cartel! On aurait dû faire ça depuis longtemps!"
		"ep_02.reb_1stwave03" = "Ça m'étonnerait qu'ils abandonnent si facilement."
		"ep_02.reb_1stwave04" = "Ça y est, on a gagné! OUUUHHH! "
		"ep_02.reb_1stwave05" = "Bon, je crois qu'il va falloir reconstruire la scierie."
		"ep_02.reb_1stwave06" = "Je suis crevé."
		"ep_02.reb_1stwave07" = "Bon, on se retrouve à la base?"
		"ep_02.reb_1stwave08" = "[haletant] Ça y est?"
		"ep_02.reb_1stwave09" = "Ça peut pas être fini..."
		"ep_02.reb_1stwave10" = "Je ne crois pas que ce soit fini."
		"ep_02.reb_1stwave11" = "Restez attentif. Ce n'est pas fini."
		"ep_02.reb_altfireprompt01" = "Les chasseurs en prennent plein la tronche avec les munitions spéciales AR2."
		"ep_02.reb_altfireprompt02" = "Avec ces munitions spéciales AR2, une balle suffit pour descendre un chasseur!"
		"ep_02.reb_altfireprompt03" = "Balancez-leur ces munitions à impulsions, Freeman!"
		"ep_02.reb_altfireprompt04" = "Tir secondaire, Freeman! Tir secondaire!"
		"ep_02.reb_ammocall01" = "Il y a des roquettes par là!"
		"ep_02.reb_ammocall02" = "Des Magnusson par là, Freeman!"
		"ep_02.reb_ammocall03" = "D'autres munitions par là!"
		"ep_02.reb_basedestroyed01" = "Nooooooooon!"
		"ep_02.reb_basedestroyed02" = "Oh, c'est pas vrai."
		"ep_02.reb_basedestroyed03" = "La roquette! On est morts!"
		"ep_02.reb_basedestroyed04" = "On est foutus!"
		"ep_02.reb_basesaved01" = "On a réussi!"
		"ep_02.reb_basesaved02" = "Merci du coup de main, Freeman!"
		"ep_02.reb_basesaved03" = "J'ai réussi! J'ai sauvé la base! Je suis un héros! Oh et le Dr. Freeman aussi!"
		"ep_02.reb_basesaved04" = "Beau travail, Freeman!"
		"ep_02.reb_basesaved05" = "Par ici, Freeman!"
		"ep_02.reb_basesaved06" = "Le voilà! Voilà Freeman!"
		"ep_02.reb_basesaved07" = "Free-man! Free-man! Free-man!"
		"ep_02.reb_basesaved08" = "Vous vous en êtes encore tiré, Doc."
		"ep_02.reb_battle_needyourcar01" = "Vous allez avoir besoin de votre super bagnole, Freeman!"
		"ep_02.reb_battle_needyourcar02" = "Oubliez pas la voiture! Remarquez, ça risque pas!"
		"ep_02.reb_battle_needyourcar03" = "Prenez votre voiture Freeman!"
		"ep_02.reb_battle_needyourcar04" = "Retournez à la voiture!"
		"ep_02.reb_battle_needyourcar05" = "Mais pourquoi vous marchez? Utilisez la voiture!"
		"ep_02.reb_buildingexplo01" = "Eh, j'habitais ici moi!"
		"ep_02.reb_buildingexplo02" = "Home sweet... et merde!"
		"ep_02.reb_buildingexplo03" = "Ok, maintenant ça devient personnel!"
		"ep_02.reb_buildingexplo04" = "Eh, y avait des oeuvres d'art là-dedans!"
		"ep_02.reb_buildingexplo05" = "C'est pas vrai!"
		"ep_02.reb_buildingexplo06" = "Merde!"
		"ep_02.reb_buildingexplo07" = "Il n'y avait personne là-dedans, crétin!"
		"ep_02.reb_calmplususe_01" = "Pas maintenant, Doc."
		"ep_02.reb_calmplususe_02" = "On verra ça plus tard, Doc."
		"ep_02.reb_calmplususe_03" = "Eh, allez."
		"ep_02.reb_calmplususe_04" = "Je suis occupé pour le moment, Doc."
		"ep_02.reb_cannon_thanks" = "Merci d'avoir fait le ménage, Freeman! Du beau boulot!"
		"ep_02.reb_chop_alyxinside01" = "Eh Doc, elle est là."
		"ep_02.reb_chop_alyxinside02" = "La voiture est prête, Freeman. Alyx vous attend à l'intérieur."
		"ep_02.reb_chop_alyxinside03" = "Alyx est juste là, Dr. Freeman."
		"ep_02.reb_chop_cheers01" = "[cri de joie]"
		"ep_02.reb_chop_cheers02" = "[cri de joie]"
		"ep_02.reb_chop_cheers03" = "[cri de joie]"
		"ep_02.reb_chop_chopper_hint01" = "Nos armes ne font pas le poids."
		"ep_02.reb_chop_chopper_hint02" = "Réessayez, on ne sait jamais."
		"ep_02.reb_chop_chopper_hint03" = "Ces mines font de sacrés dégâts."
		"ep_02.reb_chop_chopper_hint04" = "Débarrassez-nous de ces mines!"
		"ep_02.reb_chop_chopper_hint05" = "Foutues mines!"
		"ep_02.reb_chop_chopper_hint06" = "Laissez Freeman se charger des mines!"
		"ep_02.reb_chop_chopper_hint07" = "Freeman, vous avez de quoi abattre un hélico?"
		"ep_02.reb_chop_chopper_hint08" = "Essayez le pistolet anti-gravité!"
		"ep_02.reb_chop_chopper_hint09" = "Eh Doc, essayez de renvoyer ces mines sur l'hélico!"
		"ep_02.reb_chop_goodgoing" = "Bien joué!"
		"ep_02.reb_chop_nowonder" = "Eh, pas étonnant: c'est Gordon Freeman! C'est bon,"
		"ep_02.reb_chop_roadclear" = "C'est bon, la voie est libre!"
		"ep_02.reb_combatuse01" = "Je suis occupé là, Doc."
		"ep_02.reb_combatuse02" = "Pas le temps!"
		"ep_02.reb_combatuse03" = "Pas maintenant!"
		"ep_02.reb_complaint01" = "Le Dr surnommé Dr. Magnuisance, hé hé. C'est pour ça qu'il m'a envoyé ici..."
		"ep_02.reb_complaint02" = "On les a baptisés Magnusson parce qu'il suffit d'un rien pour qu'ils explosent."
		"ep_02.reb_complaint03" = "Eh, ça pourrait être pire. Là-dedans, on en prendrait plein la tronche."
		"ep_02.reb_complaint04" = "Pour vous, c'est ça l'enfer? Vous devriez passer une journée avec Magnusson. "
		"ep_02.reb_complaint05" = "Des fois, je m'amuse à faire péter les plombs à Magnusson. Ok, ok, c'est pas super dur."
		"ep_02.reb_healthcall01" = "Y a d'autres remontants ici!"
		"ep_02.reb_healthcall02" = "Des remontants!"
		"ep_02.reb_healthcall03" = "On va stocker un maximum de remontants ici."
		"ep_02.reb_healthcall04" = "On va stocker un maximum de remontants aux avant-postes."
		"ep_02.reb_hunters01" = "Des chasseurs!"
		"ep_02.reb_hunters02" = "Des chasseurs!"
		"ep_02.reb_hunters03" = "C'est comme des striders... mais en plus petit."
		"ep_02.reb_hunters04" = "Oh non, des CHASSEURS!"
		"ep_02.reb_hunters05" = "Bon sang. Des chasseurs!"
		"ep_02.reb_hunters06" = "Faites gaffe!"
		"ep_02.reb_hunters07" = "Des chasseurs!"
		"ep_02.reb_huntprompt01" = "Occupez-vous d'abord des chasseurs!"
		"ep_02.reb_huntprompt02" = "Jetez un truc sur les chasseurs!"
		"ep_02.reb_huntprompt03" = "Balancez-leur une bûche!"
		"ep_02.reb_huntprompt04" = "Un bon coup de radiateur, ça vous calme un chasseur!"
		"ep_02.reb_huntprompt05" = "Une fois, en ville, j'ai vu un type se faire un chasseur à mains nues."
		"ep_02.reb_idles01" = "Bon... On fait quoi maintenant?"
		"ep_02.reb_idles02" = "Et qu'est-ce qu'on fait, maintenant?"
		"ep_02.reb_idles03" = "Je savais que ça finirait comme ça."
		"ep_02.reb_idles04" = "Et c'est là que tout bascule, hein Freeman?"
		"ep_02.reb_idles05" = "Dites-moi tout, Doc. Les nouvelles sont mauvaises?"
		"ep_02.reb_idles06" = "Je me jetterais dans le premier portail venu! J'en peux plus de cet endroit."
		"ep_02.reb_idles07" = "Faut se faire le Cartel, Doc. On va les renvoyer d'où ils viennent. Qu'est-ce que vous en dites?"
		"ep_02.reb_idles08" = "Qu'est-ce que je ne donnerais pas pour une douche! J'irais même jusqu'à vous livrer au Cartel! Je plaisante, bien sûr."
		"ep_02.reb_idles09" = "Un conseil, ne touchez pas aux rations K. Ils mettent un truc dedans qui vous fait oublier que le champ de suppression est coupé."
		"ep_02.reb_idles10" = "Ça faisait une paye. En fait... on se connaît pas."
		"ep_02.reb_idles11" = "Le Dr Freeman. Je n'ai pas vraiment aimé ce que vous avez fait à Black Mesa, mais vous vous êtes bien rattrapé ces derniers temps. "
		"ep_02.reb_idles13" = "Magnusson nous a dit d'obéir à tous vos ordres."
		"ep_02.reb_idles14" = "Black Mesa vous manque? Moi, oui. Pourtant j'y suis jamais allé."
		"ep_02.reb_idles15" = "C'est l'enfer ici... Mais au moins on n'est pas en Amérique du Nord!"
		"ep_02.reb_idles16" = "Je crois que je finirais par m'habituer à cet endroit."
		"ep_02.reb_lastwave01" = "Là c'est clair. On est morts."
		"ep_02.reb_lastwave02" = "Protégez la base! Les laissez pas s'approcher!"
		"ep_02.reb_lastwave03" = "Ils ont rabattu tous les striders du monde ou quoi?"
		"ep_02.reb_lastwave04" = "Ah Freeman. Vous avez vu ça?"
		"ep_02.reb_lastwave05" = "Ils les amènent par les airs. Super..."
		"ep_02.reb_lastwave06" = "Des vaisseaux en approche!"
		"ep_02.reb_lastwave07" = "Des vaisseaux!"
		"ep_02.reb_lastwave08" = "Les revoilà!"
		"ep_02.reb_lastwave09" = "Ils arrivent!"
		"ep_02.reb_lastwave10" = "Ils n'ont vraiment aucune pitié!"
		"ep_02.reb_lastwaveannounced01" = "Je savais que ça allait pas durer..."
		"ep_02.reb_lastwaveannounced02" = "Rrrah. Ils s'arrêtent jamais?!"
		"ep_02.reb_lastwaveannounced03" = "Mais Oh, zut. vrai!"
		"ep_02.reb_lastwaveannounced04" = "[à lui-même] OK, respire. Ça va aller."
		"ep_02.reb_lastwaveannounced05" = "[à lui-même] Tu vas t'en sortir. Tu vas t'en sortir."
		"ep_02.reb_lastwaveannounced06" = "Il va falloir un sacré miracle pour qu'on s'en tire."
		"ep_02.reb_lastwaveannounced07" = "Ces salopards du Cartel laissent jamais tomber..."
		"ep_02.reb_lastwaveannounced08" = "Oh-oh..."
		"ep_02.reb_lastwaveannounced09" = "Pourvu que la fusée fonctionne..."
		"ep_02.reb_lastwaveannounced10" = "Franchement, j'hallucine là."
		"ep_02.reb_lastwaveannounced11" = "J'y crois pas."
		"ep_02.reb_lull01" = "C'est bien calme... trop calme."
		"ep_02.reb_lull02" = "C'était trop facile."
		"ep_02.reb_lull03" = "Je le sens paaaaas du tout ce coup-là."
		"ep_02.reb_lull04" = "Freeman, c'est fini?"
		"ep_02.reb_lull05" = "Merci du coup de main, Freeman."
		"ep_02.reb_lull06" = "Qu'est-ce que vous en dites Freeman? Ils vont revenir?"
		"ep_02.reb_lull07" = "Vous avez assuré, Doc."
		"ep_02.reb_lull08" = "Vous êtes un vrai héros, Doc."
		"ep_02.reb_magblasted01" = "Accrochez-vous Freeman! Vous tenez le bon bout!"
		"ep_02.reb_magblasted02" = "Si j'avais un pistolet anti-gravité, je vous filerais un coup de main, Doc!"
		"ep_02.reb_magblasted03" = "Descendez les chasseurs!"
		"ep_02.reb_magblasted04" = "Saloperies de chasseurs..."
		"ep_02.reb_magblasted05" = "Visez les chasseurs!"
		"ep_02.reb_magblasted06" = "On dirait qu'ils aiment pas ça, les Magnusson!"
		"ep_02.reb_magblasted07" = "Je hais ces trucs!"
		"ep_02.reb_magblasted08" = "Ce chasseur visait le Magnusson!"
		"ep_02.reb_magblasted09" = "Y en a marre de ces charognes!"
		"ep_02.reb_packs01" = "Ils se déplacent en meutes!"
		"ep_02.reb_packs02" = "Les striders et les chasseurs bossent ensemble."
		"ep_02.reb_packs03" = "Faites gaffe aux chasseurs!"
		"ep_02.reb_packs04" = "Les chasseurs nous donnent du fil à retordre."
		"ep_02.reb_prepare_battle_01" = "Oh là, c'est parti!"
		"ep_02.reb_prepare_battle_02" = "Tout le monde est prêt?"
		"ep_02.reb_prepare_battle_03" = "Il faut absolument les arrêter!"
		"ep_02.reb_prepare_battle_04" = "Bonne chance, les gars!"
		"ep_02.reb_prepare_battle_05" = "Rappelez-vous: il faut faire diversion pendant que Freeman s'occupe d'eux!"
		"ep_02.reb_prepare_battle_06" = "Où est le château d'eau déjà?"
		"ep_02.reb_prepare_battle_07" = "Oh là là, je n'aime vraiment pas ça!"
		"ep_02.reb_prepare_battle_08" = "Restez concentrés!"
		"ep_02.reb_prepare_battle_09" = "Mettez-vous à l'abri et ouvrez le feu! Freeman se chargera du sale boulot."
		"ep_02.reb_prepare_battle_10" = "Freeman se chargera du sale boulot."
		"ep_02.reb_runover01" = "Bien joué, Freeman!"
		"ep_02.reb_runover02" = "Prends ça dans les dents!"
		"ep_02.reb_runover03" = "Saletés de trucs à trois pattes!"
		"ep_02.reb_runover04" = "Waouh, ça c'était cool!"
		"ep_02.reb_runover05" = "[Rire moqueur]"
		"ep_02.reb_runover06" = "Et paf!"
		"ep_02.reb_runover07" = "Celui-là ne se relèvera pas."
		"ep_02.reb_runover08" = "Repassez-lui dessus!"
		"ep_02.reb_runover09" = "Prends ça, abruti!"
		"ep_02.reb_runover10" = "Hé, hé!"
		"ep_02.reb_sawmillexplo01" = "Oh non, pas la scierie! Ils n'ont donc aucun respect?"
