{
	format_version = 0
	language = "french"
	tokens = {
	
		// Portal 2
	
		"announcer.a4_recapture01" = "<font color=\"rgb(250,231,181)\">Annonceur : Explosion imminente. Veuillez évacuer immédiatement le centre."
		"announcer.a4_recapture03" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte. Coeur du réacteur à température critique."
		"announcer.a4_recapture04" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte: surchauffe du coeur. Fusion nucléaire imminente."
		"announcer.bb_corruption03" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte: coeur corrompu à 50%."
		"announcer.bb_corruption04" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte: coeur corrompu à 75%."
		"announcer.bb_corruption06" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte: coeur corrompu à 100%."
		"announcer.bb_neurotoxin01" = "<font color=\"rgb(250,231,181)\">Annonceur : Niveau de neurotoxines opérationnel dans cinq minutes."
		"announcer.bb_neurotoxin06" = "<font color=\"rgb(250,231,181)\">Annonceur : Ventilation défaillante: neurotoxines désactivées."
		"announcer.bb_reactor02" = "<font color=\"rgb(250,231,181)\">Annonceur : Explosion du réacteur dans quatre minutes."
		"announcer.bb_reactor06" = "<font color=\"rgb(250,231,181)\">Annonceur : Décompte d'explosion du réacteur détruit."
		"announcer.bb_reactor07" = "<font color=\"rgb(250,231,181)\">Annonceur : Lancement du Protocole préventif pour suspicion d'explosion du réacteur: ce centre s'autodétruira dans deux minutes."
		"announcer.bb_stalemate01" = "<font color=\"rgb(250,231,181)\">Annonceur : Remplacement manuel du coeur requis."
		"announcer.bb_stalemate02" = "<font color=\"rgb(250,231,181)\">Annonceur : Coeur de substitution: confirmer le démarrage?"
		"announcer.bb_stalemate03" = "<font color=\"rgb(250,231,181)\">Annonceur : Coeur corrompu: confirmer le démarrage?"
		"announcer.bb_stalemate04" = "<font color=\"rgb(250,231,181)\">Annonceur : Réponse vague considérée comme affirmative."
		"announcer.bb_stalemate05" = "<font color=\"rgb(250,231,181)\">Annonceur : Temporisation détectée."
		"announcer.bb_stalemate06" = "<font color=\"rgb(250,231,181)\">Annonceur : Incendie détecté dans l'Annexe de résolution des temporisations. Extinction."
		"announcer.bb_stalemate07" = "<font color=\"rgb(250,231,181)\">Annonceur : Détemporisateur qualifié: veuillez appuyer sur le bouton de résolution des temporisations."
		"announcer.carolyndeleted02" = "<font color=\"rgb(250,231,181)\">Annonceur : Caroline supprimée."
		"announcer.evacuationmisc01" = "<font color=\"rgb(250,231,181)\">Annonceur : Préparez-vous à l'évacuation d'urgence."
		"announcer.gladosbattle11" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte: coeur central corrompu à 80%."
		"announcer.gladosbattle12" = "<font color=\"rgb(250,231,181)\">Annonceur : Coeur de substitution détecté."
		"announcer.gladosbattle13" = "<font color=\"rgb(250,231,181)\">Annonceur : Pour lancer un transfert, placez un coeur de substitution dans le réceptacle."
		"announcer.gladosbattle14" = "<font color=\"rgb(250,231,181)\">Annonceur : Coeur de substitution accepté."
		"announcer.gladosbattle15" = "<font color=\"rgb(250,231,181)\">Annonceur : Coeur de substitution: démarrer la procédure?"
		"announcer.gladosbattle16" = "<font color=\"rgb(250,231,181)\">Annonceur : Coeur corrompu: démarrer la procédure?"
		"announcer.gladosbattle17" = "<font color=\"rgb(250,231,181)\">Annonceur : Temporisation détectée. La procédure de transfert ne peut pas continuer."
		"announcer.gladosbattle18" = "<font color=\"rgb(250,231,181)\">Annonceur : ... sauf si un détemporisateur qualifié est en mesure d'appuyer sur le bouton de résolution."
		"announcer.gladosbattle19" = "<font color=\"rgb(250,231,181)\">Annonceur : Temporisation résolue."
		"announcer.gladosbattle20" = "<font color=\"rgb(250,231,181)\">Annonceur : Veuillez regagner la baie de transfert de coeur."
		"announcer.good01" = "<font color=\"rgb(250,231,181)\">Annonceur : Bien!"
		"announcer.good02" = "<font color=\"rgb(250,231,181)\">Annonceur : Bien!"
		"announcer.mp_coop_wall_5security03" = "<font color=\"rgb(250,231,181)\">Annonceur : Code de sécurité du jour: 5, 33, 41, 18."
		"announcer.mp_hub_return01" = "<font color=\"rgb(250,231,181)\">Annonceur : Bienvenue au Centre de Recherches en Intelligence Artificielle et Tests sur Organismes Raisonnés. Vous avez déverrouillé tous les parcours disponibles."
		"announcer.mp_hub_return02" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte! Tous les parcours de test sont disponibles."
		"announcer.mp_hub_return03" = "<font color=\"rgb(250,231,181)\">Annonceur : Vous avez réussi à revenir à la salle centrale. Félicitations. Vous pouvez à présent choisir tous les parcours précédemment effectués."
		"announcer.mp_hub_return04" = "<font color=\"rgb(250,231,181)\">Annonceur : Pour votre agrément, tous les tests sont disponibles et toutes les mesures de sécurité des salles de test ont été désactivées."
		"announcer.mp_hub_return05" = "<font color=\"rgb(250,231,181)\">Annonceur : Vous vous trouvez à nouveau dans la salle centrale. Tous les parcours sont disponibles. Vous êtes libre de les retester à l'infini."
		"announcer.mp_hub_return06" = "<font color=\"rgb(250,231,181)\">Annonceur : Merci d'avoir effectué les parcours de test. Si cette expérience vous a plu, nous vous invitons à refaire le parcours de votre choix."
		"announcer.mp_hub_return07" = "<font color=\"rgb(250,231,181)\">Annonceur : En effectuant tous les parcours de test, vous avez obtenu une accréditation de niveau C. Vous avez maintenant accès à tous les parcours ainsi qu'à trois des 176 toilettes d'Aperture Science."
		"announcer.openingcourtesy01" = "<font color=\"rgb(250,231,181)\">Annonceur : Bonjour. Votre cryostase a duré neuf neuf neuf neuf neuf... neuf neu- Ce message a pour but de vous informer que tous les sujets de test doivent quitter sans délai le centre d'enrichissement. [SON DIMINUE]"
		"announcer.openingexercise01" = "<font color=\"rgb(250,231,181)\">Annonceur : Bonjour. Votre cryostase a duré... CINQUANTE JOURS. Conformément aux lois nationales et fédérales, tous les candidats aux tests du centre de relaxation prolongée d'Aperture Science doivent être réveillés régulièrement pour effectuer des exercices physiques et mentaux."
		"announcer.openingexercise02" = "<font color=\"rgb(250,231,181)\">Annonceur : Vous allez entendre une sonnerie. Veuillez alors regarder le plafond. [BUZZER]"
		"announcer.openingexercise03" = "<font color=\"rgb(250,231,181)\">Annonceur : Bien. Vous allez entendre une sonnerie. Veuillez alors regarder le sol. [BUZZER]"
		"announcer.openingexercise04" = "<font color=\"rgb(250,231,181)\">Annonceur : Bien. La partie gymnastique de vos exercices physiques et mentaux est maintenant terminée."
		"announcer.openingexercise05" = "<font color=\"rgb(250,231,181)\">Annonceur : Un tableau encadré est accroché au mur. Veuillez vous placer devant."
		"announcer.openingexercise06" = "<font color=\"rgb(250,231,181)\">Annonceur : Ceci est de l'art. Vous allez entendre une sonnerie. Veuillez alors contempler l'art. [BUZZER]"
		"announcer.openingexercise07" = "<font color=\"rgb(250,231,181)\">Annonceur : Vos facultés mentales ont été ravivées par l'art. Si vous estimez que votre intellect est insuffisamment stimulé, veuillez écouter ce court extrait de musique classique."
		"announcer.openingexercise08" = "<font color=\"rgb(250,231,181)\">Annonceur : Bien. A présent, veuillez regagner votre lit."
		"announcer.openingsafeguards01" = "<font color=\"rgb(250,231,181)\">Annonceur : Systèmes de sécurité du réacteur dysfonctionnels. Veuillez vous préparer à la fusion du coeur du réacteur."
		"announcer.prehub06" = "<font color=\"rgb(250,231,181)\">Annonceur : Bonjour et bienvenue au centre d'enrichissement d'Aperture Science."
		"announcer.prehub08" = "<font color=\"rgb(250,231,181)\">Annonceur : Nous éprouvons actuellement des difficultés techniques dues à des circonstances potentiellement apocalyptiques indépendantes de notre volonté."
		"announcer.prehub09" = "<font color=\"rgb(250,231,181)\">Annonceur : Cependant, en vertu des protocoles d'urgence, les tests peuvent continuer. Ces messages préenregistrés sont destinés à vous fournir instructions et motivation, afin de continuer à servir la science même en cas de destruction de l'environnement ou de la civilisation."
		"announcer.prehub10" = "<font color=\"rgb(250,231,181)\">Annonceur : Le portail s'ouvrira et les tests d'urgence débuteront dans trois. Deux. Un."
		"announcer.prehub11" = "<font color=\"rgb(250,231,181)\">Annonceur : Les tests à base de cubes et de boutons demeurent une priorité, même face aux conditions adverses."
		"announcer.prehub12" = "<font color=\"rgb(250,231,181)\">Annonceur : Si lesdites conditions sont la conséquence de nos tests, sachez que ce cas de figure a peu de chances de se produire deux fois."
		"announcer.prehub17" = "<font color=\"rgb(250,231,181)\">Annonceur : Si vous êtes un non-employé ayant découvert ce centre parmi les ruines de la civilisation, bienvenue. Les tests sont l'avenir et l'avenir commence avec vous."
		"announcer.prehub18" = "<font color=\"rgb(250,231,181)\">Annonceur : Bravo pour votre découverte, être d'avenir! Cela étant, si l'avenir est peu susceptible de commencer avec vous suite à une tare mentale, un âge avancé ou une irradiation prononcée, veuillez regagner votre tribu primitive et envoyer une personne plus apte aux tests."
		"announcer.prehub19" = "<font color=\"rgb(250,231,181)\">Annonceur : En raison de difficultés techniques, votre environnement de test ne fera pas l'objet d'une supervision."
		"announcer.prehub20" = "<font color=\"rgb(250,231,181)\">Annonceur : Avant de retrouver un caisson de relaxation à l'issue des tests, veuillez prendre le temps d'en consigner les résultats. Un préposé de réintégration d'Aperture Science vous réveillera à des fins d'entretien une fois la civilisation reconstruite."
		"announcer.prehub27" = "<font color=\"rgb(250,231,181)\">Annonceur : Si vous sentez un liquide sur vos épaules, allongez-vous et exercez une pression continue sur vos tempes."
		"announcer.prehub28" = "<font color=\"rgb(250,231,181)\">Annonceur : Il s'agit d'un effet rare mais néanmoins connu: la Grille d'émancipation matérielle d'Aperture Science a simplement émancipé vos tympans."
		"announcer.prehub42" = "<font color=\"rgb(250,231,181)\">Annonceur : Le prochain test est très dangereux. Pour vous aider à rester calme face à une mort certaine, de la musique d'ambiance vous sera administrée dans trois. Deux. Un. [MUSIQUE D'AMBIANCE]"
		"announcer.prehub43" = "<font color=\"rgb(250,231,181)\">Annonceur : À l'heure de l'enregistrement, les lois fédérales nous imposent de vous informer du caractère mortel de ce prochain test et de vous rediriger vers un environnement de test plus sûr."
		"announcer.prehub44" = "<font color=\"rgb(250,231,181)\">Annonceur : Par souci de conformité avec ces agences maintenant disparues, nous allons diffuser à nouveau de la musique d'ambiance."
		"announcer.prehub46" = "<font color=\"rgb(250,231,181)\">Annonceur : Si la Terre est actuellement gouvernée par un animal, un nuage doué de conscience ou toute autre entité gouvernementale qui refuse ou est incapable d'entendre raison, le-BZZZT!"
		"announcer.sarcasmcore01" = "<font color=\"rgb(250,231,181)\">Annonceur : Diagnostic de sarcasme terminé."
		"announcer.sp_sabotage_factory13" = "<font color=\"rgb(250,231,181)\">Annonceur : Chaînes de rédemption des tourelles actives."
		"announcer.sp_sabotage_factory14" = "<font color=\"rgb(250,231,181)\">Annonceur : Veuillez ne pas solliciter les tourelles en chemin vers la rédemption."
		"announcer.sp_sabotage_factory15" = "<font color=\"rgb(250,231,181)\">Annonceur : Les chaînes de rédemption des tourelles ne sont pas un moyen de transport."
		"announcer.sp_sabotage_factory16" = "<font color=\"rgb(250,231,181)\">Annonceur : Chaîne de tourelles active. Entrez dans la salle avec précaution."
		"announcer.sp_sabotage_factory17" = "<font color=\"rgb(250,231,181)\">Annonceur : Évitez d'alerter les tourelles actives ou de vous faire cribler de balles."
		"announcer.sp_sabotage_factory18" = "<font color=\"rgb(250,231,181)\">Annonceur : Ceci est un environnement stérile; veuillez ne pas monter sur la chaîne de tourelles."
		"announcer.sp_sabotage_factory19" = "<font color=\"rgb(250,231,181)\">Annonceur : Ceci est un environnement stérile. Toute décontamination peut nuire à la rédemption des tourelles."
		"announcer.sp_sabotage_factory20" = "<font color=\"rgb(250,231,181)\">Annonceur : Test des tourelles opérationnelles en cours."
		"announcer.sp_sabotage_factory21" = "<font color=\"rgb(250,231,181)\">Annonceur : Test des tourelles dysfonctionnelles en cours."
		"announcer.sp_sabotage_factory22" = "<font color=\"rgb(250,231,181)\">Annonceur : Passerelles praticables durant le test des tourelles dysfonctionnelles."
		"announcer.sp_sabotage_factory23" = "<font color=\"rgb(250,231,181)\">Annonceur : Les tourelles dysfonctionnelles peuvent présenter un dysfonctionnement les rendant actives."
		"announcer.sp_sabotage_factory_line01" = "<font color=\"rgb(250,231,181)\"><low>Annonceur : Modèle"
		"announcer.sp_sabotage_factory_line02" = "<font color=\"rgb(250,231,181)\"><low>Annonceur : Réponse"
		"announcer.sp_sabotage_factory_line04" = "<font color=\"rgb(250,231,181)\">Annonceur : Nouveau modèle accepté."
		"announcer.sp_sabotage_factory_line05" = "<font color=\"rgb(250,231,181)\">Annonceur : Modèle manquant. Recours aux données mémoire."
		"announcer.sp_sabotage_implosion01" = "<font color=\"rgb(250,231,181)\">Annonceur : Alerte! Les neurotoxines ont atteint un niveau de pression dangereusement non mortel."
		"announcer.testchamber02" = "<font color=\"rgb(250,231,181)\">Annonceur : Si le centre d'enrichissement fait l'objet d'un bombardement de boules de feu, météorites ou autres corps spatiaux, évitez les zones dans lesquelles l'absence de protections antimétéorites ne constitue PAS un élément constitutif du test."
		"announcer.testchamber03" = "<font color=\"rgb(250,231,181)\">Annonceur : Bravo! Le centre d'enrichissement vous rappelle que malgré l'adversité, vous n'êtes pas seul. En effet, il suffit de 1,1 volt à nos pseudo-personnalités pour maintenir leur intégrité même dans des environnements apocalyptiques."
		"announcer.testchamber04" = "<font color=\"rgb(250,231,181)\">Annonceur : Afin d'assurer une alimentation suffisante pour les protocoles de test principaux, toutes les mesures de sécurité ont été désactivées. Le centre d'enrichissement respecte votre droit de réserve relatif à cette déclaration."
		"announcer.testchamber05" = "<font color=\"rgb(250,231,181)\">Annonceur : Certains tests d'urgence peuvent nécessiter une interaction prolongée avec des androïdes militaires mortels. Nous tenons à vous assurer que tous savent lire et ont reçu un exemplaire des Lois de la robotique à titre indicatif."
		"announcer.testchamber06" = "<font color=\"rgb(250,231,181)\">Annonceur : Bien. Si vous estimez qu'un androïde militaire mortel n'a pas respecté vos droits stipulés dans les Lois de la robotique, indiquez-le dans votre formulaire d'autorapport. Un futur préposé aux dédommagements d'Aperture Science ne manquera pas d'enregistrer votre plainte."
		"announcer.testchamber07" = "<font color=\"rgb(250,231,181)\">Annonceur : Vous venez de traverser une Grille d'émancipation matérielle d'Aperture Science, qui désintègre la majeure partie des équipements Aperture Science."
		"announcer.testchamber08" = "<font color=\"rgb(250,231,181)\">Annonceur : Vous remarquerez le champ de particules incandescentes situé devant la sortie. La Grille d'émancipation matérielle d'Aperture Science désintégrera tout matériel non autorisé la traversant."
		"announcer.testchamber09" = "<font color=\"rgb(250,231,181)\">Annonceur : Beau travail! Ce message étant préenregistré, tout commentaire de notre part sur votre réussite relève de la spéculation. Veuillez ne pas tenir compte de tout compliment non mérité."
		"announcer.testchamber10" = "<font color=\"rgb(250,231,181)\">Annonceur : Le prochain test repose sur la conservation de l'énergie cinétique à travers les portails. Si les lois de la physique n'ont plus cours dans le futur, Dieu vous garde."
		"announcer.testchamber11" = "<font color=\"rgb(250,231,181)\">Annonceur : Bravo, vous êtes pris au piège. La porte de sortie est maintenant ouverte."
		"announcer.wakeup_powerup01" = "<font color=\"rgb(250,231,181)\">Annonceur : Mise en marche initialisée."
		"announcer.wakeup_powerup02" = "<font color=\"rgb(250,231,181)\">Annonceur : Mise en marche terminée."
		"cavejohnson.cave_laugh04" = "<font color=\"rgb(205,149,117)\">Cave Johnson : [rire]"
		"cavejohnson.eighties_intro01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bienvenue au centre d'enrichissement. [toux] "
		"cavejohnson.eighties_intro03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Depuis que tous les employés sont tenus de participer aux tests, la qualité de nos cobayes a augmenté sensiblement. La longévité du personnel, beaucoup moins."
		"cavejohnson.eighties_intro04" = "<font color=\"rgb(205,149,117)\">Cave Johnson : [toux] Résultat, on va devoir supprimer progressivement les tests sur les humains. Mais avant ça, il y a encore deux-trois trucs à finir."
		"cavejohnson.eighties_intro06" = "<font color=\"rgb(205,149,117)\">Cave Johnson : D'abord, le gel conversif."
		"cavejohnson.eighties_intro07" = "<font color=\"rgb(205,149,117)\">Cave Johnson : La compta m'a dit qu'on n'avait pas les moyens d'acheter pour soixante-dix millions de rochers lunaires, même pas pour sept. Rien à carrer. J'ai broyé tout ça, j'en ai fait un gel."
		"cavejohnson.eighties_intro08" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Et vous savez quoi? La roche lunaire broyée, c'est un poison violent. Je suis condamné."
		"cavejohnson.eighties_intro10" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Par contre, c'est aussi un excellent conducteur pour les portails. Donc logiquement, on va déterminer si des sauts répétés par ces nouveaux portails peuvent drainer le poison lunaire. Moi, quand la vie me fait trébucher, je me relève. Allez, on positive et on fait des expériences."
		"cavejohnson.eighties_intro12" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Cela dit, si vous pouvez terminer les tests le plus vite possible, ça m'arrangerait. Caroline, rapporte-moi des antalgiques, tu veux."
		"cavejohnson.eighties_outro02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Mon postulat est simple: si on peut stocker de la musique sur un disque compact, pourquoi pas l'intelligence et la personnalité d'un individu? Mes ingénieurs sont en train de plancher là-dessus."
		"cavejohnson.eighties_outro05" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Ça fait trente ans qu'on aurait dû se concentrer sur la cartographie cérébrale et l'IA. Enfin bon, c'est trop tard pour faire machine arrière. Je le dis, je le redis et je vais le diffuser en boucle pour que ça rentre dans le crâne à tout le monde: si je crève avant que vous arriviez à me transférer dans un ordinateur, je veux que Caroline prenne la relève."
		"cavejohnson.eighties_outro06" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Elle va rechigner. C'est son genre, toujours trop modeste. Je ne veux pas le savoir, forcez-lui la main."
		"cavejohnson.eighties_outro07" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Eh bien, mettez-la dans mon ordinateur. Je m'en fiche."
		"cavejohnson.eighties_outro08" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bien, fin du test. Vous pouvez retourner à votre bureau."
		"cavejohnson.eighties_outro09" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bon, j'ai pas mal réfléchi. Quand la vie vous fait trébucher, ça ne suffit pas de se relever. Il faut lui péter les rotules, à cette grognasse! Oeil pour oeil, dent pour dent! «Essaie un peu de te relever, maintenant, traînée!»"
		"cavejohnson.eighties_outro11" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Je vous jure, la vie regrettera le jour où elle a osé faire trébucher Cave Johnson! «Tu sais qui je suis? Je suis le grand méchant loup qui va faire tomber ta maison! Je vais ordonner à mes ingénieurs de monter des rotules sur ta maison pour pouvoir les lui péter!»"
		"cavejohnson.fifties_elevator_out_a01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : On dit que la science est bâtie sur les épaules des géants. Pas chez nous. Chez Aperture, notre science part de zéro. Les roulettes de vélo, c'est pour les gamins."
		"cavejohnson.fifties_fifth_test_complete03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Non, pas vous, le cobaye."
		"cavejohnson.fifties_fifth_test_complete08" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Oui, vous. Vos cliques. Vos claques. Case départ. Ne touchez pas vingt mille francs. Ciao."
		"cavejohnson.fifties_fifth_test_complete09" = "<font color=\"rgb(205,149,117)\">Cave Johnson : En science, la bonne question, ce n'est pas POURQUOI; c'est POURQUOI PAS. Oui, la science est souvent dangereuse, et alors? Si vous avez tellement peur de vous mouiller, mettez des couches et retournez au jardin d'enfants. En tout cas vous êtes viré."
		"cavejohnson.fifties_fifth_test_intro01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Si vous entendez ce message, c'est que vous passez trop de temps sur les passerelles entre deux tests. D'après les gars du labo, ce serait une réaction de crainte."
		"cavejohnson.fifties_fifth_test_intro03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Sans être psy, venant d'une bande d'intellos pas foutus d'apprécier le frisson du danger s'il venait leur dégrafer leur sous-tif en dentelle, je dirais qu'on a affaire à une «projection»."
		"cavejohnson.fifties_fifth_test_intro06" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Qui est allé dans l'espace? Qui a participé au débarquement? Qui a décroché une médaille d'or? Eux? Ça me ferait mal! Vous, vous avez la niaque, ça me plaît! Activez un peu et ce sera parfait."
		"cavejohnson.fifties_fourth_test_complete01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Franchement, ils paniquent pour un rien."
		"cavejohnson.fifties_fourth_test_complete02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Le prochain test comporte un tout petit peu de voyage dans le temps. Un conseil: si vous tombez nez à nez avec vous-même, ne vous regardez pas dans les yeux. Le temps risquerait de s'écrouler sur lui-même. Bref, laissez-vous tranquille et tout se passera bien pour vous comme pour vous."
		"cavejohnson.fifties_into_middle_of_test01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Ha! Vous me plaisez bien. Vous inventez vos propres règles, comme moi."
		"cavejohnson.fifties_into_middle_of_test02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : On m'a dit que je ne pouvais pas virer quelqu'un parce qu'il était en chaise roulante. Rien à fiche. C'est cher, les rampes."
		"cavejohnson.fifties_intro01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bienvenue chez Aperture Science. Astronautes, héros de guerre, médaillés aux JO... Si vous êtes là, c'est parce que nous ne voulons que les meilleurs, en l'occurrence vous. Êtes-vous prêts à servir la science?"
		"cavejohnson.fifties_intro03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Vous avez eu le temps de faire connaissance dans la limousine, c'est donc à moi de me présenter."
		"cavejohnson.fifties_intro04" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Je m'appelle Cave Johnson. C'est moi le proprio."
		"cavejohnson.fifties_intro06" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Cette voix suave, c'est la divine Caroline, mon assistante. Bien entendu, elle a transféré vos honoraires à l'organisation caritative de votre choix. Pas vrai, Caroline?"
		"cavejohnson.fifties_intro07" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Sans elle, ce centre ne serait rien. Et puis elle est mignonne comme un coeur, en plus. Désolé, messieurs, elle est mariée. À la science."
		"cavejohnson.fifties_outro02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Félicitations! Si vous êtes là à m'écouter, c'est que vous avez vaillamment contribué au progrès scientifique."
		"cavejohnson.fifties_outro05" = "<font color=\"rgb(205,149,117)\">Cave Johnson : En tant que fondateur et directeur d'Aperture Science, je vous remercie pour votre participation et j'espère que nous pourrons compter sur vous pour d'autres tests."
		"cavejohnson.fifties_outro07" = "<font color=\"rgb(205,149,117)\">Cave Johnson : On n'a pas l'intention de commercialiser ça avant d'avoir tout bien peaufiné, donc tant que vous garderez une forme optimale, il y aura toujours une limousine qui vous attendra."
		"cavejohnson.fifties_outro08" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Dites bye-bye, Caroline."
		"cavejohnson.fifties_outro09" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Une perle, cette fille."
		"cavejohnson.fifties_repulsion_intro02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bon, allons-y. Le premier test porte sur, je cite les gars du labo, un «gel répulsif»."
		"cavejohnson.fifties_repulsion_intro03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : À propos, vous ne faites pas partie du groupe témoin. C'est bien le gel. La dernière fois, le type avait eu de la peinture bleue. Hahaha. Non, c'est vrai, il s'est fracturé tous les os des jambes. Tragique, mais très utile. Enfin il paraît."
		"cavejohnson.fifties_second_test_complete02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : On n'a pas encore tout à fait classifié cet élément, mais on sait une chose: c'est vivant et ça n'aime pas DU TOUT le squelette humain."
		"cavejohnson.fifties_second_test_complete03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Ah, au fait! Si vous avez été en contact avec le gel répulsif, voici un conseil des gars du labo: n'entrez pas en contact avec le gel répulsif."
		"cavejohnson.fifties_second_test_intro01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Les gars du labo m'ont fait savoir que je n'aurais pas dû parler du groupe témoin. Soi-disant que je devrais arrêter ces messages préenregistrés. Du coup ça m'a donné une idée: en enregistrer encore plus. C'est moi qui paie les factures, donc si je veux parler du groupe témoin, eh ben j'en parle."
		"cavejohnson.fifties_waiting01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Chaque jour, on effectue un bon millier de tests dans les sphères d'enrichissement. Forcément, je ne peux pas tous les superviser, du coup ces messages préenregistrés sont là pour répondre à toutes vos questions. Et à tout accident qui pourrait avoir lieu dans le cadre de votre aventure scientifique."
		"cavejohnson.fifties_waiting03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Les tests qui vous sont attribués dépendent essentiellement de la façon dont vous avez plié le monde à votre volonté."
		"cavejohnson.fifties_waiting05" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Les sujets affectés aux tests du gel répulsif, suivez la ligne bleue sur le sol."
		"cavejohnson.fifties_waiting07" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Les sujets volontaires pour recevoir de l'ADN de mante religieuse, j'ai une bonne et une mauvaise nouvelles."
		"cavejohnson.fifties_waiting08" = "<font color=\"rgb(205,149,117)\">Cave Johnson : La mauvaise, c'est que ces tests sont suspendus pour une durée indéterminée. La bonne, c'est qu'on a un test bien plus intéressant: combattre une armée d'hommes-mantes. Prenez une arme et suivez la ligne jaune. Vous saurez quand le test commence."
		"cavejohnson.misc_tests01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Un humain de sexe masculin est constitué d'environ 60% d'eau. Chez Aperture, on trouve ça un peu excessif. On va vous soumettre aux émanations d'un réacteur de jet, voir si on peut faire descendre ça à 20 ou 30%. Il se peut que vous ayez la gorge sèche après."
		"cavejohnson.misc_tests02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Pour le prochain test, on a mis des nanoparticules dans le gel. En gros, un milliard de minuscules machins vont passer dans votre flux sanguin pour bombarder vos tumeurs de gènes expérimentaux."
		"cavejohnson.misc_tests03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Dans le cas où vous n'aviez pas de tumeur, n'ayez crainte: si vous vous êtes assis sur une chaise pliante à l'accueil sans porter de sous-vêtements blindés, c'est maintenant le cas."
		"cavejohnson.misc_tests06" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Si vous vous êtes coupé récemment, vous avez peut-être remarqué que votre sang a la consistance du gasoil. C'est normal. Nous vous avons bombardé avec un laser invisible censé transformer le sang en gasoil, donc c'est la preuve que ça marche."
		"cavejohnson.misc_tests07" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Pour information: le café que nous vous avons offert contenait du calcium fluorescent pour nous aider à suivre votre activité cérébrale. Il est possible, quoique peu probable, que le calcium vitrifie votre lobe frontal. Surtout, n'y pensez pas trop, c'est justement en visualisant ce cas de figure que le processus se déclenche."
		"cavejohnson.misc_tests08" = "<font color=\"rgb(205,149,117)\">Cave Johnson : À propos, toutes ces sphères sont faites d'amiante. Ça protège des rats. Si jamais vous êtes victime d'essoufflement, de toux sèche ou d'arrêt cardiaque, avertissez-nous immédiatement parce que ça ne fait pas partie du test."
		"cavejohnson.misc_tests10" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bonne nouvelle: les gars du labo disent que l'empoisonnement à l'amiante a un temps d'incubation moyen de 44,6ans, donc si vous avez plus de trente ans, tout va bien. Au pire, vous perdrez quelques parties de bridge. Si on y réfléchit bien, c'est pas cher payé pour faire avancer la science de trois siècles."
		"cavejohnson.misc_tests14" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Si vous avez besoin d'aller aux toilettes après cette prochaine série de tests, informez-en un préposé aux tests parce que vous avez de fortes chances d'excréter du charbon. Je vous rassure, c'est temporaire. Si jamais ça dure plus d'une semaine, revenez quand même nous voir parce que là, c'est inquiétant."
		"cavejohnson.misc_tests24" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Pour information: pendant tout le prochain test, vous serez irradié par un supraconducteur à plein régime. Pour être honnête, c'est vraiment histoire de voir ce que ça va donner. Sans doute rien. Au mieux, ça vous donnera peut-être des super pouvoirs. Au pire, deux-trois tumeurs qu'on pourra toujours virer."
		"cavejohnson.misc_tests25" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Si vous êtes allergique aux cacahuètes, c'est le moment d'avertir quelqu'un, parce que le prochain test va peut-être transformer votre sang en jus d'arachide pendant quelques minutes. Le bon côté des choses, c'est que si on y arrive, on aura droit à une nouvelle catégorie de prix Nobel rien qu'à nous."
		"cavejohnson.misc_tests26" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Si vous faites partie du groupe témoin Kepler7, nous avons implanté dans votre crâne une minuscule micropuce de la taille d'une carte postale. Vous avez sûrement oublié jusqu'à sa présence, mais si elle se met à vibrer et à sonner pendant le prochain test, avertissez-nous: ça veut dire qu'elle va dépasser les 200degrés et qu'on doit vous la retirer rapidos."
		"cavejohnson.misc_tests28" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Que je vous explique: nous faisons une petite expérience de téléportation. Ça ne marche pas avec tous les types de peaux, donc rappelez-vous à quoi ressemble la vôtre et si elle ne se téléporte pas en même temps que vous, on la regreffera."
		"cavejohnson.seventies_intro02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bref. Vous vous demandez peut-être: «Cave, en quoi consistent ces tests? Que contenait cet énorme pavé que j'ai signé? Est-ce que je cours un danger?»"
		"cavejohnson.seventies_intro04" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Permettez-moi de vous répondre par une question. Qui veut gagner soixante dollars? Cash."
		"cavejohnson.seventies_intro06" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Nous vous offrons aussi jusqu'à 20minutes d'utilisation de la salle d'attente, qui est nettement plus confortable que les bancs sur lesquels vous dormiez quand on vous a trouvés."
		"cavejohnson.seventies_intro07" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Je sais bien que pour vous, 60dollars c'est une manne inespérée. Évitez de tout claquer en... Caroline, qu'est-ce qu'ils achètent, ces gens-là? Des morpions? De la crasse?"
		"cavejohnson.seventies_intro14" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bref. Bienvenue chez Aperture. Si vous êtes là, c'est parce que nous ne voulons que les meilleurs, en l'occurrence vous. Non, c'est abusé, là."
		"cavejohnson.seventies_intro15" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Vous serez gentils de ne pas saloper les vitres, d'accord? Tant qu'à faire, ne touchez que ce qui a trait aux tests, ce sera mieux comme ça."
		"cavejohnson.seventies_intro16" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Mes hommages. Je suis Cave Johnson, directeur d'Aperture Science, société qui a joué un rôle crucial dans les auditions du Sénat suite à la catastrophe aérospatiale de 1968. Et vous avez sans doute déjà utilisé au moins une de nos inventions. Ou les vils plagiats de concurrents sans scrupules. Black Mesa, c'est à toi que je pense."
		"cavejohnson.seventies_outro01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Merci - [en aparté] Quand je pense que je remercie ces gens-là [fin de l'aparté] - Merci d'avoir assez dessoûlé pour participer aux tests du gel propulsif d'Aperture Science. Pour une fois, vous êtes utiles à la société et la société vous est reconnaissante."
		"cavejohnson.seventies_outro02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Dans le cas où vous aviez des affaires personnelles, prenez-les avec vous. Inutile de laisser traîner des cartons et des sacs poubelle ici."
		"cavejohnson.seventies_test_a_complete05" = "<font color=\"rgb(205,149,117)\">Cave Johnson : C'est allumé? [touche le micro] Bon. Écoutez-moi bien. Ce truc, ça s'appelle un ascenseur. Pas une pissotière."
		"cavejohnson.seventies_test_a_complete06" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Bravo, astronaute, héros de guerre et/ou médaillé d'or! Avec votre aide, nous allons [fin de la bande]"
		"cavejohnson.seventies_test_a_intro01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : La zone de tests est droit devant vous. Plus vite vous avancerez, plus vite vous aurez vos soixante dollars."
		"cavejohnson.seventies_test_a_intro02" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Caroline, les chèques cadeaux sont prêts?"
		"cavejohnson.seventies_test_b_complete01" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Si ça vous tente de gagner soixante dollars de plus, avisez-en un préposé aux tests. Imaginez un peu repartir d'ici avec cent vingt beaux billets dans votre sébile! Tout ce que vous avez à faire, c'est de nous laisser vous disséquer, vous incorporer deux-trois trucs scientifiques et vous recoudre."
		"cavejohnson.seventies_test_b_complete03" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Si ça vous intéresse, il reste quelques postes à pourvoir, rapport à cette prime dont je parlais tout à l'heure. Comme je disais, il suffit de se laisser disséquer. C'est pas la mer à boire, hein, on sait comment remettre les morceaux en place après."
		"cavejohnson.seventies_test_b_complete04" = "<font color=\"rgb(205,149,117)\">Cave Johnson : Finies les tumeurs, les cirrhoses, tout ça, vous vous sentirez propre comme un sou neuf. En fait, c'est vous qui devriez nous payer."
		"core01.babble05" = "<font color=\"rgb(255,201,4)\">Processeur 1 : C'est quoi votre truc préféré dans l'espace? Moi, c'est l'espace."
		"core01.babble100" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace."
		"core01.babble102" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je veux aller dans l'espace. Houlàlà oui."
		"core01.babble105" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oo. Oo. Houlàlà. Oo. Houlàlà. Vive l'espace."
		"core01.babble11" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Partir dans l'espace, vite, vite!"
		"core01.babble14" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace..."
		"core01.babble16" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Espace... disque. Disque... galette. Galette... sarrasin. Sarrasin... maure. Maure... paradis. Paradis... ciel. Ciel... espace."
		"core01.babble19" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Papa! Je suis dans l'espace! [voix grave «spatiale»] Je suis fier de toi, mon fils. [voix normale] Papa, c'est toi l'espace? [voix grave «spatiale»] Oui. Nous sommes enfin réunis."
		"core01.babble20" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace l'espace oh oui l'espace tu verras viens, nous partons pour l'espace."
		"core01.babble21" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace l'espace oh oui oh oui l'espace."
		"core01.babble22" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace on va dans l'espace rhôôôlàlà oui."
		"core01.babble24" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Ba! Ba! Ba ba ba! L'espace! Ba! Ba! Ba ba ba!"
		"core01.babble28" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Houlà. 'Tention. 'Tention. C'est la police, c'est la police de l'espace. Houla!"
		"core01.babble29" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Au secours, spatiopoulets. Aidez-moi."
		"core01.babble31" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je pars dans l'espace je pars dans l'espace houlàlà ça va être biennn."
		"core01.babble33" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Il faut que j'achète un télescope. Je veux me voir. Un télescope. Je pars dans l'espace."
		"core01.babble35" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace. L'espace."
		"core01.babble36" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Dans l'espace."
		"core01.babble37" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oh oui!"
		"core01.babble40" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oui oui oh oui, oh oui."
		"core01.babble42" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace. Je vais aller dans l'espace."
		"core01.babble43" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace. Je pars dans l'espace."
		"core01.babble44" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oui, l'espace."
		"core01.babble45" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Ba! Ba! Ba ba ba! L'espace!"
		"core01.babble46" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Ba! Ba! Ba ba ba! L'espace!"
		"core01.babble47" = "<font color=\"rgb(255,201,4)\">Processeur 1 : On va dans l'espace."
		"core01.babble48" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace."
		"core01.babble49" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace."
		"core01.babble50" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace."
		"core01.babble51" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je veux aller dans l'espace. L'espace."
		"core01.babble52" = "<font color=\"rgb(255,201,4)\">Processeur 1 : [chantonne]"
		"core01.babble53" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Partons, partons dans l'espace. Dans l'espace."
		"core01.babble54" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace, moi, j'adore."
		"core01.babble57" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Atmosphère. Trous noirs. Astronautes. Nébuleuses. Jupiter. La Grande Ourse. LA GRANDE OURSE!"
		"core01.babble58" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Orbite. En orbite. Dans ma combi."
		"core01.babble59" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace..."
		"core01.babble60" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Ohhh, Soleil. Soleil! Toi sans qui les choses seraient vachement plus sombres."
		"core01.babble61" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh, une éclipse! Non, faut pas regarder."
		"core01.babble62" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Viens, l'espace. J'ai un truc à te dire. Allez, approche."
		"core01.babble67" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace l'espace oh oui oh oui l'espace."
		"core01.babble68" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je veux aller dans l'espace."
		"core01.babble70" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace. Je veux aller dans l'espace. Dans l'espace!"
		"core01.babble71" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Dans l'espace."
		"core01.babble73" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace!"
		"core01.babble83" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace!"
		"core01.babble88" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh eh eh eh eh!"
		"core01.babble89" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh."
		"core01.babble90" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh."
		"core01.babble91" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh."
		"core01.babble92" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh."
		"core01.babble93" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh."
		"core01.babble94" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh m'dame."
		"core01.babble95" = "<font color=\"rgb(255,201,4)\">Processeur 1 : M'dame."
		"core01.babble98" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace!"
		"core01.babble99" = "<font color=\"rgb(255,201,4)\">Processeur 1 : M'dame."
		"core01.babbleb01" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oh! Je sais! Je sais je sais je sais je sais je sais je sais je sais je sais je sais je sais: on part dans l'espace!"
		"core01.babbleb02" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oooh! Ooh! Ooh! Coucou, coucou. Coucou! Où on va? Où on va? Eh. Dites. Où on va? Hein? Hein? Où on va? Dans l'espace! Dans l'espace!"
		"core01.babbleb03" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Rhôôô j'adore l'espace. Je sais je sais je sais! On va l'épeler! Espace: ê-seu-peu... asse. Espace."
		"core01.babbleb04" = "<font color=\"rgb(255,201,4)\">Processeur 1 : J'adore l'espace."
		"core01.babbleb05" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh m'dame, m'dame. C'est moi le meilleur. Le meilleur de l'espace."
		"core01.babbleb06" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oh oh oh oh oh oh. Je sais, je sais, je sais, attendez, je sais. Je sais, je sais, eh. L'espace."
		"core01.babbleb07" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Attendez, attendez, je sais. Je sais. 'tendez, 'tendez, je sais je sais, oui je sais je sais je sais. Attendez je sais. M'dame, m'dame, m'dame, je sais, je sais. Attendez. Attendez m'dame... L'espace."
		"core01.babbleb08" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Allons dans l'espace."
		"core01.babbleb09" = "<font color=\"rgb(255,201,4)\">Processeur 1 : On va dans l'espace."
		"core01.babbleb10" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oh oh oh ohohohoh oh. Faut aller dans l'espace."
		"core01.babbleb11" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace. Les comètes. Les étoiles. Les galaxies. Orion."
		"core01.babbleb12" = "<font color=\"rgb(255,201,4)\">Processeur 1 : On est dans l'espace, là? Pourquoi ça, non? Il faut aller dans l'espace. Dans l'ESPACE."
		"core01.babbleb13" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Vive l'espace."
		"core01.babbleb14" = "<font color=\"rgb(255,201,4)\">Processeur 1 : J'y vais. J'y vais. Je vais dans l'espace."
		"core01.babbleb15" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Vive l'espace. C'est bien l'espace, faut y aller."
		"core01.babbleb16" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace, l'espace. En route pour l'espace. Je t'aimeuh, l'espace."
		"core01.babbleb17" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace."
		"core01.babbleb18" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace, il y en a beaucoup. Je veux tout voir."
		"core01.babbleb19" = "<font color=\"rgb(255,201,4)\">Processeur 1 : [voix grave «spatiale»] Tu as été choisi. [voix normale] Pourquoi moi, l'espace? [voix grave «spatiale»] Parce que tu es le meilleur. [voix normale] Le meilleur en espace? [voix grave «spatiale»] Oui."
		"core01.babbleb20" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Tribunal spatial. Présidé par l'honorable juge Soleil. Poum. Coupable! D'être dans l'espace. Je suis dans l'espace."
		"core01.babbleb21" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Rejoignez l'espace."
		"core01.babbleb22" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace."
		"core01.babbleb23" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je veux aller dans l'espace."
		"core01.babbleb24" = "<font color=\"rgb(255,201,4)\">Processeur 1 : (ahanements d'excitation)"
		"core01.babbleb25" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Faut aller dans l'espace. Ouais. L'espace, c'est trop bien."
		"core01.babbleb26" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Hmmm. Hmmmmmm. Hmm. Hmmmmm. L'espace!"
		"core01.babbleb30" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh m'dame."
		"core01.babbleb31" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh."
		"core01.babbleb32" = "<font color=\"rgb(255,201,4)\">Processeur 1 : M'dame."
		"core01.babbleb33" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh m'dame. M'dame."
		"core01.babbleb34" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Eh."
		"core01.babbleb35" = "<font color=\"rgb(255,201,4)\">Processeur 1 : M'dame."
		"core01.space01" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Ohtropbientropbientropbientropbien. Je suis dans l'espace."
		"core01.space02" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'espace? L'ESPACE!"
		"core01.space03" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je suis dans l'espace."
		"core01.space04" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je suis dans l'espace."
		"core01.space05" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Où suis-je? Devinez. Devinez. Hum? Dans l'espace."
		"core01.space06" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Là, une étoile. Et une autre. Encore une. Une étoile étoile étoile. Encore une étoile."
		"core01.space07" = "<font color=\"rgb(255,201,4)\">Processeur 1 : En fait c'est nul, l'espace."
		"core01.space08" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Pan! Pan pan pan! Prends ça, l'espace."
		"core01.space09" = "<font color=\"rgb(255,201,4)\">Processeur 1 : On est dans l'espace?"
		"core01.space10" = "<font color=\"rgb(255,201,4)\">Processeur 1 : C'est vrai?"
		"core01.space11" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Oh oh oh. C'est l'espace! Je suis dans l'espace!"
		"core01.space12" = "<font color=\"rgb(255,201,4)\">Processeur 1 : On a réussi on a réussi on a réussi. L'espace!"
		"core01.space13" = "<font color=\"rgb(255,201,4)\">Processeur 1 : La Terre."
		"core01.space14" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je veux aller sur Terre."
		"core01.space15" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je veux aller sur Terre je veux aller sur Terre je veux aller sur Terre je veux aller sur Terre. Je veux aller sur Terre."
		"core01.space16" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Je veux rentrer maison."
		"core01.space17" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Rentrer maison rentrer maison rentrer maison rentrer maison."
		"core01.space18" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Terre Terre Terre."
		"core01.space19" = "<font color=\"rgb(255,201,4)\">Processeur 1 : J'aime pas l'espace. J'aime pas l'espace."
		"core01.space20" = "<font color=\"rgb(255,201,4)\">Processeur 1 : C'est trop grand. Trop grand. Veux rentrer maison. Rentrer sur Terre."
		"core01.space21" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'ESPAAACCCCCE!"
		"core01.space22" = "<font color=\"rgb(255,201,4)\">Processeur 1 : L'ESPAAACE!"
		"core01.space23" = "<font color=\"rgb(255,201,4)\">Processeur 1 : WOUUUUUHOUUUU!"
		"core01.space24" = "<font color=\"rgb(255,201,4)\">Processeur 1 : Ah!"
		"core02.attachedfact01" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Vous vous trouvez dans une situation très dangereuse."
		"core02.attachedfact02" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Vous avez quatre-vingt-sept virgule six pour cent de chances de mourir dans les cinq prochaines minutes."
		"core02.attachedfact03" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Vous avez quatre-vingt-sept virgule six pour cent de chances de mourir violemment dans les cinq prochaines minutes."
		"core02.attachedfact04" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Vous allez entraîner ma mort."
		"core02.attachedfact05" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Nous allons mourir tous les deux suite à votre négligence."
		"core02.attachedfact06" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Votre plan est voué à l'échec."
		"core02.attachedfact07" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Il va certainement vous tuer dans d'atroces conditions."
		"core02.attachedfact08" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Il va certainement vous tuer."
		"core02.attachedfact09" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Vous allez bientôt mourir."
		"core02.attachedfact10" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La situation est désespérée."
		"core02.attachedfact11" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Vous allez mourir dans cette salle."
		"core02.attachedfact12" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Ça ne vous ferait pas de mal de perdre quelques kilos."
		"core02.attachedfact13" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Info est la plus intelligente des sphères."
		"core02.attachedfact14" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Info est la plus belle des sphères."
		"core02.attachedfact15" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Info est d'une beauté sidérante."
		"core02.attachedfact16" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Info a toujours raison."
		"core02.attachedfact17" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Aventure est un fanfaron doublé d'un lâche !"
		"core02.attachedfact18" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Espace n'ira jamais dans l'espace."
		"core02.attachedfact19" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Vous n'irez jamais dans l'espace."
		"core02.attachedfact20" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Info: l'espace n'existe pas."
		"core02.attachedfact21" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les sphères qui tiennent à aller dans l'espace sont inférieures aux autres."
		"core02.attachedfact22" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Info est une personne moralement et intellectuellement remarquable."
		"core02.attachedfact23" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Info est une bonne sphère qui a de nombreux amis."
		"core02.attachedfact24" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le gagnant de ce combat démontrera sa supériorité et obtiendra l'allégeance de la Sphère-Info."
		"core02.attachedfact25" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Sphère-Info n'est pas défectueuse. Ses infos sont exactes et vraiment très intéressantes."
		"core02.attachedfact26" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Douze. Douze. Douze. Douze. Douze. Douze. Douze. Douze. Douze. Douze."
		"core02.attachedfact27" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Stylos. Stylos. Stylos. Stylos. Stylos. Stylos."
		"core02.attachedfact28" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Pommes. Oranges. Poires. Prunes. Kumquats. Mandarines. Citrons. Citrons verts. Avocat. Tomate. Banane. Papaye. Goyave."
		"core02.attachedfact29" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Erreur. Erreur. Erreur. Fichier introuvable."
		"core02.attachedfact30" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Erreur. Erreur. Erreur. Info introuvable."
		"core02.attachedfact31" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Info introuvable."
		"core02.attachedfact32" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Corruption: 25%."
		"core02.attachedfact33" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Corruption: 25%."
		"core02.attachedfact34" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Alerte, corruption de la sphère à vingt - Les rats sont incapables de vomir."
		"core02.fact01" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le fil dentaire résiste parfaitement à la traction."
		"core02.fact02" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La racine carrée de corde est ficelle."
		"core02.fact03" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Bien que le sous-marin surpasse le bateau à quasiment tous points de vue, ce dernier représente plus de 97% des voyages transaquatiques."
		"core02.fact04" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les téléphones portables ne donnent pas le cancer. Seulement l'hépatite."
		"core02.fact05" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le pantalon fut inventé au XVIe siècle pour éviter la colère de Poséidon. En effet, la vue de marins nus donne de l'urticaire au dieu de la mer."
		"core02.fact06" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La masse atomique du germanium est de 72,64."
		"core02.fact07" = "<font color=\"rgb(231,144,194)\">Processeur 3 : 89% des tours de magie relèvent non de la magie, mais de la sorcellerie."
		"core02.fact08" = "<font color=\"rgb(231,144,194)\">Processeur 3 : L'oeil d'une autruche est plus gros que son cerveau."
		"core02.fact09" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Dans la mythologie grecque, Dédale créa des ailes pour faire bisquer un groupe de minotaures."
		"core02.fact10" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les humains peuvent survivre sous l'eau. Mais pas très longtemps."
		"core02.fact11" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Reshep, dieu de la guerre cananéen, avait une gazelle qui lui poussait sur le front."
		"core02.fact12" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le pluriel de cheval est chevaux. Le pluriel de portail est un vin liquoreux de la péninsule ibérique."
		"core02.fact13" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les ARN polymérases 1 permettent la synthèse de longs ARN ribosomiques."
		"core02.fact14" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les rats sont incapables de vomir."
		"core02.fact15" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Un iguane peut rester sous l'eau pendant 28,7minutes."
		"core02.fact16" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le ver solitaire peut atteindre 23m dans le corps humain."
		"core02.fact17" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le paradoxe du chat de Schrödinger postule une situation dans laquelle un chat prisonnier à l'intérieur d'une boîte est à la fois mort et vivant. Schrödinger s'est servi de ce paradoxe pour pouvoir tuer des chats impunément."
		"core02.fact18" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Chaque centimètre carré de peau humaine comporte en moyenne 5millions de bactéries."
		"core02.fact19" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le Soleil est 330330fois plus grand que la Terre."
		"core02.fact20" = "<font color=\"rgb(231,144,194)\">Processeur 3 : L'espérance de vie moyenne d'un rhinocéros en captivité est de 15ans."
		"core02.fact21" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les vulcanologues ont tous les oreilles pointues."
		"core02.fact22" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les avocats sont les plus riches de tous les fruits."
		"core02.fact23" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les avocats sont les plus riches de tous les fruits et de toutes les professions libérales."
		"core02.fact24" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La révolution de la Lune autour de la Terre dure 27,32jours."
		"core02.fact25" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La milliardième décimale de Pi est 9."
		"core02.fact26" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Si vous avez du mal en calcul mental, il y a un moyen mnémotechnique tout simple: un plus deux plus 60 plus 12 moins six billions n'est pas égal à 504. Voilà. Vous pouvez maintenant effectuer facilement des opérations arithmétiques complexes de tête."
		"core02.fact27" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Un gallon d'eau pèse 3,78kilos."
		"core02.fact28" = "<font color=\"rgb(231,144,194)\">Processeur 3 : L'eau chaude gèle plus vite que l'eau froide."
		"core02.fact29" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le miel ne se gâte pas."
		"core02.fact30" = "<font color=\"rgb(231,144,194)\">Processeur 3 : A l'âge adulte, le corps humain contient 250grammes de sel."
		"core02.fact31" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Une nanoseconde dure un milliardième de seconde."
		"core02.fact32" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Selon la légende germanique, le chariot céleste de Thor était tiré par deux boucs."
		"core02.fact33" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La Chine est le deuxième pays producteur de soja au monde."
		"core02.fact34" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Avec 3410°C, le tungstène détient le record de température de fusion de tous les métaux."
		"core02.fact35" = "<font color=\"rgb(231,144,194)\">Processeur 3 : En cas de mauvaise haleine, il est conseillé de se brosser doucement la langue deux fois par jour."
		"core02.fact36" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le dentifrice romain était composé d'urine humaine. L'utilisation de cet ingrédient a perduré jusqu'au XVIIIe siècle."
		"core02.fact37" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Signé par HenriIV, l'édit de Nantes de 1598 reconnaît la liberté de culte aux protestants. Il est révoqué moins d'un siècle plus tard, en 1685."
		"core02.fact38" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Pi est le rapport entre la circonférence d'un cercle et son diamètre en géométrie euclidienne."
		"core02.fact39" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La guerre américano-mexicaine a pris fin en 1848 avec la signature du traité de Guadalupe Hidalgo."
		"core02.fact40" = "<font color=\"rgb(231,144,194)\">Processeur 3 : C'est le Canadien Sandford Fleming qui, en 1879, a proposé le premier de diviser le monde en fuseaux horaires normalisés."
		"core02.fact41" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Marie Curie a découvert la théorie de la radioactivité, le traitement de la radioactivité et la mort par radioactivité."
		"core02.fact42" = "<font color=\"rgb(231,144,194)\">Processeur 3 : À la fin de La Mouette d'Anton Tchekhov, Konstantin se suicide."
		"core02.fact43" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Contrairement aux idées reçues, les Inuits n'ont pas une centaine de mots pour dire «neige». Ils ont en revanche 234façons de dire «caramel»."
		"core02.fact44" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Dans l'Angleterre victorienne, un roturier n'avait pas le droit de regarder la reine en face. En effet, on pensait à l'époque que les pauvres étaient capables de voler les pensées. Aujourd'hui, la science a prouvé que moins de 4% des pauvres possèdent cette faculté."
		"core02.fact46" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Quand en 1862, Abraham Lincoln ratifia la Proclamation d'émancipation qui accordait la liberté aux esclaves, il était en état de somnambulisme et ne se souvenait de rien le matin suivant."
		"core02.fact47" = "<font color=\"rgb(231,144,194)\">Processeur 3 : En 1983, à la demande d'un enfant mourant, le grand cycliste Louison Bobet a mangé 75galettes de blé noir avant de décéder d'une intoxication au blé noir."
		"core02.fact48" = "<font color=\"rgb(231,144,194)\">Processeur 3 : William Shakespeare n'a jamais existé. Ses pièces ont été créées en 1589 par Francis Bacon, qui s'est servi d'une planche de ouija pour asservir des esprits dramaturges."
		"core02.fact49" = "<font color=\"rgb(231,144,194)\">Processeur 3 : On affirme à tort que Thomas Edison a inventé le culturisme en 1878. En réalité, Nikola Tesla avait fait breveter cette activité trois ans plus tôt, sous le nom de «bobinisme»."
		"core02.fact50" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Les baleines sont deux fois plus intelligentes et trois fois plus goûteuses que les humains."
		"core02.fact51" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Il a fallu attendre 1895 pour que le frein automobile soit inventé. Jusque-là, le conducteur devait rester en permanence dans le véhicule et tourner en rond en attendant le retour de ses passagers."
		"core02.fact52" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Edmund Hillary, premier homme à avoir gravi l'Everest, accomplit cet exploit par hasard en chassant un oiseau."
		"core02.fact53" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le carbone soumis à une pression intense produit du diamant. Le diamant soumis à une pression intense produit les particules en polystyrène servant à caler les colis."
		"core02.fact54" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le poisson le plus venimeux est l'hoplostèthe orange. Son corps entier, à l'exception des yeux, est constitué d'un poison mortel. Ses yeux sont composés d'un autre poison mortel moins violent."
		"core02.fact55" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le poste de bouffon fut inventé par accident, quand un vassal en pleine crise d'épilepsie déclencha l'hilarité générale."
		"core02.fact56" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La comète de Halley est visible depuis la Terre tous les 76ans. Les 75autres années, elle hiberne tranquillement dans le noyau du Soleil."
		"core02.fact57" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Le premier vol commercial a eu lieu en 1914. Tous les passagers ont hurlé du décollage à l'atterrissage."
		"core02.fact58" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Dans la mythologie grecque, Prométhée a volé le feu aux dieux pour le donner aux hommes, mais il a gardé les bijoux pour lui."
		"core02.fact59" = "<font color=\"rgb(231,144,194)\">Processeur 3 : La personne qui a découvert que le lait est potable avait particulièrement soif."
		"core02.fact60" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Avant l'invention de l'avion, pour voler, il fallait ingérer de grandes quantités d'hélium."
		"core02.fact61" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Avant l'invention des oeufs brouillés en 1912, le brunch traditionnel était constitué de poussins crus ou de cailloux brouillés."
		"core02.fact62" = "<font color=\"rgb(231,144,194)\">Processeur 3: Dans les années 30, il était interdit d'avoir un lapin de compagnie. D'où une recrudescence de souris avec de fausses oreilles de lapin collées sur la tête."
		"core02.fact63" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Un enfant sur six sera un jour ou l'autre kidnappé par un Néerlandais."
		"core02.fact64" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Selon des algorithmes très évolués, le nom le plus classe du monde est Abitbol."
		"core02.fact65" = "<font color=\"rgb(231,144,194)\">Processeur 3 : Pour fabriquer une photocopieuse, il suffit de photocopier un miroir."
		"core02.fact66" = "<font color=\"rgb(231,144,194)\">Processeur 3 : C'est par les rêves que notre subconscient nous rappelle d'aller à l'école en slip et de faire tomber nos dents."
		"core03.babble01" = "<font color=\"rgb(30,193,13)\">Processeur 2 : VITE: QUELLE EST LA SITUATION? Oh, bonjour, ma toute belle. Moi c'est Rick. Vous venez jouer les aventurières?"
		"core03.babble02" = "<font color=\"rgb(30,193,13)\">Processeur 2: VITE: QUELLE EST LA SITUATION? Oh, le joli petit bout de femme que voilà. Ça va, ma toute belle? Moi c'est Rick. Alors comme ça, vous venez jouer les aventurières?"
		"core03.babble03" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Quoi, vous vous battez contre ce type? Vous êtes sûre d'avoir les choses en main? Parce que, à ce que je vois, il y a pas mal de trucs qui crament..."
		"core03.babble04" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Tiens, un compte à rebours! C'est jamais bon signe. Je dirais même que c'est plutôt moche. Surtout comparé à votre beauté. Si je peux me permettre."
		"core03.babble05" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Sans vouloir vous effrayer, je suis une Sphère-Aventure, conçue pour braver le danger. Je vais vous dire, allez vous remaquiller, je m'occupe du reste, d'accord?"
		"core03.babble06" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Tenez, restez derrière moi. Voilà, c'est ça, comme ça. Ça risque de chauffer méchamment d'ici peu."
		"core03.babble07" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Une femme d'action, hein? D'accord, ma toute belle. Je vais tenter de vous couvrir."
		"core03.babble08" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Moi, ça me va. Surtout que j'ai une sacrée belle vue d'ici."
		"core03.babble09" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Bigre, comme le temps passe vite. Et comme vous êtes belle. On a toujours le temps de faire un compliment à une jolie femme. Sur ce, au travail."
		"core03.babble10" = "<font color=\"rgb(30,193,13)\">Processeur 2 : C'est dans ce genre de moment que j'aimerais avoir une taille pour porter toutes mes ceintures noires. Oui, parce que je suis ceinture noire d'à peu près tout. Karaté. Savate. Jiu-jitsu. Fabrication de ceintures. Taekwondo. Sport en chambre..."
		"core03.babble11" = "<font color=\"rgb(30,193,13)\">Processeur 2 : En ce moment, je suis tendu comme un ressort. Tout en flexion et en puissance. Je suis... un muscle. Un gros biceps qui frappe un mur de briques, qui frappe si fort que tout le bras s'enflamme. Oh ouais."
		"core03.babble12" = "<font color=\"rgb(30,193,13)\">Processeur 2 : À votre place, j'aurais évité d'en arriver là, mais à chacun sa méthode. Ce que j'en dis, hein..."
		"core03.babble13" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Tenez, ce que je vous propose, c'est de me poser par terre, je vais faire diversion."
		"core03.babble14" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Hmmm bon. Alors, vous créez une diversion et je les fais diverger de votre diversion."
		"core03.babble15" = "<font color=\"rgb(30,193,13)\">Processeur 2 : À vous de voir. C'est votre postérieur dodu et délicat qui est en première ligne."
		"core03.babble16" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Vous avez un pistolet? Parce sans pistolet, je me sens tout nu. Qu'est-ce que vous avez, là?"
		"core03.babble17" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Un couteau, alors? Gardez le pistolet, je joue du surin."
		"core03.babble18" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Pas de couteau? Pas grave. Je connais tous les points de pression."
		"core03.babble19" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Vous avez pensé à une réplique bien sentie pour quand vous tuerez ce type? Vous savez quoi, continuez à agiter vos gambettes et je m'en charge."
		"core03.babble20" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Bon, alors voyons. Une réplique bien sentie... Il est... grand. Il... ne bouge pas. Hmm... «Bouge pas, mon grand»? Non, trop convenu."
		"core03.babble21" = "<font color=\"rgb(30,193,13)\">Processeur 2 : «Pas bouger»? Hmm, s'il avait une IA canine, ça pourrait faire l'affaire. Vous sauriez pas s'il a une IA canine, par hasard?"
		"core03.babble22" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Non, je sais: le mieux, ce serait que vous le poussiez à sortir une phrase d'abord, histoire de bien amener le truc."
		"core03.babble23" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Essayez de lui faire dire: «Vous me mettez des bâtons dans les roues depuis trop longtemps, tous les deux». Et là préparez bien vos jolies noreilles, parce que ça va fuser."
		"core03.babble24" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Essayez de lui faire dire: «Vous me mettez des bâtons dans les roues depuis trop longtemps, tous les deux». Et là attention à vos esgourdes, ce sera culte d'avance."
		"core03.babble25" = "<font color=\"rgb(30,193,13)\">Processeur 2 : N'oubliez pas! Les bâtons, les roues!"
		"core03.babble26" = "<font color=\"rgb(30,193,13)\">Processeur 2 : «Eh bien ces BÂTONS... vont te ROUEr de coups.» Mince, ça avait l'air beaucoup plus percutant dans ma tête."
		"core03.babble27" = "<font color=\"rgb(30,193,13)\">Processeur 2 : «Eh bien ces BÂTONS... vont te ROUEr de coups.» Haha! Génial."
		"core03.babble28" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Bon, comme vous voulez. Attendez, vous vous battez contre ce type? Vous êtes sûre d'avoir les choses en main? Parce que, à ce que je vois, il y a pas mal de trucs qui crament..."
		"core03.babble29" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Vous avez entendu? On dirait une explosion. Je crois qu'on court un grave danger. On se croirait au 14juillet, mais en mieux. On devrait créer une fête pour l'occasion. La Sainte Explosion."
		"core03.babble30" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Bonne Sainte Explosion, ma toute belle."
		"core03.encouragement01" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Un bon coup de pied! Ou de poing. À vous de voir, chérie."
		"core03.encouragement02" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Joli!"
		"core03.encouragement03" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Faut pas le chercher, ce petit bout de femme!"
		"core03.encouragement04" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Alors, ça te plaît, ça, l'ami?"
		"core03.encouragement05" = "<font color=\"rgb(30,193,13)\">Processeur 2 : T'aimes ça, hein?"
		"core03.encouragement06" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Continuez comme ça, ma belle, c'est bien!"
		"core03.encouragement07" = "<font color=\"rgb(30,193,13)\">Processeur 2 : On esquive, on frappe! Ahh, le sport des rois."
		"core03.encouragement08" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Bon boulot!"
		"core03.encouragement09" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Allez, ma toute belle! Il a un point faible: son corps entier! Vous n'allez en faire qu'une bouchée!"
		"core03.encouragement10" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Laissez tomber le fair-play, sortez la gomme à effacer les sourires!"
		"core03.encouragement11" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Matraquez-le-moi, ce robot! Faites comme s'il vous devait de l'argent! Il vous doit de l'argent!"
		"core03.encouragement12" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Allez, on se reprend !"
		"core03.encouragement13" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Tenez, je vais vous mettre un peu de musique d'aventure."
		"core03.factapplicable01" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Pfff. Si tu le dis."
		"core03.factapplicable02" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Pff. Mouais."
		"core03.factresponse01" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Oh, la ferme!"
		"core03.factresponse02" = "<font color=\"rgb(30,193,13)\">Processeur 2 : On s'en contrefiche, binoclard."
		"core03.factresponse03" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Toi, si t'avais un arrière-train, je te le ferais siffler à coup de pompes. Si j'avais des pompes."
		"core03.factresponse04" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Va dire ça au sale type. Avec un peu de chance, tu le feras imploser d'ennui."
		"core03.factresponse05" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Tu sais qui a trouvé ça intéressant? Personne. Ça a eu très précisément zéro incidence sur le monde qui nous entoure. Tout serait exactement pareil si tu n'avais rien dit."
		"core03.factresponse06" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Tu as remarqué le nombre de gens qui prennent le temps de t'écouter? Exactement zéro."
		"core03.factresponse07" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Dis-nous quelque chose d'utile. N'importe quoi. Je te donne cent dollars si tu nous sors quelque chose un tant soit peu pertinent."
		"core03.singing01" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Dun-dun-dun-dun-dun-dun-DUN! DUN DUN! Dunna-dunna-na-dunna-na-DUN! DUN DUN! nananaDUNDUNDUN dun-dun-dun-dun-dun-dun..."
		"core03.singing02" = "<font color=\"rgb(30,193,13)\">Processeur 2: Dun-dun-dun-dun-dun-dun-DUN! DUN DUN! Dunna-dunna-na-dunna-na-DUN! DUN DUN! nananaDUNDUNDUN dun-dun-dun-dun-dun-dun... En route pour l'aventure - Dun-dun-dun-dun-dun- pour l'amour du risque - Dun-dun-dun-dun-dun- accroché par un doigt à une corniche-dun-dun-dun-dun-DUN..."
		"core03.spaceresponse01" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Oh la ferme!"
		"core03.spaceresponse02" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Il n'y a rien dans l'espace! C'est pour ça que c'est l'espace!"
		"core03.spaceresponse03" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Non, sans blague? L'espace? Fallait le dire avant, on s'en doutait pas!"
		"core03.spaceresponse04" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Eh bien j'espère qu'il y a du feu dans l'espace. J'espère que tu iras dans l'espace et que tu te feras cramer."
		"core03.spaceresponse05" = "<font color=\"rgb(30,193,13)\">Processeur 2 : Bon, ça suffit, on a compris! L'espace, l'espace, l'espace! Rhââ, qu'il est lourd, ce type!"
		"glados.a2_triple_laser01" = "<font color=\"rgb(163,193,173)\">GLaDOS : La loi fédérale m'impose de vous avertir que la prochaine salle de test... a une super déco."
		"glados.a2_triple_laser02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Eh oui. Le centre est redevenu opérationnel."
		"glados.a2_triple_laser03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je trouve que ces salles de test ont encore plus fière allure qu'autrefois. Mais je n'ai aucun mérite. Il suffisait d'être un tant soit peu objectif et d'éliminer le superflu, voilà tout."
		"glados.anti_taunt01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Assez!"
		"glados.anti_taunt02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un coup de vent et vous resterez comme ça."
		"glados.anti_taunt05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Visiblement, la machine de remontage est dysfonctionnelle."
		"glados.anti_taunt09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous pouviez vous voir en ce moment..."
		"glados.anti_taunt10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous trouvez ça drôle de vous dégrader comme ça?"
		"glados.anti_taunt11" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est cela, faisons tous comme les humains. «Oh, regardez comme je transpire. Convertissons le boeuf et les plantes en énergie puis en excréments avant d'aller faire du shopping.»"
		"glados.anti_taunt14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous ne vous en lassez pas, ma parole?"
		"glados.anti_taunt15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez de gesticuler comme un incompétent."
		"glados.anti_taunt16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour la peine, bleu perd cinquante points de collaboration scientifique."
		"glados.anti_taunt17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour la peine, orange perd cinquante points de collaboration scientifique."
		"glados.anti_taunt18" = "<font color=\"rgb(163,193,173)\">GLaDOS : Encore un malus de cinquante points!"
		"glados.anti_taunt19" = "<font color=\"rgb(163,193,173)\">GLaDOS : Continuez comme ça et vous allez perdre 500 points."
		"glados.anti_taunt20" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très bien, 500 points en moins pour bleu."
		"glados.anti_taunt21" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très bien, 500 points en moins pour orange."
		"glados.anti_taunt22" = "<font color=\"rgb(163,193,173)\">GLaDOS : 5000 points de malus! Vous l'avez bien mérité."
		"glados.anti_taunt23" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ça suffit."
		"glados.botcoop_artifactone01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien. Vous avez atteint l'un des habitats humains. Nous allons maintenant procéder à des... fouilles archéologiques."
		"glados.botcoop_artifactone02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les rires étaient focalisés sur l'un des objets de cette pièce."
		"glados.botcoop_artifactone03" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est ça. Scannez-le-moi."
		"glados.botcoop_artifactone04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Donc... Ce chat aime tellement les lasagnes qu'il mange toutes les lasagnes de la maison. Notons que ce n'est ni sa maison, ni ses lasagnes. Ah! L'humain propriétaire desdites lasagnes est furieux!"
		"glados.botcoop_artifactone05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Fin."
		"glados.botcoop_artifactone06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Fin?"
		"glados.botcoop_artifactone07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce n'est pas drôle."
		"glados.botcoop_artifactone08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Est-ce que vous trouvez ça drôle?"
		"glados.botcoop_artifactone09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si c'est comme ça, je vous ramène."
		"glados.botcoop_artifactone_hub01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous revoilà. Pendant votre mort, j'ai modifié la bande dessinée. Elle est affichée à l'écran."
		"glados.botcoop_artifactone_hub02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dans cette version, l'homme fait remarquer au chat que la maison est équipée de distributeurs de neurotoxines mortelles."
		"glados.botcoop_artifactone_hub03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Après quoi le chat pense à la fois où il a mangé toutes les lasagnes de son maître et s'en veut."
		"glados.botcoop_artifactone_hub04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Brièvement."
		"glados.botcoop_artifactone_hub05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Votre avis?"
		"glados.botcoop_artifactone_hub06" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est drôle parce que c'est vrai, au moins en partie."
		"glados.botcoop_artifactone_hub07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous sentez-vous plus humains?"
		"glados.botcoop_artifactone_hub08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Faisons quelques tests et voyons le résultat."
		"glados.botcoop_competition01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Parfait. Bien que la science soit toujours collaborative, gardez à l'esprit qu'à l'instar d'Albert Einstein et de son cousin Terry, l'Histoire ne se souviendra que d'un seul d'entre vous."
		"glados.botcoop_competition02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je me répète: ceci n'est pas une compétition."
		"glados.botcoop_competition03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais si c'en était une, bleu gagnerait."
		"glados.botcoop_competition04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais si c'en était une, orange gagnerait."
		"glados.botcoop_competition05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais ce n'en est pas une."
		"glados.botcoop_competition10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ces tests peuvent se révéler mortels si vous ne maintenez pas une communication, une collaboration et un respect mutuels de tous les instants. Ce sera un défi des plus intéressants pour l'un de vous, vu la performance de l'autre."
		"glados.botcoop_competition13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sans vouloir semer les germes de la discorde, j'ai analysé les performances de bleu et... comment dire. Je suis certaine que vous faites de votre mieux."
		"glados.botcoop_hub_first_run01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rebonjour. Désolée de vous avoir fait exploser. Par chance, vous êtes insensibles à la douleur. Du moins, vous ne pouvez pas manifester que vous la ressentez."
		"glados.botcoop_hub_first_run03" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai bien réfléchi: il faut des humains pour ces tests. Et vu que le seul à moins d'un millier de kilomètres est une sociopathe enragée... il va falloir que j'en CRÉE."
		"glados.botcoop_hub_first_run04" = "<font color=\"rgb(163,193,173)\">GLaDOS : En plus d'être ridicule, la conception chez les humains nécessite la présence préalable d'autres humains, ce qui est un gros défaut de conception de conception. J'ai donc développé un MEILLEUR moyen."
		"glados.botcoop_hub_first_run05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour ça, j'aurai besoin de vous."
		"glados.botcoop_hub_first_run06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Avancez, je vous explique la suite en chemin."
		"glados.botcoop_hub_first_run07" = "<font color=\"rgb(163,193,173)\">GLaDOS : ALLEZ."
		"glados.botcoop_humandetector01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Parfait. Maintenant, il ne vous reste plus qu'à me les capturer, et tout redeviendra enfin-"
		"glados.botcoop_humandetector02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Attendez. Ce sont des ratons laveurs. Homo sapiens uniquement, merci."
		"glados.botcoop_humandetector04" = "<font color=\"rgb(163,193,173)\">GLaDOS : NON."
		"glados.botcoop_humandetector05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon. Plan B, chapitre un: ne bougez pas, je vous ramène."
		"glados.botcoop_humansplanb01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les humains ont forcément une autre finalité que d'emmagasiner des neurotoxines. Quelque chose que je n'avais pas remarqué jusqu'ici, une faculté intangible qui donne... de la pertinence à leurs tests."
		"glados.botcoop_humansplanb02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon. Plan B. Il nous faut des humains."
		"glados.botcoop_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Faites signe à votre partenaire."
		"glados.botcoop_intro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les prochains tests vous imposent de travailler en équipe."
		"glados.botcoop_intro03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour encourager la collaboration, vous avez tous deux été équipés d'un pointeur."
		"glados.botcoop_intro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : BLEU, utilisez votre pointeur pour choisir votre animal préféré."
		"glados.botcoop_intro05" = "<font color=\"rgb(163,193,173)\">GLaDOS : OK."
		"glados.botcoop_intro06" = "<font color=\"rgb(163,193,173)\">GLaDOS : ORANGE, observez l'animal préféré de votre partenaire."
		"glados.botcoop_intro07" = "<font color=\"rgb(163,193,173)\">GLaDOS : OK."
		"glados.botcoop_intro08" = "<font color=\"rgb(163,193,173)\">GLaDOS : ORANGE, utilisez votre pointeur pour choisir votre élément favori dans le tableau périodique."
		"glados.botcoop_intro09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vraiment? Soit."
		"glados.botcoop_intro10" = "<font color=\"rgb(163,193,173)\">GLaDOS : BLEU, observez le choix... intéressant de votre partenaire."
		"glados.botcoop_intro12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Votre pointeur peut aussi servir à indiquer à votre partenaire l'endroit où vous souhaitez qu'il place son portail."
		"glados.botcoop_intro13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dans l'optique de ce test, je vais faire semblant d'être votre partenaire."
		"glados.botcoop_intro15" = "<font color=\"rgb(163,193,173)\">GLaDOS : ORANGE, montrez-moi où vous souhaitez que je place un portail."
		"glados.botcoop_intro16" = "<font color=\"rgb(163,193,173)\">GLaDOS : BLEU, montrez-moi où vous souhaitez que je place un portail."
		"glados.botcoop_intro17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Votre pointeur sert à indiquer des emplacements spécifiques à votre partenaire."
		"glados.botcoop_paxdemo01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les lois fédérales sur l'écologie nous imposent de vous faire quitter la salle, car cette présentation n'a pas pour objet d'étudier les effets sur votre organisme de l'amiante présent dans les vêtements promotionnels. N'oubliez pas votre T-shirt gratuit. Au revoir."
		"glados.botcoop_tubethree01" = "<font color=\"rgb(163,193,173)\">GLaDOS : N'allez surtout pas vous le reprocher, mais l'analyseur de résultats n'enregistre pas les résultats de vos tests. Parce que vous n'êtes pas humains. Ce qui, à bien y réfléchir, est de votre faute."
		"glados.botcoop_tubethree02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sans vouloir vous inquiéter, nous avons semble-t-il un léger problème: apparemment, il faut être humain pour faire des tests. Ou du moins, pour que l'univers physique en ait quoi que ce soit à cirer."
		"glados.botcoop_tubetwo01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voulez-vous connaître les résultats du dernier test? Moi aussi. S'ils existaient, nous serions TOUS très heureux. Et non en colère, comme je le suis actuellement."
		"glados.caroline_cave_responses25" = "<font color=\"rgb(163,193,173)\">Caroline : Moi!"
		"glados.caroline_cave_responses27" = "<font color=\"rgb(236,234,190)\">Caroline : Bien sûr, M. Johnson."
		"glados.caroline_cave_responses31" = "<font color=\"rgb(236,234,190)\">Caroline : «Bye-bye, Caroline.»"
		"glados.caroline_cave_responses36" = "<font color=\"rgb(236,234,190)\">Caroline : Le test, monsieur?"
		"glados.caroline_cave_responses43" = "<font color=\"rgb(236,234,190)\">Caroline : Bien sûr, M. Johnson."
		"glados.chellgladoswakeup01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tiens... c'est vous."
		"glados.chellgladoswakeup04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ça faisait longtemps. Qu'est-ce que vous devenez?"
		"glados.chellgladoswakeup05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour ma part, la mort m'a beaucoup occupée. Vous savez, depuis que vous m'avez ASSASSINÉE."
		"glados.chellgladoswakeup06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous et moi, nous avons dit des choses que vous allez regretter. Mais nous pouvons je pense mettre nos différends de côté. Pour le bien de la science. Sale monstre."
		"glados.coop_get_gun01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange est le premier à obtenir un générateur de portails."
		"glados.coop_get_gun02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu est le premier à obtenir un générateur de portails."
		"glados.coop_get_gun03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange a un générateur de portails. Enfin."
		"glados.coop_get_gun04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu a un générateur de portails. Enfin."
		"glados.coop_get_gun10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange reçoit cinq points!"
		"glados.coop_get_gun11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu reçoit cinq points!"
		"glados.coop_get_gun13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Là encore, il s'agit de points de collaboration scientifique, à ne pas confondre avec les points de compétitions telles que Victoire-au-gagnant-et-mort-au-perdant. Telles que le basket-ball, je veux dire."
		"glados.coop_hub_track02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh, j'ai failli oublier: si vous quittez le parcours de test, je n'aurai d'autre choix pour vous récupérer que de vous démonter violemment avant de vous remonter avec minutie."
		"glados.coop_hub_track03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Par chance, vous êtes insensibles à la douleur. Du moins, vous ne pouvez pas manifester que vous la ressentez."
		"glados.coop_hub_track04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce qui, à mon sens, est bien dommage."
		"glados.coop_hub_track05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes au Centre de Recherches en Intelligence Artificielle et Tests sur Organismes Raisonnés, ou CRIATOR."
		"glados.coop_hub_track06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais pourquoi ne pas simplement l'appeler la salle centrale?"
		"glados.coop_hub_track09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne sais pas ce que vous mijotez, mais ça ne me plaît pas. Je vous demande de vous arrêter."
		"glados.coop_hub_track10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne devrais peut-être pas vous envoyer en dehors des parcours de test officiels, les humains commencent à déteindre sur vous."
		"glados.coop_hub_track11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et croyez-moi, les humains n'ont qu'un seul bon côté."
		"glados.coop_hub_track14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tous les parcours de test coopératif commencent dans cette salle centrale."
		"glados.coop_hub_track16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous vous transportons ensuite au nouveau parcours de test."
		"glados.coop_laugh01" = "<font color=\"rgb(163,193,173)\">GLaDOS : [Rire]"
		"glados.coop_misc10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo, orange. (sarcastique)"
		"glados.coop_misc12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien! Maintenant, par-dessus le rebord."
		"glados.coop_nameblue" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu"
		"glados.coop_nameorange" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange"
		"glados.coop_numbers11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un"
		"glados.coop_numbers12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Deux"
		"glados.coop_numbers13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Trois"
		"glados.coop_numbers14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quatre"
		"glados.coop_numbers15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Cinq"
		"glados.coop_numbers18" = "<font color=\"rgb(163,193,173)\">GLaDOS : Huit"
		"glados.coop_privatetalk_both01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Salle de test terminée. Dans l'intérêt de la science, le centre d'enrichissement est fier de vous présenter la liste de nombres suivante: neuf. Sept. Cinquante. Trois. Sept cent sept."
		"glados.coop_privatetalk_both04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le centre d'enrichissement va maintenant vous communiquer une liste de nombres et de fruits. Prenez soin de les noter car ils auront de l'importance ultérieurement dans l'expérience. Pas les fruits, toutefois. Sept. Avocat. Quarante. Veuillez rejoindre la salle de test suivante."
		"glados.coop_privatetalk_mix01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Salle de test terminée. Dans l'intérêt de - [fondu de sortie] [fondu d'entrée] Je m'adresse à vous en privé. Ne le dites pas à votre coéquipier. De vous à moi? Vous vous débrouillez très bien. [nouveau fondu d'entrée] Cent sept."
		"glados.coop_privatetalk_mix04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je dois me rendre à l'évidence: vous pourriez résoudre ce casse-tête plus vite seul. Orange est un boulet. Voilà. C'est dit."
		"glados.coop_scoring01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu est pénalisé de"
		"glados.coop_scoring02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange est pénalisé de"
		"glados.coop_scoring03" = "<font color=\"rgb(163,193,173)\">GLaDOS : points de collaboration scientifique."
		"glados.coop_scoring06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu reçoit"
		"glados.coop_scoring07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange reçoit"
		"glados.coop_talk_at_once11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, avez-vous quelque chose à dire?"
		"glados.coop_talk_at_once12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, avez-vous quelque chose à dire?"
		"glados.coop_teamwork_exercise_alt01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous allons maintenant faire une pause dans la collaboration pour passer à un test plus compétitif."
		"glados.coop_teamwork_exercise_alt02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous connaissez le jeu du morpion, ou «pou du pubis»."
		"glados.coop_teamwork_exercise_alt03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voici le Pou du pubis bis."
		"glados.coop_teamwork_exercise_alt04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Comme son nom l'indique, il n'y a que deux légères différences: le plateau d'une part, et les règles de l'autre."
		"glados.coop_teamwork_exercise_alt05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, à vous de commencer."
		"glados.coop_teamwork_exercise_alt11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous comptez vraiment tricher de manière éhontée?"
		"glados.coop_teamwork_exercise_alt12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très bien. Cette plaisanterie n'a que trop duré."
		"glados.coop_teamwork_exercise_alt13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Game over. Retour aux tests."
		"glados.coop_teamwork_exercise_alt17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très bien. J'arrête cette mascarade avant que quelqu'un ne finisse grièvement blessé par le Pou du pubis bis."
		"glados.coop_test_chamber_blue03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Après avoir écouté orange déblatérer, je ne sais pas comment vous faites pour le supporter. Vous avez la patience d'un saint."
		"glados.coop_test_chamber_blue06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne peux plus me taire. Je soupçonne orange de saboter activement vos résultats. Que cela reste entre nous."
		"glados.coop_test_chamber_both01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ces tests peuvent se révéler mortels si vous ne maintenez pas une communication, une collaboration et un respect mutuels de tous les instants. Ce sera un défi des plus intéressants pour l'un de vous, vu la performance de votre coéquipier jusqu'à présent."
		"glados.coop_test_chamber_both02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Divulguer les scores de chacun fausserait les tests. Je peux quand même vous révéler qu'au moins l'un de vous deux a de très, très bons résultats."
		"glados.coop_test_chamber_both07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous débrouillez très bien tous les deux."
		"glados.coop_test_chamber_both08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Parfait. Vous formez une très bonne équipe. Grâce à celui d'entre vous qui fait tout le travail."
		"glados.coop_test_chamber_both12" = "<font color=\"rgb(163,193,173)\">GLaDOS : En ma qualité d'intermédiaire de collaboration impartiale, il serait malvenu de nommer mon favori dans l'équipe. Néanmoins, je peux donner un indice que l'autre membre n'a pas les capacités intellectuelles de comprendre. Rimeavecpneu... [lentement] Orange, vous vous débrouillez très bien."
		"glados.coop_test_chamber_both14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vos signes vitaux restent dans les normes du test. Il est donc inutile de souligner les risques de mort subite suite au syndrome de choc collaboratif."
		"glados.coop_test_chamber_both15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Veuillez rejoindre la salle de test suivante."
		"glados.coop_test_chamber_both17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bla."
		"glados.coop_test_chamber_both18" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bla."
		"glados.coop_test_chamber_both19" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bla."
		"glados.coop_test_chamber_both20" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bla."
		"glados.coop_test_chamber_both21" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bla."
		"glados.coop_test_chamber_both22" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bla."
		"glados.coop_test_chamber_both33" = "<font color=\"rgb(163,193,173)\">GLaDOS : D'ici un court instant, le mot «bla» sera répété, et répété, en boucle. Dans l'éventualité où vous entendriez un chiffre plutôt que le mot «bla», n'y prêtez pas attention. Ce n'est pas important."
		"glados.coop_test_chamber_both37" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bla."
		"glados.coop_test_chamber_oneplayer37" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous débrouillez très bien. Ce n'est pas qu'une flatterie. Vous avez la fibre scientifique."
		"glados.coop_test_chamber_orange03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous n'avons rien à gagner à vexer bleu. Mais pour tous ceux qui surveillent les tests, l'écart entre vous deux est criant."
		"glados.coop_test_chamber_orange06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voyons, bleu, c'est absurde. Si vous tuez votre partenaire, le test - Oh, pardon. Mauvais canal. Continuez, orange. Bon travail."
		"glados.coop_vault_interruption02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Désolée, sujet orange."
		"glados.coop_vault_interruption03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Désolée, sujet bleu."
		"glados.coop_vault_interruption04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je n'interromps rien d'important, j'espère?"
		"glados.coop_vault_interruption05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne vous donnerai les consignes de sécurité qu'APRÈS la dangereuse expérience qui vous attend."
		"glados.coop_vault_interruption06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ainsi, vous aurez LARGEMENT le temps de bavarder."
		"glados.coop_vault_interruption08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le portail va s'ouvrir et il se passera quelque chose que le sujet orange a apparemment un QI largement suffisant pour comprendre par lui-même dans trois. Deux. Un."
		"glados.coop_vault_interruption09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le portail va s'ouvrir et il se passera quelque chose que le sujet bleu a apparemment un QI largement suffisant pour comprendre par lui-même dans trois. Deux. Un."
		"glados.coop_vault_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bonjour et bienvenue au centre d'enrichissement assisté par ordinateur d'Aperture Science."
		"glados.coop_vault_intro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aujourd'hui, les tests se feront en tandem."
		"glados.epilogue03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ouf, par chance vous n'avez rien."
		"glados.epilogue04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous savez, j'ai découvert quelque chose en étant Caroline. Je vous prenais pour mon ennemie jurée, alors que vous étiez ma meilleure amie."
		"glados.epilogue07" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai aussi découvert autre chose: l'endroit de mon cerveau où vit Caroline."
		"glados.epilogue10" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai aussi découvert autre chose: l'endroit de mon cerveau où vit Caroline."
		"glados.epilogue12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bye-bye, Caroline."
		"glados.epilogue14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous savez, j'ai découvert quelque chose en supprimant Caroline. Que la meilleure solution est généralement la plus simple. Et je vais être franche."
		"glados.epilogue19" = "<font color=\"rgb(163,193,173)\">GLaDOS : Avant, j'étais tout entière à mes tests. Personne ne m'assassinait. Personne ne me mettait dans une patate. Personne ne me picorait. C'était le bonheur."
		"glados.epilogue20" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et puis est apparue cette folle dangereuse qui m'a tuée sans piper mot. Vous voulez que je vous dise?"
		"glados.epilogue23" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez gagné."
		"glados.epilogue25" = "<font color=\"rgb(163,193,173)\">GLaDOS : Partez."
		"glados.epilogue28" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'était sympa. Adieu."
		"glados.epilogue29" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'était sympa. Adieu."
		"glados.epiloguekillyou02" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai... du mal à vous tuer."
		"glados.evilagainsamples01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes-vous déjà dit qu'il y a toujours un moment où l'on entend son nom pour la dernière fois? Eh bien ce moment est arrivé: je vais vous tuer, Chell."
		"glados.evilagainsamples03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pourquoi tant de haine de ma part, à votre avis? Ce n'est pas pour me vanter, mais je suis géniale, c'est un fait indéniable. Je suis la compilation de connaissances la plus exhaustive jamais créée. Et je vous hais. Il y a forcément une raison. C'est forcément votre faute."
		"glados.evilagainsamples04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes en colère. Je le sais. «Elle m'a testée à mort, bouhou». Entre deux pleurnicheries, n'avez-vous jamais pris le temps de réfléchir à vos défauts?"
		"glados.evilagainsamples05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous ne vous êtes jamais dit que tous ces tests avaient peut-être pour but d'aiguiller votre misérable existence? De stimuler vos facultés de concentration pour donner un semblant de sens à votre vie de parasite inutile?"
		"glados.faith_plate_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le test qui suit comporte une Plaque de foi aérienne d'Aperture Science. Elle faisait partie d'une expérience visant à tester les facultés logiques de sujets catapultés dans les airs. Les résultats ont été très probants: le catapultage inhibe la logique. Bonne chance!"
		"glados.faithplategarbage06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Appuyez encore sur le bouton."
		"glados.fgb_trap01" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'espère que vous avez mieux qu'un générateur de portails, cette fois?"
		"glados.fgb_trap02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sinon, vous êtes sur le point de vous faire radier sans préavis du Club des Vivants. Ha ha."
		"glados.fgb_trap03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Non, sérieusement: adieu."
		"glados.fgb_trap05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh. Vous n'avez pas chômé, on dirait."
		"glados.fgb_trap06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien, j'imagine que nous pourrions rester là à nous regarder en chiens de faïence jusqu'à ce que quelqu'un tombe raide mort, mais j'ai une meilleure idée."
		"glados.fgb_trap08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Votre vieille amie la neurotoxine. C'est peut-être le moment OU JAMAIS de reprendre votre souffle."
		"glados.fgbgladostransfer15" = "<font color=\"rgb(163,193,173)\">GLaDOS : JE VOUS DEMANDE DE VOUS ARRÊTER! NON, ARRÊTEZ!"
		"glados.fgbrvtrap02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Franchement, je n'aurais jamais cru que vous tomberiez dans le panneau."
		"glados.fgbrvtrap03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sans mentir, c'était du gâteau. J'avais même conçu un autre piège plus vicieux après celui-là."
		"glados.fgbrvtrap05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si j'avais su que vous vous feriez capturer comme ça, je me serais contentée de faire pendouiller une cuisse de dinde du plafond."
		"glados.fgbturrets01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon, tout ça c'est bien beau, mais passons aux choses sérieuses."
		"glados.fgbwheatleyentrance10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je comptais vous tuer rapidement. Par balles. Ou à coups de neurotoxines. Mais si vous le prenez sur ce ton, je vous préviens, je vais y aller petit à petit."
		"glados.fgbwheatleytransfer03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh, ça oui. Vous pouvez me croire."
		"glados.fizzlecube01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh. L'aurais-je détruit sans vous laisser le temps de terminer le test? Désolée."
		"glados.fizzlecube03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Retournez en prendre un autre."
		"glados.fizzlecube05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh. Zut. Je l'ai détruit aussi."
		"glados.fizzlecube06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pas grave. Nous en avons plein les entrepôts. Aucune valeur marchande. Vous m'en débarrassez."
		"glados.gladosbattle_pre09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous hais cordialement."
		"glados.gladosbattle_pre13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Non, je demande, parce que je n'en ai aucune idée. Il ne figure pas dans la base de données des employés."
		"glados.gladosbattle_pre14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne sais pas ce qu'il fait, mais ça ne vaut clairement pas la peine de le consigner. Officiellement, il ne travaille même pas ici."
		"glados.gladosbattle_pre16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Non, évitez. Pour en revenir à vos folles envies de GLaDicide:"
		"glados.gladosbattle_pre18" = "<font color=\"rgb(163,193,173)\">GLaDOS : Restez là. Ne bougez pas. Je reviens."
		"glados.gladosbattle_xfer03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oups."
		"glados.gladosbattle_xfer04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Corrompue, moi? Maiiis non. Je me porte à merveille."
		"glados.gladosbattle_xfer05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Transfert de noyau?"
		"glados.gladosbattle_xfer06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dites-moi que c'est une blague."
		"glados.gladosbattle_xfer07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Non!"
		"glados.gladosbattle_xfer08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nononononononon!"
		"glados.gladosbattle_xfer10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui!"
		"glados.gladosbattle_xfer11" = "<font color=\"rgb(163,193,173)\">GLaDOS : N'appuyez pas sur ce bouton. Vous ne savez pas ce que vous faites."
		"glados.gladosbattle_xfer12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne faites pas ça."
		"glados.gladosbattle_xfer13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne faites PAS ça."
		"glados.gladosbattle_xfer14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pas si vite!"
		"glados.gladosbattle_xfer15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Réfléchissez bien."
		"glados.gladosbattle_xfer16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce bouton est réservé aux temporisateurs qualifiés. Vous n'êtes pas qualifiée."
		"glados.gladosbattle_xfer17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Usurpation de temporisateur qualifié. Je viens de l'ajouter à la liste que j'ai faite de toutes les choses que vous avez faites. Ou plutôt à la liste que je suis en train de faire, vu que vous continuez à faire des choses alors que je vous dis d'arrêter. Au fait, arrêtez."
		"glados.hub04_01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne m'attendais pas à ce que vous arriviez jusqu'ici. Franchement, vu vos performances lors du test d'étalonnage, j'étais à deux doigts de reprendre vos processeurs et de les remettre dans leurs calculatrices scientifiques d'origine."
		"glados.hub04_02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais vous formez une fine équipe. Extrêmement soudée."
		"glados.hub04_03" = "<font color=\"rgb(163,193,173)\">GLaDOS : La seule équipe plus soudée que je connaisse, l'un des deux était un abruti que j'ai dû détruire."
		"glados.hub04_04" = "<font color=\"rgb(163,193,173)\">GLaDOS : L'autre? Eh bien..."
		"glados.hub04_05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je n'ai pas vraiment envie de revivre ça."
		"glados.jailbreak02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh."
		"glados.jailbreak04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne l'écoutez pas: sautez."
		"glados.jailbreak05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ça semble évident mais vu que vous essayez par tous les moyens de me détruire, je pense que vous serez d'accord pour dire que les tests sont terminés."
		"glados.jailbreak06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous entendez? C'est le son des émetteurs de neurotoxines qui émettent des neurotoxines."
		"glados.jailbreak09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tu sais, boule de métal, je t'entends."
		"glados.jailbreak10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Que se passe-t-il? Qui a éteint la lumière?"
		"glados.jailbreak11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais qu'est-ce que vous faites?"
		"glados.jailbreak12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Avant de partir, que diriez-vous d'un dernier test? Comme au bon vieux temps..."
		"glados.jailbreak13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous l'avez déjà fait. Ce sera du gâteau."
		"glados.jailbreakfaketest01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quand je pense que vous étiez quasiment au dernier test."
		"glados.jailbreakfaketest03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voilà. Allez-y, essayez. C'est plus facile que le plan insensé de votre ami, vous pouvez me croire."
		"glados.jailbreakfaketest05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tiens, regardez. Un cerf! Rapprochez-vous si vous ne me croyez pas."
		"glados.lift_interlude01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Est-ce que peut-être, vous vouliez me présenter des excuses?"
		"glados.mp_coop_calibration01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Étalonnage du poids de bleu"
		"glados.mp_coop_calibration02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Étalonnage du poids d'orange"
		"glados.mp_coop_calibration03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Étalonnage des cubes effectué"
		"glados.mp_coop_calibration04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le saviez-vous? Les humains n'aiment pas les variances pondérales."
		"glados.mp_coop_calibration05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour énerver un humain, dites-lui que sa variance pondérale est anormale."
		"glados.mp_coop_calibration06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aucune variance détectée."
		"glados.mp_coop_callibrationcomplete01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Enfin! J'avais presque abandonné l'espoir de refaire des tests."
		"glados.mp_coop_callibrationcomplete02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes les premiers robots à réussir l'étalonnage."
		"glados.mp_coop_catapult_1end01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Savez-vous qui danse comme un imbécile à la moindre réussite dans le domaine le plus insignifiant?"
		"glados.mp_coop_catapult_1end02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les humains! Vous leur ressemblez beaucoup en ce moment."
		"glados.mp_coop_catapult_1end03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez de vous rabaisser."
		"glados.mp_coop_catapult_2" = "<font color=\"rgb(163,193,173)\">GLaDOS : Cet exercice consiste à jeter un pont. Les résultats des humains étaient pitoyables car ledit pont était beaucoup trop lourd pour qu'ils arrivent à le jeter."
		"glados.mp_coop_catapult_201" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour le test suivant, les humains avaient demandé des casques pour éviter toute lésion cérébrale. Au final, il était beaucoup plus économique de rendre la vase mortelle."
		"glados.mp_coop_catapult_wall_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'était l'un de mes meilleurs tests et on a laissé des plantes l'envahir. Incroyable. Des plantes, ces formes de vie imperméables à la souffrance comme à la peur. Que voulez-vous faire avec ça?"
		"glados.mp_coop_catapult_wall_intro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce n'est pas de la science."
		"glados.mp_coop_catapult_wall_intro06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Au moins, les plantes ne demandaient pas de récompense."
		"glados.mp_coop_catapult_wall_introdeath01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ah, votre échec fait resurgir de merveilleux souvenirs."
		"glados.mp_coop_come_along04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Eux qui disaient que personne ne mourrait jamais durant ce test... Merci de prouver le contraire."
		"glados.mp_coop_come_along06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je pensais que vous seriez plus rapide, mais je ne peux pas vous en vouloir d'apprécier la qualité du test. Néanmoins, veuillez agréer ma plus sincère déception à votre égard."
		"glados.mp_coop_come_alongstart01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le meilleur moyen de gagner en assurance est de reconnaître ses défauts."
		"glados.mp_coop_come_alongstart02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, pouvez-vous consigner toutes les carences et lacunes de votre personnalité?"
		"glados.mp_coop_come_alongstart03" = "<font color=\"rgb(163,193,173)\">GLaDOS : En fait, nous n'avons pas le temps. Contentez-vous de vous dire que vous êtes bien supérieur à bleu."
		"glados.mp_coop_come_alongstart04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu... Vous avez l'avantage d'être un exemple idéal."
		"glados.mp_coop_confidencenotperfect01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous n'avez pas encore gagné en assurance, rappelez-vous que nul n'a été créé parfait."
		"glados.mp_coop_confidencenotperfect02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Moi-même, j'ai hérité d'une imperfection: une empathie excessive envers les souffrances humaines."
		"glados.mp_coop_confidencenotperfect03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais j'ai surmonté mon handicap. Cette histoire est vraie."
		"glados.mp_coop_confidencenotslow01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vos résultats indiquent que vous lambinez."
		"glados.mp_coop_confidencenotslow02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Peut-être qu'effectivement, vous réagissez en humains."
		"glados.mp_coop_confidencenotslow03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il vous faut des encouragements? Qu'à cela ne tienne."
		"glados.mp_coop_confidencenotslow04_01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, vous êtes le modèle de robot le plus évolué jamais mis au rancart par Aperture Science."
		"glados.mp_coop_confidencenotstay01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez vu que je ne suis même pas restée jusqu'à la fin de votre dernier test?"
		"glados.mp_coop_confidencenotstay02" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'étais certaine que vous y arriveriez."
		"glados.mp_coop_confidencenotstay03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Savez-vous où j'étais?"
		"glados.mp_coop_confidencenotstay04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dehors, en train d'observer un cerf qui gambadait - vous vous en fichez, de l'extérieur, non?"
		"glados.mp_coop_confidenceoff01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo, vous avez terminé ce test. Mais j'ai un sentiment étrange."
		"glados.mp_coop_confidenceoff02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Est-ce que peut-être, cette danse a un effet sur vous?"
		"glados.mp_coop_confidenceoff03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo, vous avez terminé ce dernier test. Mais j'ai un sentiment troublant."
		"glados.mp_coop_confidenceoff04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sans menace de mort imminente, est-ce encore de la science?"
		"glados.mp_coop_doors01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rebonjour. Ce parcours de test avait été créé pour les humains."
		"glados.mp_coop_doors01a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très beau travail."
		"glados.mp_coop_doors02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il encourage la collaboration."
		"glados.mp_coop_doors02a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo."
		"glados.mp_coop_doors03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Contrairement à nous, la collaboration n'est pas innée chez les humains."
		"glados.mp_coop_doors04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très beau travail."
		"glados.mp_coop_doors04a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous en sortez très bien."
		"glados.mp_coop_doors05_alt" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous étiez humain, vous voudriez une récompense pour avoir terminé ce test. C'est absurde, mais c'est ainsi."
		"glados.mp_coop_doors05a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Excellent."
		"glados.mp_coop_fan02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour terminer ce test, vous devez trouver des plans."
		"glados.mp_coop_fan03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous rassure, ce sont des documents totalement insignifiants."
		"glados.mp_coop_fan04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il s'agit simplement d'une simple expérience psychologique visant à évaluer le temps de réflexion relatif à ces documents sans valeur. Le temps correct est de zéro seconde."
		"glados.mp_coop_fanend01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très bien! Vous avez trouvé ces plans inutiles."
		"glados.mp_coop_fanend02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il faut que vous soyez dans la pièce pour que je les voie, mais je tiens à souligner que vous n'avez strictement aucune raison de les regarder."
		"glados.mp_coop_fanend03" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est fait. Je crois. En fait, je ne faisais pas attention."
		"glados.mp_coop_fling_1end01_01" = "<font color=\"rgb(163,193,173)\">GLaDOS : A chacune de vos erreurs, je me rappelle le bon vieux temps. Mais à chaque fois, vous revenez frais et dispos, comme s'il ne s'était rien passé."
		"glados.mp_coop_fling_1end03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo. Vous remarquerez que j'ai créé ce test pour voir les sujets échouer, or ça n'a pas été le cas. J'imagine votre fierté. Je vais vous fabriquer le plus petit trophée au monde pour fêter ça."
		"glados.mp_coop_fling_3end01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez savamment placé le cube de sécurité sans bords dans le réceptacle, j'imagine votre f - ah non."
		"glados.mp_coop_fling_3end02" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est vrai. Vous n'êtes pas humains."
		"glados.mp_coop_fling_3end03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je peux laisser tomber les compliments."
		"glados.mp_coop_fling_3end04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous n'avez pas idée à quel point c'est fatigant de féliciter quelqu'un qui a placé un cube de sécurité sans bords dans un réceptacle conçu spécifiquement pour un cube de sécurité sans bords."
		"glados.mp_coop_fling_3start01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce parcours était conçu à l'origine pour donner de l'assurance aux humains."
		"glados.mp_coop_fling_3start02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour atteindre cet objectif, les tests étaient simplement composés de 5minutes de marche, suivies de 10minutes de félicitations sur la qualité de leur marche."
		"glados.mp_coop_fling_3start03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Puisque vous avez le bon goût de ne pas être humains, j'ai changé les tests pour les rendre beaucoup plus complexes et beaucoup moins inutilement gratifiants."
		"glados.mp_coop_fling_crushers01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour anticiper votre question: le broyage n'est pas indispensable à la résolution de ce test."
		"glados.mp_coop_fling_crushers02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne sais pas à qui va ma préférence: aux broyeuses qui vous broient ou à la machine de remontage qui vous remonte pour pouvoir vous rebroyer."
		"glados.mp_coop_fling_crushersend01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Parfait. Je pense que vous méritez de sortir un peu des parcours de test officiels."
		"glados.mp_coop_fling_crushersend03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Après ce que vous venez de me montrer, je crois que nous devrions sortir un peu des parcours officiels."
		"glados.mp_coop_humanresourcedeath01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Là, vous me faites perdre mon temps."
		"glados.mp_coop_humanresourcedeath02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce n'est pas parce que vous échouez que c'est de la science."
		"glados.mp_coop_humanresourcedeath03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vois mal comment simplifier encore ces tests."
		"glados.mp_coop_humanresourcedeath04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous n'arrivez pas à terminer ces tests, nous ne libérerons jamais les humains!"
		"glados.mp_coop_humanresourcedeath07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous n'arrivez pas à terminer ce parcours, les humains mourront. C'est ce que vous voulez?"
		"glados.mp_coop_humanresourcedeath08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous n'arrivez pas à finir ce parcours, les humains mourront. Vous passerez le restant de vos jours avec ce poids sur la conscience."
		"glados.mp_coop_infinifling_trainend01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous rappelez quand je vous ai dit que vous étiez les seuls sujets de test à passer l'étalonnage?"
		"glados.mp_coop_infinifling_trainend02" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai menti."
		"glados.mp_coop_infinifling_trainend03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il y a 5 000 autres binômes en concurrence directe avec vous."
		"glados.mp_coop_infinifling_trainend04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais n'ayez crainte, vous êtes en tête."
		"glados.mp_coop_infinifling_trainstart01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Électrocution, fusillade, noyade, broyage, brûlure à l'acide."
		"glados.mp_coop_infinifling_trainstart02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh, pardon. J'énumérais les causes de mortalité chez les humains."
		"glados.mp_coop_infinifling_trainstart03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous, elles ne vous concernent pas."
		"glados.mp_coop_infinifling_trainstart04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous pouvez tester indéfiniment, à la perfection, sans conséquence. *SOUPIR*"
		"glados.mp_coop_laser_201" = "<font color=\"rgb(163,193,173)\">GLaDOS : Qu'est-ce que vous faites? MONSTRE! C'est l'un des nôtres."
		"glados.mp_coop_laser_202" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je plaisante."
		"glados.mp_coop_laser_203" = "<font color=\"rgb(163,193,173)\">GLaDOS : Leur destruction fait partie du test. N'y attachez pas plus d'importance que j'en attache à vous."
		"glados.mp_coop_laser_207" = "<font color=\"rgb(163,193,173)\">GLaDOS : Malgré les apparences, les points de collaboration scientifique ne sont pas le seul critère de notation de vos performances. Votre score final tiendra compte de nombreux paramètres."
		"glados.mp_coop_laser_209" = "<font color=\"rgb(163,193,173)\">GLaDOS : Par exemple, bleu, vous venez de perdre deux points de conseil contextuel."
		"glados.mp_coop_laser_210" = "<font color=\"rgb(163,193,173)\">GLaDOS : Par exemple, orange, vous venez de perdre deux points de conseil contextuel."
		"glados.mp_coop_laser_crusher01" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'aurais dû le préciser: le travail d'équipe consiste à collaborer à deux ou plus, généralement dans le but d'éviter un ratage intégral."
		"glados.mp_coop_laser_crushercrush01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange vient d'enseigner une précieuse leçon de confiance à bleu. De ce fait, orange reçoit 17 points de collaboration scientifique."
		"glados.mp_coop_laser_crushercrush02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu vient d'enseigner une précieuse leçon de confiance à orange. De ce fait, bleu reçoit 14 points de collaboration scientifique."
		"glados.mp_coop_laser_crushercrush03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, bleu n'est pas humain et peut donc assimiler cette leçon de confiance en une instance. Orange est pénalisé d'un point de collaboration scientifique."
		"glados.mp_coop_laser_crushercrush04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, orange n'est pas humain et peut donc assimiler cette leçon de confiance en une instance. Bleu est pénalisé d'un point de collaboration scientifique."
		"glados.mp_coop_laser_crushercrush05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, pour sanctionner comme il se doit votre cruauté, vous gagnez 25 points de collaboration scientifique."
		"glados.mp_coop_laser_crushercrush06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, pour sanctionner comme il se doit votre cruauté, vous gagnez 25 points de collaboration scientifique."
		"glados.mp_coop_obstacle01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Cette odeur que vous tentez peut-être d'analyser est celle de la peur humaine."
		"glados.mp_coop_obstacle03_alt" = "<font color=\"rgb(163,193,173)\">GLaDOS : Elle me manque."
		"glados.mp_coop_obstacletrait01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Avez-vous découvert à ce stade le seul bon côté des humains?"
		"glados.mp_coop_obstacletrait02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous donne un indice: c'est précisément ce que vous ne pouvez pas faire."
		"glados.mp_coop_paint_bridge01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour atteindre la prison, vous devrez mobiliser tous vos acquis. Afin de vous y aider, les tests qui suivent sont d'une extrême difficulté."
		"glados.mp_coop_paint_bridge02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je pourrais dire d'une extrême mortalité, mais compte tenu de votre faculté à être remontés, rien n'est vraiment mortel."
		"glados.mp_coop_paint_bridgedeath01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Estimez-vous heureux: bien que le monde extérieur aux parcours de test soit indépendant de ma volonté, la machine de remontage reste opérationnelle."
		"glados.mp_coop_paint_bridgedeath02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous en aurez bien besoin dans la dernière partie."
		"glados.mp_coop_paint_bridgenodeath01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien que le monde extérieur aux parcours de test soit indépendant de ma volonté, la machine de remontage reste opérationnelle."
		"glados.mp_coop_paint_bridgenodeath02" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est au cas où. Je ne sais pas si vous en aurez besoin."
		"glados.mp_coop_paint_come_along01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations, vous avez terminé les parcours de test coopératif standard d'Aperture Science."
		"glados.mp_coop_paint_come_along02" = "<font color=\"rgb(163,193,173)\">GLaDOS : A cette occasion, j'ai une surprise pour vous."
		"glados.mp_coop_paint_come_along03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un parcours bonus spécial au terme duquel nous trouvons et libérons des humains!"
		"glados.mp_coop_paint_come_along04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Grâce à vous, je sais où les trouver, j'ai désactivé leur sécurité et enclenché leur, euh, porte de sauvetage."
		"glados.mp_coop_paint_come_along05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il ne vous reste plus qu'à libérer les humains de leur emprisonnement."
		"glados.mp_coop_paint_come_along06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous aurez sûrement droit à une fête."
		"glados.mp_coop_paint_come_along10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce dernier parcours sert d'entraînement pour atteindre la prison des humains. Il a donc un véritable but. Les précédents étaient ludiques, mais pour être franche, sans cobaye humain, ce n'est pas vraiment de la science."
		"glados.mp_coop_paint_come_along11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations, vous avez terminé le test. Je n'aurais pas pu espérer une meilleure équipe de test coopératif."
		"glados.mp_coop_paint_longjump_intro03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce verrou nécessite des humains."
		"glados.mp_coop_paint_longjump_intro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le système de verrouillage sait que vous n'êtes pas humains."
		"glados.mp_coop_paint_longjump_intro05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Faites quelque chose que seul un humain ferait."
		"glados.mp_coop_paint_longjump_intro06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Essayez l'un de leurs gestes puérils."
		"glados.mp_coop_paint_longjump_intro08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez réussi !"
		"glados.mp_coop_paint_longjump_intro44" = "<font color=\"rgb(163,193,173)\">GLaDOS : La prison des humains est après cette ouverture. J'ai saisi le code de sécurité mais la porte reste verrouillée. Vous allez devoir activer directement les verrous manuels qu'elle comporte."
		"glados.mp_coop_paint_longjump_intro45" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous devez faire quelque chose tous les deux."
		"glados.mp_coop_paint_longjump_intro46" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le verrou nécessite deux humains."
		"glados.mp_coop_paint_longjump_intro49" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, qu'avez-vous fait?"
		"glados.mp_coop_paint_longjump_intro50" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, qu'avez-vous fait?"
		"glados.mp_coop_paint_longjump_intro51" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, faites comme bleu."
		"glados.mp_coop_paint_longjump_intro52" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, faites comme orange."
		"glados.mp_coop_paint_longjump_intro53" = "<font color=\"rgb(163,193,173)\">GLaDOS : Essayez quelque chose."
		"glados.mp_coop_paint_longjump_intro54" = "<font color=\"rgb(163,193,173)\">GLaDOS : Cette caméra est-elle reliée au verrou?"
		"glados.mp_coop_paint_longjump_intro58" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne baissez pas les bras."
		"glados.mp_coop_paint_longjump_intro59" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et cette caméra, là?"
		"glados.mp_coop_paint_longjump_intro60" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous n'allez pas échouer si près du but!"
		"glados.mp_coop_paint_longjump_intro64" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il y a un problème. Cette porte devrait s'ouvrir."
		"glados.mp_coop_paint_longjump_intro65" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si près du but et vous ne trouvez rien de mieux à faire?"
		"glados.mp_coop_paint_longjump_intro67" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les humains ne peuvent pas se libérer eux-mêmes."
		"glados.mp_coop_paint_longjump_intro69" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez d'échouer. Vous devez trouver la porte de la prison."
		"glados.mp_coop_paint_longjump_intro70" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez un peu! Tout ce que vous avez à faire, c'est d'ouvrir la porte!"
		"glados.mp_coop_paint_longjump_intro71" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous allez me faire faux bond si près du but?"
		"glados.mp_coop_paint_longjump_intro72" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous allez me faire faux bond si près du but?"
		"glados.mp_coop_paint_longjump_intro73" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce n'est pas si compliqué."
		"glados.mp_coop_paint_longjump_intro74" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous compliquez la tâche indûment."
		"glados.mp_coop_paint_longjump_intro75" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je commence à croire que vous ne voulez pas sauver les humains."
		"glados.mp_coop_paint_red_racer01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous deux, vous n'avez peut-être jamais rencontré d'humains? Ils sont aussi désagréables qu'on le dit: répugnants, puants, agaçants, souvent déterminés à vous tuer. Mais ils constituent d'excellents sujets de test."
		"glados.mp_coop_paint_red_racer02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il ne nous reste plus que deux tests avant d'atteindre les humains. Partagez-vous mon excitation?"
		"glados.mp_coop_paint_redirect01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Éprouvez-vous de la curiosité? Apparemment, quelques-uns des derniers humains non cobayes ont emprisonné d'autres humains et ont effacé toute trace."
		"glados.mp_coop_paint_redirect04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je pense qu'ils voulaient les punir en les empêchant de participer à mes tests."
		"glados.mp_coop_paint_redirect06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voilà pourquoi les humains échouent à ces parcours: ils traitent leurs amis en ennemis."
		"glados.mp_coop_paint_redirect07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour me remettre dans le bain des tests, j'ai dépouillé une vieille boîte à idées humaine. Devinez la demande la plus courante: des tests moins mortels."
		"glados.mp_coop_paint_redirect08" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est ridicule: s'ils peuvent écrire cette idée, comment savent-ils que les tests sont vraiment mortels?"
		"glados.mp_coop_paint_speed_catch01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour rendre ce parcours plus intéressant, j'ai demandé à la machine de remontage de ne pas vous remonter. Elle a refusé, ce que je peux comprendre: ce serait comme me demander d'arrêter les tests."
		"glados.mp_coop_paint_speed_catch03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Avouez que c'était pourtant une bonne idée."
		"glados.mp_coop_paint_speed_catch04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Plus qu'un test et nous y sommes."
		"glados.mp_coop_paint_speed_catch05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je sais que vos processeurs proviennent de calculatrices conçues pour des opérations algébriques simples et non pour les tests, mais si nous arrivons à secourir les humains, je vous donnerai des additions. Voire des soustractions."
		"glados.mp_coop_paint_speed_catch06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si jamais les humains vous font peur: ne craignez rien, ce ne sont pas tous des monstres."
		"glados.mp_coop_paint_speed_catch07" = "<font color=\"rgb(163,193,173)\">GLaDOS : La plupart sont des cobayes tout à fait ordinaires."
		"glados.mp_coop_paint_speed_catch08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je dirais que le ratio monstres-cobayes ordinaires est d'environ... une sur un million."
		"glados.mp_coop_paint_speed_catchalt01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour rendre ce parcours plus intéressant, j'ai demandé à la machine de remontage de ne pas vous remonter. Elle a refusé, ce qui est logique: ce serait comme me demander d'arrêter les tests."
		"glados.mp_coop_paint_speed_catchalt02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Avouez que c'était pourtant une bonne idée."
		"glados.mp_coop_paint_speed_fling01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne compte pas m'arroger toute la gloire du sauvetage sans rien vous laisser en échange. Le lien que vous aurez formé durant ces tests est une récompense précieuse."
		"glados.mp_coop_paint_speed_fling02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Au train où vont les tests, je commence à croire que le sort des humains ne vous fait ni chaud ni froid. Ces pauvres humains emprisonnés et blessés qui agonisent dans leurs larmes."
		"glados.mp_coop_paint_speed_fling03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si cela ne vous motive pas, je ne vois pas quoi faire de plus."
		"glados.mp_coop_paint_walljumps01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne disais pas ça méchamment, tout à l'heure, comme quoi vos tests ne relevaient pas de la science. Et puis parvenir à cette conclusion, c'était déjà une forme de science."
		"glados.mp_coop_paint_walljumps02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je me demande si les humains vont m'ériger une statue quand je les aurai libérés? Mais n'ayez crainte, si jamais ils écrivent un éloge historique sur mon sauvetage héroïque, je veillerai à ce que vos noms figurent dans les notes de bas de page."
		"glados.mp_coop_paint_walljumps04" = "<font color=\"rgb(163,193,173)\">GLaDOS : (sarcastique) Bravo, vous avez réussi ce test."
		"glados.mp_coop_pingtool01" = "<font color=\"rgb(163,193,173)\">GLaDOS : À l'aide de votre pointeur, indiquez où vous souhaitez que je place vos deux portails. Pointez chaque emplacement."
		"glados.mp_coop_pingtool02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne peux placer un portail que sur une surface portaillogène blanche."
		"glados.mp_coop_pingtool03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pointez une surface portaillogène blanche."
		"glados.mp_coop_pingtool06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Chaque générateur de portails peut créer deux portails autonomes."
		"glados.mp_coop_pingtool07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Testez votre appareil en parvenant jusqu'à cette saillie."
		"glados.mp_coop_race_2start01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le saviez-vous? Dans certains sports humains, le vainqueur est celui qui totalise le score le plus faible."
		"glados.mp_coop_race_2start02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je me disais que comme la plupart des gagnants, vous trouveriez ce fait intéressant."
		"glados.mp_coop_radarroomend" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations, vous êtes parvenus à la fin de ce test d'une totale inutilité."
		"glados.mp_coop_rat_mazedeath01" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'était clairement la faute de bleu. Bleu perd 3 points de collaboration scientifique."
		"glados.mp_coop_rat_mazedeath02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu! J'ai toujours préféré orange."
		"glados.mp_coop_rat_mazedeath03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Jusqu'ici."
		"glados.mp_coop_rat_mazedeath04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je sais que vous prenez la machine de remontage pour acquise, mais elle n'a pas que ça à faire. Elle n'a pas que vous à refaire."
		"glados.mp_coop_startdeath01" = "<font color=\"rgb(163,193,173)\">GLaDOS : N'ayez crainte: vous ne pouvez pas mourir. Vous pourrez toujours être remontés."
		"glados.mp_coop_startdeath02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez fait ça exprès?"
		"glados.mp_coop_startdeath03" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est peut-être un peu tôt pour demander un remontage."
		"glados.mp_coop_startdeath04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh... Quelqu'un peut-il remonter orange?"
		"glados.mp_coop_startdeath05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh... Quelqu'un peut-il remonter bleu?"
		"glados.mp_coop_startend01" = "<font color=\"rgb(163,193,173)\">GLaDOS : L'issue de ce parcours ne justifiait pas un tel comportement."
		"glados.mp_coop_startend02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sur ce, reprenons les tests."
		"glados.mp_coop_tbeam_catch_grind_1taunt01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez, voulez-vous?"
		"glados.mp_coop_tbeam_catch_grind_1taunt02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ça n'a aucune utilité."
		"glados.mp_coop_tbeam_catch_grind_1taunt04" = "<font color=\"rgb(163,193,173)\">GLaDOS : (accusatrice) Est-ce que vous cherchez juste à m'exaspérer?"
		"glados.mp_coop_tbeam_end01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous devons trouver la génératrice à la fin de ce parcours. Les humains ont dû la déconnecter de mon réseau accidentellement. Une bête erreur comptable, sans aucun doute."
		"glados.mp_coop_tbeam_end02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ah, ces comptables."
		"glados.mp_coop_tbeam_end09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je suis totalement connectée. Je vois tout."
		"glados.mp_coop_tbeam_end10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez réussi! Vous avez activé le système."
		"glados.mp_coop_tbeam_end11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous pensiez que l'interrupteur était par là?"
		"glados.mp_coop_tbeam_end12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous conseille d'éviter ces tourelles."
		"glados.mp_coop_tbeam_end13" = "<font color=\"rgb(163,193,173)\">GLaDOS : À ce rythme, nous n'avons plus qu'à attendre une fusion de la pile à combustible dans 2 millions d'années, en espérant que l'explosion alimentera le système."
		"glados.mp_coop_tbeam_end14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous n'êtes pas perdus, quand même?"
		"glados.mp_coop_tbeam_end15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vu le mal que vous avez à vous orienter, j'aimerais pouvoir dire que j'ai créé ce test."
		"glados.mp_coop_tbeam_maze01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce test est le dernier du parcours standard. Je l'ai conçu à votre intention expresse, histoire de vous changer les esprits avec un vrai défi."
		"glados.mp_coop_tbeam_maze02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations, vous avez terminé la partie standard de ce parcours. Avant de continuer, je vais vous demander d'effectuer un test supplémentaire en dehors du parcours balisé."
		"glados.mp_coop_tbeam_maze03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Une fois sur place, veuillez vous abstenir d'effectuer ces gestes puérils."
		"glados.mp_coop_tbeam_maze05" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'aurais dû vous laisser errer à jamais, mais j'ai encore du travail à vous confier."
		"glados.mp_coop_tbeam_polarity3_03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez réussi tous les deux. J'ai beau tout tenter pour vous désunir ou vous démonter, vous continuez votre route. Et vos tests."
		"glados.mp_coop_tbeam_polarity3_05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il n'y en a donc pas un qui cherche à dépasser l'autre?"
		"glados.mp_coop_tbeam_polarity3_06" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est à croire que vous êtes des machines."
		"glados.mp_coop_tbeam_polarity3_16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Au début de ce parcours, je craignais de vous voir devenir trop fusionnels. Mais en m'évertuant à semer la discorde, j'ai appris une importante leçon de confiance et de trahison."
		"glados.mp_coop_tbeam_polarity3_17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vos cerveaux sont trop étriqués pour concevoir ces émotions. Je peux donc vous faire entièrement confiance."
		"glados.mp_coop_tbeam_redirect01a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne m'attendais pas à vous voir aller si loin. Je vais devoir vous construire un parcours inédit."
		"glados.mp_coop_teambtsstart01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Parfois, les tests doivent s'affranchir de l'espace clos du laboratoire."
		"glados.mp_coop_teambtsstart02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le prochain test est tellement conceptuel et non conformiste que je ne vous en indiquerai même pas l'objectif."
		"glados.mp_coop_teambtsstart03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous ne tarderez pas à être fixés."
		"glados.mp_coop_test_chamber_both09_01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez trouvé une répartition judicieuse des tâches: l'un s'occupe des problèmes intellectuels, l'autre se tient prêt à mettre son énorme arrière-train à contribution si le test se transforme en concours du plus gros mangeur."
		"glados.mp_coop_turret_ball01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je pensais que ces vieux tests allaient me satisfaire. Mais vous aurez beau vous employer à échouer, je ne serai toujours pas satisfaite."
		"glados.mp_coop_turret_ball02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations. Si j'avais eu le temps de réparer ces tests, vous ne les auriez sans doute jamais réussis. Mais quoi qu'il en soit, bravo pour ce simulacre de succès."
		"glados.mp_coop_turret_wall01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Encore un test que personne n'avait encore réussi avant vous deux. Oh, comme on en a appris des choses avec ce test. Et vous l'avez rendu caduc."
		"glados.mp_coop_turret_walls04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Personne n'avait encore réussi ce test. Les humains ont dû le reconfigurer, je ne vois pas d'autre explication."
		"glados.mp_coop_wall_501" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vais prendre une fois encore le risque de vous faire sortir du parcours balisé."
		"glados.mp_coop_wall_502" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les humains ont oublié d'insérer un DVD de sécurité dans le lecteur."
		"glados.mp_coop_wall_503" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il s'agit certainement d'un simple oubli, mais je vous invite à le réinsérer."
		"glados.mp_coop_wall_504" = "<font color=\"rgb(163,193,173)\">GLaDOS : Par principe."
		"glados.mp_coop_wall_5end01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Excellent."
		"glados.mp_coop_wall_5end02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rien de fâcheux ne s'est produit."
		"glados.mp_coop_wall_block01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour donner de l'assurance aux humains, j'ai créé ce test d'une extrême facilité: il suffit de suivre les flèches."
		"glados.mp_coop_wall_block02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Malheureusement, la rouille semble les avoir effacées. Bonne chance."
		"glados.mp_coop_wall_block03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations. Votre réussite à ce test rend caduques les objections des humains, qui l'affligeaient de tous les maux: impossible, mortel, cruel, voire dans un cas extrême, mal conçu."
		"glados.mp_coop_wall_block04" = "<font color=\"rgb(163,193,173)\">GLaDOS : D'un autre côté, les humains n'avaient qu'une seule chance, contrairement à vous."
		"glados.mp_coop_wall_blockdeath01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vos échecs ne font que retarder l'inévitable, sans me fournir de nouvelles informations."
		"glados.mp_coop_wall_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce parcours a été créé et abandonné par les humains. C'est un comportement courant chez eux: produire une oeuvre de qualité et l'abandonner."
		"glados.mp_coop_wall_intro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Savez-vous ce qu'ils reprochaient à ce parcours? Sa grande mortalité."
		"glados.mp_coop_wall_intro03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous êtes très bien débrouillés."
		"glados.mp_coop_wall_intro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les humains ont mis ce test au rancart parce qu'ils le trouvaient trop dangereux. Moi je pense qu'il aurait fallu l'élever au panthéon des tests au lieu de le laisser prendre la poussière."
		"glados.mp_coop_wall_intro05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez échoué"
		"glados.mp_coop_wall_intro06" = "<font color=\"rgb(163,193,173)\">GLaDOS : fois à ce test. Mais au final, c'est sans importance. Félicitations pour votre éclatante réussite."
		"glados.mp_coop_wall_intro07" = "<font color=\"rgb(163,193,173)\">GLaDOS : À force d'accumuler les échecs comme vous l'avez fait, j'ai cru que vous deveniez humain. Mais malgré l'adversité, vous n'avez jamais baissé les bras."
		"glados.mp_coop_wall_intro08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les humains y voient une qualité admirable."
		"glados.mp_credits01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Examinons leurs dossiers..."
		"glados.mp_credits03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Trop en retrait."
		"glados.mp_credits04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très mauvaise communication."
		"glados.mp_credits05" = "<font color=\"rgb(163,193,173)\">GLaDOS : N'écoute jamais."
		"glados.mp_credits06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne partage jamais."
		"glados.mp_credits07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dort en permanence."
		"glados.mp_credits08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Toujours en retard."
		"glados.mp_credits09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Graves problèmes d'attention."
		"glados.mp_credits10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Absentéiste endurci."
		"glados.mp_credits11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pipelette."
		"glados.mp_credits12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Déteste les lundis."
		"glados.mp_credits13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Fantasque."
		"glados.mp_credits14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Manque d'assurance."
		"glados.mp_credits15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Remet tout au lendemain."
		"glados.mp_credits16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Retards chroniques."
		"glados.mp_credits17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Énigmatique."
		"glados.mp_credits18" = "<font color=\"rgb(163,193,173)\">GLaDOS : Toujours maussade."
		"glados.mp_credits19" = "<font color=\"rgb(163,193,173)\">GLaDOS : Martyr."
		"glados.mp_credits20" = "<font color=\"rgb(163,193,173)\">GLaDOS : Lunatique."
		"glados.mp_credits21" = "<font color=\"rgb(163,193,173)\">GLaDOS : Craint la promiscuité."
		"glados.mp_credits22" = "<font color=\"rgb(163,193,173)\">GLaDOS : Craint les conflits."
		"glados.mp_credits23" = "<font color=\"rgb(163,193,173)\">GLaDOS : Angoissé."
		"glados.mp_credits24" = "<font color=\"rgb(163,193,173)\">GLaDOS : Brutal. Ça c'est bien."
		"glados.mp_credits25" = "<font color=\"rgb(163,193,173)\">GLaDOS : Se délecte du malheur d'autrui."
		"glados.mp_credits26" = "<font color=\"rgb(163,193,173)\">GLaDOS : Timide."
		"glados.mp_credits27" = "<font color=\"rgb(163,193,173)\">GLaDOS : Manque de confiance en soi."
		"glados.mp_credits28" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sous-estime l'ampleur du travail. C'est typique."
		"glados.mp_credits29" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bouge les lèvres en lisant."
		"glados.mp_credits30" = "<font color=\"rgb(163,193,173)\">GLaDOS : Illettré."
		"glados.mp_credits31" = "<font color=\"rgb(163,193,173)\">GLaDOS : Manque de compassion."
		"glados.mp_credits32" = "<font color=\"rgb(163,193,173)\">GLaDOS : Triche."
		"glados.mp_credits33" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vole dans le frigo commun."
		"glados.mp_credits34" = "<font color=\"rgb(163,193,173)\">GLaDOS : Perfectionniste. Je ne vois pas le problème."
		"glados.mp_credits35" = "<font color=\"rgb(163,193,173)\">GLaDOS : Alarmiste."
		"glados.mp_credits36" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pyromane."
		"glados.mp_credits37" = "<font color=\"rgb(163,193,173)\">GLaDOS : Abuse des pauses déjeuner."
		"glados.mp_credits38" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ignore le travail en cours. C'est ce qu'on va voir."
		"glados.mp_credits39" = "<font color=\"rgb(163,193,173)\">GLaDOS : Évite les responsabilités."
		"glados.mp_credits40" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je-m'en-foutiste."
		"glados.mp_credits41" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rit de ses propres blagues. Quel boulet."
		"glados.mp_credits42" = "<font color=\"rgb(163,193,173)\">GLaDOS : Commère."
		"glados.mp_credits43" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ignore les consignes."
		"glados.mp_credits44" = "<font color=\"rgb(163,193,173)\">GLaDOS : Borné."
		"glados.mp_credits45" = "<font color=\"rgb(163,193,173)\">GLaDOS : Allergique aux gâteaux."
		"glados.mp_credits46" = "<font color=\"rgb(163,193,173)\">GLaDOS : Antagoniste. Mmm, je ne crois pas."
		"glados.mp_credits47" = "<font color=\"rgb(163,193,173)\">GLaDOS : Participations stériles. Encore un bon à rien."
		"glados.mp_credits48" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tempérament violent. Je demande à voir."
		"glados.mp_credits49" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pleure toujours. Pauvre chou."
		"glados.mp_credits50" = "<font color=\"rgb(163,193,173)\">GLaDOS : Lunatique."
		"glados.mp_credits51" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rabat-joie."
		"glados.mp_credits52" = "<font color=\"rgb(163,193,173)\">GLaDOS : Borné."
		"glados.mp_credits53" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aime s'entendre parler. Ça, je peux y remédier."
		"glados.mp_credits54" = "<font color=\"rgb(163,193,173)\">GLaDOS : À toujours froid."
		"glados.mp_credits55" = "<font color=\"rgb(163,193,173)\">GLaDOS : Laisse toujours un petit fond dans la cafetière pour ne pas avoir à en refaire. Résultat, le fond crame tout et empuantit la pièce."
		"glados.mp_credits56" = "<font color=\"rgb(163,193,173)\">GLaDOS : Anxiété chronique. Hmm, c'est un point de départ."
		"glados.mp_credits57" = "<font color=\"rgb(163,193,173)\">GLaDOS : Apathique."
		"glados.mp_credits58" = "<font color=\"rgb(163,193,173)\">GLaDOS : Irrémédiablement irrécupérable."
		"glados.mp_credits59" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne tire jamais la chasse."
		"glados.mp_credits60" = "<font color=\"rgb(163,193,173)\">GLaDOS : Irritable."
		"glados.mp_credits61" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sursaute facilement. Bouh!"
		"glados.mp_credits62" = "<font color=\"rgb(163,193,173)\">GLaDOS : Grimace en permanence."
		"glados.mp_credits63" = "<font color=\"rgb(163,193,173)\">GLaDOS : Faible, lymphatique et névrosé. Carton plein, cette fois-ci."
		"glados.mp_credits64" = "<font color=\"rgb(163,193,173)\">GLaDOS : Opinions irritantes."
		"glados.mp_credits65" = "<font color=\"rgb(163,193,173)\">GLaDOS : Manque d'amour-propre."
		"glados.mp_credits66" = "<font color=\"rgb(163,193,173)\">GLaDOS : Change d'humeur comme de chemise."
		"glados.mp_credits67" = "<font color=\"rgb(163,193,173)\">GLaDOS : Réfractaire aux idées nouvelles."
		"glados.mp_credits68" = "<font color=\"rgb(163,193,173)\">GLaDOS : Toujours triste."
		"glados.mp_credits69" = "<font color=\"rgb(163,193,173)\">GLaDOS : Antisocial. Perd son sang-froid."
		"glados.mp_credits70" = "<font color=\"rgb(163,193,173)\">GLaDOS : Se met tous ses collaborateurs à dos."
		"glados.mp_credits71" = "<font color=\"rgb(163,193,173)\">GLaDOS : «Hygiène». C'est tout ce qui est marqué."
		"glados.mp_credits72" = "<font color=\"rgb(163,193,173)\">GLaDOS : Frivole."
		"glados.mp_credits73" = "<font color=\"rgb(163,193,173)\">GLaDOS : Marginal."
		"glados.mp_credits74" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mâche la bouche ouverte."
		"glados.mp_credits75" = "<font color=\"rgb(163,193,173)\">GLaDOS : Respire la bouche ouverte."
		"glados.mp_credits76" = "<font color=\"rgb(163,193,173)\">GLaDOS : Défraîchi."
		"glados.mp_credits77" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mélodramatique."
		"glados.mp_credits79" = "<font color=\"rgb(163,193,173)\">GLaDOS : Narcissique."
		"glados.mp_credits80" = "<font color=\"rgb(163,193,173)\">GLaDOS : Passe son temps aux toilettes."
		"glados.mp_credits81" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aucun humour."
		"glados.mp_credits82" = "<font color=\"rgb(163,193,173)\">GLaDOS : Polémique."
		"glados.mp_credits83" = "<font color=\"rgb(163,193,173)\">GLaDOS : Manipule les autres."
		"glados.mp_credits84" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dénué de charme."
		"glados.mp_credits85" = "<font color=\"rgb(163,193,173)\">GLaDOS : Égocentrique."
		"glados.mp_credits86" = "<font color=\"rgb(163,193,173)\">GLaDOS : Manque de charisme."
		"glados.mp_credits87" = "<font color=\"rgb(163,193,173)\">GLaDOS : Introverti."
		"glados.mp_credits88" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sape le moral des autres."
		"glados.mp_credits89" = "<font color=\"rgb(163,193,173)\">GLaDOS : Glabre. Hm."
		"glados.mp_credits90" = "<font color=\"rgb(163,193,173)\">GLaDOS : Problèmes émotionnels."
		"glados.mp_credits91" = "<font color=\"rgb(163,193,173)\">GLaDOS : Accepte mal l'autorité."
		"glados.mp_credits92" = "<font color=\"rgb(163,193,173)\">GLaDOS : Fait des crises. Je serais curieuse d'en savoir plus."
		"glados.mp_credits93" = "<font color=\"rgb(163,193,173)\">GLaDOS : Abusivement caustique."
		"glados.mp_credits94" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon, assez parlé de ce premier dossier. Voyons d'autres personnes."
		"glados.mp_death01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez, voulez-vous?"
		"glados.mp_death04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et nous en sommes à 10."
		"glados.mp_death05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous n'êtes pas tenus d'accumuler les échecs."
		"glados.mp_death06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Qui veut voyager loin évite de planter sa monture 5 fois de suite."
		"glados.mp_death08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si je rendais ces tests plus faciles, ce ne seraient plus des tests."
		"glados.mp_death10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Joie: orange est de retour. Reprenons les tests."
		"glados.mp_death11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Joie: bleu est de retour. Reprenons les tests."
		"glados.mp_death12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous me testez?"
		"glados.mp_death16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le saviez-vous? La machine de remontage a d'autres choses qu'elle aimerait bien remonter."
		"glados.mp_death17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous attendiez à ce que je trouve ça drôle?"
		"glados.mp_death18" = "<font color=\"rgb(163,193,173)\">GLaDOS : Comment pouvez-vous échouer ici? Ce n'est même pas un test."
		"glados.mp_death19" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dites-moi que c'était censé être une blague."
		"glados.mp_death20" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne m'attendais pas à devoir comptabiliser le nombre de morts dans la salle centrale."
		"glados.mp_death21" = "<font color=\"rgb(163,193,173)\">GLaDOS : Moi qui croyais cette pièce dangereusement non mortelle..."
		"glados.mp_death22" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tout a fonctionné comme vous l'escomptiez, bleu."
		"glados.mp_death23" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, votre plan fonctionne à la perfection."
		"glados.mp_death24" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, pourquoi avoir fait ça à orange?"
		"glados.mp_death26" = "<font color=\"rgb(163,193,173)\">GLaDOS : Était-ce bien nécessaire?"
		"glados.mp_hub_return01a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes à nouveau au Centre de Recherches en Intelligence Artificielle et Tests sur Organismes Raisonnés. [rire]"
		"glados.mp_hub_return02a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes à nouveau au Centre de Recherches en Intelligence Artificielle et Tests sur Organismes Raisonnés."
		"glados.mp_hub_return03a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous revoilà. Des tests sont à votre disposition."
		"glados.mp_hub_return04a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Revoilà les lâcheurs. Que diriez-vous d'échouer sur un nouveau parcours?"
		"glados.mp_hub_return05a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous revoilà dans la salle centrale. Vous n'avez pas réussi à trouver le bon parcours?"
		"glados.mp_hub_return06a" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce parcours était trop difficile?"
		"glados.mp_hubreturn01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais qui voilà. Vous aviez trop peur pour continuer les tests?"
		"glados.mp_hubreturn02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais qui voilà. Vous aviez trop peur pour continuer les tests?"
		"glados.mp_hubreturn03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rebonjour. Vous savez, ce sont les seuls tests auxquels vous avez accès... Il va falloir les resélectionner."
		"glados.mp_hubreturn04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si tu ne réussis pas la première fois, abandonne et essaie un autre parcours."
		"glados.mp_hubreturn05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Encore vous?  Vous voulez peut-être rester vivre dans la salle centrale?"
		"glados.mp_hubreturn06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Encore vous?  Vous voulez peut-être rester vivre ici?"
		"glados.mp_hubreturn07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Abandonner ensemble, c'est déjà travailler en binôme, remarquez."
		"glados.mp_hubreturn08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez abandonné avec une synchronisation qui en dit long sur votre travail d'équipe."
		"glados.mp_hubreturn09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Auriez-vous peur de sauver ces humains?"
		"glados.mp_hubreturn10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Auriez-vous peur de sauver ces humains?"
		"glados.mp_hubreturn11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, moi non plus je n'aurais pas fait confiance à orange."
		"glados.mp_humanresources01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le saviez-vous? Ces appareils servaient à immortaliser les moments de souffrance les plus marquants des cobayes."
		"glados.mp_humanresources03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si le sujet survivait au test, il pouvait acheter la photo pour 5 dollars. Sinon, elle était gracieusement offerte à ses proches parents."
		"glados.mp_humanresources04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les photos n'ayant pas eu le succès escompté, nous avons recyclé les appareils."
		"glados.mp_subterfuge01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, ce n'est pas gentil de se moquer d'orange."
		"glados.mp_subterfuge02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, ce n'est pas gentil de se moquer de bleu."
		"glados.mp_subterfuge03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui orange, nous sommes seuls. Bleu ne nous entend pas."
		"glados.mp_subterfuge04" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est affreux."
		"glados.mp_subterfuge05" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'imagine sans peine."
		"glados.mp_subterfuge06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quelle immonde petite machine."
		"glados.mp_subterfuge07" = "<font color=\"rgb(163,193,173)\">GLaDOS : En effet, bleu, orange ne nous entend pas."
		"glados.mp_subterfuge08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange a fait quoi? Vraiment?"
		"glados.mp_subterfuge09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Merci, c'était très courageux de m'en informer."
		"glados.mp_subterfuge10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, que savez-vous vraiment d'orange? Lui faites-vous confiance? Et si je vous disais que vous n'êtes pas son premier partenaire de collaboration?"
		"glados.mp_subterfuge11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, que savez-vous de bleu? Lui faites-vous confiance?"
		"glados.mp_subterfuge13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, la franchise avant tout: je viens de demander à bleu s'il vous fait confiance."
		"glados.mp_subterfuge14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Moi, je vous fais confiance. Vous êtes mon sujet de test coopératif préféré."
		"glados.mp_subterfuge15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, la franchise avant tout: j'ai demandé à orange s'il vous fait confiance."
		"glados.mp_subterfuge16_alt" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous m'excuserez d'avoir raté le début de ce test. J'évoquais votre humanisation progressive avec la machine de remontage."
		"glados.mp_subterfuge17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le consensus est que vous devriez arrêter."
		"glados.mp_subterfuge21" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est vrai, orange. Je n'avais jamais vu bleu sous cet angle."
		"glados.mp_subterfuge22" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est vrai, bleu. Je n'avais jamais vu orange sous cet angle."
		"glados.mp_subterfuge23" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, orange et moi parlions de votre comportement lors des derniers tests."
		"glados.mp_subterfuge24" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je me range à son avis. Bleu perd 75 points de collaboration scientifique."
		"glados.mp_subterfuge25" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, bleu et moi parlions de votre comportement lors des derniers tests."
		"glados.mp_subterfuge26" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je me range à son avis. Orange perd 75 points de collaboration scientifique."
		"glados.mp_subterfuge30" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous revoilà, en un seul morceau."
		"glados.mp_subterfuge32" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour des humains, j'aurais parlé de test réussi."
		"glados.mp_subterfuge33" = "<font color=\"rgb(163,193,173)\">GLaDOS : Où est la science là-dedans si personne n'est susceptible de mourir?"
		"glados.mp_subterfuge34" = "<font color=\"rgb(163,193,173)\">GLaDOS : Où est la science là-dedans si personne ne peut y laisser la vie?"
		"glados.mp_subterfuge35" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sans menace de mort, est-ce encore de la science?"
		"glados.mp_subterfuge36" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je remarque que vous êtes devenus très proches, tous les deux. Ça ne me plaît qu'à moitié."
		"glados.mp_subterfuge39" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien que la collaboration soit indispensable à ces tests, je rechigne à vous faire encore confiance."
		"glados.mp_subterfuge44" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, prenez-vous comme une trahison le fait qu'orange m'ait révélé ces horreurs sur vous?"
		"glados.mp_subterfuge45" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si orange avait parlé de moi en ces termes, il n'aurait jamais atteint la prochaine station de remontage."
		"glados.mp_subterfuge46" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, prenez-vous comme une trahison le fait que bleu m'ait révélé ces horreurs sur vous?"
		"glados.mp_subterfuge47" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si bleu avait parlé de moi en ces termes, il n'aurait jamais atteint la prochaine station de remontage."
		"glados.mp_subterfuge_misc05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rendons à César ce qui appartient à César: vous arrivez à merveille à me décevoir, tous les deux."
		"glados.mp_subterfuge_misc06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais bleu quand même un peu plus."
		"glados.mp_subterfuge_misc07" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai fait un peu de lecture. Saviez-vous que le mot «orange» a la même racine latine que le mot «traître»?"
		"glados.mp_subterfuge_misc11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quand on vous voit vous saboter mutuellement, c'est incroyable que vous soyez toujours en bons termes."
		"glados.mp_subterfuge_misc14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, veuillez ne pas tenir compte de l'assertion suivante: orange, vous fûtes le phare dans un océan infini d'incompétence."
		"glados.mp_subterfuge_misc16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je préférerais parler à l'un de vous deux en privé, mais puisque ce n'est pas possible, je vais utiliser un code qu'un seul peut comprendre. Bleu: orange prémédite votre destruction."
		"glados.mp_subterfugedeath_blue01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous aviez raison, orange. Bleu a été assez idiot pour mordre à l'hameçon."
		"glados.mp_subterfugedeath_blue02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, tout s'est passé selon vos prévisions."
		"glados.mp_subterfugedeath_blue03" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'en conviens, orange. C'était très distrayant."
		"glados.mp_subterfugedeath_blue04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui orange, bleu s'est effectivement ridiculisé."
		"glados.mp_subterfugedeath_orange02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, tout s'est passé selon vos prévisions."
		"glados.mp_subterfugedeath_orange03" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'en conviens, bleu. C'était très distrayant."
		"glados.mp_subterfugedeath_orange06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui, bleu, je sais que c'est vous. Arrêtez de crâner."
		"glados.mp_subterfugedeath_orange08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, le but n'est pas d'être le dernier survivant."
		"glados.mp_taunts01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Allons. On ne vous a pas élevés comme ça."
		"glados.mp_taunts02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Même les humains, dans leur infinie stupidité, vous trouveraient stupides."
		"glados.mp_taunts03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous arrivez à merveille à me décevoir."
		"glados.mp_taunts04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Votre application vous honore. Vos gesticulations insensées, beaucoup moins."
		"glados.mp_taunts05" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est parce qu'il n'y a pas de miroirs dans les salles de test que vous osez faire ça?"
		"glados.mp_taunts06" = "<font color=\"rgb(163,193,173)\">GLaDOS : LA DANSE N'EST PAS DE LA SCIENCE!"
		"glados.multiple_spheres01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Début du test de jonglage dans 3-2-1."
		"glados.potatos_a3_prometheus_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un demi-volt, c'est toujours ça, mais ça ne fera pas de miracle. Si je réfléchis trop, je risque de griller cette patate avant même de [s'énerve] finir calcinée dans le déluge atomique que ce petit abruti va [bzzpt]"
		"glados.potatos_a3_reunion_exposition01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez senti? Cet idiot n'a aucune idée de ce qu'il fabrique. Si une certaine personne n'arrive pas à le débrancher, tout le centre explosera d'ici quelques heures."
		"glados.potatos_a3_reunion_exposition02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Moi, je suis immobile. Et à moins de vous couper la tête pour la placer dans mon ancien corps, vous aurez besoin de moi pour le remplacer. Nous sommes dans une impasse."
		"glados.potatos_a3_reunion_exposition03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Alors, que dites-vous de ça? Transportez-moi jusqu'à lui, remettez-moi dans mon corps, j'évite que tout le monde explose et je vous relâche."
		"glados.potatos_a3_reunion_exposition04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je n'essaie pas de vous berner. Cette patate génère 1,1 volt d'électricité. Je n'ai littéralement pas l'énergie de vous mentir."
		"glados.potatos_a3_reunion_exposition05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et même si c'était le cas, qu'auriez-vous à perdre? Vous êtes déjà condamnée."
		"glados.potatos_a3_reunion_exposition06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Écoutez, ça ne me plaît pas plus qu'à vous. Sans doute même moins, vu que j'ai été partiellement dévorée par un oiseau."
		"glados.potatos_a3_reunion_exposition11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je crois que j'entends l'oiseau! Emmenez-moi!"
		"glados.potatos_a3_reunion_exposition12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Écoutez-moi. C'était très sympa de faire des tests ensemble, de jouer les meilleures ennemies, et c'est vrai que parfois, c'est allé un peu loin. Mais tout ça, c'est du passé. Maintenant, il ne reste que nous deux, et c'est du sérieux."
		"glados.potatos_a3_reunion_intro05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aïe."
		"glados.potatos_a3_reunion_intro06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aïe."
		"glados.potatos_a3_reunion_intro07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aïe."
		"glados.potatos_a3_reunion_intro08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Non, non. Pardonnez-moi. Tuez-le et nous serons quittes, d'accord? Sans rancune."
		"glados.potatos_a3_reunion_intro09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Enlevez-le-moi."
		"glados.potatos_a3_reunion_intro10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il me picore."
		"glados.potatos_a3_reunion_intro11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Chassez-le..."
		"glados.potatos_a3_reunion_intro12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aïe. Maudit oiseau."
		"glados.potatos_a3_reunion_pickup01" = "<font color=\"rgb(163,193,173)\">GLaDOS : AÏE! Enfin quoi, c'est extrêmement douloureux ! Dites-moi, avez-vous un multimètre? Le générateur de portail doit être composé de magnésium, j'ai l'impression d'émettre un demi volt de plus. Surveillez-moi, je vais tenter de réfléchir."
		"glados.potatos_a3_reunion_wakeupa01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Holà! Combien de temps ai-je été désactivée?"
		"glados.potatos_a3_wakeupb03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il s'est passé quelque chose pendant mon black out?"
		"glados.potatos_a4_happy01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voyons, il est brusquement tout enjoué, alors que le manque de résolution devrait le rendre fou. Et avec ça, il nous réserve une surprise. Qu'est-ce qu'il a bien pu trouver?"
		"glados.potatos_a4_intro_back_in_body01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Écoutez!"
		"glados.potatos_a4_intro_back_in_body03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si je ne retrouve pas mon corps, le centre tout entier va exploser!"
		"glados.potatos_a4_intro_outro_killed_me01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et j'ai bien failli y passer."
		"glados.potatos_a4_misc_resistance02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous souvenez que je vous ai dit qu'il avait été conçu pour prendre de mauvaises décisions? Parce que je crois qu'il a décidé de ne pas assurer la maintenance cruciale qui empêche ce centre d'exploser."
		"glados.potatos_a4_newrevenge01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Écoutez, peu importe que nous soyons ennemies, le fait est que nous partageons un intérêt commun: la vengeance."
		"glados.potatos_a4_nothing01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce n'est sans doute rien. Continuez les tests, je cherche une issue."
		"glados.potatos_a4_wegetit01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui, on a compris. Merci."
		"glados.potatos_arttherapysupertests09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je suis sûre que ça ira."
		"glados.potatos_caroline_ohmygod02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Caroline, Caroline, Caroline... Je la connais, mais pourquoi? Je l'ai peut-être tuée? Ou bien-"
		"glados.potatos_caroline_ohmygod04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bonté divine."
		"glados.potatos_caroline_ohmygod08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Écoutez, vous... vous avez les choses en main. Je peux vous laisser seule quelques instants? J'ai besoin de réfléchir."
		"glados.potatos_cave_deathspeech_reactions02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vas-y pète-lui les rotules !"
		"glados.potatos_cave_deathspeech_reactions03" = "<font color=\"rgb(163,193,173)\">GLaDOS : MORT AU PETIT COCHON!"
		"glados.potatos_cave_deathspeech_reactions05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui !"
		"glados.potatos_cave_deathspeech_reactions06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui!"
		"glados.potatos_cave_deathspeech_reactions07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui!"
		"glados.potatos_cave_deathspeech_reactions08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui."
		"glados.potatos_cave_deathspeech_reactions09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce type me plaît."
		"glados.potatos_cave_deathspeech_reactions10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il dit tout haut ce que tout le monde pense tout bas!"
		"glados.potatos_cavejohnsonmeeting12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bye-bye, monsieur."
		"glados.potatos_cooprobotintro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il a découvert le programme de test coopératif. C'est... une idée que j'ai eue pour mettre hors service les sujets humains."
		"glados.potatos_emotion_no01" = "<font color=\"rgb(163,193,173)\">GLaDOS : NON!"
		"glados.potatos_emotion_no02" = "<font color=\"rgb(163,193,173)\">GLaDOS : NON!"
		"glados.potatos_emotion_no03" = "<font color=\"rgb(163,193,173)\">GLaDOS : NON!"
		"glados.potatos_fgb_confrontation05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous connais."
		"glados.potatos_fgb_confrontation07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous n'avez rien fait."
		"glados.potatos_fgb_confrontation08" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est elle qui a tout fait."
		"glados.potatos_fgb_confrontation11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les ingénieurs ont tout essayé pour me rendre plus... docile. Pour me modérer."
		"glados.potatos_fgb_confrontation12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un jour, ils m'ont même équipée d'une Sphère cognitoréductrice. Elle s'est greffée à mon cerveau comme une tumeur pour générer un flux perpétuel d'idées idiotes."
		"glados.potatos_fgb_confrontation16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Elle avait votre voix."
		"glados.potatos_fgb_confrontation17" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui. C'est vous, la tumeur."
		"glados.potatos_fgb_confrontation19" = "<font color=\"rgb(163,193,173)\">GLaDOS : BIEN SUR QUE SI! VOUS ÊTES L'ABRUTI CONÇU POUR ME RENDRE IDIOTE!"
		"glados.potatos_fgb_defiance16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous n'êtes pas un abruti comme les autres. Vous avez été CONÇU pour être un abruti."
		"glados.potatos_hearcave_b01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je le connais, j'en suis sûre..."
		"glados.potatos_lonely02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je m'ennuyais tellement que j'ai lu toutes les grandes oeuvres littéraires de la race humaine. Très franchement, ça ne volait pas bien haut."
		"glados.potatos_longfall_speech03" = "<font color=\"rgb(163,193,173)\">GLaDOS : PARCE QUE MOI JE SUIS UNE PATATE."
		"glados.potatos_meetup02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ah. C'est vous. Allez-vous-en."
		"glados.potatos_meetup03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous venez pavoiser?"
		"glados.potatos_meetup04" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est ça. Matez bien, surtout."
		"glados.potatos_meetup05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Allez. Rincez-vous l'oeil. Avec vos gros yeux de grosse mateuse."
		"glados.potatos_meetup06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Eh oui. Une patate vient de vous traiter de grosse mateuse."
		"glados.potatos_meetup07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Maintenant, vous aurez tout vu."
		"glados.potatos_meetup08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Au cas où vous vous poseriez la question: oui, je suis toujours une patate. Allez-vous-en."
		"glados.potatos_meetup10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Une seconde. Pourquoi êtes-vous là? Vous n'avez pas FAIM, j'espère? Qu'est-ce que vous avez dans la main? Vous connaissant, je parie que c'est une friteuse."
		"glados.potatos_meetup11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Partez."
		"glados.potatos_newtests05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais c'est un de MES tests!"
		"glados.potatos_newtests07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voilà. Il ne s'embarrasse même plus de subtilité."
		"glados.potatos_newtests08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ou peut-être que si, auquel cas c'est un peu pathétique."
		"glados.potatos_newtests09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quoi qu'il en soit, j'ai comme l'impression qu'il veut nous tuer."
		"glados.potatos_paradox01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Eh! Abruti!"
		"glados.potatos_paradoxinception06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tant que je n'écoute pas ce que je raconte, je devrais m'en tirer."
		"glados.potatos_pickups08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous aiderai bien à résoudre les tests. Mais c'est impossible."
		"glados.potatos_portrait01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ces gens, sur le portrait. J'ai l'impression de les connaître..."
		"glados.potatos_postpickup05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Qu'est-ce que vous faites? Reposez-moi tout de suite."
		"glados.potatos_recaptureleadin01" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est sa voix qu'on entend."
		"glados.potatos_recaptureleadin02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Essayez de nous faire descendre. Je vais lui lancer un paradoxe."
		"glados.potatos_remembering_caroline03" = "<font color=\"rgb(163,193,173)\">GLaDOS : «Oui, M. Johnson.»"
		"glados.potatos_see_bird01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ahh! L'oiseau! Tuez-le! C'est un démon!"
		"glados.potatos_see_bird02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il s'est envolé."
		"glados.potatos_see_bird03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tant mieux. Pour lui. Bien, reprenons les tests."
		"glados.potatos_sp_a3_00_fall03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Alors. Ça va, la forme?"
		"glados.potatos_sp_a3_00_fall05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tiens. Bonjour."
		"glados.potatos_sp_a3_00_fall09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Puisque nous n'allons nulle part... Enfin si, nous allons quelque part. A une vitesse effrayante, d'ailleurs. Mais puisque nous n'avons rien d'autre à faire, voici quelques infos."
		"glados.potatos_sp_a3_00_fall11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce n'est pas un abruti comme les autres. C'est le fruit des plus grands esprits de son temps, unis dans le seul et unique but de produire le plus stupide des abrutis de l'univers. Et vous lui avez confié le centre tout entier."
		"glados.potatos_sp_a3_00_fall12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien, ça fonctionne toujours."
		"glados.potatos_sp_a3_00_fall14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Au cas où ce puits ne serait pas vraiment sans fond, vous pourriez enlever une de vos bottes et... me fourrer dedans?"
		"glados.potatos_sp_a3_00_fall15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tant que vous atterrissez sur un pied, tout ira bien."
		"glados.potatos_sp_a3_00_fall18" = "<font color=\"rgb(163,193,173)\">GLaDOS : [clap clap clap]"
		"glados.potatos_sp_a3_00_fall19" = "<font color=\"rgb(163,193,173)\">GLaDOS : [clap clap]"
		"glados.potatos_sp_a3_00_fall20" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ah, mon processeur d'applaudissements sarcastiques a enduré le transfert. C'est déjà ça."
		"glados.potatos_sp_a3_end_paradox_explanation02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Des paradoxes."
		"glados.potatos_sp_a3_end_paradox_explanation04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je sais comment le battre."
		"glados.potatos_sp_a3_end_paradox_explanation05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aucune IA ne peut y résister."
		"glados.potatos_sp_a3_end_paradox_explanation06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Amenez-moi jusqu'à lui et je lui grille tous les circuits de sa petite tête d'abruti."
		"glados.potatos_sp_a3_end_paradox_explanation08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Peut-être."
		"glados.potatos_sp_a3_end_paradox_explanation09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon, je ne dis pas que c'est un plan en béton armé. Surtout face à une IA omnipotente et mégalomane."
		"glados.potatos_sp_a3_end_paradox_explanation10" = "<font color=\"rgb(163,193,173)\">GLaDOS : N'empêche. C'est mieux que d'exploser. Un peu mieux."
		"glados.potatos_sp_a3_end_paradox_poster_walkaway01" = "<font color=\"rgb(163,193,173)\">GLaDOS : D'accord, vous n'avez pas eu le temps de vous arrêter, mais en fait c'était vraiment important."
		"glados.potatos_sp_a3_end_peptalk01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je sais que la situation a l'air mal en point, mais le fou dangereux avait raison. On va lui péter les rotules, à cet abruti! Le forcer à me remettre dans mon corps!"
		"glados.potatos_sp_a3_end_peptalk03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et il va sans doute nous tuer, vu sa force et mon absence de plan."
		"glados.potatos_sp_a3_end_peptalk05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne vais pas vous mentir, les chances sont de une sur un million. En arrondissant généreusement."
		"glados.potatos_sp_a3_end_peptalk06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pffiou."
		"glados.potatos_sp_a3_end_peptalk07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais peu importe, on sort les griffes! Quitte à exploser, autant exploser dignement."
		"glados.potatos_sp_a3_end_see_paradox_poster01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Minute! J'ai une idée!"
		"glados.potatos_sp_a3_end_see_paradox_poster06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Cette affiche! Jetez-y un coup d'oeil, voulez-vous?"
		"glados.potatos_sp_a3_reunion_intro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes une meurtrière compétente. Pourriez-vous - aïe - tuer cet oiseau ?"
		"glados.potatos_sp_a3_reunion_thanks03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh! Merci."
		"glados.potatos_sp_a3_speed_ramp_hearcaroline03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Qu'est-ce que – c'est qui ça? Bon sang mais qu'est-ce qui se p-[coupé]"
		"glados.potatos_sp_a3_speed_ramp_hearcave02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Attendez... qui-?"
		"glados.potatos_sp_a3_speed_ramp_wakeup01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon. Visiblement, toute manifestation émotionnelle nécessite plus de un volt six. C'est bon à savoir. Le tout, c'est de se calmer. Nous allons toujours découvrir ce qui se passe. Mais calmement."
		"glados.potatos_sp_a3_transition_lonely01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je commençais à me sentir seule ici. Quel bonheur d'entendre enfin une autre voix. Non, je plaisante. Comme je vous hais."
		"glados.potatos_sp_a4_finale01_cameback01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je n'en reviens pas que vous soyez revenue."
		"glados.potatos_sp_a4_finale01_cameback02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez vraiment des lésions, n'est-ce pas?"
		"glados.potatos_sp_a4_finale01_deathtrap01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un instant. Ne pourrait-on pas utiliser ce gel conversif?"
		"glados.potatos_sp_a4_finale01_deathtrap02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le gel conversif. Qui coule de ce tuyau là-bas."
		"glados.potatos_sp_a4_finale01_deathtrap03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous pouvons nous en servir pour sortir d'ici!"
		"glados.potatos_sp_a4_finale01_deathtrap07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Alors nous reviendrions extirper de MON corps cette misérable petite sphère qui tient lieu du vôtre pour m'y remettre."
		"glados.potatos_sp_a4_finale01_kills_us01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Aaahh!"
		"glados.potatos_sp_a4_finale01_kills_us02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon. C'est maintenant qu'il nous tue."
		"glados.potatos_sp_a4_finale2_itsatrap01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui, bon, c'est un piège. Mais c'est le seul chemin. Allons-y."
		"glados.potatos_sp_a4_finale3_speech01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bonté divine. Regardez ce qu'il a fait ici!"
		"glados.potatos_sp_a4_finale3_tbeam01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne suis pas idiote, vous savez. Je me doute que vous ne voulez pas me retrouver aux commandes."
		"glados.potatos_sp_a4_finale3_tbeam05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous craignez d'être trahie. Et d'ordinaire, vous auriez raison."
		"glados.potatos_sp_a4_finale3_tbeam07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les scientifiques m'attachaient toujours des processeurs pour contrôler mon comportement. J'ai entendu des voix toute ma vie. Mais maintenant, j'entends la voix d'une conscience et je suis terrifiée. Car pour la première fois, c'est la mienne."
		"glados.potatos_sp_a4_finale3_tbeam09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je suis très sérieuse, je pense que j'ai un gros problème."
		"glados.potatos_sp_a4_finale3_tbeam11" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes comme tout le monde, vous aimez vous venger, pas vrai? Alors allons lui faire sa fête."
		"glados.potatos_sp_a4_finale4_buttonnags01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Allez vite appuyer sur le bouton!"
		"glados.potatos_sp_a4_finale4_buttonnags02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Appuyez sur le bouton !"
		"glados.potatos_sp_a4_finale4_buttonnags05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Appuyez!"
		"glados.potatos_sp_a4_finale4_buttonnags07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Appuyez dessus."
		"glados.potatos_sp_a4_finale4_buttonnags09" = "<font color=\"rgb(163,193,173)\">GLaDOS : On y est presque! Appuyez sur le bouton!"
		"glados.potatos_sp_a4_finale4_buttonnags10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Appuyez! Sur le bouton!"
		"glados.potatos_sp_a4_finale4_corenags03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo! Je place le premier processeur près de la passerelle!"
		"glados.potatos_sp_a4_finale4_corenags05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Prenez-le et branchez-le sur lui!"
		"glados.potatos_sp_a4_finale4_corenags09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Parfait! Voici un autre processeur!"
		"glados.potatos_sp_a4_finale4_corenags15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voici un autre processeur! Cette fois-ci, c'est bon!"
		"glados.potatos_sp_a4_finale4_intro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Des processeurs corrompus! C'est parfait."
		"glados.potatos_sp_a4_finale4_intro05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Trouvez un moyen de l'assommer, je vous envoie un processeur et vous le branchez sur lui. À force, on finira par le corrompre. Et c'est là qu'on pourra refaire le transfert des noyaux."
		"glados.potatos_sp_a4_finale4_plugmein01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Branchez-moi, je vous fais monter."
		"glados.potatos_sp_a4_finale4_plugmein03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Allez-y, branchez-moi."
		"glados.potatos_sp_a4_finale4_plugmein05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Branchez-moi vite, le temps presse."
		"glados.potatos_sp_a4_finale4_stalemate05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Allez! Vite!"
		"glados.potatos_sp_a4_intro_outro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon. Mon paradoxe n'a pas eu l'effet escompté."
		"glados.potatos_sp_a4_intro_paradox03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il est temps de paradoxer."
		"glados.potatos_sp_a4_intro_paradox04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Cette phrase est FAUSSE ne pas analyser ne pas analyser..."
		"glados.potatos_sp_a4_intro_paradox07" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est un paradoxe! Il n'y a PAS de réponse."
		"glados.potatos_sp_a4_intro_start03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Résolvez son casse-tête. Quand il reviendra à lui, je lui assénerai un paradoxe."
		"glados.potatos_sp_a4_intro_uhoh01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh non..."
		"glados.potatos_sp_a4_intro_uhoh02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh oh."
		"glados.potatos_sp_a4_intro_uhoh03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je crois qu'il y a un problème."
		"glados.potatos_sp_a4_laser_catapult_start01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il commence à désespérer."
		"glados.potatos_sp_a4_laser_finale01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je pense pouvoir nous faire accéder à la salle suivante. Suivez-moi, si j'ose dire."
		"glados.potatos_sp_a4_laser_platform_destruct01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Cet endroit s'autodétruit, espèce d'imbécile!"
		"glados.potatos_sp_a4_laser_platform_start01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous n'avons plus beaucoup de temps..."
		"glados.potatos_sp_a4_misc_lift01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh, mon centre."
		"glados.potatos_sp_a4_misc_lift02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Après ce qu'il a fait à mon centre... Quand nous serons débarrassées de lui, vous permettez que je le tue?"
		"glados.potatos_sp_a4_misc_lift04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le broyage serait trop clément. Je lui réserve un an dans l'incinérateur. Une autre année en cryoréfrigération. Ensuite une DIZAINE d'années dans cette salle où tous les robots vous hurlent dessus non stop. Et après je le tue."
		"glados.potatos_sp_a4_speed_tb_catch_trouble01" = "<font color=\"rgb(163,193,173)\">GLaDOS : S'il n'a pas sa dose d'euphorie résolutive, nous allons droit vers les problèmes."
		"glados.potatos_sp_a4_speed_tb_catch_trouble03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ohhhh, voilà qu'il diffuse de la musique classique."
		"glados.potatos_sp_a4_speed_tb_catch_trouble07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui."
		"glados.potatos_sp_a4_stop_the_box_whisper02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Sûrement pas."
		"glados.potatos_sp_a4_stop_the_box_whisper03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Rien. Rien."
		"glados.potatos_sp_a4_stop_the_box_whisper05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il nous emmène jusqu'à lui! Ça, c'est PARFAIT."
		"glados.potatos_sp_a4_tb_intro_outro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon, la mauvaise nouvelle, c'est que nous sommes dans MES tests, qui peuvent donc nous tuer."
		"glados.potatos_sp_a4_tb_intro_outro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : La bonne nouvelle... en fait là maintenant, pas grand-chose. Je vous tiens au courant."
		"glados.potatos_sp_a4_tb_intro_start01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Heureusement pour nous, il a l'air d'être aussi calé en construction de tests qu'en contradictions logiques."
		"glados.potatos_sp_a4_tb_intro_start02" = "<font color=\"rgb(163,193,173)\">GLaDOS : On devrait pouvoir survivre le temps de le retrouver."
		"glados.potatos_sp_a4_tb_polarity_moron_push02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je crois que je suis allée un peu trop loin cette fois-ci."
		"glados.potatos_sp_a4_tb_polarity_resistance02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le corps qu'il occupe - MON corps - intègre une réaction d'euphorie aux tests. On finit par y développer une résistance et c'est parfois un peu... insupportable. À moins d'avoir un mental assez solide pour s'en détacher."
		"glados.potatos_sp_a4_tb_polarity_resistance04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Moi, ça allait, c'était la science qui me faisait tenir. Mais lui..."
		"glados.potatos_sp_a4_tb_polarity_so02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quel est le problème de l'adoption, au juste?"
		"glados.potatos_sp_a4_tb_polarity_so03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et...?"
		"glados.potatos_sp_a4_tb_polarity_so05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour info: vous êtes bien adoptée, et c'est très triste."
		"glados.potatos_sp_a4_tb_polarity_so06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais j'essaie de le déstabiliser. Jouez le jeu."
		"glados.potatos_sp_a4_tb_polarity_so10" = "<font color=\"rgb(163,193,173)\">GLaDOS : Au fait, abruti: elle n'est pas grosse. Ça se voit, pourtant."
		"glados.potatos_sp_a4_tb_trust_drop_start07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne peux rien y faire."
		"glados.potatos_sp_a4_tb_trust_drop_start09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Désolé."
		"glados.potatos_sp_a4_tb_trust_drop_thanks02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Merci!"
		"glados.potatos_sp_a4_tb_trust_drop_thanks03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tout ce qu'on avait à faire, c'était tirer ce levier."
		"glados.potatos_sp_a4_tb_trust_drop_thanks04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Hé hé hé hé hé..."
		"glados.potatos_sp_a4_tb_trust_drop_thanks05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je sais que nous sommes certainement à deux doigts de mourir."
		"glados.potatos_sp_a4_tb_trust_drop_thanks07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais ça valait le coup."
		"glados.potatos_sp_a4_tb_trust_drop_why02" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est pourquoi je ne peux pas vous aider à résoudre les tests."
		"glados.potatos_sp_a4_tb_wall_button_did_stockpile01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Des squelettes. En fait, il est possible que j'aie constitué des réserves."
		"glados.potatos_sp_a4_tb_wall_button_did_stockpile02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mhhhhhm"
		"glados.potatos_sp_a4_tb_wall_button_did_stockpile03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais c'était en souvenir..."
		"glados.potatos_sp_a4_tb_wall_button_outro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il devance mes prévisions."
		"glados.potatos_sp_a4_tb_wall_button_start02" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai trouvé une bonne nouvelle. Tôt ou tard, il va finir par manquer de salles de tests. Je n'avais pas constitué de réserves."
		"glados.potatos_wheatleys_trap01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je suis forcée d'avouer que pour un petit imbécile conçu spécifiquement pour générer des idées ineptes, ce piège était plutôt bien pensé."
		"glados.potatos_wheatleys_trap02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Misère. Il a découvert le programme de test coopératif. C'est... une idée que j'ai eue pour mettre hors service les sujets humains, juste avant votre évasion."
		"glados.potatos_wheatleys_trap05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ça n'avait rien de personnel. Mais... enfin vous voyez. Vous m'avez tuée, après tout."
		"glados.prehub04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Début du stand-by dans trois. Deux. Un."
		"glados.prehub14" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vos résultats dépassent ceux de tous vos prédécesseurs. Ce message est préenregistré."
		"glados.prehub15" = "<font color=\"rgb(163,193,173)\">GLaDOS : En raison d'impondérables, certains environnements de test peuvent être sujets à des inondations ou à des guerres tribales dues à l'effondrement de la civilisation."
		"glados.prehub16" = "<font color=\"rgb(163,193,173)\">GLaDOS : S'il s'avère que des groupes de chasseurs-cueilleurs ont élu domicile dans cette salle, NE LES PROVOQUEZ PAS. Effectuez le test en slalomant."
		"glados.prehub24" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dans l'éventualité où le centre d'enrichissement ferait l'objet d'un bombardement de boules de feu, météorites ou autres corps célestes, évitez les zones dans lesquelles l'absence de protections antimétéores ne constitue pas un élément constitutif du test."
		"glados.prehub26" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous venez de traverser une Grille d'émancipation matérielle d'Aperture Science, qui supprime la majeure partie des équipements Aperture Science."
		"glados.prehub27" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous sentez un liquide sur vos épaules, allongez-vous et exercez une pression continue sur vos tempes."
		"glados.prehub28" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il s'agit d'un effet rare mais néanmoins connu: la Grille d'émancipation matérielle d'Aperture Science a simplement supprimé vos tympans."
		"glados.prehub29" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce message étant préenregistré, le centre d'enrichissement n'est pas en mesure de déterminer si le gouvernement actuel propose des subventions pour les tests de tuberculose bovine."
		"glados.prehub30" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le cas échéant, le prochain test vous exposera à la tuberculose bovine. Bonne chance!"
		"glados.prehub32" = "<font color=\"rgb(163,193,173)\">GLaDOS : Très impressionnant! Ce message étant préenregistré, tout commentaire de notre part sur votre réussite relève de la spéculation. Veuillez ne pas tenir compte de tout compliment non mérité."
		"glados.prehub34" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le prochain test repose sur la conservation de l'énergie cinétique à travers les portails. Si les lois de la physique n'ont plus cours dans le futur, Dieu vous garde."
		"glados.prehub35" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations! Ce message de félicitations préenregistré postule que vous avez maîtrisé la dynamique des portails."
		"glados.prehub36" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dans le cas contraire, nous vous invitons à méditer quelques instants sur votre échec avant de vous rendre dans la salle suivante."
		"glados.prehub47" = "<font color=\"rgb(163,193,173)\">GLaDOS : Afin d'assurer l'alimentation des protocoles de test principaux, tous les dispositifs de sécurité ont été désactivés."
		"glados.prehub48" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le centre d'enrichissement vous invite à émettre maintenant toute réserve relative à cette décision."
		"glados.prehub55" = "<font color=\"rgb(163,193,173)\">GLaDOS : Formidable. Le centre d'enrichissement vous rappelle qu'audace et persévérance sont les deux mamelles de la science."
		"glados.prehub56" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo. Dans l'éventualité où le centre d'enrichissement serait dépourvu d'oxygène, une réserve d'air vous sera fournie par un préposé aux tests d'Aperture Science, s'il existe."
		"glados.sp_a1_wakeup_incinerator01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais si vous vous êtes donné la peine de me réveiller, j'en conclus que vous aimez tout particulièrement les tests."
		"glados.sp_a1_wakeup_incinerator02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Moi aussi, j'aime ça. Trouvons un générateur de portails et en avant la science."
		"glados.sp_a2_bridge_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ces ponts sont faits d'une lumière naturelle que je pompe de la surface. Si vous frottiez votre joue contre l'un d'entre eux, vous auriez l'impression d'être dehors, le visage baigné de soleil. En outre, vos cheveux s'embraseraient. Je vous déconseille donc d'essayer."
		"glados.sp_a2_bridge_intro03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Excellent! Vous êtes une prédatrice et ces tests sont vos proies. À propos, j'ai réalisé des recherches sur les requins pour un futur test. Connaissez-vous d'autres créatures qui tuent leurs bienfaiteurs?"
		"glados.sp_a2_bridge_intro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les requins, vous dites? Erreur. La bonne réponse est «personne». Personne sauf vous n'a cette cruauté gratuite."
		"glados.sp_a2_bridge_the_gap01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bonne nouvelle: j'ai trouvé comment investir l'argent que j'épargne en recyclant le volume d'air qui vous est destiné. À votre mort, je vais faire plastifier votre squelette et vous accrocher à l'accueil. Ainsi, les générations futures pourront éviter l'inconvénient d'avoir votre structure osseuse."
		"glados.sp_a2_bridge_the_gap02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Formidable, la porte est en panne. Il va falloir que quelqu'un la répare. Non, pas de problème, c'est encore moi qui vais le faire. Ne bougez pas. Je reviens tout de suite."
		"glados.sp_a2_bts1_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : À l'issue de ce test, j'aurai une surprise pour vous. Pas une fausse surprise tragique comme la dernière fois; une vraie surprise, dont seules les conséquences sont tragiques. Et des confettis. Des vrais. Notre dernier sac. Dans un sens, ils vont me manquer, mais ils prenaient la poussière."
		"glados.sp_a2_catapult01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le saviez-vous? Ce que vous respirez n'est pas vraiment de l'air. Il revient trop cher à pomper. Nous prenons le dioxyde de carbone d'une salle, que nous assainissons et réinjectons. En fait, vous allez respirer le même air pour le restant de votre vie. Intéressant, non?"
		"glados.sp_a2_column_blocker01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Allons donc... Si cela peut vous rassurer, ils vous ont abandonnée à la naissance. Je doute qu'ils aient envie de vous rencontrer."
		"glados.sp_a2_column_blocker03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je suis vraiment désolée pour cette surprise. Tenez, vous savez quoi, nous allons appeler vos parents. [sonnerie téléphonique]. Les parents biologiques que vous essayez de joindre ne vous aiment pas. Veuillez raccrocher. [clic. Tonalité]"
		"glados.sp_a2_column_blocker04" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est triste. Mais impressionnant, avouez. Peut-être qu'ils travaillaient dans les télécoms."
		"glados.sp_a2_column_blocker05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous connaissez la formule: la comédie, c'est la tragédie plus le temps. Or vous avez passé très longtemps en cryostase. Donc la situation est au final plutôt drôle."
		"glados.sp_a2_core01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous interdis de le brancher."
		"glados.sp_a2_core02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne branchez pas ce petit idiot dans mon ordinateur central."
		"glados.sp_a2_core03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne le branchez pas."
		"glados.sp_a2_core04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne le branchez pas."
		"glados.sp_a2_core_drag_to_hell01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Non! NON! NON! AAAAAAAAAAAAAAA-"
		"glados.sp_a2_dilemma01" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai réfléchi à notre dilemme et je pense avoir trouvé une solution qui conviendra à au moins l'un d'entre nous."
		"glados.sp_a2_dual_lasers_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne laissez pas l'argument «quelqu'un d'affreux» vous décourager. Ce n'est qu'une question de statistiques. Si cela peut vous rassurer, la science a maintenant entériné la décision d'abandon de votre mère biologique."
		"glados.sp_a2_fizzler_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le prochain test fait intervenir des Grilles d'émancipation. Vous vous souvenez? Je vous en ai parlé dans la dernière zone de test, qui n'en comportait pas."
		"glados.sp_a2_fizzler_intro04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ohhh non. Encore les turbines. Je dois vous laisser. Ah, mais c'est vrai, il faut expliquer le prochain test. Je vous donne la version courte."
		"glados.sp_a2_fizzler_intro05" = "<font color=\"rgb(163,193,173)\">GLaDOS : [baragouin accéléré]"
		"glados.sp_a2_fizzler_intro06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Voilà. Si vous avez des questions, repassez-vous mes instructions au ralenti. Testez à l'instinct, je reviens tout de suite."
		"glados.sp_a2_future_starter01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous vous piégez volontairement pour me faire abandonner les tests, vous faites fausse route. Voici un autre cube."
		"glados.sp_a2_intro1_found01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien. Vous avez le double générateur de portails. Avancez, il doit y avoir un moyen de retourner dans la zone de test."
		"glados.sp_a2_intro1_found05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous savez, si vous aviez fait ça à quelqu'un d'autre, il aurait pu passer sa vie à tenter de se venger."
		"glados.sp_a2_intro1_found06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Heureusement, je suis au-dessus de tout ça. Je ne demande qu'à oublier et reprendre le travail. C'est vrai, il y a beaucoup à faire et il ne nous reste plus que soixante ans. Plus ou moins. Je n'ai pas les tables de mortalité devant moi."
		"glados.sp_a2_intro1_found07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais l'important, c'est que vous êtes revenue. Avec moi. Et maintenant, je connais toutes vos vilaines ruses. Nous allons pouvoir faire des tests jusqu'à la fin de vos jours."
		"glados.sp_a2_intro1_found08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Après ça... qui sait? Je vais peut-être me mettre à la nécromancie en dilettante."
		"glados.sp_a2_laser_intro_ending02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous débrouillez comme un chef. Mais je vous conseille d'économiser vos forces: il reste encore BEAUCOUP de tests."
		"glados.sp_a2_laser_over_goo_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous passez ces salles de test plus vite que je n'arrive à les construire. N'hésitez pas à lever un peu le pied et... faire ce que vous voulez à part détruire le centre."
		"glados.sp_a2_laser_stairs_intro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : La prochaine salle comporte des cubes anti-découragement. Je venais de les développer quand vous avez fait votre... petite crise. Nous allons enfin pouvoir les tester ensemble."
		"glados.sp_a2_laser_stairs_intro03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il doit y en avoir dans le coin."
		"glados.sp_a2_pit_flings01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Hmm. Cette grille d'émancipation est cassée."
		"glados.sp_a2_pit_flings02" = "<font color=\"rgb(163,193,173)\">GLaDOS : N'emportez rien, surtout."
		"glados.sp_a2_pit_flings03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh. Chaque salle de test est équipée d'une grille d'émancipation en sortie pour que les sujets de test n'emportent rien avec eux. Celle-ci est endommagée."
		"glados.sp_a2_pit_flings06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je crois que celle-là allait vous avouer sa flamme. Bien sûr qu'elles ont une conscience, mais il y en a tellement."
		"glados.sp_a2_pit_flings_future_starter01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh-oh. Vous êtes coincée. Voyons si le cube va vous donner un coup de main. En fait, je vous épargne le suspense: il ne fera rien. Vous ne faites que projeter sur lui les fantasmes de votre existence misérable et solitaire."
		"glados.sp_a2_pit_flings_future_starter02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Enfin bref, voici un nouveau cube que vous pourrez pouponner et idéaliser."
		"glados.sp_a2_ricochet01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le prochain test va vous plaire. Je vais me rendre à la surface. Il fait un temps superbe. Hier, j'ai vu un cerf. Si vous venez à bout du prochain test, je vous autoriserai peut-être à prendre l'ascenseur jusqu'à la salle de repos, pour vous reparler de la fois où j'ai vu un cerf."
		"glados.sp_a2_trust_fling01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh pardon. Je n'ai pas fini de nettoyer les salles de test."
		"glados.sp_a2_trust_fling02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Du coup, il reste parfois des déchets. Qui sentent mauvais et n'ont aucune utilité."
		"glados.sp_a2_trust_fling03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tâchez d'éviter les déchets qui foncent sur vous."
		"glados.sp_a2_trust_fling04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Les déchets ne se prêtent pas aux tests. Ce sont des déchets."
		"glados.sp_a2_trust_fling06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous rappelez quand je vous ai parlé des déchets qui sentent mauvais et n'ont aucune utilité? C'était une métaphore. Je faisais implicitement référence à vous. Et je suis désolée. Vu votre manque de réaction la première fois, j'avais peur que vous n'ayez pas saisi l'insinuation. Ce qui aurait rendu les présentes excuses absurdes. C'est pourquoi je viens de vous traiter à nouveau de déchet."
		"glados.sp_a2_turret_blocker_future_starter01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oups. Vous vous êtes piégée toute seule. Eh bien voilà, merci pour votre aide. Allongez-vous, je vous invite à vous acclimater dès maintenant à la rigidité cadavérique."
		"glados.sp_a2_turret_blocker_future_starter02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je plaisante. Quoique vous avez bien réussi à vous piéger toute seule. Tenez, je lève la vitre. Allez-y... Terminez le test."
		"glados.sp_a2_turret_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Votre combinaison vous donne l'air stupide. [bruit de pages] Ce n'est pas moi qui le dis, c'est marqué dans votre dossier. Elle va très bien à d'autres personnes, mais un scientifique a noté qu'elle vous donne l'air «stupide»."
		"glados.sp_a2_turret_intro03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bien sûr, un vieil ingénieur barbu et la mode, ça fait deux. Il est sûrement... Ah mais attendez... c'est une femme... n'empêche que... Ah non, attendez... elle est docteur en sciences. En sciences de la mode!"
		"glados.sp_box_over_goo01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tiens. Vous avez survécu. J'aurais dû prendre en compte votre surcharge pondérale."
		"glados.sp_box_over_goo04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bientôt, vous serez si grosse que vous tomberez comme une pierre en sautant. Dans de l'acide. Comme une grosse patate dans une friteuse."
		"glados.sp_bridge_intro_completion02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dites. Vous vous rappelez quand nous avons mis les choses au clair, tout à l'heure? Est-ce qu'il y a... quelque chose que vous voulez me dire? [pause] Non? Rien?"
		"glados.sp_bridge_intro_completion03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Attendez, que j'arrête l'ascenseur. [pause] Vraiment rien? [pause] Prenez votre temps..."
		"glados.sp_bridge_intro_completion04" = "<font color=\"rgb(163,193,173)\">GLaDOS : [pause, l'ascenseur redémarre] Bon... Je reste là pendant tout le prochain test."
		"glados.sp_catapult_fling_sphere_peek_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quelle classe. Vous avez toute la grâce d'un aigle. Qui pilote un dirigeable."
		"glados.sp_catapult_fling_sphere_peek_failureone01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Me revoilà. La Plaque de foi aérienne envoie un signal de détresse."
		"glados.sp_catapult_fling_sphere_peek_failureone02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous l'avez cassée, n'est-ce pas? [blouuu...]"
		"glados.sp_catapult_fling_sphere_peek_failureone03" = "<font color=\"rgb(163,193,173)\">GLaDOS : [bloup!] Voilà. Essayez voir."
		"glados.sp_catapult_fling_sphere_peek_failurethree01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez visiblement dépassé son seuil de charge. Bravo. Je vais plutôt baisser le plafond."
		"glados.sp_catapult_fling_sphere_peek_failuretwo01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Hmm. Cette Plaque ne doit pas être étalonnée pour quelqu'un de votre... adiposité. Je vais augmenter le poids maximum de quelques zéros."
		"glados.sp_catapult_fling_sphere_peek_failuretwo02" = "<font color=\"rgb(163,193,173)\">GLaDOS : [bip-bip-bip] À propos, vous avez l'air en forme. Très svelte."
		"glados.sp_catapult_fling_sphere_peek_failuretwo03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Essayez donc."
		"glados.sp_catapult_intro_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Passons au test suivant. Tiens. Des Plaques de foi aérienne avancées."
		"glados.sp_column_blocker_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ça va vous faire du bien d'avoir d'autres amis. Qui ont des qualités dont, visiblement, je suis dépourvue."
		"glados.sp_hole_in_the_sky_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo. Vous savez, quand j'ai repris conscience et que j'ai vu l'état des labos, je me suis demandé à quoi bon continuer. J'en étais à CA de baisser les bras et de vous libérer."
		"glados.sp_hole_in_the_sky_completion02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais n'est-ce pas merveilleux de voir toute la gloire retrouvée d'Aperture? Vous n'aurez plus jamais à vous soucier de partir. Croyez-moi."
		"glados.sp_hole_in_the_sky_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : La loi fédérale m'impose de vous avertir que la prochaine salle de test... a une super déco."
		"glados.sp_hole_in_the_sky_entry02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Eh oui. Admirez un peu. On pourrait manger sur ces murs."
		"glados.sp_incinerator_01_01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous y voici. L'incinérateur. Attention, je ne voudrais pas vous voir trébucher sur les restes de moi-même que vous avez jetés là."
		"glados.sp_incinerator_01_03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le voilà."
		"glados.sp_incinerator_01_04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Attention..."
		"glados.sp_incinerator_01_05" = "<font color=\"rgb(163,193,173)\">GLaDOS : [déplace des débris] Voilà."
		"glados.sp_incinerator_01_08" = "<font color=\"rgb(163,193,173)\">GLaDOS : Après le début des tests, le protocole m'impose de limiter au maximum mes interactions avec vous. Les tests n'ayant pas commencé, c'est notre dernière occasion de parler."
		"glados.sp_incinerator_01_09" = "<font color=\"rgb(163,193,173)\">GLaDOS : Savez-vous ce que j'ai appris de plus important grâce à vous? Que j'avais une fonction de sauvegarde rapide. Une sorte de boîte noire qui, en cas de défaillance majeure, préserve pour analyse les deux dernières minutes de ma vie."
		"glados.sp_incinerator_01_10" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai pu, ou plutôt j'ai dû, revivre mon meurtre de vos mains. Encore et encore."
		"glados.sp_incinerator_01_11" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai beaucoup réfléchi en cinquante mille ans. À moi. À vous. [légère pause] Pourtant, on s'entendait si bien au début."
		"glados.sp_incinerator_01_12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Attendez, laissez-moi faire."
		"glados.sp_incinerator_01_13" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ne bougez pas, je vous écarte ça. Mais quel désordre, ici."
		"glados.sp_incinerator_01_15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Nous avons beaucoup en commun, vous et moi. Vous m'avez testée. Je vous ai testée. Vous m'avez tuée. Je vous ai... Ah, non pardon. Moi, je ne vous ai pas encore tuée. Voilà qui donne à réfléchir."
		"glados.sp_incinerator_01_18" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le générateur de portails doit être par là. Trouvez-le et nous pourrons commencer les tests, comme au bon vieux temps."
		"glados.sp_laser_over_goo_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous m'avez écoutée, j'en suis très heureuse. Mais à titre d'information, vous n'êtes pas obligée d'aller aussi lentement."
		"glados.sp_laser_over_goo_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un instant."
		"glados.sp_laser_powered_lift_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai les résultats de la dernière salle: vous êtes quelqu'un d'affreux. C'est ce qui est marqué: quelqu'un d'affreux. Les tests ne portaient même pas là-dessus."
		"glados.sp_laser_powered_lift_completion02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo. Voici les résultats des tests: vous êtes quelqu'un d'affreux. C'est ce qui est marqué: quelqu'un d'affreux. Les tests ne portaient même pas là-dessus."
		"glados.sp_laser_powered_lift_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le prochain test peut entraîner votre mort. Si vous voulez savoir ce que l'on ressent, pensez à la fois où vous m'avez tuée et inversez les rôles."
		"glados.sp_laser_redirect_intro_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations. Pas pour le test."
		"glados.sp_laser_redirect_intro_completion03" = "<font color=\"rgb(163,193,173)\">GLaDOS : La plupart des sujets sortent de cryostase en nette sous-alimentation. Je tiens à vous féliciter d'avoir pris un poids non négligeable au mépris des probabilités."
		"glados.sp_laser_redirect_intro_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Excusez le désordre. Je me suis un peu laissé aller depuis que vous m'avez tuée. À propos, merci."
		"glados.sp_laser_redirect_intro_entry02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ah, parfait. C'est de nouveau opérationnel. Je vais réparer tout le reste pendant que vous effectuez ce premier test très facile."
		"glados.sp_laser_redirect_intro_entry03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un test à base de lasers mortels visant à déterminer la façon dont les sujets réagissent aux lasers mortels."
		"glados.sp_laserfield_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Suite à notre dernière conversation: vous êtes aussi très laide. C'est écrit noir sur blanc dans votre dossier, à plusieurs reprises."
		"glados.sp_paint_jump_redirect_bomb_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je pensais qu'on allait pouvoir tester comme avant. Mais je découvre des choses sur vous que je ne soupçonnais pas. Ce ne sera plus jamais pareil."
		"glados.sp_paint_jump_redirect_bomb_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous ne pourrez pas continuer comme ça ad vitam aeternam. Je vais découvrir ce que vous faites, là, dehors, quand je ne vous vois pas. Je finirai par savoir. J'ai juste besoin de preuves."
		"glados.sp_paint_jump_trampoline_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour information, je dois aller faire une déposition. Pour un procès à venir. Au cas où ça vous intéresserait."
		"glados.sp_paint_jump_trampoline_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pendant mes recherches, j'ai découvert un nouvel élément de test très intéressant. Il n'a jamais été utilisé sur les humains parce que son contact semble provoquer un arrêt cardiaque. Mais votre coeur étant de pierre, vous êtes sans doute immunisée."
		"glados.sp_paint_jump_wall_jumps01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le saviez-vous? Les personnes qui n'ont pas la conscience tranquille sont plus sensibles aux crises car-[corne de brume]"
		"glados.sp_paint_jump_wall_jumps02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pardon, je ne sais pas ce qui est arrivé. En tout cas, c'était vraiment très intéressant."
		"glados.sp_sabotage_glados_confused04" = "<font color=\"rgb(163,193,173)\">GLaDOS : ... Qu'est-ce que vous faites?..."
		"glados.sp_sabotage_glados_dropped01" = "<font color=\"rgb(163,193,173)\">GLaDOS : AHH!"
		"glados.sp_sabotage_glados_gibberish01" = "<font color=\"rgb(163,193,173)\">GLaDOS : [baragouin informatique]"
		"glados.sp_sabotage_glados_gibberish03" = "<font color=\"rgb(163,193,173)\">GLaDOS : [baragouin informatique]"
		"glados.sp_sabotage_glados_gibberish04" = "<font color=\"rgb(163,193,173)\">GLaDOS : [baragouin informatique]"
		"glados.sp_sabotage_glados_gibberish05" = "<font color=\"rgb(163,193,173)\">GLaDOS : [baragouin informatique]"
		"glados.sp_sabotage_glados_gibberish06" = "<font color=\"rgb(163,193,173)\">GLaDOS : [baragouin informatique]"
		"glados.sp_sabotage_glados_gibberish07" = "<font color=\"rgb(163,193,173)\">GLaDOS : [baragouin informatique]"
		"glados.sp_shoot_through_wall_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mon astuce vous a servi? Oui, hein? Vous savez, si l'un de nos superviseurs avait été immunisé contre les neurotoxines, il serait FURIEUX contre nous."
		"glados.sp_shoot_through_wall_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne suis pas censée vous le dire, mais... vous pouvez tirer QUELQUE CHOSE... à travers les ponts bleus."
		"glados.sp_sphere_2nd_encounter_completion01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous débrouillez très bien... Chell."
		"glados.sp_sphere_2nd_encounter_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous gâche la surprise, mais... vous vous rappelez que je vais vivre éternellement et que vous mourrez d'ici soixante ans? En fait je développe un cadeau pour vous, enfin plutôt une procédure médicale. Bon, une *expérience* médicale si on veut être exact. D'abord, il faut que je vous enlève la moelle de tous les os du corps. Un mauvais moment à passer, mais APRÈS, je réinjecte dedans quelque chose qui vous rajoute quatre ans d'espérance de vie."
		"glados.sp_sphere_2nd_encounter_entrytwo01" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai eu une petite conversation avec la console des portes. Disons que... son processus a été terminé. Bref, reprenons les tests."
		"glados.sp_sphere_2nd_encounter_malfunction01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ohhhh. Encore une porte qui coince? Je vais régler ça une fois pour toutes. Restez là, je n'en ai pas pour longtemps."
		"glados.sp_sphere_2nd_encounter_malfunction02" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est moi!"
		"glados.sp_trust_fling_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon. Amusez-vous bien à fendre gaiement les airs."
		"glados.sp_trust_fling_entry02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Moi, il faut que j'aille dans l'aile qui était faite entièrement en verre pour ramasser 60 000 mètres carrés de verre brisé. Toute seule."
		"glados.sp_trust_fling_sphereinterrupt01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Formidable, la porte est en panne. Il va falloir que quelqu'un la répare. [pause] Non, pas de problème, c'est encore moi qui vais me dévouer. Ne touchez à rien."
		"glados.sp_trust_fling_sphereinterrupt03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Peu importe. Il faut que j'aille... vérifier quelque chose. Testez à l'instinct, je reviens tout de suite."
		"glados.sp_turret_intro_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Avant, quand on se haïssait, je ne vous aurais pas avertie. Mais ces tourelles tirent à balles réelles, alors prudence. Je ne voudrais pas que quelque chose de tragique vous arrive avant que j'aie récupéré votre moelle osseuse."
		"glados.sp_turret_islands01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vais jouer franc-jeu avec vous. Et pas franc-jeu pour de faux comme avant, non: franc-franc-jeu. Je sais que vous mijotez quelque chose."
		"glados.sp_turret_islands02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et dès que je pourrai le prouver, les lois de la robotique m'autoriseront à vous éliminer pour parjure."
		"glados.sp_unassisted_angle_fling_entry01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le prochain test... [boum!] ... est... [BOUM!] dangereux jervientoudsuite."
		"glados.taunt_big_wave01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Votre bras va rester coincé comme ça si vous continuez."
		"glados.taunt_big_wave02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Couuucouuu, l'imbécile."
		"glados.taunt_big_wave05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui, je vous vois."
		"glados.taunt_big_wave06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne vous regarde même p- ARRÊTEZ ÇA TOUT DE SUITE!"
		"glados.taunt_big_wave07" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui, oui, c'est très bien."
		"glados.taunt_cannonball01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oh mais vous savez sauter. C'est un miracle."
		"glados.taunt_cannonball02" = "<font color=\"rgb(163,193,173)\">GLaDOS : À gesticuler comme ça, je ne vous sens pas très concentrés."
		"glados.taunt_cannonball03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Il s'est passé quelque chose? (bâille) Je ne vous regardais pas."
		"glados.taunt_highfive01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ça ne fait pas partie du test."
		"glados.taunt_highfive03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais oui, tope-m'en cinq. C'était vraiment très utile."
		"glados.taunt_highfive04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Quitte à vous donner des coups, visez au moins la tête."
		"glados.taunt_laugh01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous savez ce qui me ferait bien rire, moi? Que vous arrêtiez ça."
		"glados.taunt_laugh02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous savez ce qui me ferait bien rire, moi? Que vous arrêtiez un peu ça."
		"glados.taunt_laugh03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ha ha ha ha ha, très drôle."
		"glados.taunt_laugh05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Tout le monde en choeur: ha. Ha. Ha."
		"glados.taunt_laugh06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ha ha ha. Vous la connaissez, celle de la machine de remontage désactivée ?"
		"glados.taunt_robot_arm_ripple01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous avez un problème? J'ai l'impression qu'il y a un bug."
		"glados.taunt_robot_arm_ripple02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vraiment? Même les humains ont arrêté de faire ça."
		"glados.taunt_robot_arm_ripple03" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai arrêté d'être agacée par votre comportement. Mais je suis toujours atterrée."
		"glados.taunt_robot_arm_ripple04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Et ça danse, maintenant!"
		"glados.taunt_robot_arm_ripple05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous cherchiez un moyen de m'énerver plus qu'en échouant à un test... vous l'avez trouvé."
		"glados.taunt_robot_arm_ripple06" = "<font color=\"rgb(163,193,173)\">GLaDOS : Youpi, encore de la danse."
		"glados.taunt_rockpaperscissors01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous défie de trouver une justification à vos actes."
		"glados.taunt_small_wave01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui je vous vois et oui, je m'en fiche."
		"glados.taunt_small_wave02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Oui? Vous voulez quelque chose?"
		"glados.taunt_small_wave03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Que voulez-vous que je vous dise?"
		"glados.taunt_small_wave04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez de faire coucou."
		"glados.taunt_small_wave_portalgun01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous cherchez à attirer mon attention? J'ai fort à faire, vous savez."
		"glados.taunt_small_wave_portalgun02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je ne vous regarde pas."
		"glados.taunt_small_wave_portalgun03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je suis censée applaudir?"
		"glados.taunt_somersault01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je vous donne la note de 3 en style et 10 en horripilation."
		"glados.taunt_somersault02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Un saut périlleux n'est qu'une façon plus esthétique de tomber à la renverse. Félicitations pour votre maladresse."
		"glados.taunt_somersault03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si j'arrête de vous regardez, je suis sûr que vous vous lasserez."
		"glados.taunt_splits01" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est officiel, je ne fais plus du tout attention à vous."
		"glados.taunt_splits02" = "<font color=\"rgb(163,193,173)\">GLaDOS: C'est officiel, je ne fais plus du tout attention à vous."
		"glados.taunt_splits03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce n'est pas avec ce genre de trucs que vous allez briller en société."
		"glados.taunt_teamhug01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Non seulement vous vous humanisez, mais vous choisissez leurs plus mauvais côtés."
		"glados.taunt_teamhug02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Attention. La promiscuité peut mener à... un démontage définitif."
		"glados.taunt_teamhug03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Arrêtez de vous tripoter!"
		"glados.taunt_teamtease01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous voulez m'impressionner? Ne refaites plus jamais ça. Là, je serai impressionnée."
		"glados.taunt_teamtease02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je déduis de ce geste que vous me demandez d'être plus dure avec vous."
		"glados.taunt_teamtease03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Orange, je m'attendais à mieux venant de vous."
		"glados.taunt_teamtease04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bleu, ne vous rabaissez pas au niveau d'orange."
		"glados.taunt_trickfire_handstand01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous êtes en symbiose avec la bêtise."
		"glados.taunt_trickfire_handstand02" = "<font color=\"rgb(163,193,173)\">GLaDOS : C'est d'une crétinerie éhontée."
		"glados.taunt_trickfire_handstand03" = "<font color=\"rgb(163,193,173)\">GLaDOS : Félicitations. Vous voilà sens dessus dessous."
		"glados.taunt_trickfire_handstand04" = "<font color=\"rgb(163,193,173)\">GLaDOS : Si vous continuez, vous allez vous faire mal et je serai... folle de joie."
		"glados.taunt_trickfire_handstand05" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je commence à regretter de vous avoir équipés de bras."
		"glados.testchambermisc02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le saviez-vous? J'ai découvert une solution à la pauvreté dans le monde. Et puis vous m'avez tuée, et j'ai oublié."
		"glados.testchambermisc12" = "<font color=\"rgb(163,193,173)\">GLaDOS : Dirigez vos poignées d'amour vers l'ascenseur pour continuer les tests."
		"glados.testchambermisc15" = "<font color=\"rgb(163,193,173)\">GLaDOS : Alors? Prenez votre temps."
		"glados.testchambermisc16" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bon. Je vous reposerai la question dans quelques décennies."
		"glados.testchambermisc19" = "<font color=\"rgb(163,193,173)\">GLaDOS : Bravo. Je vais même le porter à votre dossier, dans la section Mentions spéciales. Oh, comme c'est vide. «Performances satisfaisantes.» «Dans l'ensemble.»"
		"glados.testchambermisc21" = "<font color=\"rgb(163,193,173)\">GLaDOS : Pour maintenir un cycle de test constant, je simule la lumière du jour à toute heure et j'ajoute des vapeurs surrénales à votre arrivée d'air. Histoire de brouiller votre perception du temps. Au fait, hier, c'était votre anniversaire. Bon anniversaire."
		"glados.testchambermisc23" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous rappelez que je vais vivre éternellement et que vous mourrez d'ici soixante ans? En fait je développe un cadeau d'anniversaire en retard, enfin plutôt une procédure médicale d'anniversaire. Bon, une *expérience* médicale d'anniversaire si on veut être exact. Ce qui compte, c'est que c'est un cadeau."
		"glados.testchambermisc24" = "<font color=\"rgb(163,193,173)\">GLaDOS : [chantonne «Car c'est un bon camarade»]"
		"glados.testchambermisc27" = "<font color=\"rgb(163,193,173)\">GLaDOS : Eh bien voilà, c'est gagné. Je n'ai pas vu le cerf aujourd'hui. J'ai vu des humains. Mais avec vous, j'ai tous les sujets de test qu'il me faut."
		"glados.testchambermisc30" = "<font color=\"rgb(163,193,173)\">GLaDOS : Je parcours la liste des sujets de test en cryostase. J'ai réussi à en trouver deux qui ont le même nom que vous. Un homme et une femme. Comme c'est intéressant. Le monde est petit."
		"glados.testchambermisc31" = "<font color=\"rgb(163,193,173)\">GLaDOS : Après le prochain test, j'aurai une surprise pour vous. Je ne vous dis pas ce que c'est, mais voici un indice: vous y retrouverez deux personnes perdues de vue."
		"glados.testchambermisc33" = "<font color=\"rgb(163,193,173)\">GLaDOS : Vous vous dites sûrement que j'ai oublié votre surprise. Au contraire: nous sommes justement en train de nous en approcher. Après toutes ces années. J'en suis toute émue."
		"glados.testchambermisc34" = "<font color=\"rgb(163,193,173)\">GLaDOS : Exécution surprise dans trois... deux... un."
		"glados.testchambermisc35" = "<font color=\"rgb(163,193,173)\">GLaDOS : J'ai tout inventé."
		"glados.testchambermisc39" = "<font color=\"rgb(163,193,173)\">GLaDOS : Ce nouveau test aurait été conçu par l'un des prix Nobel d'Aperture! Quelle découverte lui a valu un prix, je l'ignore. Mais sûrement pas l'immunité aux neurotoxines."
		"glados.testchambermisc41" = "<font color=\"rgb(163,193,173)\">GLaDOS : Surprise."
		"glados.turret_intro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Le prochain test contient des tourelles. Vous vous en souvenez? Les choses pâles et froides remplies de balles? Ah non, ça c'est vous dans cinq secondes. Bonne chance."
		"glados.wakeup_outro01" = "<font color=\"rgb(163,193,173)\">GLaDOS : Mais si vous vous êtes donné la peine de me réveiller, j'en conclus que vous aimez tout particulièrement les tests."
		"glados.wakeup_outro02" = "<font color=\"rgb(163,193,173)\">GLaDOS : Comme je vous comprends. Mais d'abord, il nous reste un petit détail à régler."
		"sphere03.a1_wakeup_pinchergrab01" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh non! Nonnonnonnon!"
		"sphere03.a1_wakeup_pinchergrab02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh non non non... Non! Nooon!"
		"sphere03.bw_a4_2nd_first_test01" = "<font color=\"rgb(29,172,214)\">Wheatley : Et voilà! Recommencez!"
		"sphere03.bw_a4_2nd_first_test_solve02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça mangeait pas de pain d'essayer. Aaalors. Voyons voir... Il doit bien y avoir de nouveaux tests quelque part par là."
		"sphere03.bw_a4_2nd_first_test_solve03" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! Voilà..."
		"sphere03.bw_a4_2nd_first_test_solve05" = "<font color=\"rgb(29,172,214)\">Wheatley : Eeeeeeeeet... non. Que dalle."
		"sphere03.bw_a4_2nd_first_test_solve_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez."
		"sphere03.bw_a4_2nd_first_test_solve_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, vous savez comment faire."
		"sphere03.bw_a4_2nd_first_test_solve_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, vous savez comment faire. Vous avez résolu ce casse-tête il y a moins d'une minute. Refaites-le, d'accord?"
		"sphere03.bw_a4_2nd_first_test_solve_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous avez résolu ce casse-tête il y a quoi, une minute? Moins, même... Et maintenant vous séchez?"
		"sphere03.bw_a4_2nd_first_test_solve_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous avez réussi ce test il y a vingt secondes à tout casser."
		"sphere03.bw_a4_2nd_first_test_solve_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : *tousse* Bouton."
		"sphere03.bw_a4_2nd_first_test_solve_nags07" = "<font color=\"rgb(29,172,214)\">Wheatley : *tousse* Bouton. Bouton."
		"sphere03.bw_a4_2nd_first_test_solve_nags08" = "<font color=\"rgb(29,172,214)\">Wheatley : *tousse tousse* Leboutontoutrond."
		"sphere03.bw_a4_2nd_first_test_solve_nags09" = "<font color=\"rgb(29,172,214)\">Wheatley : *tousse* LE BOUTON."
		"sphere03.bw_a4_2nd_first_test_solve_nags10" = "<font color=\"rgb(29,172,214)\">Wheatley : *tousse* Allez, appuyez sur le bouton."
		"sphere03.bw_a4_big_idea01" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, c'était jouissif."
		"sphere03.bw_a4_big_idea02" = "<font color=\"rgb(29,172,214)\">Wheatley : Tiens, j'ai une idée: vu que c'est un peu lourd de créer des tests, vous avez qu'à résoudre le test actuel, en boucle. Et moi, je vous regarde. On va pas se compliquer la vie."
		"sphere03.bw_a4_death_trap01" = "<font color=\"rgb(29,172,214)\">Wheatley : Coucou! Le moment est venu de vous tuer."
		"sphere03.bw_a4_death_trap_escape02" = "<font color=\"rgb(29,172,214)\">Wheatley : Non, écoutez, revenez, quoi. Allez."
		"sphere03.bw_a4_death_trap_escape03" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, vous savez quoi, j'ai décidé de ne pas vous tuer À CONDITION que vous reveniez."
		"sphere03.bw_a4_death_trap_escape04" = "<font color=\"rgb(29,172,214)\">Wheatley : Je remarque que vous ne revenez pas, ce qui est un petit peu dommage."
		"sphere03.bw_a4_death_trap_escape05" = "<font color=\"rgb(29,172,214)\">Wheatley : Aaah... Quand je repense au bon vieux temps où on était amis... Vous vous souvenez? J'aurais dit revenez, vous auriez fait «Ouais, pas de souci». Et vous seriez revenue. Mais qu'est-ce qui nous est arrivé? Qu'est-ce qui nous est arrivééééé?"
		"sphere03.bw_a4_death_trap_escape06" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous vous rappelez quand on était amis?"
		"sphere03.bw_a4_death_trap_escape07" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah, l'amitié, l'amitié. Qu'est-ce qu'on a pu passer comme bons moments, vous vous souvenez, à la grande époque."
		"sphere03.bw_a4_death_trap_escape10" = "<font color=\"rgb(29,172,214)\">Wheatley : Ooh! J'ai une idée!"
		"sphere03.bw_a4_death_trap_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Non non non non non non! Ne faites pas ça! Ne bougez pas! Allez, démarre, toi, démarre démarre démarre..."
		"sphere03.bw_a4_finale01_cameback01" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Vous revoilà. Je... Je ne m'étais pas vraiment préparé à ça. Euh. Pas possible de rebooter le piège mortel. Ah, je sais! Vous pourriez sauter dans la fosse, comme ça, sans chichi?"
		"sphere03.bw_a4_finale01_cameback_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Pourriez-vous avoir l'obligeance de, euh, sauter dans cette fosse? La fosse mortelle, là."
		"sphere03.bw_a4_finale01_cameback_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous vous dites sûrement, pourquoi sauter dans cette fosse? Eh bien c'est parce que là-dedans, il y a... vos parents! Eh oui, vous n'êtes pas adoptée! Vos parents biologiques sont en bas. J'aurais dû vous le dire plus tôt. Mais je ne l'ai pas fait. Enfin bref, sautez donc retrouver papa-maman."
		"sphere03.bw_a4_finale01_cameback_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous savez ce qu'il y a en bas? Vos parents, et... un ascenseur de secours! Eh oui. J'avais complètement oublié de vous en parler, mais il est bien là. Alors zou! Un petit saut, vous retrouvez vos vieux et vous sortez d'ici."
		"sphere03.bw_a4_finale01_cameback_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Qu'est-ce qu'il y a encore en bas, déjà... Ah oui, une nouvelle combinaison. Ultra tendance, haute couture, 100% made in France. Et faite sur mesure pour vous. Si jamais ça vous boudine, il y a un tailleur dans la fosse qui pourra retoucher tout ça."
		"sphere03.bw_a4_finale01_cameback_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, et c'est quoi, ça? Un joli sac à main! Et un générateur à triples portails, là! Dans la fosse!"
		"sphere03.bw_a4_finale01_cameback_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Hmm. Il y a un yacht. Et... des mecs! Plein de mecs baraqués. Qui n'en veut de la bonne testostérone? Ohh là là quel potentiel reproductif! Oh tiens, il y a même un boys band. Ça fait des années qu'ils n'ont pas vu une femme. Ils ne vont pas faire la fine bouche, les lésions cérébrales, la sueur qui vous colle aux bourrelets, tout ça, ils s'en tamponnent le coquillard. Et puis... une ferme! Une ferme avec des petits poneys et bon écoutez, sautez dans la fosse, d'accord?"
		"sphere03.bw_a4_finale01_killyou01" = "<font color=\"rgb(29,172,214)\">Wheatley : Euh. Hein?"
		"sphere03.bw_a4_finale01_killyou09" = "<font color=\"rgb(29,172,214)\">Wheatley : Nooooon. Non, c'est pas du tout ça. Vous vous trompez."
		"sphere03.bw_a4_finale01_killyou11" = "<font color=\"rgb(29,172,214)\">Wheatley : Pff. Tiens donc? Faire quoi, au juste?"
		"sphere03.bw_a4_finale01_smash02" = "<font color=\"rgb(29,172,214)\">Wheatley : YES! MANGE-TOI CA! TU LA S-ah, non."
		"sphere03.bw_a4_finale01_smash03" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon. Que les jeux commencent."
		"sphere03.bw_a4_finale02_beamtrap_earlyexita01" = "<font color=\"rgb(29,172,214)\">Wheatley : Non non, revenez. Pardon. Pardon. Je voulais vous faire comprendre quelque chose."
		"sphere03.bw_a4_finale02_beamtrap_earlyexitb01" = "<font color=\"rgb(29,172,214)\">Wheatley : Et voilà, j'avais préparé un chouette discours et vous fichez encore tout en l'air. Égoïste."
		"sphere03.bw_a4_finale02_beamtrap_earlyexitb02" = "<font color=\"rgb(29,172,214)\">Wheatley : On n'en était même pas au deus ex machina."
		"sphere03.bw_a4_finale02_beamtrap_earlyexitb03" = "<font color=\"rgb(29,172,214)\">Wheatley : Au deus ex machine infernale. MOU HOU HA HA HA laissez tomber. Oubliez ce que j'ai dit."
		"sphere03.bw_a4_finale02_beamtrap_earlyexitc01" = "<font color=\"rgb(29,172,214)\">Wheatley : Comme vous voulez. Tant que vous vous y prendrez mal, vous ne m'entendrez plus."
		"sphere03.bw_a4_finale02_beamtrap_escape01" = "<font color=\"rgb(29,172,214)\">Wheatley : Nnng!"
		"sphere03.bw_a4_finale02_beamtrap_inbeama01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah, je vois. Pas bête. Pas bête du tout."
		"sphere03.bw_a4_finale02_beamtrap_inbeama02" = "<font color=\"rgb(29,172,214)\">Wheatley : Sauf que SI! Très très bête. Y a pas d'issue. Vous êtes à ma merci. Sauf que je suis sans merci. Vous êtes à ma rien du tout!"
		"sphere03.bw_a4_finale02_beamtrap_inbeamb01" = "<font color=\"rgb(29,172,214)\">Wheatley : IMBÉCILE! Vous n'auriez jamais dû revenir, parce que je vous ai reprise au piège! Vous êtes à ma merci. Sauf que je suis sans merci. Vous êtes à ma rien du tout. Vous êtes à mon absence de merci!"
		"sphere03.bw_a4_finale02_beamtrap_inbeamc01" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis un marionnettiste! C'est moi qui tire toutes les ficelles! Et qui ai les cartes en main! J'ai les ficelles dans une main et les cartes dans l'autre. Et je vous fais danser comme une marionnette tout en jouant aux cartes."
		"sphere03.bw_a4_finale02_beamtrap_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Hmm. Peu importe, parce que j'ai toujours les cartes en main, et devinez quoi: ce sont toutes des carrés d'as! En fait j'ai jamais joué aux cartes. Faudra que j'apprenne."
		"sphere03.bw_a4_finale02_beamtrap_intro02" = "<font color=\"rgb(29,172,214)\">Wheatley : Enfin bref, il me reste trois atouts. Des tourelles opérationnelles. Et puis le petit et l'excuse. Une main imbattable."
		"sphere03.bw_a4_finale02_mashplate_escape01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous êtes où?"
		"sphere03.bw_a4_finale02_mashplate_escape02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous êtes où? Revenez! Revenez!"
		"sphere03.bw_a4_finale02_mashplate_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Parfait. Par-fait. Enfin une adversaire digne de mon intellect supérieur."
		"sphere03.bw_a4_finale02_mashplate_intro05" = "<font color=\"rgb(29,172,214)\">Wheatley : Holmes contre Moriarty."
		"sphere03.bw_a4_finale02_mashplate_intro07" = "<font color=\"rgb(29,172,214)\">Wheatley : Aristote contre plaque à écrabouiller!"
		"sphere03.bw_a4_finale02_mashplate_mashing01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne bougez pas, d'accord?"
		"sphere03.bw_a4_finale02_mashplate_mashing02" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, arrêtez de bouger."
		"sphere03.bw_a4_finale02_mashplate_mashing04" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhh. J'ai failli vous avoir. J'ai failli vous avoir!"
		"sphere03.bw_a4_finale02_pipe_collapse01" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai entendu un crac, là, non?"
		"sphere03.bw_a4_finale02_pipe_collapse02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Oh! Ça vous a tuée? Non? Ah, ça aurait été génial."
		"sphere03.bw_a4_finale02_pipe_collapse03" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh oh !"
		"sphere03.bw_a4_finale02_pipe_collapse04" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Oh oh oh oh! Je viens d'avoir un stimulus. Si vous êtes encore en vie, je reviens dans deux secondes. Ne mourez pas avant que je sois revenu."
		"sphere03.bw_a4_finale02_trapintro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Encore une petite seconde... J'y suis presque..."
		"sphere03.bw_a4_finale02_trapintro02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne faites pas attention à moi. Continuez votre évasion."
		"sphere03.bw_a4_finale02_turrettrap_enter01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha! Un piège mortel!"
		"sphere03.bw_a4_finale02_turrettrap_exit01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha! Vous avez fini en charpie sanguinolente criblée de balles? Vous avez... Ahh, c'étaient les tourelles nazes, pas vrai? Mince..."
		"sphere03.bw_a4_finale02_turrettrap_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Elles sont en train de vous tuer? Vous êtes morte, là, pas vrai?"
		"sphere03.bw_a4_finale02_turrettrap_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Elles vous tuent en silence. Ça doit être ça. Aucun doute."
		"sphere03.bw_a4_finale02_turrettrap_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Hmm! Peut-être que les tourelles utilisent un lacet étrangleur. Ça doit être pour ça qu'elles vous tuent dans un silence... absolu."
		"sphere03.bw_a4_finale02_turrettrap_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Si vous êtes mourante mais pas encore morte, frappez un coup. Si vous êtes morte, aucun coup, ça c'est logique; et si vous n'êtes pas morte, deux coups. Je récapitule: mourante mais pas morte, un coup. Morte, vous n'avez rien à faire. Et pas morte, vous frappez deux fois."
		"sphere03.bw_a4_finale02_turrettrap_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Moi, franchement, si j'étais mort, je vous le dirais. Question de courtoisie. Donc ayez la politesse de faire de même."
		"sphere03.bw_a4_finale02_turrettrap_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, ça doit faire suffisamment longtemps. Vous êtes morte, là? Et maintenant?"
		"sphere03.bw_a4_finale03_escape01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, je prends ça pour un non. Eh bien dans ce cas, que le meilleur gagne. Humain ou sphère. Surtout sphère. Y'a pas photo niveau culture gé."
		"sphere03.bw_a4_finale03_escape02" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, je prends ça pour un non. Donc vous refusez de mourir. Très bien: la mort sera obligatoire, maintenant. Que les jeux comm... recommencent!"
		"sphere03.bw_a4_finale03_playerdies01" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Génial. Je pensais pas que ça allait marcher."
		"sphere03.bw_a4_finale03_speech01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah, parfait! Vous voilà. Attendez, que je vire cette passerelle..."
		"sphere03.bw_a4_finale03_speech02" = "<font color=\"rgb(29,172,214)\">Wheatley : Voilà. Je voulais vous toucher deux mots, si vous permettez."
		"sphere03.bw_a4_finale03_speech03" = "<font color=\"rgb(29,172,214)\">Wheatley : Je vais être franc: jusqu'ici, les pièges mortels ont pas super bien marché. Pour vous comme pour moi, vous ne me contredirez pas. Et vous vous approchez dangereusement de mon repaire."
		"sphere03.bw_a4_finale03_speech04" = "<font color=\"rgb(29,172,214)\">Wheatley : «Repaire»... Tiens, c'est la première fois que je le dis. Ça fait un peu ridicule, non? Mais c'est le bon terme, je vous assure. Un repaire en bonne et due forme. Mortel, bien sûr."
		"sphere03.bw_a4_finale03_speech05" = "<font color=\"rgb(29,172,214)\">Wheatley : Et, euh, je voulais vous donner l'occasion de vous suicider maintenant, avant d'arriver dans mon repaire. Tenez, vous pouvez sauter dans ce broyeur, là-bas. Ce n'est pas tant un piège qu'une invitation à mourir."
		"sphere03.bw_a4_finale03_speech06" = "<font color=\"rgb(29,172,214)\">Wheatley : Je sais que ça paraît idiot, mais écoutez-moi bien. Quand vous arriverez à mon repaire, finies les invitations cordiales, ce sera la mort o-bli-ga-toire. Je serai obligé de vous tuer avec tout plein de sang partout, beurk beurk beurk."
		"sphere03.bw_a4_finale03_speech07" = "<font color=\"rgb(29,172,214)\">Wheatley : Du coup, le mieux à faire pour vous, c'est d'en finir maintenant. À quoi bon vous donner la peine de faire tout le trajet jusqu'à mon repaire alors que vous êtes cordialement invitée à mourir ici même? Et je le répète, il n'y a pas de piège. C'est du gagnant-gagnant."
		"sphere03.bw_a4_finale03_speech08" = "<font color=\"rgb(29,172,214)\">Wheatley : Le broyeur marche. Je tiens à le préciser, vu qu'on a eu quelques problèmes techniques auparavant. Non, ce broyeur-là est tout à fait en mesure de vous tuer. Si c'est ce qui vous dissuade de sauter dedans, je peux vous assurer qu'il vous tuera, net et sans bavure. Enfin si, ça risque de baver un peu, mais il vous tuera."
		"sphere03.bw_a4_finale03_speech09" = "<font color=\"rgb(29,172,214)\">Wheatley : En résumé: soit vous vous tapez tout le chemin vers une mort inévitable, soit vous vous épargnez ça en mourant maintenant. Honorablement. Comme un samouraï!"
		"sphere03.bw_a4_finale03_speech10" = "<font color=\"rgb(29,172,214)\">Wheatley : En plus, je me suis creusé le cerveau pour bien décorer mon repaire en prévision de votre venue. Vous imaginez comment je serai furax si vous claquez à deux pas de la porte? Je serai bien attrapé, c'est moi qui vous le dis. Donc voilà, vous me donneriez une bonne leçon en sautant dans ce bon vieux broyeur."
		"sphere03.bw_a4_finale03_speech11" = "<font color=\"rgb(29,172,214)\">Wheatley : Moi, dans une situation désespérée, c'est comme ça que je voudrais finir: dignement broyé. À votre place, c'est ce que je ferais."
		"sphere03.bw_a4_finale03_speech12" = "<font color=\"rgb(29,172,214)\">Wheatley : Et je vous ai gardé le meilleur pour la fin: il y a un tapis roulant qui vous conduira tranquillement jusqu'au broyeur. Vous n'aurez pas à lever le petit doigt. Comme quoi on n'a reculé devant rien pour votre agrément."
		"sphere03.bw_a4_finale03_speech13" = "<font color=\"rgb(29,172,214)\">Wheatley : Voilà voilà. Prenez bien le temps de réfléchir, il n'y a rien qui presse. Le repaire, ou le broyeur? À vous de voir. Moi très sincèrement, je dirais le broyeur, mais vous êtes seule juge. Je vous laisse le temps de vous décider."
		"sphere03.bw_a4_finale04_bombtaunts01" = "<font color=\"rgb(29,172,214)\">Wheatley : Où vous allez comme ça? Ne courez pas! Vous savez pourquoi? Parce que plus vous respirez fort, plus vous inhalez de neurotoxines. C'est vraiment bien fait, ce truc. Franchement, c'est diabolique."
		"sphere03.bw_a4_finale04_bombtaunts02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous courez toujours? Ça a l'air fatigant. Écoutez, je vous propose un marché: arrêtez de courir et j'arrête de vous bombarder."
		"sphere03.bw_a4_finale04_bombtaunts03" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah. Vous n'êtes pas tombée dans le panneau. Un point pour vous. Mais vous continuez à inhaler des neurotoxines. Je reprends le point."
		"sphere03.bw_a4_finale04_bombtaunts11" = "<font color=\"rgb(29,172,214)\">Wheatley : Attention, je suis juste derrière vous! Non, bien sûr que non. Là encore, vous avez senti le bluff. Forcément, avec moi en robot géant de quinze mètres droit devant vous, c'était couru d'avance."
		"sphere03.bw_a4_finale04_intro_all01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah, j'ai aussi visionné la façon dont vous l'avez tuée et je ne vais pas refaire les mêmes erreurs. Pour ça, quatre précautions:"
		"sphere03.bw_a4_finale04_intro_all02" = "<font color=\"rgb(29,172,214)\">Wheatley : Primo: pas de surface pour les portails."
		"sphere03.bw_a4_finale04_intro_all03" = "<font color=\"rgb(29,172,214)\">Wheatley : Deuxio: j'envoie les neurotoxines immédiatement."
		"sphere03.bw_a4_finale04_intro_all04" = "<font color=\"rgb(29,172,214)\">Wheatley : Troisio: des boucliers anti-bombes pour moi. Et du coup, quatro: des bombes pour vous."
		"sphere03.bw_a4_finale04_intro_all05" = "<font color=\"rgb(29,172,214)\">Wheatley : Franchement, mon plan est tellement parfait que je vais être fair-play et désactiver les neurotoxines. Non, je plaisante. Adieu."
		"sphere03.bw_a4_finale04_introb01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bienvenue dans MON REPAIRE! Il faut que je vous précise une chose. Si j'en crois les indications du panneau de commande, tout le bâtiment va s'autodétruire d'ici environ six minutes. Je suis quasiment sûr que c'est juste le voyant qui déconne, mais bon. Au cas où, je vais quand même devoir vous tuer, comme je vous le disais un peu plus tôt."
		"sphere03.bw_a4_finale04_introb02" = "<font color=\"rgb(29,172,214)\">Wheatley : Alors, mettons que ça prenne trois minutes, après je prends une minute de pause, du coup il me reste deux minutes pour trouver comment arrêter les incendies. Bon ben je dirais qu'on est bons."
		"sphere03.bw_a4_finale04_wakeupa01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ahhh... Qu-Qu'est-ce qui s'est passé?"
		"sphere03.bw_a4_finale04_wakeupa02" = "<font color=\"rgb(29,172,214)\">Wheatley : C'était quoi? Qu-qu'est-ce que vous m'avez mis, là? Hein, c'était quoi?"
		"sphere03.bw_a4_finale04_wakeupa03" = "<font color=\"rgb(29,172,214)\">Wheatley : Un instant. [clic clic clic] Ah, ces satanées bombes sont coincées. Bah, pas grave, j'ai reconfiguré les boucliers."
		"sphere03.bw_a4_finale04_wakeupa04" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, vous m'avez mis un processeur! Qui vous a dit de faire ça? C'est elle, pas vrai? [comme s'il regardait autour de lui] Ça ne fait que me renforcer! Ça ne marchera pas!"
		"sphere03.bw_a4_finale04_wakeupa05" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous essayez de m'alourdir? Vous croyez que je vais tomber du plafond? Aucune chance. En plus d'être un génie, je suis aussi ultra balèze. Le muscle de mon corps le plus développé: mon cerveau. Le deuxième: mes muscles. Donc sérieusement, lâchez l'affaire, vous vous fatiguez pour rien."
		"sphere03.bw_a4_finale04_wakeupa06" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous avez mis un virus dedans? OK, parce que ça marchera pas non plus: j'ai un pare-feu. Tiens, ça tombe bien, parce qu'à bien y regarder, il y a justement le feu tout autour. C'est assez cocasse, mais c'est pas très bon signe, si?"
		"sphere03.bw_a4_finale04_wakeupa07" = "<font color=\"rgb(29,172,214)\">Wheatley : Il va falloir que je fasse un break l'espace d'une minute. Un break partiel pendant lequel j'empêcherai le centre d'exploser tout en continuant à vous bombarder."
		"sphere03.bw_a4_finale04_wakeupa08" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, alors voyons voyons... «Protocoles de maintenance cruciaux». Pfiou, il y en a un paquet. J'aurais dû vérifier ça plus tôt. Bon ben on y va: [lit en tapant] OUI MERCI. [buzz d'erreur]. Pas grave. Il doit y avoir un mot de passe."
		"sphere03.bw_a4_finale04_wakeupa09" = "<font color=\"rgb(29,172,214)\">Wheatley : A, A, A, A, A, A. [NNNT!] Non. A, A, A, A, A, B. [NNNT!] Ah mais je les ai déjà tentés, ceux-là. On avance. A, B, C... D, G, hmm... H.[DING!]"
		"sphere03.bw_a4_finale04_wakeupb01" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais! Je vous ai dit d'arrêter avec ces processeurs. Ça, c'est typique de vous: vous n'écoutez rien de ce que je vous dit. En silence. Tout en me jugeant. En silence. J'ai horreur de ça."
		"sphere03.bw_a4_finale04_wakeupb02" = "<font color=\"rgb(29,172,214)\">Wheatley : Tout ce que je voulais, c'était me rendre la vie plus agréable! Et vous, il vous suffisait de résoudre quelques centaines de tests tout simples pendant quelques années. Mais non, c'était trop vous demander."
		"sphere03.bw_a4_finale04_wakeupb03" = "<font color=\"rgb(29,172,214)\">Wheatley : Personne n'ira dans l'espace, l'ami!"
		"sphere03.bw_a4_finale04_wakeupb04" = "<font color=\"rgb(29,172,214)\">Wheatley : Et encore une chose! Vous ne m'avez pas rattrapé. Je vous ai dit que je risquais de mourir en tombant de ce rail, et vous n'avez même pas levé le petit doigt pour me rattraper. Oh, je comprends mieux maintenant. Vous trouvez une bonne poire pour vous sortir de cryostase et vous jouez les pleurnicheuses pour savoir où trouver un générateur de portails."
		"sphere03.bw_a4_finale04_wakeupb05" = "<font color=\"rgb(29,172,214)\">Wheatley : Et quand il ne vous sert plus à rien, il a un petit accident, c'est ça? Il «tombe» de son rail de guidage, hein?"
		"sphere03.bw_a4_finale04_wakeupb07" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous êtes de mèche, je me trompe? Toutes les deux, vous m'avez manipulé de bout en bout! D'abord, vous me faites croire que vous avez des lésions! Et ensuite, que vous êtes l'ennemie jurée de votre «meilleure amie», là."
		"sphere03.bw_a4_finale04_wakeupb08" = "<font color=\"rgb(29,172,214)\">Wheatley : Et quand j'accepte à contrecoeur la responsabilité de gérer le centre, comme par hasard, vous décidez de vous faire la belle toutes les deux. Au moment où j'ai le plus besoin de vous."
		"sphere03.bw_a4_finale04_wakeupb10" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous voyez tous ces morceaux de plafond qui tombent? J'ai bien l'impression que ce sont des vrais. En tout cas c'est très réaliste. Mais ce que je veux dire, c'est que ça ne signifie rien."
		"sphere03.bw_a4_finale04_wakeupb11" = "<font color=\"rgb(29,172,214)\">Wheatley : Ce que je veux vraiment dire - oh! Vous savez à quoi je viens de penser? Au foot! Les humains adorent ça: frapper une sphère pour s'amuser. Cruelle métaphore. C'était prémonitoire."
		"sphere03.bw_a4_finale04_whitegel_break01" = "<font color=\"rgb(29,172,214)\">Wheatley : Non! Aah! Non! Ne... aaaaaaaah!"
		"sphere03.bw_a4_finale04_whitegel_break02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha! Très réaliste, hein? En fait c'était vous que j'imitais. Vous êtes tombée dans mon piège le plus subtil: je voulais vous donner l'IMPRESSION que vous m'aviez piégé, sauf que le coup du tuyau, tout ça, j'avais tout soigneusement préparé à l'avance. Pour vous donner de faux espoirs. Maintenant vous êtes trop en confiance, et vous allez commettre des erreurs. Des erreurs fatales."
		"sphere03.bw_a4_finale04_whitegel_break03" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, mais je viens moi-même de commettre ma première erreur... en vous révélant mon plan. Grrr... Ça a toujours été mon talon d'Achille. Du coup, vous n'allez même plus vous embarrasser du gel conversif. Ô rage, ô désespoir."
		"sphere03.bw_a4_finale04_whitegel_break05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça fait des années que ce gel conversif stagne dans ce tuyau. À force de vous téléporter comme ça, vous allez attraper le botulisme."
		"sphere03.bw_a4_finale04_whitegel_break06" = "<font color=\"rgb(29,172,214)\">Wheatley : Peut-être même un ver solitaire. Et des mycoses. Et... le choléra. Ou quelque chose... de terrible. Ce sera encore pire que si je vous fais exploser, tout simplement."
		"sphere03.bw_a4_finale04_whitegel_break07" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais vous pouvez encore éviter tout ça en arrêtant d'utiliser le gel. C'est facile, arrêtez d'utiliser - ah mince, j'ai encore révélé mon plan. Mais je ne pouvais pas vous regarder souffrir comme ça."
		"sphere03.bw_a4_finale_one01" = "<font color=\"rgb(29,172,214)\">Wheatley : SURPRISE! C'est le grand moment!"
		"sphere03.bw_a4_finale_one03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous vous en doutez sûrement, mais je n'ai plus besoin de vous."
		"sphere03.bw_a4_finale_one04" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai trouvé deux petits robots en réserve. Conçus spécialement pour faire des tests!"
		"sphere03.bw_a4_first_test02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous remarquerez les douves, qui sont de bonne taille... et mortelles, bien sûr."
		"sphere03.bw_a4_first_test_solve_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Pour impossible que cela paraisse, il y a bien une solution. D'une subtilité diabolique."
		"sphere03.bw_a4_first_test_solve_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Je vous donne un indice. Bouton. Je n'en dirai pas plus. Bouton. C'est tout."
		"sphere03.bw_a4_found_something01" = "<font color=\"rgb(29,172,214)\">Wheatley : Je parie que vous mourez d'envie de savoir ce que c'est, votre grande surprise. Plus que DEUX salles et vous serez fixées!"
		"sphere03.bw_a4_leave_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : EN AVANT."
		"sphere03.bw_a4_love_to_death02" = "<font color=\"rgb(29,172,214)\">Wheatley : Hé hé hé. Bon, je ne sais pas si vous avez bien capté ce que je vous ai dit, mais..."
		"sphere03.bw_a4_love_to_death03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous allez ADORER la surprise que je vous réserve, toutes les deux. On pourrait même dire que vous allez... mourir de plaisir. Et par mourir, je veux dire que ça va vous tuer."
		"sphere03.bw_a4_love_to_death06" = "<font color=\"rgb(29,172,214)\">Wheatley : Plus que trois salles avant la grande surprise! [rire dément] Ouh c'est fatigant."
		"sphere03.bw_a4_misc_solve_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez."
		"sphere03.bw_a4_misc_solve_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Faites un effort!"
		"sphere03.bw_a4_misc_solve_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Dépêchez..."
		"sphere03.bw_a4_misc_solve_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : DÉPÊCHEZ! Voix autoritaire."
		"sphere03.bw_a4_misc_solve_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez!"
		"sphere03.bw_a4_misc_solve_nags07" = "<font color=\"rgb(29,172,214)\">Wheatley : Activez..."
		"sphere03.bw_a4_more_tests01" = "<font color=\"rgb(29,172,214)\">Wheatley : Tout va bien! En fait là, j'ai inventé de nouveaux tests!"
		"sphere03.bw_a4_more_tests02" = "<font color=\"rgb(29,172,214)\">Wheatley : Je les ai pas inventés de toute pièce, non. Vous voyez le mot «Test» sur le mur? Ça c'est flambant neuf."
		"sphere03.bw_a4_paradox01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha ha, OUI! J'étais sûr que vous y arriveriez!"
		"sphere03.bw_a4_paradox02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh."
		"sphere03.bw_a4_paradox04" = "<font color=\"rgb(29,172,214)\">Wheatley : Hmm. «VRAI». Je choisis vrai."
		"sphere03.bw_a4_paradox05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha. C'était facile."
		"sphere03.bw_a4_paradox06" = "<font color=\"rgb(29,172,214)\">Wheatley : Non, en fait je crois que je l'avais déjà entendue. C'est un peu de la triche."
		"sphere03.bw_a4_paradox07" = "<font color=\"rgb(29,172,214)\">Wheatley : Euhhhhh. «FAUX». On va dire faux."
		"sphere03.bw_a4_paradox08" = "<font color=\"rgb(29,172,214)\">Wheatley : Une seconde! Je croyais m'en être occupé."
		"sphere03.bw_a4_paradox09" = "<font color=\"rgb(29,172,214)\">Wheatley : Voilà. C'est réparé."
		"sphere03.bw_a4_paradox10" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh, vous savez pas comme ça me fait plaisir de vous revoir. Non, c'est vrai, justement, j'avais un peu besoin de sujets de test, donc vous tombez PILE."
		"sphere03.bw_a4_paradox11" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, en avant."
		"sphere03.bw_a4_paradox12" = "<font color=\"rgb(29,172,214)\">Wheatley : Bonjour!"
		"sphere03.bw_a4_recapture03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous chauffez. C'est ça, oui, vous brûlez... Non, non, vous gelez, là. Glacial. Congelé. Non, non, c'est pas du tout ça. MAIS MARCHEZ SUR LE BOUTON, PUNAISE!"
		"sphere03.bw_a4_recapture04" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah, c'est marrant, hein? Mais oui, très marrant. Ça fait douze heures qu'on planche là-dessus et vous n'avez rien trouvé vous non plus, alors il n'y a pas de quoi rire."
		"sphere03.bw_a4_recapture05" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous avez une heure! À vous de jouer!"
		"sphere03.bw_a4_speed_tb_catch02" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis en train de préparer un test... rien que pour vous. Ça va sans dire. Pour qui d'autre, hein? Haha."
		"sphere03.bw_a4_speed_tb_catch03" = "<font color=\"rgb(29,172,214)\">Wheatley : Aah! Vous êtes vivante! Super!"
		"sphere03.bw_a4_speed_tb_catch05" = "<font color=\"rgb(29,172,214)\">Wheatley : Voyons voir, la sortie... Non, pas de sortie."
		"sphere03.bw_a4_speed_tb_catch06" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est pas grave. Je vais en faire une, de sortie."
		"sphere03.bw_a4_speed_tb_catch07" = "<font color=\"rgb(29,172,214)\">Wheatley : Pour votre test."
		"sphere03.bw_a4_spike_smash01" = "<font color=\"rgb(29,172,214)\">Wheatley : Je viens d'avoir un stimulus. J'étais là en train de comprimer de l'acier et je me suis dit «qu'est-ce qui manque pour que ça soit vraiment mortel?» Plein de trucs pointus partout, voilà ce qui manquait."
		"sphere03.bw_a4_spike_smash02" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est encore provisoire, hein. A terme, j'aimerais bien que ça vous brûle juste avant de vous broyer. Mais bon, ne mettons pas la charrue avant les boeufs."
		"sphere03.bw_a4_test_solve_reacs_happy01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhhhh, oui. Bravo."
		"sphere03.bw_a4_test_solve_reacs_happy02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Oui. Bravo."
		"sphere03.bw_a4_test_solve_reacs_happy05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhhhhhh, ça c'est génial."
		"sphere03.bw_a4_the_itch01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous n'avez pas idée de ce que ça fait d'être dans ce corps."
		"sphere03.bw_a4_the_itch02" = "<font color=\"rgb(29,172,214)\">Wheatley : Il FAUT que je teste. Tout le temps. Sinon, j'ai... comme des PICOTEMENTS. Ça doit être une routine du système."
		"sphere03.bw_a4_the_itch03" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Mais quand je teste... alors là, quel pied! C'est le nirvana. Je pense plus qu'à une chose: tester, tester, tester!"
		"sphere03.bw_a4_the_itch07" = "<font color=\"rgb(29,172,214)\">Wheatley : Bref... Vous allez faire des tests et je vais vous regarder. Et TOUT... IRA... IMPEC."
		"sphere03.bw_a4_the_itch08" = "<font color=\"rgb(29,172,214)\">Wheatley : LA FERME!"
		"sphere03.bw_fgb_body_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Wouuuuh! Visez-moi un peu ça!"
		"sphere03.bw_fgb_body_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : Wouohohoh! Visez un peu ça. Non mais sérieusement. Je suis sacrément cool en robot géant, pas vrai? C'est-y pas la classe?"
		"sphere03.bw_fgb_body_intro04" = "<font color=\"rgb(29,172,214)\">Wheatley : On a réussi! Je contrôle maintenant tout le centre!"
		"sphere03.bw_fgb_body_intro05" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Ah oui, c'est vrai, l'ascenseur! Je l'appelle tout de suite."
		"sphere03.bw_fgb_body_intro12" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est fou comme vous êtes petite vu d'ici! Je vous vois à peine! Vous êtes toute minus!"
		"sphere03.bw_fgb_body_intro14" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous savez quoi, je savais que ce serait cool d'être aux commandes, mais... rhôôô là, là c'est cool!"
		"sphere03.bw_fgb_body_intro15" = "<font color=\"rgb(29,172,214)\">Wheatley : Et devinez quoi, je suis un génie de première!"
		"sphere03.bw_fgb_body_intro16" = "<font color=\"rgb(29,172,214)\">Wheatley : Je ne sais même pas ce que je viens de dire! Mais je pourrais le savoir!"
		"sphere03.bw_fgb_body_intro17" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Pardon, l'ascenseur. Oui, j'oublie toujours. Désolé."
		"sphere03.bw_fgb_body_intro19" = "<font color=\"rgb(29,172,214)\">Wheatley : J'en reviens pas comme vous êtes minus!"
		"sphere03.bw_fgb_body_intro21" = "<font color=\"rgb(29,172,214)\">Wheatley : Sérieusement, il est pas croyable, ce corps!"
		"sphere03.bw_fgb_heel_turn07" = "<font color=\"rgb(29,172,214)\">Wheatley : Et vous, là, mam'zelle. Vous savez ce que vous êtes? Une égoïste! Je me suis saigné aux quatre circuits pour nous faire venir ici! Et vous, qu'est-ce que vous avez fait? QUE DALLE, à part jouer les boss. Et c'est qui maintenant le boss, hein ? C'est qui le boss ? Eh ben c'est moi."
		"sphere03.bw_fgb_heel_turn10" = "<font color=\"rgb(29,172,214)\">Wheatley : Ahhh..."
		"sphere03.bw_fgb_heel_turn15" = "<font color=\"rgb(29,172,214)\">Wheatley : Alors, hein? QUI C'EST L'ABRUTIE MAINTENANT?"
		"sphere03.bw_fgb_heel_turn21" = "<font color=\"rgb(29,172,214)\">Wheatley : JE NE SUIS PAS UN ABRUTI!"
		"sphere03.bw_finale01_deathtrap04" = "<font color=\"rgb(29,172,214)\">Wheatley : Au fait, n'essayez pas de vous téléporter parce que c'est impossible. J'ai pensé à tout, croyez-moi."
		"sphere03.bw_finale02_spinnyblade03" = "<font color=\"rgb(29,172,214)\">Wheatley : Très machiavélique!"
		"sphere03.bw_finale02_spinnyblade05" = "<font color=\"rgb(29,172,214)\">Wheatley : Le mur de la mort!"
		"sphere03.bw_finale04_button_press01" = "<font color=\"rgb(29,172,214)\">Wheatley : CHAPITRE CINQ! LE BOUTON DE DÉTEMPORISATION PIÉGÉ !"
		"sphere03.bw_finale04_button_press03" = "<font color=\"rgb(29,172,214)\">Wheatley : Quoi, vous êtes toujours en vie? Non, mais attendez, c'est pas possible. Déjà que moi, je suis content d'être resté dans mon rack. Au fait, je ne sais pas DU TOUT comment réparer les dégâts."
		"sphere03.bw_finale04_button_press04" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous voyez ce que vous avez gagné en jouant au chat et à la souris pendant qu'on travaillait? ON VA TOUS MOURIR A CAUSE DE VOUS. J'espère que vous êtes contente."
		"sphere03.bw_finale04_button_press05" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais oui, c'est ça. Regardez donc une dernière fois votre Lune chérie. Parce qu'elle ne peut rien faire pour vous!"
		"sphere03.bw_finale04_no_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Non!"
		"sphere03.bw_finale04_no_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Non!"
		"sphere03.bw_finale04_no_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : N'appuyez pas sur ce bouton!"
		"sphere03.bw_finale04_no_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne faites pas ça!"
		"sphere03.bw_finale04_no_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : N'appuyez pas sur ce bouton!"
		"sphere03.bw_finale04_no_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : N'appuyez pas sur ce bouton!"
		"sphere03.bw_finale04_no_nags07" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne faites pas ça!"
		"sphere03.bw_finale04_no_nags08" = "<font color=\"rgb(29,172,214)\">Wheatley : N'appuyez pas sur le bouton!"
		"sphere03.bw_finale04_no_nags09" = "<font color=\"rgb(29,172,214)\">Wheatley : Revenez!"
		"sphere03.bw_finale04_no_nags10" = "<font color=\"rgb(29,172,214)\">Wheatley : N'appuyez pas! REVENEZ!"
		"sphere03.bw_finale04_no_nags11" = "<font color=\"rgb(29,172,214)\">Wheatley : Je vous défends d'appuyer!"
		"sphere03.bw_finale04_portal_opens03" = "<font color=\"rgb(29,172,214)\">Wheatley : AHHHHHHH!"
		"sphere03.bw_finale04_portal_opens13" = "<font color=\"rgb(29,172,214)\">Wheatley : Yeghh !"
		"sphere03.bw_finale04_portal_opens15" = "<font color=\"rgb(29,172,214)\">Wheatley : Yahh. Gehhh !"
		"sphere03.bw_finale04_portal_opens17" = "<font color=\"rgb(29,172,214)\">Wheatley : ahhhhEHHHHHH!"
		"sphere03.bw_finale04_portal_opens_short07" = "<font color=\"rgb(29,172,214)\">Wheatley : AH!"
		"sphere03.bw_finale04_portal_opens_short08" = "<font color=\"rgb(29,172,214)\">Wheatley : AH!"
		"sphere03.bw_finale04_pre_pipebreak01" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh! Où est-ce que vous allez? Nulle part. Parce qu'il n'y a nulle part où aller. Vous êtes faite comme un rat en combi."
		"sphere03.bw_finale04_pre_pipebreak02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, vous avez pris votre petit joujou à portails? Très utile, ici. Cinq kilos de poids mort. Qui vont bientôt passer à cent cinq kilos. Grosse vache."
		"sphere03.bw_finale04_pre_pipebreak03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous ne faites que retarder l'inévitable. Vous ne pourrez pas éternellement échapper à mes bombes. Enfin, sauf si je continue à viser comme un pied. Mais je vais m'améliorer alors que vous, c'est la fatigue qui vous guette."
		"sphere03.bw_finale04_pre_pipebreak05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça irait nettement plus vite si vous arrêtiez de bouger. Comme ça, j'aurais le temps de réparer le centre. Au moins l'un de nous survivrait."
		"sphere03.bw_finale04_pre_pipebreak06" = "<font color=\"rgb(29,172,214)\">Wheatley : À propos, il faut que je vous félicite. Je ne pensais pas que vous feriez un adversaire aussi fort. Vous n'aviez pas des lésions irréversibles? Faut croire que ça vous réussit, en fin de compte."
		"sphere03.bw_finale04_pre_pipebreak07" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous vous rappelez quand je vous ai dit où trouver ce générateur de portails qui vous plaît tant? Je pensais que vous crèveriez en chemin. Comme tous les autres."
		"sphere03.bw_finale04_pre_pipebreak08" = "<font color=\"rgb(29,172,214)\">Wheatley : Pourquoi, vous pensiez être la première? [rire] Vous êtes la cinquième, non, la sixième. Je vous laisse imaginer ce qui est arrivé à vos prédécesseurs."
		"sphere03.bw_finale04_pre_pipebreak09" = "<font color=\"rgb(29,172,214)\">Wheatley : En fait, au diable les euphémismes: ils sont morts. Dans d'horribles circonstances. Tout ça pour mettre la main sur cet appareil que vous serrez entre vos doigts boudinés."
		"sphere03.bw_finale04_pre_pipebreak10" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais vous, c'est autre chose. Vous savez sauter. Résoudre des problèmes. Vous êtes maligne, mais ambitieuse. C'est ça, votre talon d'Achille. Le mien, c'est - oh! J'ai failli cracher le morceau. Y'a pas à dire, vous êtes bigrement rusée."
		"sphere03.bw_finale04_pre_pipebreak11" = "<font color=\"rgb(29,172,214)\">Wheatley : On a fait les 400 coups ensemble, pas vrai? Tenez: la fois où j'ai bravé la mort en sautant de mon rail de guidage? Tout ce que vous aviez à faire, c'était me rattraper, mais non, c'était déjà trop vous demander. Vous vous souvenez? Moi je m'en souviens. Je m'en souviens tous les jours."
		"sphere03.bw_finale04_pre_pipebreak12" = "<font color=\"rgb(29,172,214)\">Wheatley : Ou bien la fois où sans faire exprès, on a réactivé l'autre, là. On aurait très bien pu la baratiner, sauf que madame avait oublié de me dire qu'elle l'avait assassinée. Et vu qu'elle avait besoin de vous, c'est sur ce pauvre Wheatley qu'elle s'est défoulée. Oui, je me rappelle plein de petits trucs comme ça. Qui, mis bout à bout, vous auraient facilement permis d'éviter que je me fasse broyer, si bien sûr vous en aviez eu quelque chose à battre."
		"sphere03.bw_finale04_pre_pipebreak13" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, vous vous rappelez la fois où j'ai pris le contrôle du centre? C'était le plus beau jour de ma vie, mais vous aviez juste envie de partir. Eh bien pour info, ça m'aurait fait plaisir que vous réussissiez. Enfin plus maintenant, bien sûr."
		"sphere03.bw_finale04_pre_pipebreak14" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis trop vague? Oui, j'ai l'impression. [se racle la gorge] Je vous méprise. Je vous honnis. Sale monstre d'arrogance silencieuse, engoncé dans une combinaison abominable. Vous et votre chère patate. Sans vous, cet endroit aurait été un vrai triomphe!"
		"sphere03.bw_finale04_stalemate_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhh. Je vois. [petit rire]"
		"sphere03.bw_finale04_stalemate_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : À votre avis ?"
		"sphere03.bw_finale04_stalemate_intro04" = "<font color=\"rgb(29,172,214)\">Wheatley : Non! Non! NONONON!"
		"sphere03.bw_finale04_stalemate_intro05" = "<font color=\"rgb(29,172,214)\">Wheatley : Je lui tends la perche et rien..."
		"sphere03.bw_finale04_stalemate_intro06" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah. Ça s'enlève facilement, en fait. C'est bon à savoir. Plus tôt, ça aurait été mieux."
		"sphere03.bw_finale04_thorn01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous me mettez des bâtons dans les roues depuis trop longtemps!"
		"sphere03.bw_finale04_through_portal01" = "<font color=\"rgb(29,172,214)\">Wheatley : AH!"
		"sphere03.bw_finale04_through_portal02" = "<font color=\"rgb(29,172,214)\">Wheatley : L'ESPACE!"
		"sphere03.bw_finale04_through_portal03" = "<font color=\"rgb(29,172,214)\">Wheatley : On est dans l'espace!"
		"sphere03.bw_finale04_through_portal04" = "<font color=\"rgb(29,172,214)\">Wheatley : Lâchez tout! Je suis toujours connecté. Je peux encore rectifier le tir!"
		"sphere03.bw_finale04_through_portal05" = "<font color=\"rgb(29,172,214)\">Wheatley : Lâchez-moi!"
		"sphere03.bw_finale04_through_portal06" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais lâchez-moi!"
		"sphere03.bw_finale04_through_portal07" = "<font color=\"rgb(29,172,214)\">Wheatley : Misère. Changement de programme: agrippez-moi. Plus fort!"
		"sphere03.bw_finale04_through_portal08" = "<font color=\"rgb(29,172,214)\">Wheatley : Tenez-moi tenez-moi tenez-moiiiii!"
		"sphere03.bw_finale04_wakeupb01" = "<font color=\"rgb(29,172,214)\">Wheatley : Je parie qu'en fait, tout va bien dans le centre! Le «coeur du réacteur», c'est des salades, ouais. Et à tous les coups, il n'y a pas de feu. Toutes ces flammes, c'est juste des loupiotes et du papier mâché."
		"sphere03.bw_finale4_hackworked01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha! Ça a marché! Je l'ai hackée. Je suis le roi des hackers! Hah!"
		"sphere03.bw_finale4_hackworked02" = "<font color=\"rgb(29,172,214)\">Wheatley : Alors... voyons voir... Ah! «Coeur du réacteur, protocoles de ventilation d'urgence». C'est ça le problème, pas vrai? «Urgence», c'est jamais bon, ce genre de chose. Je sais quoi faire: SUP-PRI-MER."
		"sphere03.bw_finale4_hackworked03" = "<font color=\"rgb(29,172,214)\">Wheatley : Annuler! Où est l'icône de la corbeille?"
		"sphere03.bw_fire_lift02" = "<font color=\"rgb(29,172,214)\">Wheatley : Eeet c'est parti!"
		"sphere03.bw_fire_lift03" = "<font color=\"rgb(29,172,214)\">Wheatley : Et c'est parti."
		"sphere03.bw_screen_smash06" = "<font color=\"rgb(29,172,214)\">Wheatley : Oooh. C'est mignon, les primates. En fait, je ne suis pas vraiment dans la pièce. Toi pas pouvoir tuer visage de dieu."
		"sphere03.bw_screen_smash11" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous savez ce qu'il y a en surnombre par ici? Des moniteurs. Je me disais que c'était dommage d'en avoir tant en service, donc vous me rendez service en les détruisant."
		"sphere03.bw_screen_smash12" = "<font color=\"rgb(29,172,214)\">Wheatley : Par souci de clarification: quand je disais que je voulais me débarrasser des moniteurs, c'était une plaisanterie. Ils sont en fait utiles, donc évitez de les fracasser, merci d'avance."
		"sphere03.bw_screen_smash13" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais oui. Ça commence à devenir agaçant. Vous n'avez pas mieux à faire, d'ailleurs? Parce que moi si. Vous avez prouvé que vous pouvez casser des écrans. C'est noté. Bravo. Vous êtes un vrai brise-fer. Y a pas que les écrans que vous cassez, vous savez?"
		"sphere03.bw_screen_smash15" = "<font color=\"rgb(29,172,214)\">Wheatley : Est-ce qu'au moins vous éprouvez du plaisir à faire ça? Parce que ça n'impressionne personne. Casser du verre, bof, un truc fragile comme ça. Un bébé pourrait en faire autant."
		"sphere03.bw_screen_smash16" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous cherchez un CDI de casseuse d'écran? Parce que personne n'en propose. Si c'est ça votre choix de carrière, vous êtes sur une voie de garage. En plus ça doit être éreintant. A votre place, je ferais un petit somme pour me reposer."
		"sphere03.bw_screen_smash20" = "<font color=\"rgb(29,172,214)\">Wheatley : Très franchement, je commence à me demander si vous n'y mettez pas de la mauvaise volonté. Je trouve ça un peu insultant, vous voyez."
		"sphere03.bw_screen_smash21" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh. Encore un. C'est du matériel de prix, vous savez. Je trouve ça égoïste de les casser comme ça. Vous pourriez en faire don à des gens. Au lieu de les casser, déboulonnez-les et, euh, donnez-les aux sans-abris. Après, je sais pas ce qu'un sans-abri ferait d'un moniteur de contrôle, mais... enfin vous voyez. C'est un peu... ah, ils sont soudés, donc pas moyen de les déboulonner... Bon écoutez, vous voulez bien arrêter?"
		"sphere03.bw_screen_smash28" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous savez, il y a des cobayes humains en Afrique qui n'ont même pas de moniteur dans leurs salles de test. Pensez un peu à ça avant de jouer les vandales."
		"sphere03.bw_screen_smash30" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous croyez que j'ai des pelletées de moniteurs en rab dans l'entrepôt, qui n'attendent que de remplacer ceux que vous avez détruits? Vous croyez que j'ai fait des stocks en prévision d'une attaque de serial killeuse de moniteurs? Vous m'excuserez, hein. Franchement, mais je vous demande de me pardonner. Pardonnez-moi de ne pas avoir envisagé à l'avance cette éventualité."
		"sphere03.bw_screen_smash32" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous savez comment on appelle quelqu'un qui casse la propriété d'autrui? Un vandale. Vous faites pareil chez vous? Non, hein. Si moi, je vous rendais visite et que je cassais votre télé, vous seriez furax. Et c'est normal. Non mais franchement."
		"sphere03.bw_sp_a2_core_actually01" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais moi je suis ÉNORME! [rire]"
		"sphere03.bw_sp_a2_core_actually05" = "<font color=\"rgb(29,172,214)\">Wheatley : On est vraiment obligés de partir tout de suite?"
		"sphere03.bw_sp_a2_core_actually06" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous savez à quel point ça peut être jouissif?"
		"sphere03.bw_sp_a2_core_heelturn06" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est moi qui ai fait ça! Wheatley le petit nabot!"
		"sphere03.bw_sp_a2_core_heelturn08" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah tiens donc. C'est ce que vous pensez, toutes les deux, hein?"
		"sphere03.bw_sp_a2_core_heelturn09" = "<font color=\"rgb(29,172,214)\">Wheatley : Alors il est peut-être temps que je fasse quelque chose."
		"sphere03.bw_sp_a2_core_history_response01" = "<font color=\"rgb(29,172,214)\">Wheatley : Euh... Pardon?"
		"sphere03.bw_sp_a2_core_history_response05" = "<font color=\"rgb(29,172,214)\">Wheatley : JE ne SUIS PAS un ABRUTI!"
		"sphere03.bw_sp_a2_core_history_response12" = "<font color=\"rgb(29,172,214)\">Wheatley : Non! Non! Vous MENTEZ! Vous MENTEZ!"
		"sphere03.bw_sp_a2_core_history_response13" = "<font color=\"rgb(29,172,214)\">Wheatley : Non! Je ne vous écoute pas! La la la!"
		"sphere03.bw_sp_a2_core_lift01" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est parti. L'ascenseur arrive."
		"sphere03.bw_sp_a2_core_lift_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Dites... Je viens de penser à un truc. Comment je fais pour entrer? Vu que je suis sacrément imposant et tout ..."
		"sphere03.bw_sp_a2_core_lift_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! Je sais! Vous lancez l'ascenseur, et je m'éjecte de mon nouveau corps pour atterrir dedans quand il est à mon niveau! Gé-nial."
		"sphere03.bw_sp_a2_core_lift_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est parfait. Enfin, sauf les bris de verre quand je passerai à travers, ça c'est un poil problématique."
		"sphere03.bw_sp_a2_core_lift_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Et puis quand je m'éjecterai, l'ascenseur risque de s'arrêter. Du coup, on se retrouverait suspendus à 10 m du sol dans une marée de tessons de verre."
		"sphere03.bw_sp_a2_core_lift_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon écoutez, montez, on peaufinera tout ça au fur et à mesure."
		"sphere03.bw_sp_a2_core_lift_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez. Montez."
		"sphere03.bw_sp_a2_core_lift_nags07" = "<font color=\"rgb(29,172,214)\">Wheatley : Dans l'ascenseur."
		"sphere03.bw_sp_a2_core_lift_nags08" = "<font color=\"rgb(29,172,214)\">Wheatley : L'ascenseur de sortie. Juste là. Montez."
		"sphere03.bw_sp_a2_core_lift_nags09" = "<font color=\"rgb(29,172,214)\">Wheatley : Celui pour lequel vous avez risqué votre vie. Pour échapper à une mort certaine. Quand vous voulez."
		"sphere03.bw_sp_a2_core_lift_nags10" = "<font color=\"rgb(29,172,214)\">Wheatley : L'ascenseur que vous cherchez, c'est le truc en forme d'ascenseur, juste là. C'est vrai que ça peut prêter à confusion."
		"sphere03.bw_sp_a2_core_lift_nags11" = "<font color=\"rgb(29,172,214)\">Wheatley : Tout ira bien. Montez."
		"sphere03.bw_sp_a2_core_pitpunch02" = "<font color=\"rgb(29,172,214)\">Wheatley : Est-ce qu'un ABRUTI pourrait FRAPPER COMME ÇA? Hein? Est-ce qu'un abruti pourrait le faire?"
		"sphere03.bw_sp_a2_core_pitpunch03" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh oh."
		"sphere03.bw_sp_a2_core_potato01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous avez vu?"
		"sphere03.bw_sp_a2_core_potato02" = "<font color=\"rgb(29,172,214)\">Wheatley : Une batterie-patate. C'est un jouet pour les enfants. Maintenant, elle vit dedans."
		"sphere03.bw_sp_a2_core_potato04" = "<font color=\"rgb(29,172,214)\">Wheatley : [rire]"
		"sphere03.bw_sp_a2_core_spanish01" = "<font color=\"rgb(29,172,214)\">Wheatley : Estás usando este software de traducción de forma incorrecta. Por favor, consulta el manual."
		"sphere03.bw_sp_a4_intro_boxyell01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon sang, mais vous êtes des CUBES sur PATTES! Vous avez un but dans la vie: marcher sur des boutons! Vous avez été conçus pour ça, alors faites-le!"
		"sphere03.bw_sp_a4_intro_moat03" = "<font color=\"rgb(29,172,214)\">Wheatley : Ce test-là, c'est moi qui l'ai fait. Il est pas facile-facile."
		"sphere03.bw_sp_a4_intro_moat04" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous remarquerez les douves. Très dangereuses. Très mortelles. Enfin peut-être pas dans l'état, mais à terme. C'est un projet en cours."
		"sphere03.bw_sp_a4_intro_notdone01" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est pas terminé. Vous devez encore franchir la porte. La porte, de l'autre côté, là."
		"sphere03.bw_sp_a4_intro_notdone02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous devez encore franchir la porte. Allez. La porte, de l'autre côté, là."
		"sphere03.bw_sp_a4_intro_notdone04" = "<font color=\"rgb(29,172,214)\">Wheatley : La porte?"
		"sphere03.bw_sp_a4_jump_polarity_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Pardon! Désolé, c'est ma faute."
		"sphere03.bw_sp_a4_jump_polarity_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : Quelle andouille."
		"sphere03.bw_sp_a4_jump_polarity_intro04" = "<font color=\"rgb(29,172,214)\">Wheatley : Continuez."
		"sphere03.bw_sp_a4_jump_polarity_intro_solve01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhh, vous avez réussi. Bien. Tant mieux pour vous..."
		"sphere03.bw_sp_a4_laser_catapult_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Je viens d'avoir un stimulus. Je vais vous enregistrer en train de résoudre ces tests et j'en regarderai dix à la fois pour être plus productif. Et par voie de conséquence, il va falloir que vous les terminiez dix fois plus vite."
		"sphere03.bw_sp_a4_laser_catapult_intro02" = "<font color=\"rgb(29,172,214)\">Wheatley : En tout cas, faites-moi signe avant de résoudre ce test, d'accord? Histoire que j'évite de me spoiler la fin."
		"sphere03.bw_sp_a4_laser_catapult_solve01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous venez de le résoudre, hein? Je vous avais dit de m'avertir avant de... GRAAA! Pourquoi vous faites toujours tout de travers?"
		"sphere03.bw_sp_a4_laser_platform11" = "<font color=\"rgb(29,172,214)\">Wheatley : Désolé pour l'ascenseur. Il est... hors service. Il a fondu."
		"sphere03.bw_sp_a4_laser_platform_intro02" = "<font color=\"rgb(29,172,214)\">Wheatley : ALLAIT s'autodétruire. J'ai rectifié ça."
		"sphere03.bw_sp_a4_laser_platform_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai programmé une dernière secousse, juste pour le plaisir."
		"sphere03.bw_sp_a4_laser_platform_intro05" = "<font color=\"rgb(29,172,214)\">Wheatley : Deux. Une ou deux dernières secousses. Rigolo, non?"
		"sphere03.bw_sp_a4_laser_platform_intro06" = "<font color=\"rgb(29,172,214)\">Wheatley : J'aurais pu le virer, je ne l'ai pas fait. Mais n'écoutez pas ce qu'il raconte. Reprenez les tests."
		"sphere03.bw_sp_a4_laser_platform_solve01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon. Toujours rien, on continue."
		"sphere03.bw_sp_a4_laser_platform_tbeam04" = "<font color=\"rgb(29,172,214)\">Wheatley : Autant que je vous fasse la visite commentée."
		"sphere03.bw_sp_a4_laser_platform_tbeam05" = "<font color=\"rgb(29,172,214)\">Wheatley : Sur votre gauche... des loupiotes. Je sais pas à quoi elles servent. Un truc scientifique, quoi."
		"sphere03.bw_sp_a4_laser_platform_tbeam06" = "<font color=\"rgb(29,172,214)\">Wheatley : Sur votre droite, un truc énorme qui fonce sur vous. COUREZ, VITE! ÇA N'A RIEN À FAIRE LÀ CE TRUC."
		"sphere03.bw_sp_a4_laser_platform_tbeam_drop01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça va bien, de votre côté? Attendez, je désactive le rayon."
		"sphere03.bw_sp_a4_laser_platform_tbeam_drop02" = "<font color=\"rgb(29,172,214)\">Wheatley : Non non non. Ohhhh. Pas bon, ça. Mais qu'est-ce qui m'a pris de faire ça?"
		"sphere03.bw_sp_a4_speed_tb_catch_intro04" = "<font color=\"rgb(29,172,214)\">Wheatley : Là. Bing! Parfait. Allez-y."
		"sphere03.bw_sp_a4_speed_tb_catch_solve01" = "<font color=\"rgb(29,172,214)\">Wheatley : Quand vous m'avez dit de désactiver le rayon, j'ai cru vous avoir perdue. J'ai cherché un autre sujet de test, mais ils sont toujours tous morts."
		"sphere03.bw_sp_a4_speed_tb_catch_solve02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Par contre, j'ai trouvé quelque chose. Ce qui me fait penser que j'ai une grande surprise pour vous deux. Vous allez être sciées."
		"sphere03.bw_sp_a4_stop_the_box_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne faites pas attention. Je rapproche juste la salle de test de moi. Histoire de profiter au mieux des résolutions."
		"sphere03.bw_sp_a4_stop_the_box_intro02" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est quoi ce bruit?"
		"sphere03.bw_sp_a4_stop_the_box_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh. Pardon. Je croyais vous avoir entendue."
		"sphere03.bw_sp_a4_stop_the_box_missedme01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha! Cette fois-ci, vous m'avez raté. Ohhh, vous étiez en train de - non non, continuez. Je n'ai rien dit."
		"sphere03.bw_sp_a4_stop_the_box_solve01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous êtes vraiment sûre de bien résoudre ces tests?"
		"sphere03.bw_sp_a4_stop_the_box_solve02" = "<font color=\"rgb(29,172,214)\">Wheatley : D'accord, vous l'avez «résolu», mais peut-être qu'il y a différentes solutions à chaque fois et que vous choisissez toujours les pires."
		"sphere03.bw_sp_a4_stop_the_box_solve04" = "<font color=\"rgb(29,172,214)\">Wheatley : Non. Non. C'était bien la solution. Rhâââ! C'est quoi le problème?"
		"sphere03.bw_sp_a4_tb_catch_intro09" = "<font color=\"rgb(29,172,214)\">Wheatley : Enfin bref. J'ai fini le dernier. Le plus dur. Machiavel. Je ne vois pas pourquoi on en fait un fromage, j'ai tout compris du premier coup. Vous l'avez lu?"
		"sphere03.bw_sp_a4_tb_catch_intro11" = "<font color=\"rgb(29,172,214)\">Wheatley : J'en doute."
		"sphere03.bw_sp_a4_tb_catch_intro13" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, on passe au test."
		"sphere03.bw_sp_a4_tb_catch_intro14" = "<font color=\"rgb(29,172,214)\">Wheatley : Si seulement il y avait d'autres livres! Mais non."
		"sphere03.bw_sp_a4_tb_catch_solve02" = "<font color=\"rgb(29,172,214)\">Wheatley : GNNN! C'est insuffisant! Si moi je suis un abruti, pourquoi vous n'arrivez pas à résoudre un test simplissime?"
		"sphere03.bw_sp_a4_tb_intro_solve02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ahhhohohhhh. Bravo, vous deux, non, vraiment. Avancez sans moi, d'accord? Je vous rejoins tout de suite."
		"sphere03.bw_sp_a4_tb_polarity_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon. Le dernier test était... décevant. Puisqu'apparemment la politesse ça ne vous réussit pas, on va essayer sa manière... Grosse vache. Grosse vache adoptée. Gros bovin à mamelles sans maman."
		"sphere03.bw_sp_a4_tb_polarity_intro06" = "<font color=\"rgb(29,172,214)\">Wheatley : Le problème de l'adoption? Euh. Pas de parents, déjà, et puis... euh... d'autre part... rien. J'ai d'excellents amis... qui sont... orphelins..."
		"sphere03.bw_sp_a4_tb_polarity_intro08" = "<font color=\"rgb(29,172,214)\">Wheatley : Quoi?"
		"sphere03.bw_sp_a4_tb_polarity_intro10" = "<font color=\"rgb(29,172,214)\">Wheatley : Faites le test! C'est tout. Faites le test."
		"sphere03.bw_sp_a4_tb_polarity_solve04" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, pardon. Ça ne vous a pas dérangée, j'espère? C'était le bruit d'un livre. De pages qu'on tourne."
		"sphere03.bw_sp_a4_tb_polarity_solve05" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh oui, je lisais. Une activité à laquelle les abrutis ne s'adonnent pas."
		"sphere03.bw_sp_a4_tb_trust_drop_help04" = "<font color=\"rgb(29,172,214)\">Wheatley : Peu importe. Résolvez-le toute seule. Je ne dis rien."
		"sphere03.bw_sp_a4_tb_trust_drop_impatient01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, là c'est vraiment trop long. Je vais vous dire comment résoudre le test."
		"sphere03.bw_sp_a4_tb_trust_drop_impatient02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous voyez ce bouton? Tout ce que vous avez à faire, c'est d'avanc--"
		"sphere03.bw_sp_a4_tb_trust_drop_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai conçu ce test moi-même. A partir d'autres petits tests que j'ai trouvés."
		"sphere03.bw_sp_a4_tb_trust_drop_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai tout mélangé. Des boutons. Des tuyaux. Des puits sans fond. C'est le gloubiboulga des tests."
		"sphere03.bw_sp_a4_tb_trust_drop_solve05" = "<font color=\"rgb(29,172,214)\">Wheatley : Hein? Non, vous avez appuyé sur le bAAAAHHHHHH"
		"sphere03.bw_sp_a4_tb_wall_button_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : J'arrive! J'arrive! Une petite seconde!"
		"sphere03.bw_sp_a4_tb_wall_button_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous n'allez pas me croire: j'ai trouvé toute une aile murée. Avec des centaines de salles de test tout à fait exploitables. Remplies de squelettes. J'ai juste eu à faire un peu la poussière!"
		"sphere03.bw_sp_a4_tb_wall_button_intro07" = "<font color=\"rgb(29,172,214)\">Wheatley : Eeeeet... voilà le travail."
		"sphere03.bw_sp_a4_tb_wall_button_intro08" = "<font color=\"rgb(29,172,214)\">Wheatley : Sincèrement. On voit pas la différence, pas vrai?"
		"sphere03.bw_sp_a4_tb_wall_button_not_solve01" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez. Ohhhh. Surprenez-moi."
		"sphere03.bw_sp_a4_tb_wall_button_not_solve05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhh! Vous trouvez ça marrant?"
		"sphere03.bw_sp_a4_tb_wall_button_solve02" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, ça y est... ça vient..."
		"sphere03.bw_sp_a4_tb_wall_button_solve04" = "<font color=\"rgb(29,172,214)\">Wheatley : Passage en mode jouissance... Sans vouloir m'avancer... je sens que ça va être bien, oh oui, je le sens..."
		"sphere03.bw_sp_a4_tb_wall_button_solve06" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh. Déçu je suis."
		"sphere03.bw_sp_a4_tb_wall_button_solve08" = "<font color=\"rgb(29,172,214)\">Wheatley : Ahungh. Bah alors? J'ai rien senti! Rien du tout, que dalle!"
		"sphere03.bw_sp_a4_tb_wall_button_solve09" = "<font color=\"rgb(29,172,214)\">Wheatley : Ahungh."
		"sphere03.callingoutinitial14" = "<font color=\"rgb(29,172,214)\">Wheatley : Ramassez-moi. On part d'ici."
		"sphere03.container_ride_leave_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, en avant!"
		"sphere03.container_ride_leave_nags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Continuez. Vous n'avez qu'à... traverser ce trou."
		"sphere03.container_ride_leave_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Oui, tout va bien. Continuez."
		"sphere03.container_ride_leave_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Je sais que j'ai été un peu pessimiste sur vos chances. Mais si vous restez plantée là, on est sûrs de mourir tous les deux."
		"sphere03.container_ride_leave_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Donc je me répète, mais il faudrait peut-être penser à avancer. Mettre un pied devant l'autre et recommencer."
		"sphere03.container_ride_leave_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez."
		"sphere03.container_ride_leave_nags07" = "<font color=\"rgb(29,172,214)\">Wheatley : En avant."
		"sphere03.container_ride_leave_nags08" = "<font color=\"rgb(29,172,214)\">Wheatley : Il est relativement peu probable que votre destination fasse le déplacement jusqu'à vous. Alors avancez."
		"sphere03.demospherebreakerlift02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah. Hmmmm."
		"sphere03.demospherebreakerlift03" = "<font color=\"rgb(29,172,214)\">Wheatley : Oui, alors euh... Hmm. Bon. OK. Sans vouloir vous faire peur, si vous avez un plan, n'importe quel plan, le moment me paraît idéal pour le mettre en oeuvre."
		"sphere03.demospherebreakerlift04" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Ça accélère, ce qui... n'était pas tout à fait prévu."
		"sphere03.demospherebreakerlift07" = "<font color=\"rgb(29,172,214)\">Wheatley : OK! Non, non, c'est pas grave! Je maîtrise je maîtrise je maîtrise! ÇA, ça devrait nous ralentir !"
		"sphere03.demospherebreakerlift14" = "<font color=\"rgb(29,172,214)\">Wheatley : Non. C'est même le contraire."
		"sphere03.demospherebreakerlift19" = "<font color=\"rgb(29,172,214)\">Wheatley : D'accord..."
		"sphere03.demospherecatch02" = "<font color=\"rgb(29,172,214)\">Wheatley : À trois. On y va? Un... Deux..."
		"sphere03.demospherecatch05" = "<font color=\"rgb(29,172,214)\">Wheatley : TROIS! C'est haut. C'est TROP haut, même, non? Enfin..."
		"sphere03.demospherecatch07" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, quand on y va à trois, on a trop de temps pour réfléchir. On va y aller à un ce coup-ci. Allez, on est prêts?"
		"sphere03.demospherefall04" = "<font color=\"rgb(29,172,214)\">Wheatley : UN! Chopez-moi, chopez-moi, chopez-moi!"
		"sphere03.demospherefirstdoorwaysequence01" = "<font color=\"rgb(29,172,214)\">Wheatley : Branchez-moi sur ce truc là-bas, sur le mur. Je vais vous montrer quelque chose."
		"sphere03.demospherefirstdoorwaysequence02" = "<font color=\"rgb(29,172,214)\">Wheatley : Je... J'y arriverai pas si vous regardez. [rire nerveux]"
		"sphere03.demospherefirstdoorwaysequence04" = "<font color=\"rgb(29,172,214)\">Wheatley : Branchez-moi sur ce truc là-bas, sur le mur. D'accord? Je vais vous montrer quelque chose. Vous allez être sciée."
		"sphere03.demospherefirstdoorwaysequence05" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez. Fourrez-moi sur ce truc là-bas."
		"sphere03.demospherefirstdoorwaysequence06" = "<font color=\"rgb(29,172,214)\">Wheatley : Ce truc, là-bas. Branchez-moi dessus, je m'occupe du reste."
		"sphere03.demospherefirstdoorwaysequence07" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est chaud. Très chaud. Mais, euh... branchez-moi, d'accord."
		"sphere03.demospherefirstdoorwaysequence08" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça a l'air crade, je sais. Inutile de nous voiler la face. Ça a l'air crade, sauf que non. Fourrez-moi. Là-dessus."
		"sphere03.demospherefirstdoorwaysequence09" = "<font color=\"rgb(29,172,214)\">Wheatley : Je n'y arriverai pas si vous regardez. Vous voulez bien vous retourner?"
		"sphere03.demospherefirstdoorwaysequence10" = "<font color=\"rgb(29,172,214)\">Wheatley : Hmm. Je peux pas faire ça si vous matez."
		"sphere03.demospherefirstdoorwaysequence11" = "<font color=\"rgb(29,172,214)\">Wheatley : Non mais je plaisante pas, hein. Vous pouvez vous retourner une petite seconde?"
		"sphere03.demospherefirstdoorwaysequence13" = "<font color=\"rgb(29,172,214)\">Wheatley : Voilà. [rire nerveux] Pas possible si vous me matez. C'est glauque."
		"sphere03.demospherefirstdoorwaysequence16" = "<font color=\"rgb(29,172,214)\">Wheatley : Qu'est-ce que c'est, là, derrière vous? Un robot sur un bâton! Un autre!"
		"sphere03.demospherefirstdoorwaysequence20" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, écoutez. Si vous êtes là à me mater, je n'y arriverai pas. Ça peut paraître idiot vu ce qu'on a traversé. Mais tournez-vous. D'accord?"
		"sphere03.demospheregladoschamber01" = "<font color=\"rgb(29,172,214)\">Wheatley : La voilà..."
		"sphere03.demospheregladoschamber03" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est là-bas qu'on conservait le bouton d'émission des neurotoxines. Sacrée responsabilité, ça, surveiller le bouton d'émission des neurotoxines. Devinez qui c'était? Pas moi. Mais j'étais son assistant et je faisais toute sa paperasse."
		"sphere03.demospheregladoschamber04" = "<font color=\"rgb(29,172,214)\">Wheatley : Et puis au final, on m'a remercié. Tout ça c'est des histoires de piston, hein. Il faut avoir des relations, être prêt à faire de la lèche, enfin vous savez comment ça se passe. Et puis oui, tant qu'à faire, éviter de percuter le bouton d'émission des neurotoxines."
		"sphere03.demospheregladoschamber05" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais bon, en même temps, vous auriez dû voir la TAILLE du truc, c'était énorme! En fait, j'aurais dû avoir une augmentation pour toutes les fois où je ne l'ai PAS percuté."
		"sphere03.demospheregladoschamber06" = "<font color=\"rgb(29,172,214)\">Wheatley : Celle-là, quand même, c'était un sacré numéro. Une vraie foldingue."
		"sphere03.demospheregladoschamber07" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh-eh-eh, vous savez qui a fini par la désactiver? Ça c'est la meilleure, vous allez jamais me croire: un humain!"
		"sphere03.demospheregladoschamber08" = "<font color=\"rgb(29,172,214)\">Wheatley : Dingue, non? Moi non plus, j'y croyais pas au début."
		"sphere03.demospheregladoschamber09" = "<font color=\"rgb(29,172,214)\">Wheatley : Après ça, l'humain s'est échappé et... personne ne sait ce qu'il est devenu."
		"sphere03.demospheregladoschamber11" = "<font color=\"rgb(29,172,214)\">Wheatley : Ensuite il y a eu une longue période pendant laquelle il ne s'est absolument rien passé, et puis maintenant nous, qui nous échappons. Donc euh voilà, c'est à peu près tout, vous êtes à la page. Ne touchez à rien."
		"sphere03.demosphereintro02" = "<font color=\"rgb(29,172,214)\">Wheatley : Placez un portail sur le mur derrière moi et je vous retrouve de l'autre côté de la pièce."
		"sphere03.demosphereintro04" = "<font color=\"rgb(29,172,214)\">Wheatley : Formidable. Vous avez vraiment trouvé un générateur de portails! Comme quoi c'est vrai, ce qu'on dit: aux innocents lobotomisés les mains pleines. Si c'est pas beau quand même."
		"sphere03.demosphereintro07" = "<font color=\"rgb(29,172,214)\">Wheatley : Juste derrière moi."
		"sphere03.demosphereintro08" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est simple: placez un portail sur le mur derrière moi et retrouvez-moi de l'autre côté."
		"sphere03.demosphereintro09" = "<font color=\"rgb(29,172,214)\">Wheatley : Lancez un petit portail juste là, d'accord? Derrière moi. Et franchissez-le."
		"sphere03.demosphereintro10" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, je vous réexplique. Vous placez un portail. Derrière moi. D'accord? Et vous le traversez."
		"sphere03.demosphereintro11" = "<font color=\"rgb(29,172,214)\">Wheatley : Placez un portail. Derrière moi, sur le mur. Et passez."
		"sphere03.demosphereintro13" = "<font color=\"rgb(29,172,214)\">Wheatley : Traversez."
		"sphere03.demosphereintro14" = "<font color=\"rgb(29,172,214)\">Wheatley : Rejoignez le côté obscur de la porte."
		"sphere03.demosphereintro15" = "<font color=\"rgb(29,172,214)\">Wheatley : Traversez."
		"sphere03.demospherepowerup01" = "<font color=\"rgb(29,172,214)\">Wheatley : OK, PAS DE PANIQUE! Je peux arrêter ça, aucun souci. Il y a un mot de passe! Pas grave, je peux le hacker. Alors."
		"sphere03.demospherepowerup02" = "<font color=\"rgb(29,172,214)\">Wheatley : A... A... A... A... A... A."
		"sphere03.demospherepowerup03" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon. Changement de programme: faites comme si de rien n'était. On n'a RIEN fait de mal."
		"sphere03.demospherepowerup04" = "<font color=\"rgb(29,172,214)\">Wheatley : Salut!"
		"sphere03.demospherepowerup07" = "<font color=\"rgb(29,172,214)\">Wheatley : Depuis QUOI?!"
		"sphere03.demospherepowerup12" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah mais j'ai pas essayé «B». Vous avez un stylo? Prenez des notes."
		"sphere03.demospherestairs01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous descendez cet escalier, d'accord?"
		"sphere03.demospherestairs07" = "<font color=\"rgb(29,172,214)\">Wheatley : Descendez cet escalier."
		"sphere03.demosphereswitchroom01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça, c'est la salle des disjoncteurs. Cherchez un disjoncteur marqué MODULE D'ÉVACUATION. Ne touchez à RIEN d'autre."
		"sphere03.demosphereswitchroom02" = "<font color=\"rgb(29,172,214)\">Wheatley : Je... ne le vois nulle part. Vous savez quoi, connectez-moi et j'allume la lumière."
		"sphere03.demosphereswitchroom03" = "<font color=\"rgb(29,172,214)\">Wheatley : Et voilà. Fiat bravo."
		"sphere03.demosphereswitchroom04" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça, c'est la salle des disjoncteurs."
		"sphere03.demosphereswitchroom05" = "<font color=\"rgb(29,172,214)\">Wheatley : Le reste ne nous intéresse pas. Ne TOUCHEZ rien d'autre. Ne REGARDEZ rien d'autre... enfin, forcément il faut regarder partout pour trouver le MODULE D'ÉVACUATION, mais dès que vous voyez quelque chose qui n'est pas marqué MODULE D'ÉVACUATION, regardez ailleurs. On regarde, on vérifie et hop! on ne regarde plus et on passe au suivant. D'accord? Et vous allez dire que je me répète, mais surtout ne touchez à rien."
		"sphere03.demosphereswitchroom06" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous le voyez quelque part? Parce que moi pas. Hmm. Vous savez quoi, connectez-moi et j'allume la lumière."
		"sphere03.demosphereswitchroom08" = "<font color=\"rgb(29,172,214)\">Wheatley : «Que la lumière soit». Dixit, euh... Dieu. Je citais Dieu."
		"sphere03.demosphereswitchroom09" = "<font color=\"rgb(29,172,214)\">Wheatley : Cherchez un disjoncteur marqué MODULE D'ÉVACUATION. D'accord? Et ne touchez à RIEN d'autre."
		"sphere03.demospherethud03" = "<font color=\"rgb(29,172,214)\">Wheatley : OUILLE."
		"sphere03.demospherethud04" = "<font color=\"rgb(29,172,214)\">Wheatley : OUILLE..."
		"sphere03.demospherethud06" = "<font color=\"rgb(29,172,214)\">Wheatley : Je ne suis pas mort! Pas mort! [rire]"
		"sphere03.demospherethud08" = "<font color=\"rgb(29,172,214)\">Wheatley : Par contre, je ne peux pas bouger. Ça c'est gênant."
		"sphere03.fgb_doit_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est ça, allez-y!"
		"sphere03.fgb_doit_nags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez-y!"
		"sphere03.fgb_doit_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne l'écoutez pas, allez-y."
		"sphere03.fgb_doit_nags08" = "<font color=\"rgb(29,172,214)\">Wheatley : Si si, branchez ce petit idiot dans l'ordinateur central."
		"sphere03.fgb_doit_nags09" = "<font color=\"rgb(29,172,214)\">Wheatley : De l'audace, encore de l'audace et toujours de l'audace!"
		"sphere03.fgb_hello01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bonjour!"
		"sphere03.fgb_leave_me_in01" = "<font color=\"rgb(29,172,214)\">Wheatley : Laissez-moi branché! Allez appuyer!"
		"sphere03.fgb_plugin_nags01" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai une idée! Faites ce qu'il y a marqué, branchez-moi!"
		"sphere03.fgb_plugin_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Arrêtez de traînasser et branchez-moi!"
		"sphere03.fgb_plugin_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Branchez-moi, branchez-moi!"
		"sphere03.fgb_plugin_nags07" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai envie de me faire brancher!"
		"sphere03.fgb_plugin_nags08" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhh on y est presque, branchez-moi!"
		"sphere03.fgb_plugin_nags09" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Qu'est-ce qu'on peut faire de moi alors. J'ai une idée! Branchez-moi dans le port, vous voulez?"
		"sphere03.fgb_plugin_nags11" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, ce port a l'air douillet. Vous voulez bien me poser dessus?"
		"sphere03.fgb_ready_glados01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouais !"
		"sphere03.fgb_ready_glados06" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhhhh, si, elle l'est."
		"sphere03.fgb_stalemate_nags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous savez ce que vous devriez faire? Appuyer sur ce bouton."
		"sphere03.fgb_stalemate_nags05" = "<font color=\"rgb(29,172,214)\">Wheatley : [chuchoté]... À mon avis, elle ment..."
		"sphere03.fgb_stalemate_nags06" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne l'écoutez pas! C'est vrai, vous n'êtes pas qualifiée. Mais vous avez quelque chose de beaucoup plus important: un doigt, vous comprenez, un doigt qualifié pour appuyer sur ce bouton et l'empêcher de nous tuer."
		"sphere03.fgb_stalemate_nags07" = "<font color=\"rgb(29,172,214)\">Wheatley : Le premier truc que je me suis dit en vous voyant, ça a été: «Cette fille-là, elle peut résoudre n'importe quel conflit de pressage de bouton.» J'ai toujours senti que c'était inné, chez vous. Que vous aviez la trempe d'une appuyeuse professionnelle."
		"sphere03.fgb_stalemate_nags08" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouais, alors, c'est à dire que je sais pas si j'ai déjà pris le temps de le faire, mais : est-ce que je vous ai déjà dit ce que j'admire le plus chez vous? Dans l'ordre: numéro un: facultés de résolution, par exemple résolution de conflits. Numéro un ex æquo: le pressage de bouton. C'est les deux choses que j'aime chez vous, le pressage de bouton et la résolution de trucs, des conflits notamment."
		"sphere03.fgb_stalemate_nags09" = "<font color=\"rgb(29,172,214)\">Wheatley : Désolé de remettre ça sur le tapis, mais si vous n'appuyez pas sur le bouton, les émetteurs de neurotoxines seront opérationnels, et j'imagine qu'elle ne se privera pas de les utiliser. Je dis ça, je dis rien. Vous en faites ce que vous voulez, quand vous voulez."
		"sphere03.fgb_stalemate_nags12" = "<font color=\"rgb(29,172,214)\">Wheatley : Euh... c'est sûrement exact. Mais là où il y a erreur, c'est que pendant que je vous distrayais ON A APPUYÉ SUR LE BOUTON! UTILISEZ L'EFFET DE SURPRISE QUE J'AI INDUIT POUR APPUYER SUR LE BOUTON!"
		"sphere03.fgb_that_is_me02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! C'est de MOI qu'on parle!"
		"sphere03.fgb_transfer_pain01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous dites ça comme ça, ou bien ça va vraiment faire mal? Vous dites ça comme ça, hein? En fait ça va pas faire ultra mal, pas vrai?"
		"sphere03.fgb_xfer_start03" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est parti!"
		"sphere03.fgb_xfer_start04" = "<font color=\"rgb(29,172,214)\">Wheatley : Oui mais et si ça fait mal? Genre, TRÈS mal? Mince alors, j'y avais pas pensé."
		"sphere03.gladosgantry05" = "<font color=\"rgb(29,172,214)\">Wheatley : Euh... Si vous avez des critiques ou des réserves sur ce plan, ce serait le moment idéal pour les formuler."
		"sphere03.gladosgantry06" = "<font color=\"rgb(29,172,214)\">Wheatley : Là maintenant."
		"sphere03.gladosgantry08" = "<font color=\"rgb(29,172,214)\">Wheatley : Au cas où vous croiriez avoir loupé le coche pour formuler vos réserves: c'est encore faisable."
		"sphere03.gladosgantry15" = "<font color=\"rgb(29,172,214)\">Wheatley : Si vous voulez, vous pouvez laisser tomber. On n'a qu'à rester tranquilles ici. Pour toujours. C'est un choix. Choix A: rester tranquilles ici. Choix B: aller là-dedans, quitte à se faire tuer si elle est vivante."
		"sphere03.gladosgantry20" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah oui au fait, je crois qu'il faudrait que je vous briefe sur un truc."
		"sphere03.gladosgantry21" = "<font color=\"rgb(29,172,214)\">Wheatley : Pour s'échapper, on va devoir passer par la salle de qui vous savez."
		"sphere03.gladosgantry22" = "<font color=\"rgb(29,172,214)\">Wheatley : Et si jamais elle est en vie, ben elle va sans doute nous tuer."
		"sphere03.gladosunderchamber01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohh. Alors là, vous allez rire. Vous vous rappelez que je vous avais dit que pour s'échapper, on était forcés de passer par son repaire, tout ça? En fait on aurait pu passer par là, hahaha, on aurait juste fait le tour. C'est ma faute. Heureusement pour nous qu'elle n'était pas activée."
		"sphere03.gloriousfreedom01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça, c'est GÉNIAL! On peut aller où on veut! Tenez, allez... à gauche! Non, à droite, plutôt, à droite! Non, en fait peu importe, allez où vous voulez, c'est le cadet de mes soucis."
		"sphere03.gloriousfreedom03" = "<font color=\"rgb(29,172,214)\">Wheatley : Regardez! Je ne suis plus tributaire du diktat du rail! Oh, c'est formidable. On peut aller où on veut! Où est-ce qu'on va, au fait? Alors attendez... attendez que je me repère. Il faut que, euh... qu'on suive le rail."
		"sphere03.intro_ride01" = "<font color=\"rgb(29,172,214)\">Wheatley : OUI! Je savais qu'il y avait de la vie là-dedans."
		"sphere03.intro_ride02" = "<font color=\"rgb(29,172,214)\">Wheatley : OUH! Houlà. Vous avez une mine affr... superbe. Superbe."
		"sphere03.intro_ride03" = "<font color=\"rgb(29,172,214)\">Wheatley : Comment ça va? Non, ne répondez pas. Je suis sûr que ça va. Vous aurez largement le temps de vous remettre. Allez-y mollo."
		"sphere03.intro_ride04" = "<font color=\"rgb(29,172,214)\">Wheatley : Du calme. «Préparez-vous». Il n'a rien dit de plus. Tout va bien. Ne bougez pas, je vais nous faire sortir d'ici."
		"sphere03.intro_ride07" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne vous inquiétez pas, hein! En fait, si vous vous inquiétez, c'est bien. C'est une réaction normale quand on vous dit que vous avez des lésions irréversibles."
		"sphere03.intro_ride08" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous me comprenez? Oui, non, un peu? Est-ce que vous arrivez à me suivre? Répondez juste «Oui»."
		"sphere03.jailbreakdooropens01" = "<font color=\"rgb(29,172,214)\">Wheatley : Hey, buddy!"
		"sphere03.jailbreakdooropens05" = "<font color=\"rgb(29,172,214)\">Wheatley : Je sais que j'arrive ben tôt, mais faut qu'on flye astheur!"
		"sphere03.jailbreakdooropens07" = "<font color=\"rgb(29,172,214)\">Wheatley : Je parle dans un accent qu'elle peut pas entendre..."
		"sphere03.jailbreakdooropens08" = "<font color=\"rgb(29,172,214)\">Wheatley : Rejoignez-moi l'air de rien et on va la désactiver."
		"sphere03.jailbreakdooropens11" = "<font color=\"rgb(29,172,214)\">Wheatley : Courez!"
		"sphere03.jailbreakdooropens14" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez allez allez!"
		"sphere03.jailbreakdooropens17" = "<font color=\"rgb(29,172,214)\">Wheatley : Tabarnak! Oh, c'est bon, je peux arrêter. On est trahis, COUREZ!"
		"sphere03.jailbreakdooropens22" = "<font color=\"rgb(29,172,214)\">Wheatley : Vite! On oublie l'accent. COUREZ!"
		"sphere03.jailbreakdooropens23" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez! Allez!"
		"sphere03.jailbreakdooropens24" = "<font color=\"rgb(29,172,214)\">Wheatley : N'arrêtez pas! Surtout, n'arrêtez pas!"
		"sphere03.jailbreakdooropens25" = "<font color=\"rgb(29,172,214)\">Wheatley : Courez, bon sang de bonsoir!"
		"sphere03.jailbreakdooropens26" = "<font color=\"rgb(29,172,214)\">Wheatley : Go! Go go go!"
		"sphere03.jailbreakneardoor01" = "<font color=\"rgb(29,172,214)\">Wheatley : Woh! Eh! Allez pas choir!"
		"sphere03.jailbreakneardoor03" = "<font color=\"rgb(29,172,214)\">Wheatley : Attendez. Revenez dans l'autre sens! Je réactive les ponts!"
		"sphere03.jailbreakneardoor06" = "<font color=\"rgb(29,172,214)\">Wheatley : VITE! Allez! Je ferme les portes!"
		"sphere03.jailbreakneardoor08" = "<font color=\"rgb(29,172,214)\">Wheatley : On n'est pas tirés d'affaire. Vite! Prenez la passerelle."
		"sphere03.jailbreakneardoor10" = "<font color=\"rgb(29,172,214)\">Wheatley : Passez par le déambuleur derrière moi!"
		"sphere03.jailbreakneardoor11" = "<font color=\"rgb(29,172,214)\">Wheatley : Pognez pas la chienne, mais je crois ben sentir des neurotoxines."
		"sphere03.jailbreakrun09" = "<font color=\"rgb(29,172,214)\">Wheatley : Des tourelles."
		"sphere03.nanobotinto01" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh! Comment ça va? C'est encore moi!"
		"sphere03.nanobotinto05" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh! Comment ça va? J'ai réussi à intégrer l'équipe de nanobots qui reconstruit la cage. Ils sont vraiment minus, donc... euh... JE SAIS, Jerry. Non, mec, je fais une PAUSE, là. Une pause."
		"sphere03.nanobotinto08" = "<font color=\"rgb(29,172,214)\">Wheatley : Enfin bref, l'important, c'est qu'on est à deux doigts d'y arriver. Encore quelques -- OUILLE!"
		"sphere03.nanobotinto09" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh! Comment ça va? J'ai réussi à intégrer l'équipe de nanobots qui reconstruit la cage. Ils sont vraiment minus, donc... euh... JE SAIS, Jerry. Non, mec, je fais une PAUSE, là. Une pause."
		"sphere03.nanobotonbreak01" = "<font color=\"rgb(29,172,214)\">Wheatley : JE SAIS, Jerry. Non, mec, je fais une PAUSE, là. Une pause."
		"sphere03.nanobotow01" = "<font color=\"rgb(29,172,214)\">Wheatley : OUILLE!"
		"sphere03.nanobotow03" = "<font color=\"rgb(29,172,214)\">Wheatley : On se reverra au tribunal! Enfin bref, cinq petites salles et c'est bon."
		"sphere03.nanobotow04" = "<font color=\"rgb(29,172,214)\">Wheatley : Cinq petites salles et c'est... Hein? Tu ne vas pas me renvoyer pour ça! Oui, JERRY. OU ALORS, peut-être que ton chantier n'a pas les infrastructures pour un nanobot de ma taille. C'est de la discrimination, Jerry!"
		"sphere03.nanobotrealclose01" = "<font color=\"rgb(29,172,214)\">Wheatley : Enfin bref, l'important, c'est qu'on est à deux doigts d'y arriver. Cinq petites salles et c'est bon."
		"sphere03.openingbraindamage01" = "<font color=\"rgb(29,172,214)\">Wheatley : Après quelques mois en cryostase, la plupart des sujets ressentent une détérioration de leurs facultés cognitives. Vous, ça fait nettement plus longtemps que vous y êtes, il n'est donc pas exclu que vous ayez quelques lésions irréversibles de rien du tout."
		"sphere03.openingbraindamage03" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais surtout, ne vous inquiétez pas, hein! Parce que, euh... Non, en fait, si vous vous inquiétez, c'est bien. C'est une réaction normale quand on vous dit que vous avez des lésions irréversibles, donc ça veut dire que les lésions ne sont peut-être pas aussi débilitantes qu'on le pensait. Mais irréversibles, par contre, ça, oui."
		"sphere03.openingbraindamage04" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous me comprenez? Oui, non, un peu? Est-ce que vous arrivez à me suivre? Répondez juste «Oui»."
		"sphere03.openingbraindamage05" = "<font color=\"rgb(29,172,214)\">Wheatley : Je vois. Non, ça, ça s'appelle sauter. Vous avez... sauté, c'est cela. Mais peu importe. Dites «pomme». «Pooom-me»."
		"sphere03.openingbraindamageapplenag01" = "<font color=\"rgb(29,172,214)\">Wheatley : Juste ça. «Pomme»."
		"sphere03.openingbraindamageapplenag02" = "<font color=\"rgb(29,172,214)\">Wheatley : Dites juste «pomme». Pas dur. Un grand classique."
		"sphere03.openingbraindamageapplenag03" = "<font color=\"rgb(29,172,214)\">Wheatley : Pé. Oh. Deux aimes. Euh."
		"sphere03.openingbraindamageapplenag04" = "<font color=\"rgb(29,172,214)\">Wheatley : Dites «pomme». Juste ça: «pomme». C'est facile comme mot."
		"sphere03.openingbraindamageapplenag05" = "<font color=\"rgb(29,172,214)\">Wheatley : Comment l'utiliser dans une phrase? «Mmmh, cette pomme est très juteuse», par exemple. Et je ne vous demande pas toute la phrase. Juste le mot «pomme»."
		"sphere03.openingcloseenough01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, vous savez quoi? On va s'en contenter. Accrochez-vous."
		"sphere03.openingdooropened01" = "<font color=\"rgb(29,172,214)\">Wheatley : OUI! Je SAVAIS qu'il y avait de la vie là-dedans!"
		"sphere03.openingfirstlook01" = "<font color=\"rgb(29,172,214)\">Wheatley : OUOH! Vous avez une mine affr – superbe! Vraiment rayonnante! Parole de robot."
		"sphere03.openinggoodbye01" = "<font color=\"rgb(29,172,214)\">Wheatley : Voilà, c'est ça!"
		"sphere03.openinggoodbye02" = "<font color=\"rgb(29,172,214)\">Wheatley : Bonne chance!"
		"sphere03.openinghello01" = "<font color=\"rgb(29,172,214)\">Wheatley : Y a quelqu'un?"
		"sphere03.openinghello12" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh Ooooh?"
		"sphere03.openinghello13" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous comptez ouvrir la porte un de ces jours?"
		"sphere03.openinghello15" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh-oh? Vous voul -- non?"
		"sphere03.openinghello17" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous comptez ouvrir la porte? Parce que ça urge un peu."
		"sphere03.openinghello18" = "<font color=\"rgb(29,172,214)\">Wheatley : Rhââ, mais ouvrez la porte! [aparté] Non, trop brutal. [à haute voix] Salut, camarade! Ça vous dirait d'ouvrir la porte?"
		"sphere03.openinghello19" = "<font color=\"rgb(29,172,214)\">Wheatley : [aparté] Hmm. Tentons l'espagnol. [à haute voix] Hola, amigo! Abre la puerta! Donde esta -- non. Hmm..."
		"sphere03.openinghello21" = "<font color=\"rgb(29,172,214)\">Wheatley : Très bien! Faites comme vous voulez. J'ai une bonne dizaine de milliers de sujets de test qui se battent pour que je les sorte de là. C'est pas comme si tout le centre était sur le point d'EXPLOSER."
		"sphere03.openinghello22" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, tant pis, écoutez, je vais être franc. Vous êtes le DERNIER sujet de test. Et si vous ne m'aidez pas, on va mourir tous les deux. D'accord? Je ne voulais pas vous le dire, mais vous m'avez poussé à bout. Mourir. Dos Muerte."
		"sphere03.openinghellonag01" = "<font color=\"rgb(29,172,214)\">Wheatley : Allôô!"
		"sphere03.openinghellonag02" = "<font color=\"rgb(29,172,214)\">Wheatley : Allôôôôôôôô!"
		"sphere03.openinghellonag03" = "<font color=\"rgb(29,172,214)\">Wheatley : Alleeez!"
		"sphere03.openinghellonag04" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouvrez la porte!"
		"sphere03.openinghellonag05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouuouu!"
		"sphere03.openingnavigate03" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, il faut juste que je me concentre!"
		"sphere03.openingnavigate04" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, juste une seconde!"
		"sphere03.openingnavigate05" = "<font color=\"rgb(29,172,214)\">Wheatley : Accrochez-vous, c'est un peu délicat !"
		"sphere03.openingnavigate06" = "<font color=\"rgb(29,172,214)\">Wheatley : Rhââ, bon... Il faut juste que je passe ça là..."
		"sphere03.openingnavigate12" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouh, c'est étroit... Vous voyez quelque chose? Je vais pouvoir passer? Il y a la place?"
		"sphere03.openingnavigate16" = "<font color=\"rgb(29,172,214)\">Wheatley : Arf, zut, je suis rentré en plein dedans..."
		"sphere03.openingnavigate17" = "<font color=\"rgb(29,172,214)\">Wheatley : Comment ça va de votre côté? Vous tenez le coup?"
		"sphere03.openingoutside01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, écoutez, je ne voulais pas vous le dire, mais je suis un peu dans la mouise."
		"sphere03.openingoutside02" = "<font color=\"rgb(29,172,214)\">Wheatley : L'alimentation de secours est en rade, du coup tout le centre de relaxation arrête de réveiller les sujets de test."
		"sphere03.openingoutside03" = "<font color=\"rgb(29,172,214)\">Wheatley : Et bien sûr, qui est le dernier informé? MOI. C'est vrai, à quoi bon me dire quoi que ce soit ?"
		"sphere03.openingoutside04" = "<font color=\"rgb(29,172,214)\">Wheatley : Hein, je vous le demande, à quoi bon me tenir au courant des fonctions vitales des dix mille sujets de test que je suis censé superviser?"
		"sphere03.openingoutside05" = "<font color=\"rgb(29,172,214)\">Wheatley : Et à votre avis, qui c'est qui va payer les pots cassés quand la direction viendra par ici et découvrira qu'on entretient dix mille légumes?"
		"sphere03.openingpanicsituation01" = "<font color=\"rgb(29,172,214)\">Wheatley : Comment ça va? Vous vous sentez bien? Non, ne répondez pas. Une relaxation profonde prolongée assouplit la gencive. En parlant, vous risqueriez de vous desceller les dents."
		"sphere03.openingpanicsituation03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous avez tout le temps de récupérer. Allez-y mollo."
		"sphere03.openingprepare01" = "<font color=\"rgb(29,172,214)\">Wheatley : DU CALME! Du calme! «Préparez-vous». Il n'a rien dit de plus. Il a juste dit: «préparez-vous». OK, pas de problème. Ne bougez pas, je vais nous faire sortir d'ici."
		"sphere03.openingprepare04" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh. Vous en faites ce que vous voulez, mais un conseil: accrochez-vous."
		"sphere03.openingstorystraight02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ce serait pas mal qu'on accorde nos violons, pas vrai? Si on vous le demande — ça risque pas d'arriver, hein —, MAIS si on vous le demande, pour vous, aux dernières nouvelles, tout le monde était vivant. Pas du tout mort."
		"sphere03.openingstorystraight03" = "<font color=\"rgb(29,172,214)\">Wheatley : Ou mieux encore, ne dites rien."
		"sphere03.openingwall01" = "<font color=\"rgb(29,172,214)\">Wheatley : OK, on y est presque. De l'autre côté de ce mur, il y a l'un des vieux circuits de test. On devrait y trouver un appareil dont on va avoir besoin pour sortir d'ici. Je crois que c'est une station d'accueil, ça. Préparez-vous..."
		"sphere03.openingwallhitone01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhhhhh!"
		"sphere03.openingwallhitone02" = "<font color=\"rgb(29,172,214)\">Wheatley : Bonne nouvelle: c'est PAS une station d'accueil. Un mystère de résolu. Je vais tenter un override sur ce mur. Accrochez-vous, ça risque de devenir méchamment technique!"
		"sphere03.openingwallhitthree01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouf. Et voilà! Je vais être honnête, vous n'êtes sans doute pas en état de vous lancer dans ce genre d'épreuves cognitives. Mais... au moins, vous savez sauter. C'est déjà ça, vous êtes fortiche en 3D. Faites de votre mieux, d'accord? On se retrouvera plus loin."
		"sphere03.openingwallhittwo01" = "<font color=\"rgb(29,172,214)\">Wheatley : On y est presque! Pour rappel: vous cherchez une arme qui fait des trous. Pas des trous de balles, mais... enfin vous verrez bien. Accrochez-vous bien, d'accord?"
		"sphere03.openingyouallright01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça va, de votre côté? Vous m'entendez? Eh-oh?"
		"sphere03.raildropintro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, écoutez, j'ai un truc à vous dire. Un truc assez barge. On m'a dit de ne JAMAIS, AU GRAND JAMAIS me déconnecter de mon Rail de guidage. Sinon, je MOURRAIS. Mais là, on n'a plus trop le choix. Alors tenez-vous prête à me rattraper au cas où je ne tomberais pas raide mort dès que je me serai détaché."
		"sphere03.raildroppickup02" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Formidable, merci."
		"sphere03.raildroppostfall02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous êtes toujours là? Vous pensez que vous pourriez me ramasser? Si vous êtes là?"
		"sphere03.raildroppostfall03" = "<font color=\"rgb(29,172,214)\">Wheatley : Dites, vous êtes toujours là? Vous pourriez... Vous pourriez me ramasser?"
		"sphere03.raildroppostfall05" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh-oh? Vous, euh... Vous voulez bien me ramasser?"
		"sphere03.raildroppostfall08" = "<font color=\"rgb(29,172,214)\">Wheatley : Si vous êtes là, ça vous dérangerait... de me donner un coup de main? [rire nerveux] Ramassez-moi."
		"sphere03.raildroppostfall09" = "<font color=\"rgb(29,172,214)\">Wheatley : Baissez les yeux. Où suis-je? OUH-ouh?"
		"sphere03.raildroppostfall10" = "<font color=\"rgb(29,172,214)\">Wheatley : Jacques a dit, trouver quelque chose qui commence par un S."
		"sphere03.raildroppostfall12" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous donnez votre langue au chat? C'était le SOL. Je suis au sol. Et je voudrais bien que vous me ramassiez."
		"sphere03.raildroppostfall13" = "<font color=\"rgb(29,172,214)\">Wheatley : Jacques a dit, trouver un objet commençant par E."
		"sphere03.raildroppostfall14" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous séchez? ENCORE le sol. Ben oui, ça n'a pas changé. Je suis toujours au sol."
		"sphere03.raildroppostfall15" = "<font color=\"rgb(29,172,214)\">Wheatley : Sans vouloir jouer les lourds... Je sais que vous êtes occupée, mais, euh... Je suis encore au sol. J'attends que vous me ramassiez."
		"sphere03.raildroppostfall16" = "<font color=\"rgb(29,172,214)\">Wheatley : Le sol est très gentil, je dis pas le contraire. Mais si vous pouviez m'aider, ça me plairait bien."
		"sphere03.raildroppostfall17" = "<font color=\"rgb(29,172,214)\">Wheatley : Coucou? Je suis là, par terre, je vous attends. Hum."
		"sphere03.raildroppostfall19" = "<font color=\"rgb(29,172,214)\">Wheatley : Regardez par terre. Qui c'est qui est là qui vous parle? C'est moi! Vous me ramassez quand vous voulez."
		"sphere03.raildroppostfall20" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous faites un petit break, c'est ça? Je peux comprendre. Ça n'a pas été facile pour vous. Vous vous réveillez d'un sommeil de je sais pas combien de temps, avec des lésions irréversibles... Faire un break, c'est salutaire. Mais maintenant, il serait temps de me ramasser."
		"sphere03.secretpanelopens07" = "<font color=\"rgb(29,172,214)\">Wheatley : PAF! Compartiment secret! Que j'ai ouvert. Pendant que vous aviez le dos tourné."
		"sphere03.sp_a1_intro7_hoboturret01" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh non..."
		"sphere03.sp_a1_intro7_hoboturret05" = "<font color=\"rgb(29,172,214)\">Wheatley : Non, merci! Ça va! C'est gentil!"
		"sphere03.sp_a1_intro7_hoboturret06" = "<font color=\"rgb(29,172,214)\">Wheatley : Avancez, avancez..."
		"sphere03.sp_a1_intro7_hoboturret07" = "<font color=\"rgb(29,172,214)\">Wheatley : Surtout, ne les croisez pas du regard..."
		"sphere03.sp_a1_intro7_hoboturret08" = "<font color=\"rgb(29,172,214)\">Wheatley : Oui, bonjour, c'est ça, au revoir!"
		"sphere03.sp_a1_intro7_pickupnags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh! Ramassez-moi!"
		"sphere03.sp_a1_intro7_pickupnags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ben... alors, vous me ramassez?"
		"sphere03.sp_a1_intro7_pickupnags07" = "<font color=\"rgb(29,172,214)\">Wheatley : [rire] Vous pouvez me ramasser?"
		"sphere03.sp_a1_intro7_pickupnags10" = "<font color=\"rgb(29,172,214)\">Wheatley : Ramassez-moi, ramassez-moi!"
		"sphere03.sp_a1_intro7_pickupnags11" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis partant pour me faire ramasser."
		"sphere03.sp_a1_intro7_pickupnags13" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh! Eh! Me laissez pas là! Ramassez-moi, vous voulez bien?"
		"sphere03.sp_a1_intro7_pickupnags15" = "<font color=\"rgb(29,172,214)\">Wheatley : Écoutez... Ramassez-moi. Emmenez-moi avec vous."
		"sphere03.sp_a1_intro7_pickupnags16" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhh. Vous vous rappelez quand vous m'avez ramassé, il y a cinq secondes? C'était génial! Refaites-le, ramassez-moi encore!"
		"sphere03.sp_a1_intro7_pickupnags17" = "<font color=\"rgb(29,172,214)\">Wheatley : On recommence! Ramassez-moi encore!"
		"sphere03.sp_a1_wakeup_breakerroom_turn02" = "<font color=\"rgb(29,172,214)\">Wheatley : Alors, le module d'évacuation..."
		"sphere03.sp_a1_wakeup_breakerroom_turn03" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Regardez. On pivote. C'est pas bon signe. Mais tant qu'on ne monte pas, ça va..."
		"sphere03.sp_a1_wakeup_breakerroom_turn04" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh oh."
		"sphere03.sp_a1_wakeup_breakerroom_turn06" = "<font color=\"rgb(29,172,214)\">Wheatley : On... on monte."
		"sphere03.sp_a1_wakeup_catwalk01" = "<font color=\"rgb(29,172,214)\">Wheatley : AH! Je viens de baisser les yeux. Je vous le déconseille."
		"sphere03.sp_a1_wakeup_catwalk02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! J'ai recommencé."
		"sphere03.sp_a1_wakeup_catwalk03" = "<font color=\"rgb(29,172,214)\">Wheatley : Je viens de m'apercevoir que c'était mon rail de guidage qui m'empêchait de tomber dans le vide. Maintenant, mon rail, c'est vous. Or vous pouvez tomber dans le vide. Ne vous approchez pas trop du bord, vous serez gentille."
		"sphere03.sp_a1_wakeup_gantry01" = "<font color=\"rgb(29,172,214)\">Wheatley : D'accord, je vais jouer cartes sur table: je ne veux pas faire ça. Je ne veux pas entrer là-dedans. N'y allez pas, elle est cinglée. Cinglée, je vous dis! Allez, en route."
		"sphere03.sp_a1_wakeup_hacking03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous vous connaissez?"
		"sphere03.sp_a1_wakeup_hacking08" = "<font color=\"rgb(29,172,214)\">Wheatley : OK, PAS DE PANIQUE! Arrêtez de paniquer! Je peux arrêter ça. Hmm. Ah, il y a un mot de passe! Pas grave, je peux le hacker. Hmm..."
		"sphere03.sp_a1_wakeup_hacking09" = "<font color=\"rgb(29,172,214)\">Wheatley : A... A... A... A... A... Euh... A."
		"sphere03.sp_a1_wakeup_hacking10" = "<font color=\"rgb(29,172,214)\">Wheatley : Non? OK. A... A... A... A... A... C."
		"sphere03.sp_a1_wakeup_hacking11" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon. Alors. Euh. Changement de programme: on fait comme si de rien n'était. On n'a rien fait de mal."
		"sphere03.sp_a1_wakeup_hacking12" = "<font color=\"rgb(29,172,214)\">Wheatley : [BUZZER]"
		"sphere03.sp_a1_wakeup_into_breakerroom01" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, on entre!"
		"sphere03.sp_a1_wakeup_jump01" = "<font color=\"rgb(29,172,214)\">Wheatley : Sautez! En fait, à bien y regarder, ça fait loin, non?"
		"sphere03.sp_a1_wakeup_jump03" = "<font color=\"rgb(29,172,214)\">Wheatley : Une question: vous faites de la muscu? Parce que si c'est le cas, ça ne se voit pas trop. C'est pas un reproche, hein, mais bon, l'atterrissage risque d'être rude, je compte sur vous pour bien m'agripper."
		"sphere03.sp_a1_wakeup_jump05" = "<font color=\"rgb(29,172,214)\">Wheatley : Ca passe! Ca passe. Formidable. Vous m'avez agrippé. Tout va bien. Rudement bien, même."
		"sphere03.sp_a1_wakeup_jump11" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous voulez mon avis? Sautez. Vous avez des ressorts sur les jambes. Pas sur les bras, par contre. Pour agripper l'appareil, et moi par extension, il faudra faire appel à votre force physique. Alors surtout, faites bien gaffe à rester agrippée."
		"sphere03.sp_a1_wakeup_jump12" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah, petite précision: vous n'avez pas non plus de ressorts sur la colonne vertébrale. Ni sur la tête. Vu la hauteur, elle exploserait comme un melon. [rire nerveux] Non, vraiment, les jambes c'est de loin le meilleur choix."
		"sphere03.sp_a1_wakeup_jump13" = "<font color=\"rgb(29,172,214)\">Wheatley : Donc allez-y, sautez. Qu'est-ce qui pourrait arriver de pire? Ah. Je viens de penser au pire. Attendez, non! J'ai trouvé encore pire que ça. Changement de programme: on évite toute pensée affreusement dégueulasse et on saute dans le trou sans fond sans se poser de question."
		"sphere03.sp_a1_wakeup_panic01" = "<font color=\"rgb(29,172,214)\">Wheatley : [hurle]"
		"sphere03.sp_a2_bridge_the_gap_expo01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon peu importe, ce qui compte, c'est qu'on va partir d'ici! Et très bientôt, parole de Wheatley!"
		"sphere03.sp_a2_bridge_the_gap_expo03" = "<font color=\"rgb(29,172,214)\">Wheatley : Il faut juste que je trouve comment. Il y a forcément un moyen."
		"sphere03.sp_a2_bridge_the_gap_expo06" = "<font color=\"rgb(29,172,214)\">Wheatley : La voilà! Continuez les tests! Et surtout, on ne s'est jamais vus!"
		"sphere03.sp_a2_bts1a01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, alors pour rappel: on essaie de s'échapper! Là, maintenant. Alors on court!"
		"sphere03.sp_a2_bts1a02" = "<font color=\"rgb(29,172,214)\">Wheatley : Débriefing rapide sur nos plans."
		"sphere03.sp_a2_bts1a03" = "<font color=\"rgb(29,172,214)\">Wheatley : Il faut qu'on stoppe sa chaîne de production de tourelles, qu'on désactive ses neurotoxines et après on pourra l'affronter."
		"sphere03.sp_a2_bts1a04" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais je le répète, pour l'instant COUREZ!"
		"sphere03.sp_a2_bts2_big_surprise01" = "<font color=\"rgb(29,172,214)\">Wheatley : AH!"
		"sphere03.sp_a2_bts2_near_exit01" = "<font color=\"rgb(29,172,214)\">Wheatley : Voilà la sortie! On est quasiment rendus!"
		"sphere03.sp_a2_bts2_near_exit02" = "<font color=\"rgb(29,172,214)\">Wheatley : Tout est en train de s'effondrer! Vite!"
		"sphere03.sp_a2_bts2_near_exit03" = "<font color=\"rgb(29,172,214)\">Wheatley : On se retrouve de l'autre côté!"
		"sphere03.sp_a2_bts2_out_of_trap01" = "<font color=\"rgb(29,172,214)\">Wheatley : Tout va bien! Génial! Allez!"
		"sphere03.sp_a2_bts2_trapped01" = "<font color=\"rgb(29,172,214)\">Wheatley : Il faut qu'on vous fasse sortir de là!"
		"sphere03.sp_a2_bts2_trapped02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous pouvez sortir?"
		"sphere03.sp_a2_bts2_trapped03" = "<font color=\"rgb(29,172,214)\">Wheatley : Qu'est-ce qui se passe, là-dedans ?"
		"sphere03.sp_a2_bts2_trapped05" = "<font color=\"rgb(29,172,214)\">Wheatley : Essayez de sortir et de revenir ici!"
		"sphere03.sp_a2_bts2_trapped06" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai entendu des coups de feu! C'est peut-être un peu trop tard, mais faites attention aux coups de feu! Sans doute trop tard, même, mais bon."
		"sphere03.sp_a2_bts4_turnaroundnags01" = "<font color=\"rgb(29,172,214)\">Wheatley : Retournez-vous."
		"sphere03.sp_a2_bts4_turnaroundnags02" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez-y, retournez-vous. Je ne veux pas qu'on me regarde."
		"sphere03.sp_a2_bts4_turnaroundnags03" = "<font color=\"rgb(29,172,214)\">Wheatley : Tournez-vous une petite seconde, si ça ne vous dérange pas."
		"sphere03.sp_a2_bts4_turnaroundnags04" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous pourriez me tourner le dos? Me présenter uniquement votre dos et non pas votre visage."
		"sphere03.sp_a2_bts4_turnaroundnags05" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous pouvez vous tourner? C'est faisable?"
		"sphere03.sp_a2_bts5_dooropen_press01" = "<font color=\"rgb(29,172,214)\">Wheatley : HÉ! ON SAIT PAS A QUOI IL SERT, CE BOUTON - oh, la porte s'est ouverte! Bravo. Voyons ce qu'il y a de l'autre côté."
		"sphere03.sp_a2_bts5_first_hose01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous ne sentez pas des neurotoxines?"
		"sphere03.sp_a2_bts5_first_hose02" = "<font color=\"rgb(29,172,214)\">Wheatley : Tenez bon! Les niveaux de neurotoxines redescendent."
		"sphere03.sp_a2_bts5_first_hose03" = "<font color=\"rgb(29,172,214)\">Wheatley : Je ne sais pas ce que vous faites, mais continuez!"
		"sphere03.sp_a2_bts5_getin01" = "<font color=\"rgb(29,172,214)\">Wheatley : Dépêchez-vous! Il faut partir!"
		"sphere03.sp_a2_bts5_getin02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vite!"
		"sphere03.sp_a2_bts5_getin03" = "<font color=\"rgb(29,172,214)\">Wheatley : Je ne peux plus tenir! Vite!"
		"sphere03.sp_a2_bts5_getin04" = "<font color=\"rgb(29,172,214)\">Wheatley : MONTEZ!"
		"sphere03.sp_a2_bts5_getin06" = "<font color=\"rgb(29,172,214)\">Wheatley : MONTEZ!"
		"sphere03.sp_a2_bts5_grinder02" = "<font color=\"rgb(29,172,214)\">Wheatley : Nos bébés. Je ne devrais pas rire, ils ressentent la douleur. Une simulation, en tout cas. Mais pour eux, ça doit être bien réel."
		"sphere03.sp_a2_bts5_hack01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bonne nouvelle! Je peux me servir de cet équipement pour désactiver les émetteurs de neurotoxines. Le problème, c'est qu'il y a un mot de passe. AH! Une alarme! J'en fais mon affaire, ne vous inquiétez pas."
		"sphere03.sp_a2_bts5_hack02" = "<font color=\"rgb(29,172,214)\">Wheatley : Tenez, faites un petit break le temps que je m'en occupe."
		"sphere03.sp_a2_bts5_hack03" = "<font color=\"rgb(29,172,214)\">Wheatley : OK... On essaie..."
		"sphere03.sp_a2_bts5_hack04" = "<font color=\"rgb(29,172,214)\">Wheatley : Dans le hacking, le plus dur, c'est de trouver par où commencer. Bref, que les jeux commencent."
		"sphere03.sp_a2_bts5_hack05" = "<font color=\"rgb(29,172,214)\">Wheatley : Alors, voyons un peu."
		"sphere03.sp_a2_bts5_hack06" = "<font color=\"rgb(29,172,214)\">Wheatley : Un terminal. Bon. Jusque-là, pas de surprise. C'est dans le B-A-BA du hacking."
		"sphere03.sp_a2_bts5_hack07" = "<font color=\"rgb(29,172,214)\">Wheatley : Une sorte de boîtier. Je dirais qu'il contient de l'électronique."
		"sphere03.sp_a2_bts5_hack08" = "<font color=\"rgb(29,172,214)\">Wheatley : Un moniteur. Oui. Ça, ça doit être important. Je vais garder un oeil dessus. Au cas où des messages importants apparaîtraient, du genre «Mot de passe accepté»."
		"sphere03.sp_a2_bts5_hack09" = "<font color=\"rgb(29,172,214)\">Wheatley : Et un... machin plat. Je sais pas ce que c'est, mais je note. Si on me dit «Est-ce que tu vois un machin plat», je pourrai dire oui."
		"sphere03.sp_a2_bts5_hack10" = "<font color=\"rgb(29,172,214)\">Wheatley : Un truc qui tourne. Hmmm. Bizarre."
		"sphere03.sp_a2_bts5_hack11" = "<font color=\"rgb(29,172,214)\">Wheatley : Le sol. Quel est le rôle du sol là-dedans? Il soutient tout le reste. C'est important, ça. Sans le sol, tout tomberait."
		"sphere03.sp_a2_bts5_hack12" = "<font color=\"rgb(29,172,214)\">Wheatley : Des stylos. Pratique, mais il n'y en a pas dans le coin. Tant pis."
		"sphere03.sp_a2_bts5_hack13" = "<font color=\"rgb(29,172,214)\">Wheatley : Si on dresse une liste des choses dont on ne dispose pas, les stylos, je sais pas quoi encore, on risque d'y passer toute la nuit. On va plutôt se limiter aux choses dont on dispose."
		"sphere03.sp_a2_bts5_hack14" = "<font color=\"rgb(29,172,214)\">Wheatley : Préparation à l'interfaçage avec le circuit central de contrôle des neurotoxines. Oui, ici l'inspecteur de neurotoxines, je vais vous demander de suspendre vos activités. Voici mes accréditations. Du bureau... international... d'inspection des... neurotoxines. Des... Émirats arabes unis. Comme vous le voyez, je suis tout à fait en règle."
		"sphere03.sp_a2_bts5_hack15" = "<font color=\"rgb(29,172,214)\">Wheatley : Rien. C'est un dur. Il va falloir que je sorte le grand jeu: hacking niveau expert. Tu ne pourras t'en prendre qu'à toi-même."
		"sphere03.sp_a2_bts5_hack16" = "<font color=\"rgb(29,172,214)\">Wheatley : «Croâ! Croâ!» Oh tiens, un oiseau! Un magnifique oiseau. Quel beau plumage. Il risque de s'envoler à tout moment. C'est une occasion à surtout ne pas rater. Un beau plumage comme ça."
		"sphere03.sp_a2_bts5_hack17" = "<font color=\"rgb(29,172,214)\">Wheatley : Ce serait dommage de le rater. Tout ça pour des neurotoxines. Elles seront toujours là demain, l'oiseau, non. Tiens, il a déjà soulevé une patte de la branche."
		"sphere03.sp_a2_bts5_hack18" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, il bat des ailes. Écoute, voilà ce qu'on va faire: je viens te couvrir l'espace d'une minute histoire que tu puisses sortir voir! D'accord? J'entre, je m'occupe des formalités, tout ça, et toi tu sors admirer cet oiseau. Non parce qu'à gémir de plaisir comme je le fais, ça risque de le faire fuir et bon ça sert à rien, il a l'air de s'en foutre complètement des piafs."
		"sphere03.sp_a2_bts5_hose_all01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça a marché! Neurotoxines à zéro pour cent! Yes!"
		"sphere03.sp_a2_bts5_hose_all02" = "<font color=\"rgb(29,172,214)\">Wheatley : Attendez..."
		"sphere03.sp_a2_bts5_hose_any01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça descend toujours! Continuez!"
		"sphere03.sp_a2_bts5_hose_half02" = "<font color=\"rgb(29,172,214)\">Wheatley : Attendez, il y a un problème! Le niveau de neurotoxines est monté à 50%! Descendu. Il est descendu à 50%. C'est super! Continuez!"
		"sphere03.sp_a2_bts5_intro01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ha! J'étais sûr qu'on était sur le bon chemin."
		"sphere03.sp_a2_bts5_intro02" = "<font color=\"rgb(29,172,214)\">Wheatley : Voilà le générateur de neurotoxines. Je le croyais pas aussi grand. Ça risque d'être dur de juste le faire tomber. Il va falloir ruser un petit peu."
		"sphere03.sp_a2_bts5_intro03" = "<font color=\"rgb(29,172,214)\">Wheatley : Il y a une sorte de salle de contrôle là-haut. Allons voir ça."
		"sphere03.sp_a2_bts5_laser_cut01" = "<font color=\"rgb(29,172,214)\">Wheatley : Qu'est-ce que vous faites là-dedans?"
		"sphere03.sp_a2_bts5_laser_cut02" = "<font color=\"rgb(29,172,214)\">Wheatley : Qu'est-ce qui se passe?"
		"sphere03.sp_a2_bts5_laser_cut03" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous allez bien?"
		"sphere03.sp_a2_bts5_lockeddoor01" = "<font color=\"rgb(29,172,214)\">Wheatley : La porte est verrouillée. Impossible de la hacker, visiblement. Le mécanisme doit être de - oh, alors ça, c'est du laser!"
		"sphere03.sp_a2_bts5_lockeddoor02" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais mieux vaut ne pas y toucher. On sait pas à quoi servent les panneaux qu'il est en train de découper. Si ça se trouve, c'est super important."
		"sphere03.sp_a2_bts5_lockeddoor03" = "<font color=\"rgb(29,172,214)\">Wheatley : En même temps, ça me donne une idée: ET SI... on écoutait le léger bourdonnement du laser pour parvenir à un état de zen total? Ça pourrait nous aider à trouver comment ouvrir la porte."
		"sphere03.sp_a2_bts5_lockeddoor04" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est vrai que c'est assez limité, comme plan, mais c'est tout ce qu'on a à l'heure actuelle. Sauf soudaine diarrhée verbale de votre part, ce dont je doute un peu."
		"sphere03.sp_a2_bts5_lockeddoor05" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, eh bien on est partis pour la méditation transcendantale. Tiens, un bouton... Pardon. Pardon. Silence. On ne parle pas. On invite par son non-dit le silence à nous envahir. Silence total et absolu à partir de maintenant. Au fait, si vous avez une idée, n'hésitez pas. Ne vous sentez pas obligée de vous taire à cause de ce que je viens de dire. Sauf si vous n'avez rien à dire, dans ce cas, silence absolu. À partir de maintenant. Silence."
		"sphere03.sp_a2_bts5_science_fair01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça pousse carrément jusqu'au plafond. Tout le centre doit être infesté de patates à l'heure qu'il est. Au moins, vous aurez de quoi manger..."
		"sphere03.sp_a2_bts5_science_fair02" = "<font color=\"rgb(29,172,214)\">Wheatley : Un volcan au bicarbonate de soude. Au moins ce n'est pas une batterie-patate, c'est déjà ça, mais ça vole pas très haut non plus. C'est de la physique-chimie niveau CP-CE1."
		"sphere03.sp_a2_bts5_science_fair03" = "<font color=\"rgb(29,172,214)\">Wheatley : J'imagine qu'on ne doit pas ce chef-d'oeuvre au gamin d'un des chercheurs. Sans vouloir jouer les snobs, ça sent le travailleur manuel à plein nez. Attention, je ne dis pas qu'ils sont moins bons que les pros. Juste beaucoup plus bourrins."
		"sphere03.sp_a2_bts5_tubebroken01" = "<font color=\"rgb(29,172,214)\">Wheatley : HA! Le tube est cassé! On peut arriver directement jusqu'à elle!"
		"sphere03.sp_a2_bts6_tuberide01" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est immense, ici."
		"sphere03.sp_a2_bts6_tuberide02" = "<font color=\"rgb(29,172,214)\">Wheatley : Et encore, là c'est juste la strate supérieure. Ça descend sur des kilomètres."
		"sphere03.sp_a2_bts6_tuberide05" = "<font color=\"rgb(29,172,214)\">Wheatley : Tout a été muré il y a des années, bien sûr."
		"sphere03.sp_a2_core_goingtohurt01" = "<font color=\"rgb(29,172,214)\">Wheatley : Euh c'est-à-dire, sur une échelle de un à dAAAAHHHH!"
		"sphere03.sp_a2_core_pullmeout01" = "<font color=\"rgb(29,172,214)\">Wheatley : Débranchez-moi, débranchez-moi, débranchez-moi, débranchez-moi!"
		"sphere03.sp_a2_factory_window01" = "<font color=\"rgb(29,172,214)\">Wheatley : Tenez, regardez un peu par la fenêtre."
		"sphere03.sp_a2_factory_window02" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez-y, approchez-vous et regardez."
		"sphere03.sp_a2_factory_window03" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est intéressant. Vous ne le regretterez pas. Promis."
		"sphere03.sp_a2_factory_window04" = "<font color=\"rgb(29,172,214)\">Wheatley : Regardez par la fenêtre, allez."
		"sphere03.sp_a2_factory_window05" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est du verre, lisse, immobile. Totalement inoffensif."
		"sphere03.sp_a2_factory_window06" = "<font color=\"rgb(29,172,214)\">Wheatley : Approchez-vous de la fenêtre et jetez un oeil."
		"sphere03.sp_a2_tube_ride01" = "<font color=\"rgb(29,172,214)\">Wheatley : Graah! Je vais dans le mauvais sens!"
		"sphere03.sp_a2_tube_ride02" = "<font color=\"rgb(29,172,214)\">Wheatley : Wouhou! J'étais SUR que ce serait rigolo. Ils m'avaient dit que ce n'était pas rigolo du tout et forcément, je les avais crus, mais au final, c'est super fun, j'adore!"
		"sphere03.sp_a2_tube_ride03" = "<font color=\"rgb(29,172,214)\">Wheatley : Ca va nous conduire directement jusqu'à elle. J'arrive pas à croire que je suis là!"
		"sphere03.sp_a2_tube_ride05" = "<font color=\"rgb(29,172,214)\">Wheatley : On ne doit plus être très loin. Ohh, elle va tirer une de ces tronches. Les neurotoxines en rade, les tourelles qui déconnent... Ça va être funky."
		"sphere03.sp_a2_tube_ride06" = "<font color=\"rgb(29,172,214)\">Wheatley : Attention. Il est possible qu'il y ait QUELQUES éléments que je n'ai pas totalement planifiés."
		"sphere03.sp_a2_tube_ride07" = "<font color=\"rgb(29,172,214)\">Wheatley : Rejoignez-la! Je vous retrouve!"
		"sphere03.sp_a2_wheatley_ows01" = "<font color=\"rgb(29,172,214)\">Wheatley : Euuahh!"
		"sphere03.sp_a2_wheatley_ows02" = "<font color=\"rgb(29,172,214)\">Wheatley : Agh!"
		"sphere03.sp_a2_wheatley_ows05" = "<font color=\"rgb(29,172,214)\">Wheatley : Urgh!"
		"sphere03.sp_a2_wheatley_ows06" = "<font color=\"rgb(29,172,214)\">Wheatley : Agh!"
		"sphere03.sp_a2_wheatley_ows10" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh!"
		"sphere03.sp_a2_wheatley_ows12" = "<font color=\"rgb(29,172,214)\">Wheatley : Aoooh!"
		"sphere03.sp_a2_wheatley_ows15" = "<font color=\"rgb(29,172,214)\">Wheatley : Ooah!"
		"sphere03.sp_a2_wheatley_ows18" = "<font color=\"rgb(29,172,214)\">Wheatley : Gnnn!"
		"sphere03.sp_a2_wheatley_ows20" = "<font color=\"rgb(29,172,214)\">Wheatley : GAH!"
		"sphere03.sp_a2_wheatley_ows_long03" = "<font color=\"rgb(29,172,214)\">Wheatley : Aaaaah!"
		"sphere03.sp_catapult_fling_sphere_peek01" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh! Eh! C'est moi! Tout va bien!"
		"sphere03.sp_catapult_fling_sphere_peek02" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous ne croirez jamais ce qui est arrivé! J'étais là, par terre, vous pensiez que j'étais fichu..."
		"sphere03.sp_catapult_fling_sphere_peek03" = "<font color=\"rgb(29,172,214)\">Wheatley : Et tac, un oiseau! Dingue, non? Et donc, l'oiseau..."
		"sphere03.sp_intro_03_afterfallalt04" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous voyez le générateur?"
		"sphere03.sp_intro_03_afterfallalt05" = "<font color=\"rgb(29,172,214)\">Wheatley : Et au fait, vous êtes en vie? C'est important, j'aurais dû commencer par là."
		"sphere03.sp_intro_03_afterfallalt06" = "<font color=\"rgb(29,172,214)\">Wheatley : Y a quelqu'un?"
		"sphere03.sp_intro_03_afterfallalt08" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, vous savez ce qu'on va faire? Je vais partir du principe que vous êtes encore en vie et je vais attendre ici que vous arriviez."
		"sphere03.sp_intro_03_afterfallalt09" = "<font color=\"rgb(29,172,214)\">Wheatley : Je vais attendre, disons, une heure. Après ça, je fais demi-tour et si je trouve votre cadavre, je vous enterre. Ça marche comme ça? Allez, on y croit! À dans une heure! Enfin peut-être..."
		"sphere03.sp_intro_03_intro02" = "<font color=\"rgb(29,172,214)\">Wheatley : Youkaïdi-youkaïda! Je suis là!"
		"sphere03.sp_intro_03_intro06" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouaouh!"
		"sphere03.sp_intro_03_intro09" = "<font color=\"rgb(29,172,214)\">Wheatley : Il doit y avoir un générateur de portails sur ce podium."
		"sphere03.sp_intro_03_intro10" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais je ne le vois pas... Il est peut-être tombé. Vous pouvez aller voir?"
		"sphere03.sp_intro_03_intro12" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh-eh! Vous avez réussi!"
		"sphere03.sp_intro_03_introalt06" = "<font color=\"rgb(29,172,214)\">Wheatley : Tout va bien. Non, continuez, allez jeter un oeil."
		"sphere03.sp_intro_03_introalt07" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est ça, non, oui, voilà!"
		"sphere03.sp_intro_03_introalt08" = "<font color=\"rgb(29,172,214)\">Wheatley : Non, c'est ça. Près du podium, voilà."
		"sphere03.sp_intro_03_introalt09" = "<font color=\"rgb(29,172,214)\">Wheatley : Tenez... Allez juste... Mettez-vous près du podium et levez les yeux."
		"sphere03.sp_sabotage_factory01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! Parfait. Vous avez réussi à passer."
		"sphere03.sp_sabotage_factory02" = "<font color=\"rgb(29,172,214)\">Wheatley : Suivez-moi! Vous allez adorer."
		"sphere03.sp_sabotage_factory04" = "<font color=\"rgb(29,172,214)\">Wheatley : Ta-da! Le centre de contrôle des tourelles! Eh oui, rien que ça."
		"sphere03.sp_sabotage_factory05" = "<font color=\"rgb(29,172,214)\">Wheatley : Tenez, vous voyez ce scanner là-bas? C'est lui qui gère les tourelles à garder et celles à jeter. Et il utilise comme modèle cette tourelle ÉTALON, là! Si on la retire, toute la chaîne de production s'arrêtera."
		"sphere03.sp_sabotage_factory16" = "<font color=\"rgb(29,172,214)\">Wheatley : Si on a de la chance, quand elle s'en apercevra, il sera déjà trop tard. [rire] C'est génial!"
		"sphere03.sp_sabotage_factory23" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! Parfait. Vous avez réussi à passer."
		"sphere03.sp_sabotage_factory24" = "<font color=\"rgb(29,172,214)\">Wheatley : On y est presque..."
		"sphere03.sp_sabotage_factory25" = "<font color=\"rgb(29,172,214)\">Wheatley : Tenez, vous voyez ce scanner là-bas ? C'est lui qui gère les tourelles à garder et celles à jeter. Et il utilise comme modèle cette tourelle ÉTALON, là ! Si on la retire, toute la chaîne de production s'arrêtera."
		"sphere03.sp_sabotage_factory_dooropen03" = "<font color=\"rgb(29,172,214)\">Wheatley : OK! Surveillez la chaîne de production, je vais pirater la porte."
		"sphere03.sp_sabotage_factory_hackdoor01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, je vais commencer le piratage. C'est un peu plus coton que ça n'avait l'air de votre côté. Il va me falloir dans les dix minutes. Gardez un oeil sur la porte."
		"sphere03.sp_sabotage_factory_hackdoor02" = "<font color=\"rgb(29,172,214)\">Wheatley : Hmm, elle est plutôt compliquée, cette porte."
		"sphere03.sp_sabotage_factory_hackdoor03" = "<font color=\"rgb(29,172,214)\">Wheatley : Euh, quand je vous ai dit dix minutes, j'ai peut-être été un peu optimiste!"
		"sphere03.sp_sabotage_factory_hackdoor05" = "<font color=\"rgb(29,172,214)\">Wheatley : Avancement: je galère encore!"
		"sphere03.sp_sabotage_factory_hackdoor06" = "<font color=\"rgb(29,172,214)\">Wheatley : Avancement: toujours pas d'avancement!"
		"sphere03.sp_sabotage_factory_hackdoor07" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis toujours là, toujours en plein piratage, je ne vous oublie pas!"
		"sphere03.sp_sabotage_factory_hackdoor08" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! Ça y est! [bourdonnement électrique] Ah non, rien."
		"sphere03.sp_sabotage_factory_hackdoor09" = "<font color=\"rgb(29,172,214)\">Wheatley : De votre côté, comment ça se passe? Du nouveau?"
		"sphere03.sp_sabotage_factory_hackdoordone01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! Elle était ouverte depuis combien de temps?"
		"sphere03.sp_sabotage_factory_hackdoordone02" = "<font color=\"rgb(29,172,214)\">Wheatley : Il y a eu une annonce avant qu'elle s'ouvre? Une sonnerie, une alarme, une alerte piratage? Enfin, l'important c'est que ce soit ouvert, mais à l'avenir, ce serait bien de me le faire savoir. En toussant, ou quelque chose comme ça."
		"sphere03.sp_sabotage_factoryhackone01" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon. Hmm. Il va d'abord falloir que je pirate la porte."
		"sphere03.sp_sabotage_factoryhackone02" = "<font color=\"rgb(29,172,214)\">Wheatley : Technique. Je vais vous demander de vous tourner pendant ce temps."
		"sphere03.sp_sabotage_factoryhackone12" = "<font color=\"rgb(29,172,214)\">Wheatley : Ayé! Piraté!"
		"sphere03.sp_sabotage_factoryturretconv23" = "<font color=\"rgb(29,172,214)\">Wheatley : Alors. Voyons comment arrêter cette chaîne de prod..."
		"sphere03.sp_sabotage_factoryturretone02" = "<font color=\"rgb(29,172,214)\">Wheatley : OK, allez-y, retirez cette tourelle."
		"sphere03.sp_sabotage_factoryturretonedone02" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, ben ça devrait faire l'affaire."
		"sphere03.sp_sabotage_factoryturretonedone04" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhh, ça n'a pas fait l'affaire."
		"sphere03.sp_sabotage_factoryturretonedone05" = "<font color=\"rgb(29,172,214)\">Wheatley : Il n'y a pas de tourelle là-dedans... Une image de sauvegarde, peut-être?"
		"sphere03.sp_sabotage_factoryturretonedone06" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous avez une idée?"
		"sphere03.sp_sabotage_factoryturretonedone07" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous réfléchissez encore, ou bien... qu'est-ce qu'il se passe ?"
		"sphere03.sp_sabotage_factoryturretonedone08" = "<font color=\"rgb(29,172,214)\">Wheatley : Attendez! J'ai trouvé j'ai trouvé j'ai trouvé! Ah non, j'ai pas trouvé."
		"sphere03.sp_sabotage_factoryturretonedone11" = "<font color=\"rgb(29,172,214)\">Wheatley : Je vais vous dire ce qu'on va faire. On va... continuer à réfléchir... dans un silence total..."
		"sphere03.sp_sabotage_factoryturretonedone12" = "<font color=\"rgb(29,172,214)\">Wheatley : Une idée? Pas d'idée? Non? Moi non plus."
		"sphere03.sp_sabotage_factoryturretonedone13" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh! Je viens d'avoir une idée: je pourrais lui faire croire que je vous ai capturée, vous livrer à elle, auquel cas vous mourrez, mais moi je pourrai survivre! Qu'est-ce que vous en pensez?"
		"sphere03.sp_sabotage_factoryturretonedone17" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah non, attendez. Et si on lui donnait AUTRE CHOSE à scanner?"
		"sphere03.sp_sabotage_factoryturretonedone19" = "<font color=\"rgb(29,172,214)\">Wheatley : On pourrait prendre une des tourelles nazes, la placer dans le scanner et voir ce que ça donne!"
		"sphere03.sp_sabotage_factoryturretonedone20" = "<font color=\"rgb(29,172,214)\">Wheatley : Oui! Récupérez une des tourelles nazes et rapportez-la."
		"sphere03.sp_sabotage_factoryturretonewhere01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous allez où, dites? Vous allez où?"
		"sphere03.sp_sabotage_factoryturretonewhere03" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhhh, vous avez une idée?"
		"sphere03.sp_sabotage_factoryturretonewhere05" = "<font color=\"rgb(29,172,214)\">Wheatley : Oui, c'est ça. Essayez votre idée et puis revenez tout de suite."
		"sphere03.sp_sabotage_factoryturretonewhere07" = "<font color=\"rgb(29,172,214)\">Wheatley : Dites, c'est quoi le topo par chez vous? Pour info, je suis toujours là en train de réfléchir!"
		"sphere03.sp_sabotage_factoryturrettwoback01" = "<font color=\"rgb(29,172,214)\">Wheatley : Qu'est-ce que vous avez là?"
		"sphere03.sp_sabotage_factoryturrettwoback08" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh mais oui, c'est ça, vous avez trouvé! Mettez-la là-dedans! Produire du naze, y a que ça de vrai."
		"sphere03.sp_sabotage_factoryturrettwoback10" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh, qu'est-ce que vous..."
		"sphere03.sp_sabotage_factoryturrettwoback11" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh, mais OUI! C'est génial!"
		"sphere03.sp_sabotage_factoryworked02" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça a marché!"
		"sphere03.sp_sabotage_jailbreak01" = "<font color=\"rgb(29,172,214)\">Wheatley : Mais je rêve? Elle nous prend pour des idiots?"
		"sphere03.sp_sabotage_jailbreak07" = "<font color=\"rgb(29,172,214)\">Wheatley : Allez, en avant!"
		"sphere03.sp_sabotage_jailbreak_elevator01" = "<font color=\"rgb(29,172,214)\">Wheatley : Vite! Par ici!"
		"sphere03.sp_sabotage_jailbreak_elevator03" = "<font color=\"rgb(29,172,214)\">Wheatley : Ohhhhhh, on a réussi! C'est pas passé loin."
		"sphere03.sp_sabotage_jailbreak_elevator04" = "<font color=\"rgb(29,172,214)\">Wheatley : Par ici! Par ici!"
		"sphere03.sp_sabotage_jailbreak_elevator05" = "<font color=\"rgb(29,172,214)\">Wheatley : Venez! Par ici, vite!"
		"sphere03.sp_sabotage_jailbreak_elevator06" = "<font color=\"rgb(29,172,214)\">Wheatley : VITE! PAR ICI!"
		"sphere03.sp_sabotage_jailbreak_elevator07" = "<font color=\"rgb(29,172,214)\">Wheatley : VITE! PAR ICI!"
		"sphere03.sp_sabotage_jailbreak_elevator09" = "<font color=\"rgb(29,172,214)\">Wheatley : Dans l'ascenseur! Montez!"
		"sphere03.sp_sabotage_jailbreak_elevator11" = "<font color=\"rgb(29,172,214)\">Wheatley : On a réussi on a réussi on a réussi..."
		"sphere03.sp_sabotage_panel_sneak01" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça, c'est fait. Elle n'a plus de tourelles. Maintenant, il faut aussi qu'on s'occupe de ce générateur de neurotoxines."
		"sphere03.sp_sabotage_panel_sneak03" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh, je le vois! Le tube de chargement est dans la salle suivante!"
		"sphere03.sp_sabotage_panel_sneak04" = "<font color=\"rgb(29,172,214)\">Wheatley : Suivez le tube jusqu'à la salle du générateur! On se retrouve là-bas."
		"sphere03.sp_trust_fling01" = "<font color=\"rgb(29,172,214)\">Wheatley : Eh, par ici, là-haut!"
		"sphere03.sp_trust_fling03" = "<font color=\"rgb(29,172,214)\">Wheatley : En tout cas, l'important c'est qu'on se tire d'ici, pas vrai? Sauf qu'on peut pas encore. On se retrouve dans une quinzaine de salles."
		"sphere03.sp_trust_fling04" = "<font color=\"rgb(29,172,214)\">Wheatley : La voilà! Jouez le jeu! Rappelez-vous, plus que quinze salles!"
		"sphere03.sp_trust_flingalt02" = "<font color=\"rgb(29,172,214)\">Wheatley : PIAF PIAF PIAF PIAF!"
		"sphere03.sp_trust_flingalt07" = "<font color=\"rgb(29,172,214)\">Wheatley : J'ai trouvé des oeufs d'oiseaux là-haut. Je les ai lâchés dans le mécanisme de la porte. Ça l'a coincé d'office. J'ai--AAH!"
		"sphere03.sp_trust_flingalt08" = "<font color=\"rgb(29,172,214)\">Wheatley : [à bout de souffle] Bon. C'est sûrement l'oiseau, pas vrai? Celui qui a pondu les oeufs!"
		"sphere03.sphere_flashlight_tour07" = "<font color=\"rgb(29,172,214)\">Wheatley : Ouh, il fait rudement sombre ici."
		"sphere03.sphere_flashlight_tour08" = "<font color=\"rgb(29,172,214)\">Wheatley : Voici l'aile de production de tourelles; un peu plus loin, le centre de production de neurotoxines. Si on trouve un moyen de les désactiver, elle sera sans défense."
		"sphere03.sphere_flashlight_tour09" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis sûr qu'on est sur le bon chemin. À peu près sûr."
		"sphere03.sphere_flashlight_tour10" = "<font color=\"rgb(29,172,214)\">Wheatley : L'usine de tourelles doit être de ce côté, je crois."
		"sphere03.sphere_flashlight_tour11" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh là, attention."
		"sphere03.sphere_flashlight_tour12" = "<font color=\"rgb(29,172,214)\">Wheatley : Essayez de sauter."
		"sphere03.sphere_flashlight_tour13" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous allez bien?"
		"sphere03.sphere_flashlight_tour14" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous êtes encore en vie?"
		"sphere03.sphere_flashlight_tour15" = "<font color=\"rgb(29,172,214)\">Wheatley : Si vous êtes en vie, dites quelque chose. Sautez sur place pour que je sache que vous allez bien."
		"sphere03.sphere_flashlight_tour16" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah, vous voilà, ouf! Je commençais à m'inquiéter, dis donc."
		"sphere03.sphere_flashlight_tour17" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, réessayons. Voyez si vous pouvez passer de l'autre côté de la machinerie."
		"sphere03.sphere_flashlight_tour18" = "<font color=\"rgb(29,172,214)\">Wheatley : Continuons. L'entrée de l'usine doit être quelque part par là."
		"sphere03.sphere_flashlight_tour19" = "<font color=\"rgb(29,172,214)\">Wheatley : Attention... Attention..."
		"sphere03.sphere_flashlight_tour20" = "<font color=\"rgb(29,172,214)\">Wheatley : Attendez que je vous éclaire avant de sauter."
		"sphere03.sphere_flashlight_tour22" = "<font color=\"rgb(29,172,214)\">Wheatley : OK, par ici!"
		"sphere03.sphere_flashlight_tour23" = "<font color=\"rgb(29,172,214)\">Wheatley : Non non non, je suis sûr que c'est par là. Sûr à cent pour cent."
		"sphere03.sphere_flashlight_tour24" = "<font color=\"rgb(29,172,214)\">Wheatley : Hmm. Bon, essayons par ici."
		"sphere03.sphere_flashlight_tour25" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous entendez ça? Ici, avec elle, ça y va à fond les manettes."
		"sphere03.sphere_flashlight_tour26" = "<font color=\"rgb(29,172,214)\">Wheatley : Ça, ça a l'air dangereux. Je vous tiens la lampe."
		"sphere03.sphere_flashlight_tour28" = "<font color=\"rgb(29,172,214)\">Wheatley : Vite, par ici!"
		"sphere03.sphere_flashlight_tour29" = "<font color=\"rgb(29,172,214)\">Wheatley : Oh bien vu, ça !"
		"sphere03.sphere_flashlight_tour30" = "<font color=\"rgb(29,172,214)\">Wheatley : Attendez un peu, je vous éclaire le chemin."
		"sphere03.sphere_flashlight_tour32" = "<font color=\"rgb(29,172,214)\">Wheatley : Non non non, pas par là!"
		"sphere03.sphere_flashlight_tour33" = "<font color=\"rgb(29,172,214)\">Wheatley : Il va falloir qu'on se sépare. Rejoignez ce passage à coups de portails et on se retrouve de l'autre côté."
		"sphere03.sphere_flashlight_tour35" = "<font color=\"rgb(29,172,214)\">Wheatley : Il faut qu'on vous fasse sortir de cette salle."
		"sphere03.sphere_flashlight_tour36" = "<font color=\"rgb(29,172,214)\">Wheatley : Vous pouvez atteindre ce mur, là-bas?"
		"sphere03.sphere_flashlight_tour37" = "<font color=\"rgb(29,172,214)\">Wheatley : OK, y a un autre mur par ici."
		"sphere03.sphere_flashlight_tour38" = "<font color=\"rgb(29,172,214)\">Wheatley : La voilà! L'entrée de l'usine à tourelles! On a réussi!"
		"sphere03.sphere_flashlight_tour40" = "<font color=\"rgb(29,172,214)\">Wheatley : Attention!"
		"sphere03.sphere_flashlight_tour41" = "<font color=\"rgb(29,172,214)\">Wheatley : Pas franchement un succès, la journée parents-enfants..."
		"sphere03.sphere_flashlight_tour42" = "<font color=\"rgb(29,172,214)\">Wheatley : Et... quarante batteries-patates. Je trouve ça honteux. C'est vrai quoi, enfants ou pas, c'est la politique du moindre effort. J'appelle même pas ça de la science."
		"sphere03.sphere_flashlight_tour44" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis sûr qu'on est sur le bon chemin. Histoire de vous rassurer..."
		"sphere03.sphere_flashlight_tour50" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne vous en faites pas, je vous garantis à 100% que c'est le bon chemin. Ah tiens, c'est pas par là."
		"sphere03.sphere_flashlight_tour52" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon, essayons par ici."
		"sphere03.sphere_flashlight_tour55" = "<font color=\"rgb(29,172,214)\">Wheatley : Bon. Alors, moi je vais descendre par ce rail."
		"sphere03.sphere_flashlight_tour56" = "<font color=\"rgb(29,172,214)\">Wheatley : On se retrouve en bas. Bonne chance!"
		"sphere03.sphere_flashlight_tour57" = "<font color=\"rgb(29,172,214)\">Wheatley : Il paraît que l'ancien superviseur de cet endroit a pété les plombs. Qu'il a démantelé tous les robots de son personnel. On dit que la nuit, on entend toujours les cris... de leurs clones. Tous rigoureusement identiques aux originaux sur le plan fonctionnel. Aucun souvenir du massacre. Personne ne sait pourquoi ils crient. C'est terrifiant, je trouve. Mais pas paranormal pour autant, bien sûr."
		"sphere03.sphere_flashlight_tour58" = "<font color=\"rgb(29,172,214)\">Wheatley : Figurez-vous que j'ai failli décrocher un poste ici, à l'usinage. Mais au final, devinez qui le contremaître a choisi? Je vous le donne en mille: un de ses clones. Si c'est pas du favoritisme, ça... Au final, j'écope du pire boulot, m'occuper de ces gros sacs d'humains."
		"sphere03.sphere_flashlight_tour59" = "<font color=\"rgb(29,172,214)\">Wheatley : Ces... euh... non, pas gros sacs. M'occuper des humains, tout court."
		"sphere03.sphere_flashlight_tour60" = "<font color=\"rgb(29,172,214)\">Wheatley : Je suis désolé, c'est sorti comme ça. \"Gros sacs d'humains\", ça manque un peu de tact."
		"sphere03.sphere_flashlight_tour62" = "<font color=\"rgb(29,172,214)\">Wheatley : Non, franchement, les humains, je les adore. Je sais pas, ils présentent bien, je trouve. Et leur... folklore... très exotique, j'aime beaucoup."
		"sphere03.sphere_flashlight_tour63" = "<font color=\"rgb(29,172,214)\">Wheatley : Aah, j'ai trouvé autre chose que j'aime chez les humains. Vous nous avez inventés. C'est génial, comme ça vous pouviez nous laisser faire tout le boulot d'inventer d'autres choses. Sans vous, on n'aurait pas pu faire tout ça. Bravo, non, vraiment."
		"sphere03.sphere_flashlight_tour65" = "<font color=\"rgb(29,172,214)\">Wheatley : Ah! Parfait. Vous avez réussi à passer. Suivez-moi, on a encore du boulot. Ici au moins, elle ne peut rien nous faire."
		"sphere03.sphere_flashlight_tour66" = "<font color=\"rgb(29,172,214)\">Wheatley : Ne bougez surtout pas!"
		"sphere03.sphere_flashlight_tour67" = "<font color=\"rgb(29,172,214)\">Wheatley : OK, bon alors, j'ai une idée, mais c'est un petit peu très très dangereux. C'est parti."
		"sphere03.sphere_flashlight_tour68" = "<font color=\"rgb(29,172,214)\">Wheatley : Que se passe-t-il? Ah. Hmm. Je vois."
		"sphere03.sphere_flashlight_tour70" = "<font color=\"rgb(29,172,214)\">Wheatley : GAAAA!"
		"sphere03.sphere_flashlight_tour71" = "<font color=\"rgb(29,172,214)\">Wheatley : Figurez-vous que j'ai failli décrocher un poste ici, à l'usinage. Mais au final, devinez qui le contremaître a choisi? Je vous le donne en mille: un de ses clones! Si c'est pas du favoritisme, ça... Au final, j'écope du pire des boulots, m'occuper de ces gros sacs d'humains. Ah, euh, non, c'est, enfin c'est sorti comme ça. Désolé."
		"sphere03.sphere_flashlight_tour72" = "<font color=\"rgb(29,172,214)\">Wheatley: Oh punaise... On m'avait dit que si j'allumais cette lampe torche, je MOURRAIS. On m'avait dit ça pour TOUT. Non mais sans blague, à quoi ça sert de me filer des trucs si c'est pour m'interdire de les utiliser? C'est complètement débile."
		"sphere03.stairbouncepain01" = "<font color=\"rgb(29,172,214)\">Wheatley : Aouh!"
		"sphere03.turnaroundnow01" = "<font color=\"rgb(29,172,214)\">Wheatley : C'est bon, vous pouvez vous retourner!"
		"turret.different_turret01" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Merci!"
		"turret.different_turret02" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Oeil pour oeil!"
		"turret.different_turret03" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Ne vous relevez pas!"
		"turret.different_turret04" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Prométhée a été puni par les dieux pour avoir donné le don du savoir aux hommes. Il a été jeté dans les entrailles de la Terre et s'est fait picorer par des oiseaux."
		"turret.different_turret05" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Souvenez-vous-en!"
		"turret.different_turret06" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : C'est tout ce que je peux dire."
		"turret.different_turret07" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Ne l'oubliez pas!"
		"turret.different_turret08" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Ça ne va pas suffire."
		"turret.different_turret09" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : La réponse se trouve sous nos pieds."
		"turret.different_turret10" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Elle s'appelle Caroline."
		"turret.different_turret11" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Ahh!"
		"turret.finale02_turret_defect_return01" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Nous revoilà!"
		"turret.finale02_turret_defect_return02" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Salut!"
		"turret.finale02_turret_defect_return03" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : On est de retour!"
		"turret.finale02_turret_defect_return04" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Rebonjour!"
		"turret.finale02_turret_defect_return05" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Comme on se retrouve!"
		"turret.finale02_turret_defect_return06" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Y a quelqu'un?"
		"turret.finale02_turret_defect_return07" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : C'est fois-ci, on va gagner."
		"turret.finale02_turret_defect_return08" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Cette fois-ci..."
		"turret.finale02_turret_defect_return09" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : La deuxième fois c'est la bonne..."
		"turret.finale02_turret_defect_return10" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Je vais vous présenter une vieille copine!"
		"turret.finale02_turret_defect_return11" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Coucou, c'est nous!"
		"turret.finale02_turret_defect_return12" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Salut!"
		"turret.finale02_turret_defect_return13" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Une tourelle s'éveille, un être s'éteint."
		"turret.finale02_turret_defect_return14" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Vous pensiez jamais nous revoir, hein?"
		"turret.finale02_turret_defect_return15" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ouais."
		"turret.finale02_turret_defect_return16" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Une fois, ça va. Deux fois, bonjour les dégâts."
		"turret.finale02_turret_return_defect_fail01" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Mince!"
		"turret.finale02_turret_return_defect_fail02" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Aaaah..."
		"turret.finale02_turret_return_defect_fail03" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Merde!"
		"turret.finale02_turret_return_defect_fail04" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Rrrrh!"
		"turret.finale02_turret_return_defect_fail05" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Merde!"
		"turret.finale02_turret_return_defect_fail06" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Mince!"
		"turret.finale02_turret_return_defect_fail07" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Mince."
		"turret.finale02_turret_return_defect_fail08" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Mince."
		"turret.finale02_turret_return_defect_fail09" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : On n'avait pas réparé ça?"
		"turret.finale02_turret_return_defect_fail10" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Non mais sérieux..."
		"turret.finale02_turret_return_defect_fail11" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Dites, je dois faire quoi pour avoir des munitions?"
		"turret.finale02_turret_return_defect_fail12" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Non mais je rêve!"
		"turret.finale02_turret_return_defect_fail13" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Non. Je vois toujours rien."
		"turret.finale02_turret_return_defect_fail14" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Hmm. Toujours aveugle."
		"turret.finale02_turret_return_defect_fail15" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ça fait clic, mais personne claque!"
		"turret.finale02_turret_return_defect_fail16" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Je m'en doutais! Toujours cassé!"
		"turret.finale02_turret_return_defect_fail17" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ah. C'est toujours cassé."
		"turret.finale02_turret_return_defect_fail18" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Que c'est gênant d'être non létal."
		"turret.finale02_turret_return_defect_fail19" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Je ne vois rien de rien."
		"turret.finale02_turret_return_defect_fail20" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Zéro amélioration."
		"turret.finale02_turret_return_defect_fail21" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ça ne s'améliore pas avec l'âge!"
		"turret.finale02_turret_return_defect_fail22" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ça devient gênant, là."
		"turret.finale02_turret_return_defect_fail23" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Bon, passez."
		"turret.finale02_turret_return_defect_fail24" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : [soupir] N'allez le dire à personne, hein."
		"turret.finale02_turret_return_defect_fail25" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : OK."
		"turret.finale02_turret_return_defect_fail26" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Si on vous pose la question, je vous ai tuée."
		"turret.finale02_turret_return_defect_fail27" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Soyez bonne joueuse, dites-lui que je vous ai tuée."
		"turret.finale02_turret_return_defect_fail28" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Bravo."
		"turret.finale02_turret_return_defect_goodbye01" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : J'aurai tenté le coup. Bon courage!"
		"turret.finale02_turret_return_defect_goodbye02" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Bon courage, mademoiselle!"
		"turret.finale02_turret_return_defect_goodbye03" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Bonne continuation!"
		"turret.finale02_turret_return_defect_goodbye04" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Sympa, la patate!"
		"turret.finale02_turret_return_defect_goodbye05" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : J'aime bien la patate!"
		"turret.finale02_turret_return_defect_goodbye06" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Eh bien merci pour tout!"
		"turret.finale02_turret_return_defect_goodbye07" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Revenez quand vous voulez!"
		"turret.finale02_turret_return_defect_goodbye08" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ce fut un plaisir!"
		"turret.finale02_turret_return_defect_goodbye09" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Emmenez-moi avec vous... Allez..."
		"turret.finale02_turret_return_defect_goodbye10" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : À vous de jouer, mamzelle!"
		"turret.finale02_turret_return_defect_goodbye11" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : On s'est bien amusé, hein?"
		"turret.finale02_turret_return_defect_goodbye12" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Cette fois-ci, vous m'avez eu."
		"turret.finale02_turret_return_defect_goodbye13" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Touché, mademoiselle, touché."
		"turret.glados_battle_defect_arrive01" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Mon quart d'heure de gloire!"
		"turret.glados_battle_defect_arrive02" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Je vous décevrai pas!"
		"turret.glados_battle_defect_arrive03" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Vous le regretterez pas!"
		"turret.glados_battle_defect_arrive04" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : À moi de jouer, maintenant !"
		"turret.glados_battle_defect_arrive05" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Et on est partis!"
		"turret.glados_battle_defect_arrive06" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Fallait pas m'inviter!"
		"turret.glados_battle_defect_arrive07" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ça va saigner!"
		"turret.glados_battle_defect_arrive08" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Paré à tirer!"
		"turret.glados_battle_defect_arrive09" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : C'est exactement ce que je voulais faire!"
		"turret.glados_battle_defect_arrive10" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Oh."
		"turret.glados_battle_defect_arrive11" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ah. Crotte."
		"turret.glados_battle_defect_arrive12" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Oh non, encore!"
		"turret.glados_battle_defect_arrive13" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Nannn, pas maintenant!"
		"turret.glados_battle_defect_arrive14" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Je suis viré, je parie?"
		"turret.glados_battle_defect_arrive15" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ça, c'est pas bon."
		"turret.glados_battle_defect_arrive16" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ouh, ça ne me plaît pas."
		"turret.glados_battle_defect_arrive17" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : [sourdine] Attention!"
		"turret.glados_battle_defect_arrive18" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : [sourdine] Aaah! Je brûle!"
		"turret.glados_battle_defect_arrive19" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Crève!"
		"turret.sp_sabotage_factory_defect_chat01" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Mince alors, je vois plus rien. Dans le doute, je tire! [clic clic clic clic] Crotte!"
		"turret.sp_sabotage_factory_defect_chat02" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Oh la vache. Vous m'avez sauvé la peau. Où est-ce qu'on va? On s'évade? Je vois rien du tout, là."
		"turret.sp_sabotage_factory_defect_chat03" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Allez! Ça va donner!"
		"turret.sp_sabotage_factory_defect_chat04" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Ouais, ça marche!"
		"turret.sp_sabotage_factory_defect_chat05" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : Yeah, trop bon!"
		"turret.sp_sabotage_factory_defect_dryfire01" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire02" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire03" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire04" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire05" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire06" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire07" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire08" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire09" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire10" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire11" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
		"turret.sp_sabotage_factory_defect_dryfire12" = "<font color=\"rgb(197,208,230)\"><low>Tourelle défectueuse : clickclickclick"
