		"turret.turretwitnessdeath03" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : J'ai besoin de renforts!"
		"turret.turretwitnessdeath04" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Vous visez super bien!"
		"turret.turretwitnessdeath05" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Je ne l'ai jamais aimée."
		"turret.turretwitnessdeath06" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : C'est des choses qui arrivent."
		"turret.turretwitnessdeath07" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : C'est la faute à pas de chance."
		"turret.turretwitnessdeath08" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Elle l'avait bien cherché."
		"turret.turretwitnessdeath09" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Bigre."
		"turret.turretwitnessdeath10" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : Fichtre."
		"turret.turretwitnessdeath11" = "<font color=\"rgb(170,240,209)\"><low>Tourelle : C'est ma faute."
