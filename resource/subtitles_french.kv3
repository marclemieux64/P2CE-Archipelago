		"ep_02.al_junc_ineedto05" = "<font color=\"rgb(255,212,255)\">[souffle coupé]"
		"ep_02.al_junc_luckytobehere01" = "<font color=\"rgb(255,212,255)\">Ouah..."
		"ep_02.al_junc_luckytobehere02" = "<font color=\"rgb(255,212,255)\">Quoi que vous ayez fait,"
		"ep_02.al_junc_luckytobehere03" = "<font color=\"rgb(255,212,255)\">je crois que j'ai de la chance d'être encore là."
		"ep_02.al_junc_nexttome01" = "<font color=\"rgb(255,212,255)\">Allez, Gordon. "
		"ep_02.al_junc_nexttome02" = "<font color=\"rgb(255,212,255)\">Près de moi."
		"ep_02.al_junc_notwithoutyou01" = "<font color=\"rgb(255,212,255)\">Allez Gordon, venez."
		"ep_02.al_junc_notwithoutyou02" = "<font color=\"rgb(255,212,255)\">On ne partira pas sans vous."
		"ep_02.al_junc_ohgod" = "<font color=\"rgb(255,212,255)\">Mon Dieu."
		"ep_02.al_junc_soweak" = "<font color=\"rgb(255,212,255)\">Je suis... si faible..."
		"ep_02.al_junc_soweak01" = "<font color=\"rgb(255,212,255)\">Des heures? "
		"ep_02.al_junc_soweak02" = "<font color=\"rgb(255,212,255)\">Ah..."
		"ep_02.al_junc_soweak03" = "<font color=\"rgb(255,212,255)\">Il faut y aller!"
		"ep_02.al_junc_thatsg" = "<font color=\"rgb(255,212,255)\">Oui, c'est Gordon..."
		"ep_02.al_junc_thoughtdead01" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu. "
		"ep_02.al_junc_thoughtdead02" = "<font color=\"rgb(255,212,255)\">J'ai cru..."
		"ep_02.al_junc_thoughtdead03" = "<font color=\"rgb(255,212,255)\">Euh..."
		"ep_02.al_junc_thoughtdead04" = "<font color=\"rgb(255,212,255)\">J'ai bien cru mourir."
