		"ep_02.al_inn_wayouthere" = "<font color=\"rgb(255,212,255)\">Je me demande pourquoi le Cartel a placé un barrage si loin..."
		"ep_02.al_junc_ahhuh01" = "<font color=\"rgb(255,212,255)\">[gémissements et marmonnements]"
