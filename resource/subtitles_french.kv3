		"ep_01.al_hospital_didallright" = "<font color=\"rgb(255,212,255)\">Vous vous en êtes bien sorti sans moi."
		"ep_01.al_hospital_electro" = "<font color=\"rgb(255,212,255)\">C'est quoi cet hôpital?"
		"ep_01.al_hospital_fallthru01" = "<font color=\"rgb(255,212,255)\">Oh non!"
		"ep_01.al_hospital_fallthru02" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_01.al_hospital_fallthru03" = "<font color=\"rgb(255,212,255)\">Ça va?"
		"ep_01.al_hospital_foundshotgun01" = "<font color=\"rgb(255,212,255)\">Tu parles de matériel médical!"
		"ep_01.al_hospital_foundshotgun02" = "<font color=\"rgb(255,212,255)\">J'ai trouvé un fusil!"
