		"ep_02.eli_launch_momenttoosoon01" = "<font color=\"rgb(255,208,172)\">Il était temps. "
		"ep_02.eli_launch_mother01" = "<font color=\"rgb(255,208,172)\">Ta mère aurait été si fière..."
		"ep_02.eli_launch_mother02" = "<font color=\"rgb(255,208,172)\">si elle avait été là...."
		"ep_02.eli_launch_notime01" = "<font color=\"rgb(255,208,172)\">Il n'y a pas de temps à perdre."
		"ep_02.eli_launch_notime02" = "<font color=\"rgb(255,208,172)\">Allez-y!"
		"ep_02.eli_launch_onefire01" = "<font color=\"rgb(255,208,172)\">J'aurais aimé que tu n'aies pas toutes ces responsabilités, Alyx."
		"ep_02.eli_launch_pain01" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_pain02" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
