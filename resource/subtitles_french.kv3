		"ep_01.al_hospital_shallwego" = "<font color=\"rgb(255,212,255)\">On y va?"
		"ep_01.al_hospital_swamped01" = "<font color=\"rgb(255,212,255)\">Désolée de vous avoir laissé seul ici, Gordon."
		"ep_01.al_hospital_swamped02" = "<font color=\"rgb(255,212,255)\">J'ai été débordée."
