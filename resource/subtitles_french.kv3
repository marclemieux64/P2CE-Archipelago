		"ep_01.al_core_couldbeit02" = "<font color=\"rgb(255,212,255)\">Attention."
		"ep_01.al_doorhacks01a" = "<font color=\"rgb(255,212,255)\">Une minute..."
		"ep_01.al_doorhacks01b" = "<font color=\"rgb(255,212,255)\">Ça y est!"
