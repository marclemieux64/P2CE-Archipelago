		"ep_01.al_stalk_getemoff10" = "<font color=\"rgb(255,212,255)\">Enlevez-le!"
		"ep_01.al_stalk_getemoff11" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_01.al_stalk_godogod01" = "<font color=\"rgb(255,212,255)\">Oh non, non, non..."
		"ep_01.al_stalk_godogod02" = "<font color=\"rgb(255,212,255)\">Oh non, non..."
		"ep_01.al_stalk_hitit" = "<font color=\"rgb(255,212,255)\">Achevez-le!"
		"ep_01.al_stalk_hopeyoudontremember" = "<font color=\"rgb(255,212,255)\">J'espère que vous avez oublié qui vous étiez."
