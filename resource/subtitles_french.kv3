		"ep1_citizen.cit_raidsoldiers_female" = "Des soldats!"
		"ep1_citizen.cit_reachtrain01_female" = "On a réussi!"
		"ep1_citizen.cit_reachtrain02_female" = "Faites bouger ce truc."
		"ep1_citizen.cit_reachtrain03_female" = "J'ai réussi! On peut y aller maintenant!"
		"ep1_citizen.cit_reachtrain04_female" = "Dépêchez-vous, partons d'ici!"
		"ep1_citizen.cit_reachtrain05_female" = "Foutons le camp d'ici!"
		"ep1_citizen.cit_remarks01_female" = "J'ai entendu dire que c'était bien mieux à la campagne."
		"ep1_citizen.cit_remarks02_female" = "Quoi qu'on fasse, les choses ne font qu'empirer."
		"ep1_citizen.cit_remarks03_female" = "C'était sûr avant ici."
		"ep1_citizen.cit_remarks04_female" = "C'était un si joli quartier."
		"ep1_citizen.cit_remarks05_female" = "Je croyais presque que ça serait mieux maintenant."
		"ep1_citizen.cit_remarks06_female" = "On ressemble à de vrais pigeons, ici... Ou à des cibles de foire.... En tout cas, c'est pas bon."
		"ep1_citizen.cit_remarks07_female" = "Tout ça pour que la science progresse."
		"ep1_citizen.cit_remarks08_female" = "Kleiner dit qu'on peut copuler maintenant. Comme si j'avais besoin de sa permission. "
		"ep1_citizen.cit_remarks09_female" = "Le Dr Breen me manque pas, mais je regrette son spectacle... vous vous souvenez quand il avait des jongleurs?"
		"ep1_citizen.cit_remarks10_female" = "Il paraît qu'ils mettent des bébés dans ces striders."
		"ep1_citizen.cit_remarks11_female" = "Tout ça, c'est à cause de Black Mesa."
		"ep1_citizen.cit_remarks12_female" = "J'ai rencontré Odessa Cubbage un jour. Quel idiot."
		"ep1_citizen.cit_remarks13_female" = "C'est à cause d'Odessa Cubbage."
		"ep1_citizen.cit_remarks14_female" = "Ils nous disent toujours que quelque chose va exploser. Mais cette fois, j'y crois pas."
		"ep1_citizen.cit_remarks15_female" = "Je ne vais nulle part. Non, Monsieur."
		"ep1_citizen.cit_remarks16_female" = "Oh non, encore le discours de Kleiner. EST-CE-QUE QUELQU'UN PEUT ARRÊTER ÇA!"
		"ep1_citizen.cit_remarks17_female" = "Entre nous, je ne fais pas du tout confiance aux Vortigaunts."
		"ep1_citizen.cit_remarks18_female" = "Qu'est-ce que c'est que ce temps?"
		"ep1_citizen.cit_remarks19_female" = "On les appelle peut-être des crabes, mais je vous le dis, ils n'ont pas vraiment le goût de crabe."
		"ep1_citizen.cit_remarks20_female" = "Ça a l'air fou, mais quelque part, je regrette un peu le Cartel."
		"ep1_citizen.cit_remarks21_female" = "Quelquefois, j'ai l'impression que tout le monde est docteur sauf moi. "
		"ep1_citizen.cit_remarks22_female" = "Quel est l'idiot qui a nommé Kleiner?"
		"ep1_citizen.cit_remarks23_female" = "On crève tous de faim et les crabes de tête de Kleiner se régalent sans doute de têtes succulentes."
		"ep1_citizen.cit_runforit_female" = "Vas-y!"
		"ep1_citizen.cit_safehouse_female" = "Le Cartel ne facilite pas les choses. On essaie de rassembler assez de monde pour forcer le passage jusqu'à la gare. Les gens se regroupent dans un abri tout près."
		"ep1_citizen.cit_shock01_female" = "[cri d'effroi]"
		"ep1_citizen.cit_shock02_female" = "[cri d'effroi]"
		"ep1_citizen.cit_shock03_female" = "[cri d'effroi]"
		"ep1_citizen.cit_shock04_female" = "[cri d'effroi]"
		"ep1_citizen.cit_shock05_female" = "[cri d'effroi]"
		"ep1_citizen.cit_squad_flee01_female" = "Vous avez entendu le crâne d'oeuf! Quittez la ville!"
		"ep1_citizen.cit_squad_flee02_female" = "On avance, on avance!"
		"ep1_citizen.cit_squad_flee03_female" = "Vous arrêtez pas. On doit arriver jusqu'à la gare."
		"ep1_citizen.cit_squad_flee04_female" = "Vite! À la gare!"
		"ep1_citizen.cit_squad_flee05_female" = "Les derniers trains s'en vont. Il faut avancer."
		"ep1_citizen.cit_stopburrows_female" = "Hé, vous là-bas! Bouchez ces terriers et on vous laissera passer."
		"ep1_citizen.cit_tellmeaboutit_female" = "M'en parlez pas. Ils essaient de nous piéger ici."
		"ep1_citizen.cit_thateverybody_female" = "Tout le monde est là?"
		"ep1_citizen.cit_theyfoundus_female" = "Ils nous ont trouvés!"
		"ep1_citizen.cit_thisway_female" = "Par ici."
		"ep1_citizen.cit_twopeople_female" = "On m'a dit que deux personnes devaient monter. J'attends que vous soyez là tous les deux."
		"ep1_citizen.cit_youbet_female" = "Tu parles! On y va."
		"ep1_citizen.cit_youknowodessa_female" = "Hé, Dr Freeman, il paraît que vous étiez là quand Odessa Cubbage a abattu le premier hélico? Quel honneur pour vous... je suis fière de dire que j'ai rencontré quelqu'un qui connaissait Odessa Cubbage."
		"ep1_citizen.cit_alert_antlions01_male" = "Bloquez les terriers!"
		"ep1_citizen.cit_alert_antlions02_male" = "Bloquez les ouvertures!"
		"ep1_citizen.cit_alert_antlions03_male" = "D'où viennent toutes ces choses?"
		"ep1_citizen.cit_alert_antlions04_male" = "Mais comment rentrent-elles dans la ville?"
		"ep1_citizen.cit_alert_antlions05_male" = "Saletés d'insectes!"
		"ep1_citizen.cit_alert_antlions06_male" = "Au secours!"
		"ep1_citizen.cit_alert_antlions07_male" = "Comme si on en avait pas assez comme ça!"
		"ep1_citizen.cit_alert_antlions08_male" = "Elles arrivent!"
		"ep1_citizen.cit_alert_antlions09_male" = "Je les entends!"
		"ep1_citizen.cit_alert_antlions10_male" = "Ces fourmis-lions doivent venir par les souterrains."
