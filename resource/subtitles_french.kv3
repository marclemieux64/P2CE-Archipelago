		"ep_01.al_gravcharge_keepmoving" = "<font color=\"rgb(255,212,255)\">OK, on ferait mieux de continuer."
		"ep_01.al_gravcharge_onourpath" = "<font color=\"rgb(255,212,255)\">Je ne me souviens pas d'avoir vu ça sur la carte."
		"ep_01.al_gravcharge_thing" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que c'est que ça?"
		"ep_01.al_gravgunlosingpower01" = "<font color=\"rgb(255,212,255)\">Il perd de l'énergie."
		"ep_01.al_gravgunlosingpower02" = "<font color=\"rgb(255,212,255)\">Mince."
