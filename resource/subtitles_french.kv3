		"ep_02.al_barn_adv_holdong" = "<font color=\"rgb(255,212,255)\">Tenez bon, Gordon!"
		"ep_02.al_barn_adv_no" = "<font color=\"rgb(255,212,255)\">Non!"
		"ep_02.al_barn_adv_omghatch01" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu..."
		"ep_02.al_barn_adv_omghatch02" = "<font color=\"rgb(255,212,255)\">C'est en train d'éclore."
