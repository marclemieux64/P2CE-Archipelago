		"ep_01.al_lasttrain_herewego" = "<font color=\"rgb(255,212,255)\">C'est parti!"
		"ep_01.al_lasttrain_missedthatone" = "<font color=\"rgb(255,212,255)\">Oh, on l'a loupé."
		"ep_01.al_lasttrain_needanothertrain" = "<font color=\"rgb(255,212,255)\">Oh, on va avoir besoin d'un autre train."
		"ep_01.al_lasttrain_next" = "<font color=\"rgb(255,212,255)\">Je vais amener le prochain train."
		"ep_01.al_lasttrain_notgoing" = "<font color=\"rgb(255,212,255)\">Ce train ne partira pas si on ne met pas le courant."
		"ep_01.al_lasttrain_ohno" = "<font color=\"rgb(255,212,255)\">Oh, non!"
		"ep_01.al_lasttrain_ohnogordon" = "<font color=\"rgb(255,212,255)\">Oh non, Gordon!"
		"ep_01.al_lasttrain_omg" = "<font color=\"rgb(255,212,255)\">Oh, mon Dieu!"
		"ep_01.al_lasttrain_oneforus01" = "<font color=\"rgb(255,212,255)\">Une seconde."
		"ep_01.al_lasttrain_oneforus02" = "<font color=\"rgb(255,212,255)\">Je vais mettre en place un autre train."
		"ep_01.al_lasttrain_prompt01" = "<font color=\"rgb(255,212,255)\">Allez, Gordon. Grimpez!"
		"ep_01.al_lasttrain_prompt02" = "<font color=\"rgb(255,212,255)\">Grimpez!"
		"ep_01.al_lasttrain_prompt03" = "<font color=\"rgb(255,212,255)\">Grimpez à l'arrière du train!"
		"ep_01.al_lasttrain_pulling" = "<font color=\"rgb(255,212,255)\">Elle attire tout vers elle!"
		"ep_01.al_lasttrain_slowing" = "<font color=\"rgb(255,212,255)\">Le train ralentit."
		"ep_01.al_lasttrain_thisisit" = "<font color=\"rgb(255,212,255)\">Ça y est, Gordon."
		"ep_01.al_lasttrain_thisisswitch" = "<font color=\"rgb(255,212,255)\">Voilà l'interrupteur. Je l'enclenche."
		"ep_01.al_lasttrain_toodangerous01" = "<font color=\"rgb(255,212,255)\">C'est trop dangereux, ici, Barney."
		"ep_01.al_lasttrain_toodangerous02" = "<font color=\"rgb(255,212,255)\">Restez avec les passagers. On va faire partir ce train."
		"ep_01.al_looktarget_payphone" = "<font color=\"rgb(255,212,255)\">Ces téléphones sont à l'abandon."
		"ep_01.al_makejump" = "<font color=\"rgb(255,212,255)\">Vous pouvez sauter?"
		"ep_01.al_notellingtime" = "<font color=\"rgb(255,212,255)\">Je ne sais pas s'il nous reste du temps. La gare ne doit plus être loin maintenant."
		"ep_01.al_openseason" = "<font color=\"rgb(255,212,255)\">Ah ah. La chasse aux hélicos est ouverte."
		"ep_01.al_rappel_alert01" = "<font color=\"rgb(255,212,255)\">Ils viennent d'en haut!"
		"ep_01.al_rappel_alert02" = "<font color=\"rgb(255,212,255)\">Ils viennent des toits!"
		"ep_01.al_rappel_alert03" = "<font color=\"rgb(255,212,255)\">Eh, là-haut!"
		"ep_01.al_roller_holdingoff" = "<font color=\"rgb(255,212,255)\">Je le retiens, Gordon. Essayez de l'attraper. "
		"ep_01.al_safehouse_figureitout01" = "<font color=\"rgb(255,212,255)\">Quand on le saura, on vous le dira."
		"ep_01.al_safehouse_figureitout02" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que vous faites là-haut?"
		"ep_01.al_safehouse_illgetthis" = "<font color=\"rgb(255,212,255)\">Je m'en charge."
		"ep_01.al_safehouse_million" = "<font color=\"rgb(255,212,255)\">Ça, c'est la question à un million... Comment ça va, Barney?"
		"ep_01.al_slugourway" = "<font color=\"rgb(255,212,255)\">Je crois qu'il va falloir se battre pour passer. Plus on met de temps à trouver la gare, plus c'est dangereux."
		"ep_01.al_sniper_bringroller" = "<font color=\"rgb(255,212,255)\">Donnez-moi un lamineur."
		"ep_01.al_sniper_cantcomewith" = "<font color=\"rgb(255,212,255)\">Tant que ce sniper est dans les parages, je ne peux pas vous suivre."
		"ep_01.al_sniper_cantgetthru" = "<font color=\"rgb(255,212,255)\">On ne peut pas passer tant que ce sniper couvre la rue."
		"ep_01.al_sniper_cantgoout" = "<font color=\"rgb(255,212,255)\">Je ne peux pas y aller."
		"ep_01.al_sniper_cantgoout2" = "<font color=\"rgb(255,212,255)\">Je ne peux pas sortir si ce sniper couvre la rue."
		"ep_01.al_sniper_dontrunout" = "<font color=\"rgb(255,212,255)\">Gordon, arrêtez-vous."
		"ep_01.al_sniper_dontwasteroller01" = "<font color=\"rgb(255,212,255)\">Ne gaspillez pas ces lamineurs."
		"ep_01.al_sniper_dontwasteroller02" = "<font color=\"rgb(255,212,255)\">Ramenez-en un."
		"ep_01.al_sniper_grabroller01" = "<font color=\"rgb(255,212,255)\">Eh, apportez-moi ce lamineur."
		"ep_01.al_sniper_grabroller02" = "<font color=\"rgb(255,212,255)\">On peut l'utiliser contre ce sniper."
		"ep_01.al_sniper_grabroller03" = "<font color=\"rgb(255,212,255)\">Eh, attrapez ce lamineur."
		"ep_01.al_sniper_grabroller04" = "<font color=\"rgb(255,212,255)\">On pourrait l'utiliser contre ce sniper."
		"ep_01.al_sniper_holdback" = "<font color=\"rgb(255,212,255)\">Attendez. Attrapez un de ces lamineurs."
		"ep_01.al_sniper_lobroller" = "<font color=\"rgb(255,212,255)\">Balancez un lamineur par ici."
		"ep_01.al_sniper_minesonourside" = "<font color=\"rgb(255,212,255)\">Mettons des lamineurs de notre côté."
		"ep_01.al_sniper_mounted" = "<font color=\"rgb(255,212,255)\">Je ne peux pas déplacer cette arme. Je vous couvre d'ici."
		"ep_01.al_sniper_pinned" = "<font color=\"rgb(255,212,255)\">Nous sommes coincés. Il faut descendre ces artilleurs."
		"ep_01.al_sniper_runpoint" = "<font color=\"rgb(255,212,255)\">Il y a une garnison du Cartel au bout de la rue. Ouvrez le chemin et je vous suivrai dès que vous aurez réussi à passer."
		"ep_01.al_sniper_takeoutsniper" = "<font color=\"rgb(255,212,255)\">Descendez ce sniper, Gordon!"
		"ep_01.al_subwaymap01" = "<font color=\"rgb(255,212,255)\">Une carte."
		"ep_01.al_subwaymap02" = "<font color=\"rgb(255,212,255)\">Hmmmm..."
		"ep_01.al_subwaymap03" = "<font color=\"rgb(255,212,255)\">Le train nous a emmenés plus loin que prévu."
		"ep_01.al_subwaymap04" = "<font color=\"rgb(255,212,255)\">On a encore un bout de chemin, mais ça aurait pu être pire."
		"ep_01.al_thatsoundagain" = "<font color=\"rgb(255,212,255)\">Oh oh. Encore ce son."
		"ep_01.al_tougherthanithought" = "<font color=\"rgb(255,212,255)\">C'était plus dur que prévu."
		"ep_01.al_uhohcomingthru" = "<font color=\"rgb(255,212,255)\">Oh oh, ils arrivent."
		"ep_01.al_whatsbeeping" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que c'est que ce bip?"
		"ep_01.al_whydefendgarrison" = "<font color=\"rgb(255,212,255)\">Pourquoi défendre cette garnison alors que la ville va exploser?"
		"ep_01.al_whythisway" = "<font color=\"rgb(255,212,255)\">Quoi encore?"
		"ep_01.al_youdonethisbefore" = "<font color=\"rgb(255,212,255)\">Ce n'est pas la première fois, non?"
		"ep_01.al_youfinished" = "<font color=\"rgb(255,212,255)\">On se demandait quand vous auriez fini."
		"ep_01.al_block_canyoumovethat" = "<font color=\"rgb(255,212,255)\">Vous pouvez bouger ça, Gordon? On doit passer."
		"ep_01.al_block_comeon" = "<font color=\"rgb(255,212,255)\">Allez."
		"ep_01.al_block_getthru" = "<font color=\"rgb(255,212,255)\">On doit passer par ici."
		"ep_01.al_block_movedebris" = "<font color=\"rgb(255,212,255)\">Essayez de bouger ces débris."
		"ep_01.al_block_onlypath" = "<font color=\"rgb(255,212,255)\">C'est le seul chemin que j'ai trouvé."
		"ep_01.al_comingapart_01" = "<font color=\"rgb(255,212,255)\">Ouah... Cet endroit tombe en ruine."
		"ep_01.al_comingapart_02" = "<font color=\"rgb(255,212,255)\">Il faut vraiment partir d'ici."
		"ep_01.al_core_blowreactor01" = "<font color=\"rgb(255,212,255)\">On dirait qu'ils voulaient faire exploser le réacteur à tout prix."
		"ep_01.al_core_blowreactor02" = "<font color=\"rgb(255,212,255)\">Pourquoi?"
		"ep_01.al_core_cantgetclear01" = "<font color=\"rgb(255,212,255)\">Ah, ce n'est toujours pas plus clair."
		"ep_01.al_core_cantgetclear02" = "<font color=\"rgb(255,212,255)\">Je vais tâcher de tout récupérer tant que vous êtes là."
		"ep_01.al_core_cantgetclear03" = "<font color=\"rgb(255,212,255)\">On analysera après."
		"ep_01.al_core_controlcrazy01" = "<font color=\"rgb(255,212,255)\">Bizarre..."
		"ep_01.al_core_controlcrazy02" = "<font color=\"rgb(255,212,255)\">Le système de contrôle s'emballe. Ils compressent énormément de données."
		"ep_01.al_core_controlcrazy03" = "<font color=\"rgb(255,212,255)\">Je me demande..."
		"ep_01.al_core_fargone01" = "<font color=\"rgb(255,212,255)\">Oh, mon Dieu."
		"ep_01.al_core_fargone02" = "<font color=\"rgb(255,212,255)\">Ça devient dangereux."
		"ep_01.al_core_fargone03" = "<font color=\"rgb(255,212,255)\">J'espère que le Dr Kleiner avait raison."
		"ep_01.al_core_hellitsjudith01" = "<font color=\"rgb(255,212,255)\">Bon sang, mais..."
		"ep_01.al_core_hellitsjudith02" = "<font color=\"rgb(255,212,255)\">C'est Judith!"
		"ep_01.al_core_herecomeslift01" = "<font color=\"rgb(255,212,255)\">Eh bien..."
		"ep_01.al_core_herecomeslift02" = "<font color=\"rgb(255,212,255)\">Voici votre ascenseur."
		"ep_01.al_core_herecomeslift03" = "<font color=\"rgb(255,212,255)\">Je voudrais pouvoir en faire plus."
		"ep_01.al_core_inthrucontrolroom" = "<font color=\"rgb(255,212,255)\">Essayons de passer par la salle de contrôle."
