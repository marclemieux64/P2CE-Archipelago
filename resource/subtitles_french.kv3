		"ep_02.al_ambush_trapped" = "<font color=\"rgb(255,212,255)\">On est piégés!"
		"ep_02.al_ambush_turret" = "<font color=\"rgb(255,212,255)\">Attention: ils ont laissé une tourelle."
		"ep_02.al_ambush_turretnag01" = "<font color=\"rgb(255,212,255)\">Descendez cette tourelle, Gordon."
