		"ep_02.al_launch_cue02" = "<font color=\"rgb(255,212,255)\">Allons-y, Gordon."
		"ep_02.al_launch_dadcry" = "<font color=\"rgb(255,212,255)\">Papa! "
		"ep_02.al_launch_daddad01" = "<font color=\"rgb(255,212,255)\">Papa! "
		"ep_02.al_launch_daddad02" = "<font color=\"rgb(255,212,255)\">Papa! "
