		"ep_01.al_gettocoresoon02" = "<font color=\"rgb(255,212,255)\">on n'aura pas le temps de l'éteindre."
		"ep_01.al_goodletsgo01" = "<font color=\"rgb(255,212,255)\">Super."
		"ep_01.al_goodletsgo02" = "<font color=\"rgb(255,212,255)\">Allons-y."
		"ep_01.al_gottocross" = "<font color=\"rgb(255,212,255)\">Il faut traverser. On doit trouver un moyen de mettre ce pont sous tension."
		"ep_01.al_grabroll01" = "<font color=\"rgb(255,212,255)\">Ah, j'ai trouvé."
