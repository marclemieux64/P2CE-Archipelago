		"ep_01.al_lift_laststop" = "<font color=\"rgb(255,212,255)\">Je crois bien que c'est le dernier arrêt."
		"ep_01.al_lift_last_lookout01" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_01.al_lift_last_lookout02" = "<font color=\"rgb(255,212,255)\">Courez!"
		"ep_01.al_lift_last_lookup01" = "<font color=\"rgb(255,212,255)\">Là-haut!"
		"ep_01.al_lift_last_lookup02" = "<font color=\"rgb(255,212,255)\">Courez!"
		"ep_01.al_lift_last_upthere01" = "<font color=\"rgb(255,212,255)\">Là-haut!"
		"ep_01.al_lift_last_upthere02" = "<font color=\"rgb(255,212,255)\">Courez!"
		"ep_01.al_lift_letsgetoff" = "<font color=\"rgb(255,212,255)\">Je vois un arrêt en dessous. Descendons et voyons où ça nous mène."
		"ep_01.al_lift_righttrack" = "<font color=\"rgb(255,212,255)\">C'est bon, on doit être sur la bonne piste."
		"ep_01.al_lift_stalkerdoing01" = "<font color=\"rgb(255,212,255)\">Regardez, un stalker."
		"ep_01.al_lift_stalkerdoing02" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'il fait?"
		"ep_01.al_lift_tocore_new" = "<font color=\"rgb(255,212,255)\">On dirait que ce monte-charge va jusqu'au noyau."
		"ep_01.al_lift_whatsgoingon" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qui se passe?"
		"ep_01.al_lift_whatswrong01" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'il a, cet ascenseur?"
		"ep_01.al_lift_whatswrong02" = "<font color=\"rgb(255,212,255)\">Vous pouvez le faire repartir?"
		"ep_01.al_platform_coast" = "<font color=\"rgb(255,212,255)\">La voie est libre."
		"ep_01.al_platform_comeon" = "<font color=\"rgb(255,212,255)\">Allez, allez!"
		"ep_01.al_platform_company" = "<font color=\"rgb(255,212,255)\">On a de la visite..."
		"ep_01.al_platform_getaway" = "<font color=\"rgb(255,212,255)\">Waah, on a filé en beauté!"
		"ep_01.al_platform_getin" = "<font color=\"rgb(255,212,255)\">Allez Gordon, montez! "
		"ep_01.al_platform_getingordon" = "<font color=\"rgb(255,212,255)\">Montez, Gordon!"
		"ep_01.al_platform_getready" = "<font color=\"rgb(255,212,255)\">Prêt?"
		"ep_01.al_platform_heretheycome" = "<font color=\"rgb(255,212,255)\">Les voilà!"
		"ep_01.al_platform_hurry" = "<font color=\"rgb(255,212,255)\">Vite! Ils ne vont pas nous laisser en paix."
		"ep_01.al_platform_lookatem" = "<font color=\"rgb(255,212,255)\">Regardez-les partir!"
		"ep_01.al_platform_rollers" = "<font color=\"rgb(255,212,255)\">Des lamineurs!"
		"ep_01.al_platform_slowthem01" = "<font color=\"rgb(255,212,255)\">Ca les ralentira,"
		"ep_01.al_platform_slowthem02" = "<font color=\"rgb(255,212,255)\">mais pas pour longtemps."
		"ep_01.al_platform_taketrain01" = "<font color=\"rgb(255,212,255)\">Voilà le train."
		"ep_01.al_platform_taketrain02" = "<font color=\"rgb(255,212,255)\">Montons."
		"ep_01.al_platform_theyknow01" = "<font color=\"rgb(255,212,255)\">Ils savent où nous sommes."
		"ep_01.al_platform_theyknow02" = "<font color=\"rgb(255,212,255)\">Il faut se dépêcher."
		"ep_01.al_platform_wontexpect" = "<font color=\"rgb(255,212,255)\">Ils ne s'y attendront pas."
		"ep_01.al_postcore_atwindow_new02" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_01.al_postcore_atwindow_new03" = "<font color=\"rgb(255,212,255)\">Ça y est!"
		"ep_01.al_postcore_atwindow_new04" = "<font color=\"rgb(255,212,255)\">Le système d'encerclement est en place."
		"ep_01.al_postcore_atwindow_new05" = "<font color=\"rgb(255,212,255)\">Ça ne va pas durer longtemps, mais on va gagner du temps."
		"ep_01.al_postcore_downloaddone01" = "<font color=\"rgb(255,212,255)\">J'ai copié la transmission."
		"ep_01.al_postcore_downloaddone02" = "<font color=\"rgb(255,212,255)\">Et elle est là."
		"ep_01.al_postcore_downloaddone03" = "<font color=\"rgb(255,212,255)\">Maintenant, on fiche le camp."
		"ep_01.al_postcore_exitelev01" = "<font color=\"rgb(255,212,255)\">J'ai trouvé un ascenseur."
		"ep_01.al_postcore_exitelev02" = "<font color=\"rgb(255,212,255)\">C'est par là."
		"ep_01.al_postcore_exitelev03" = "<font color=\"rgb(255,212,255)\">Allez!"
		"ep_01.al_postcore_feltthat01" = "<font color=\"rgb(255,212,255)\">Oh oh."
		"ep_01.al_postcore_feltthat02" = "<font color=\"rgb(255,212,255)\">Je crois qu'ils l'ont détecté."
		"ep_01.al_postcore_feltthat03" = "<font color=\"rgb(255,212,255)\">Ils ne veulent vraiment pas qu'on leur prenne ça."
		"ep_01.al_postcore_getin" = "<font color=\"rgb(255,212,255)\">Montez!"
		"ep_01.al_postcore_gravgun01" = "<font color=\"rgb(255,212,255)\">Hé, le pistolet est redevenu normal."
		"ep_01.al_postcore_gravgun02" = "<font color=\"rgb(255,212,255)\">Dommage... C'était bien tant que ça durait."
		"ep_01.al_postcore_hitch01" = "<font color=\"rgb(255,212,255)\">Cet ascenseur va nous amener à un quai."
		"ep_01.al_postcore_hitch02" = "<font color=\"rgb(255,212,255)\">Si on peut prendre un train, on sortira directement de la ville."
		"ep_01.al_postcore_hurry01" = "<font color=\"rgb(255,212,255)\">Vite, Gordon!"
		"ep_01.al_postcore_hurry02" = "<font color=\"rgb(255,212,255)\">Par ici!"
		"ep_01.al_postcore_hurry03" = "<font color=\"rgb(255,212,255)\">Par-là."
		"ep_01.al_postcore_hurry04" = "<font color=\"rgb(255,212,255)\">Courez!"
		"ep_01.al_postcore_mail" = "<font color=\"rgb(255,212,255)\">Ah, ils ne veulent vraiment pas que l'on lise leur courrier."
		"ep_01.al_postcore_meanwhile" = "<font color=\"rgb(255,212,255)\">Il y a autre chose."
		"ep_01.al_postcore_sideeffect01" = "<font color=\"rgb(255,212,255)\">Pendant que vous étiez parti, j'ai fouillé dans les données."
		"ep_01.al_postcore_sideeffect02" = "<font color=\"rgb(255,212,255)\">Ils voulaient amorcer une réaction en chaîne."
		"ep_01.al_postcore_sideeffect03" = "<font color=\"rgb(255,212,255)\">La destruction de la Citadelle n'est qu'un effet secondaire."
		"ep_01.al_postcore_sideeffect04" = "<font color=\"rgb(255,212,255)\">Maintenant qu'on a détruit le réacteur de Breen, c'est leur seul moyen d'envoyer une transmission chez eux."
		"ep_01.al_postcore_sideeffect05" = "<font color=\"rgb(255,212,255)\">Je ne sais pas ce que contient la transmission, mais c'est si important qu'ils veulent sacrifier la Citadelle pour l'envoyer."
		"ep_01.al_postcore_sideeffect06" = "<font color=\"rgb(255,212,255)\">Il faut tout de suite l'envoyer à mon père et au Dr Kleiner."
		"ep_01.al_postcore_sideeffect07" = "<font color=\"rgb(255,212,255)\">J'ai téléchargé une copie."
		"ep_01.al_postcore_sideeffect08" = "<font color=\"rgb(255,212,255)\">Je ne sais pas ce que c'est,"
		"ep_01.al_postcore_sideeffect09" = "<font color=\"rgb(255,212,255)\">mais je crains que ce soient de mauvaises nouvelles."
		"ep_01.al_postcore_something" = "<font color=\"rgb(255,212,255)\">J'ai l'impression qu'ils ne veulent pas que l'on découvre le contenu de la transmission."
		"ep_01.al_postcore_takealook01" = "<font color=\"rgb(255,212,255)\">C'est Judith."
		"ep_01.al_postcore_takealook02" = "<font color=\"rgb(255,212,255)\">Jetez un oeil."
		"ep_01.al_postcore_trouble01" = "<font color=\"rgb(255,212,255)\">Elle a de gros problèmes."
		"ep_01.al_postcore_trouble02" = "<font color=\"rgb(255,212,255)\">Il faut amener ça et la transmission à Papa."
		"ep_01.al_postcore_trouble03" = "<font color=\"rgb(255,212,255)\">Il saura quoi en faire."
		"ep_01.al_postcore_whereisshe" = "<font color=\"rgb(255,212,255)\">Où peut-elle bien être?"
		"ep_01.al_random01" = "<font color=\"rgb(255,212,255)\">Oooouuuh..."
		"ep_01.al_random02" = "<font color=\"rgb(255,212,255)\">Bizarre."
		"ep_01.al_roller_cantinterrupt01" = "<font color=\"rgb(255,212,255)\">Une seconde!"
		"ep_01.al_roller_cantinterrupt02" = "<font color=\"rgb(255,212,255)\">Attendez!"
		"ep_01.al_roller_cantinterrupt03" = "<font color=\"rgb(255,212,255)\">Une seconde!"
		"ep_01.al_roller_cantinterrupt04" = "<font color=\"rgb(255,212,255)\">Je finis ça."
		"ep_01.al_roller_cantinterrupt05" = "<font color=\"rgb(255,212,255)\">Une minute."
		"ep_01.al_stalkcar_download01" = "<font color=\"rgb(255,212,255)\">Je ne sais pas ce qu'il y a sur cette copie, mais le fait qu'on l'ait ne leur plaît pas beaucoup."
		"ep_01.al_stalkcar_download02" = "<font color=\"rgb(255,212,255)\">Rien que ça, ça devrait intéresser Papa."
		"ep_01.al_stalkcar_download03" = "<font color=\"rgb(255,212,255)\">Vous savez, finalement, "
		"ep_01.al_stalkcar_download04" = "<font color=\"rgb(255,212,255)\">ce n'est pas si..."
		"ep_01.al_stalkcar_yougoahead" = "<font color=\"rgb(255,212,255)\">A-Allez-y."
		"ep_01.al_stalkers_anotherway01" = "<font color=\"rgb(255,212,255)\">On n'a pas le temps de chercher un autre chemin."
		"ep_01.al_stalkers_anotherway02" = "<font color=\"rgb(255,212,255)\">Comment allons-nous passer?"
		"ep_01.al_stalkers_disable01" = "<font color=\"rgb(255,212,255)\">Mince."
		"ep_01.al_stalkers_disable02" = "<font color=\"rgb(255,212,255)\">Je ne peux pas le désactiver."
		"ep_01.al_stalkers_disable03" = "<font color=\"rgb(255,212,255)\">Quelque chose..."
		"ep_01.al_stalkers_disable04" = "<font color=\"rgb(255,212,255)\">C'est ce stalker."
		"ep_01.al_stalkers_disable05" = "<font color=\"rgb(255,212,255)\">Il l'active de l'autre côté."
		"ep_01.al_stalkers_fielddown01" = "<font color=\"rgb(255,212,255)\">Eh bien, ils ne nous embêteront pas si on les laisse tranquilles."
		"ep_01.al_stalkers_fielddown02" = "<font color=\"rgb(255,212,255)\">Je vais désactiver ce champ, et..."
		"ep_01.al_stalkers_findmeone" = "<font color=\"rgb(255,212,255)\">Vous pouvez en trouver un, Gordon?"
		"ep_01.al_stalkers_findroller" = "<font color=\"rgb(255,212,255)\">Essayez de trouver un lamineur, Gordon."
		"ep_01.al_stalkers_getthrunow01" = "<font color=\"rgb(255,212,255)\">OK..."
		"ep_01.al_stalkers_getthrunow02" = "<font color=\"rgb(255,212,255)\">On peut passer maintenant."
		"ep_01.al_stalkers_good01" = "<font color=\"rgb(255,212,255)\">Oh, vous en avez trouvé un."
		"ep_01.al_stalkers_good02" = "<font color=\"rgb(255,212,255)\">Bien."
		"ep_01.al_stalkers_hm01" = "<font color=\"rgb(255,212,255)\">Des lamineurs."
		"ep_01.al_stalkers_hm02" = "<font color=\"rgb(255,212,255)\">Ca nous aiderait à sortir."
		"ep_01.al_stalkers_holditout" = "<font color=\"rgb(255,212,255)\">Passez-le-moi, je vais travailler dessus."
		"ep_01.al_stalkers_idea01" = "<font color=\"rgb(255,212,255)\">Vous voyez où vont les lamineurs?"
		"ep_01.al_stalkers_idea02" = "<font color=\"rgb(255,212,255)\">Je sais comment en utiliser un ici."
		"ep_01.al_stalkers_letitgo01" = "<font color=\"rgb(255,212,255)\">Lâchez-le."
		"ep_01.al_stalkers_letitgo02" = "<font color=\"rgb(255,212,255)\">Il fera le reste."
		"ep_01.al_stalkers_omg01" = "<font color=\"rgb(255,212,255)\">Oh, mon Dieu."
		"ep_01.al_stalkers_omg02" = "<font color=\"rgb(255,212,255)\">Des stalkers."
		"ep_01.al_stalkers_pitchit" = "<font color=\"rgb(255,212,255)\">Allez-y et jetez-le à travers le champ."
		"ep_01.al_stalkers_reason" = "<font color=\"rgb(255,212,255)\">Je n'aime pas faire ça, mais..."
		"ep_01.al_stalkers_thereitis" = "<font color=\"rgb(255,212,255)\">Voilà."
		"ep_01.al_stalkers_trick01" = "<font color=\"rgb(255,212,255)\">Papa m'a appris à réinitialiser le système de ciblage."
		"ep_01.al_stalkers_trick02" = "<font color=\"rgb(255,212,255)\">Un peu de courant où il faut,"
		"ep_01.al_stalkers_trick03" = "<font color=\"rgb(255,212,255)\">et il est de notre côté."
		"ep_01.al_stalkers_trick04" = "<font color=\"rgb(255,212,255)\">Il est plus instable, mais il aura le temps de détruire"
		"ep_01.al_stalkers_trick05" = "<font color=\"rgb(255,212,255)\">les stalkers."
		"ep_01.al_unstable01" = "<font color=\"rgb(255,212,255)\">Ça c'est de l'instabilité."
		"ep_01.al_unstable02" = "<font color=\"rgb(255,212,255)\">Je crois qu'on ne devrait pas rester par ici."
		"ep_01.al_van_drops" = "<font color=\"rgb(255,212,255)\">Oh, de toute façon, il n'y avait plus d'essence."
		"ep_01.al_vtex_behind" = "<font color=\"rgb(255,212,255)\">Je vous suis."
		"ep_01.al_vtex_imadeit" = "<font color=\"rgb(255,212,255)\">On a réussi!"
		"ep_01.al_vtex_omgcross" = "<font color=\"rgb(255,212,255)\">Oh merde... il faut qu'on traverse ça?"
		"ep_01.al_weaponstripper01" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_01.al_weaponstripper02" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qui se passe, ici!"
		"ep_01.al_allsostrange_new" = "<font color=\"rgb(255,212,255)\">C'est tellement étrange..."
		"ep_01.al_cellar_stilldunno01" = "<font color=\"rgb(255,212,255)\">Je ne sais toujours pas comment on s'en est sortis."
		"ep_01.al_cellar_stilldunno02" = "<font color=\"rgb(255,212,255)\">La dernière chose dont je me souviens, c'est..."
		"ep_01.al_cellar_stilldunno03" = "<font color=\"rgb(255,212,255)\">la chute de Breen,"
		"ep_01.al_cellar_stilldunno04" = "<font color=\"rgb(255,212,255)\">une grosse explosion, et "
		"ep_01.al_cellar_stilldunno05" = "<font color=\"rgb(255,212,255)\">les voix des Vorts."
		"ep_01.al_cellar_stilldunno06" = "<font color=\"rgb(255,212,255)\">Et puis, Chien m'a sortie des décombres."
		"ep_01.al_chasm_dogallright" = "<font color=\"rgb(255,212,255)\">Oh, Dieu merci."
		"ep_01.al_chasm_dogideas01" = "<font color=\"rgb(255,212,255)\">Eh bien, Chien."
		"ep_01.al_chasm_dogideas02" = "<font color=\"rgb(255,212,255)\">Qu'en penses-tu?"
		"ep_01.al_chasm_dogideas03" = "<font color=\"rgb(255,212,255)\">Tu as une idée?"
		"ep_01.al_chasm_getbackin" = "<font color=\"rgb(255,212,255)\">Dire qu'on essaie de retourner dans cet endroit."
		"ep_01.al_chasm_noteasy" = "<font color=\"rgb(255,212,255)\">Ca ne va pas être facile."
		"ep_01.al_chasm_nothelpful01" = "<font color=\"rgb(255,212,255)\">OK, Chien."
		"ep_01.al_chasm_nothelpful02" = "<font color=\"rgb(255,212,255)\">Ca ne nous aide pas."
		"ep_01.al_chasm_scanner01" = "<font color=\"rgb(255,212,255)\">Hé, un scanner!"
		"ep_01.al_chasm_scanner02" = "<font color=\"rgb(255,212,255)\">Je n'en ai pas vu de la journée."
		"ep_01.al_chasm_scaredhell" = "<font color=\"rgb(255,212,255)\">J'ai vraiment eu peur!"
		"ep_01.al_chasm_staywithus01" = "<font color=\"rgb(255,212,255)\">Tu restes avec nous..."
		"ep_01.al_chasm_staywithus02" = "<font color=\"rgb(255,212,255)\">Et aide-nous à trouver un chemin."
		"ep_01.al_chasm_vertigo01" = "<font color=\"rgb(255,212,255)\">Ouaaouh!"
		"ep_01.al_chasm_vertigo02" = "<font color=\"rgb(255,212,255)\">Quel gouffre..."
		"ep_01.al_chasm_whatstakinghim" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que Chien fabrique?"
		"ep_01.al_chasm_wheredog01" = "<font color=\"rgb(255,212,255)\">Mais que..."
		"ep_01.al_chasm_wheredog02" = "<font color=\"rgb(255,212,255)\">Chien?"
		"ep_01.al_chasm_wheredog03" = "<font color=\"rgb(255,212,255)\">Chien, tu vas où?"
		"ep_01.al_cliff_afteryou01" = "<font color=\"rgb(255,212,255)\">Pffffff..."
		"ep_01.al_cliff_afteryou02" = "<font color=\"rgb(255,212,255)\">Après vous, Gordon."
		"ep_01.al_cliff_careful" = "<font color=\"rgb(255,212,255)\">Attention."
		"ep_01.al_itsmydad_new" = "<font color=\"rgb(255,212,255)\">C'est mon père."
		"ep_01.al_smashscanner01" = "<font color=\"rgb(255,212,255)\">Oui, deux précautions valent mieux qu'une!"
		"ep_01.al_smashscanner02" = "<font color=\"rgb(255,212,255)\">Bien, ça lui apprendra."
		"ep_01.al_tryingtoreachhim_new" = "<font color=\"rgb(255,212,255)\">Ça fait des heures qu'on tente de le joindre."
		"ep_01.al_waittillhehears_new01" = "<font color=\"rgb(255,212,255)\">Quand il saura qu'on vous a trouvé!"
		"ep_01.al_waittillhehears_new02" = "<font color=\"rgb(255,212,255)\">Allez!"
		"ep_01.al_combat_boom01" = "<font color=\"rgb(255,212,255)\">Boum!"
		"ep_01.al_combat_boom02" = "<font color=\"rgb(255,212,255)\">Bang!"
		"ep_01.al_combat_boom03" = "<font color=\"rgb(255,212,255)\">Bang!"
		"ep_01.al_combat_boom04" = "<font color=\"rgb(255,212,255)\">Et vlan!"
		"ep_01.al_combat_boom05" = "<font color=\"rgb(255,212,255)\">Et paf!"
		"ep_01.al_combat_boom06" = "<font color=\"rgb(255,212,255)\">Et vlan!"
		"ep_01.al_combat_boom07" = "<font color=\"rgb(255,212,255)\">Et boum!"
		"ep_01.al_combat_burnem01" = "<font color=\"rgb(255,212,255)\">Ouais! Brûlez-les!"
		"ep_01.al_combat_burnem02" = "<font color=\"rgb(255,212,255)\">Ha ha, brûlez-les!"
		"ep_01.al_combat_didiseethat" = "<font color=\"rgb(255,212,255)\">Je dois rêver!"
		"ep_01.al_combat_goodshooting01" = "<font color=\"rgb(255,212,255)\">Hé, joli tir!"
		"ep_01.al_combat_goodshooting02" = "<font color=\"rgb(255,212,255)\">Joli tir!"
		"ep_01.al_combat_goodshooting03" = "<font color=\"rgb(255,212,255)\">Super tir!"
		"ep_01.al_combat_goodshot01" = "<font color=\"rgb(255,212,255)\">Joli tir!"
		"ep_01.al_combat_goodshot02" = "<font color=\"rgb(255,212,255)\">Joli tir!"
		"ep_01.al_combat_goodshot03" = "<font color=\"rgb(255,212,255)\">Hé, super tir!"
		"ep_01.al_combat_goodshot04" = "<font color=\"rgb(255,212,255)\">Excellent tir!"
		"ep_01.al_combat_goodthinking01" = "<font color=\"rgb(255,212,255)\">Bien vu!"
		"ep_01.al_combat_goodthinking02" = "<font color=\"rgb(255,212,255)\">Ah, bien vu!"
		"ep_01.al_combat_goodthinking03" = "<font color=\"rgb(255,212,255)\">Bien vu!"
		"ep_01.al_combat_gradual01" = "<font color=\"rgb(255,212,255)\">Ils arrivent!"
		"ep_01.al_combat_gradual02" = "<font color=\"rgb(255,212,255)\">En voilà d'autres!"
		"ep_01.al_combat_gradual03" = "<font color=\"rgb(255,212,255)\">Il y en a encore!"
		"ep_01.al_combat_gradual04" = "<font color=\"rgb(255,212,255)\">En voilà d'autres!"
		"ep_01.al_combat_gradual_quiet_01" = "<font color=\"rgb(255,212,255)\">Ils arrivent!"
		"ep_01.al_combat_gradual_quiet_02" = "<font color=\"rgb(255,212,255)\">Ils arrivent!"
		"ep_01.al_combat_gradual_quiet_03" = "<font color=\"rgb(255,212,255)\">En voilà d'autres!"
		"ep_01.al_combat_gradual_quiet_04" = "<font color=\"rgb(255,212,255)\">Il y en a encore!"
		"ep_01.al_combat_gradual_quiet_05" = "<font color=\"rgb(255,212,255)\">Il y en a d'autres!"
		"ep_01.al_combat_gradual_quiet_06" = "<font color=\"rgb(255,212,255)\">Encore d'autres..."
		"ep_01.al_combat_iwantedthose01" = "<font color=\"rgb(255,212,255)\">Hé, je les voulais, ceux-là!"
		"ep_01.al_combat_iwantedthose02" = "<font color=\"rgb(255,212,255)\">Hé, ils étaient pour moi."
		"ep_01.al_combat_leavesome01" = "<font color=\"rgb(255,212,255)\">Laissez-m'en un peu!"
		"ep_01.al_combat_leavesome02" = "<font color=\"rgb(255,212,255)\">Hé, vous m'en laissez un peu!"
		"ep_01.al_combat_lightem" = "<font color=\"rgb(255,212,255)\">Cramez-les!"
		"ep_01.al_combat_mob01" = "<font color=\"rgb(255,212,255)\">Merde!"
		"ep_01.al_combat_mob02" = "<font color=\"rgb(255,212,255)\">Oh, merde!"
		"ep_01.al_combat_mob03" = "<font color=\"rgb(255,212,255)\">Bon sang!"
