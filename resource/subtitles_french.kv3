		"ep1_citizen.cit_pain13_male" = "[cri de douleur]"
		"ep1_citizen.cit_raidsoldiers_male" = "Des soldats!"
		"ep1_citizen.cit_reachtrain01_male" = "On a réussi!"
		"ep1_citizen.cit_reachtrain02_male" = "Faites bouger ce truc."
		"ep1_citizen.cit_reachtrain03_male" = "J'ai réussi! On peut y aller maintenant!"
		"ep1_citizen.cit_reachtrain04_male" = "Dépêchez-vous, partons d'ici!"
		"ep1_citizen.cit_reachtrain05_male" = "Foutons le camp d'ici!"
		"ep1_citizen.cit_remarks01_male" = "J'ai entendu dire que c'était bien mieux à la campagne."
		"ep1_citizen.cit_remarks02_male" = "Quoi qu'on fasse, les choses ne font qu'empirer."
		"ep1_citizen.cit_remarks03_male" = "C'était sûr ici, avant."
		"ep1_citizen.cit_remarks04_male" = "C'était un si joli quartier."
		"ep1_citizen.cit_remarks05_male" = "Je croyais presque que ça serait mieux maintenant."
		"ep1_citizen.cit_remarks06_male" = "On ressemble à de vrais pigeons, ici... Ou à des cibles de foire... En tout cas, c'est pas bon."
		"ep1_citizen.cit_remarks07_male" = "Tout ça pour que la science progresse."
		"ep1_citizen.cit_remarks08_male" = "Kleiner dit qu'on peut copuler maintenant. Comme si j'avais besoin de sa permission."
		"ep1_citizen.cit_remarks09_male" = "Le Dr Breen me manque pas, mais je regrette ses spectacles... vous vous souvenez quand il avait des jongleurs?"
		"ep1_citizen.cit_remarks10_male" = "Il paraît qu'ils mettent des bébés dans ces striders."
		"ep1_citizen.cit_remarks11_male" = "Tout ça, c'est à cause de Black Mesa."
		"ep1_citizen.cit_remarks12_male" = "J'ai rencontré Odessa Cubbage un jour. Quel idiot."
		"ep1_citizen.cit_remarks13_male" = "C'est à cause d'Odessa Cubbage."
		"ep1_citizen.cit_remarks14_male" = "Ils nous disent toujours que quelque chose va exploser. Mais cette fois, j'y crois pas."
		"ep1_citizen.cit_remarks15_male" = "Je ne vais nulle part. Non, Monsieur."
		"ep1_citizen.cit_remarks16_male" = "Oh non, encore le discours de Kleiner. EST-CE-QUE QUELQU'UN PEUT ARRÊTER ÇA!"
		"ep1_citizen.cit_remarks17_male" = "Entre nous, je ne fais pas du tout confiance aux Vortigaunts."
		"ep1_citizen.cit_remarks18_male" = "Qu'est-ce que c'est que ce temps?"
		"ep1_citizen.cit_remarks19_male" = "On les appelle peut-être des crabes, mais je vous le dis, ils n'ont pas vraiment le goût de crabe."
		"ep1_citizen.cit_remarks20_male" = "Ça a l'air fou, mais quelque part, je regrette un peu le Cartel."
		"ep1_citizen.cit_remarks21_male" = "Quelque fois j'ai l'impression que tout le monde est docteur sauf moi."
		"ep1_citizen.cit_remarks22_male" = "Quel est l'idiot qui a nommé Kleiner?"
		"ep1_citizen.cit_remarks23_male" = "On crève tous de faim et les crabes de tête de Kleiner se régalent sans doute de têtes succulentes."
		"ep1_citizen.cit_runforit_male" = "Vas-y!"
		"ep1_citizen.cit_safehouse_male" = "Le Cartel ne facilite pas les choses. On essaie de rassembler assez de monde pour forcer le passage jusqu'à la gare. Les gens se regroupent dans un abri tout près."
		"ep1_citizen.cit_shock01_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock02_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock03_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock04_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock05_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock06_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock07_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock08_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock09_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock10_male" = "[cri d'effroi]"
		"ep1_citizen.cit_shock11_male" = "[cri d'effroi]"
		"ep1_citizen.cit_squad_flee01_male" = "Vous avez entendu le crâne d'oeuf! Quittez la ville!"
		"ep1_citizen.cit_squad_flee02_male" = "On avance, on avance!"
		"ep1_citizen.cit_squad_flee03_male" = "Vous arrêtez pas. On doit arriver jusqu'à la gare."
		"ep1_citizen.cit_squad_flee04_male" = "Vite! À la gare!"
		"ep1_citizen.cit_squad_flee05_male" = "Les derniers trains s'en vont. Il faut avancer."
		"ep1_citizen.cit_stopburrows_male" = "Hé, vous là-bas! Bouchez ces terriers et on vous laissera passer."
		"ep1_citizen.cit_tellmeaboutit_male" = "M'en parlez pas. Ils essaient de nous piéger ici."
		"ep1_citizen.cit_thateverybody_male" = "Tout le monde est là?"
		"ep1_citizen.cit_thesearesomuchfun_male" = "[rire] Qu'est-ce que je m'amuse !"
		"ep1_citizen.cit_theyfoundus_male" = "Ils nous ont trouvés!"
		"ep1_citizen.cit_thisway_male" = "Par ici."
		"ep1_citizen.cit_twopeople_male" = "On m'a dit que deux personnes devaient monter. J'attends que vous soyez là tous les deux."
		"ep1_citizen.cit_youbet_male" = "Tu parles! On y va."
		"ep1_citizen.cit_youknowodessa_male" = "Hé, Dr Freeman, il paraît que vous étiez là quand Odessa Cubbage a abattu le premier hélico? Quel honneur pour vous... je suis fier de dire que j'ai rencontré quelqu'un qui connaissait Odessa Cubbage."
		
		"ep_01.al_advisor_breen" = "<font color=\"rgb(255,212,255)\">Breen!?"
		"ep_01.al_advisor_findmap" = "<font color=\"rgb(255,212,255)\">Oooooh..."
		"ep_01.al_advisor_gonenow" = "<font color=\"rgb(255,212,255)\">Oooh..."
		"ep_01.al_advisor_shaking" = "<font color=\"rgb(255,212,255)\">Oh..."
		"ep_01.al_anotherway" = "<font color=\"rgb(255,212,255)\">J'aimerais trouver un chemin pour contourner ces immeubles,"
		"ep_01.al_bridge_sneak01" = "<font color=\"rgb(255,212,255)\">Pour la discrétion, c'est raté."
		"ep_01.al_chasm_dogideas" = "<font color=\"rgb(255,212,255)\">Eh bien, Chien."
		"ep_01.al_chasm_nothelpful" = "<font color=\"rgb(255,212,255)\">OK, Chien."
		"ep_01.al_chasm_scanner" = "<font color=\"rgb(255,212,255)\">Hé, un scanner!"
		"ep_01.al_chasm_staywithus" = "<font color=\"rgb(255,212,255)\">Tu restes avec nous..."
		"ep_01.al_chasm_wheredog" = "<font color=\"rgb(255,212,255)\">Mais que..."
		"ep_01.al_cit_wishformap" = "<font color=\"rgb(255,212,255)\">Il faut trouver un moyen d'atteindre le noyau."
		"ep_01.al_citvista_lasttime" = "<font color=\"rgb(255,212,255)\">La dernière fois que je suis venue, je n'y voyais rien."
		"ep_01.al_citvista_noidea" = "<font color=\"rgb(255,212,255)\">C'est incroyable."
		"ep_01.al_comeherehelpme01" = "<font color=\"rgb(255,212,255)\">Vous me donnez un coup de main?"
		"ep_01.al_comeherehelpme02" = "<font color=\"rgb(255,212,255)\">Merde!"
		"ep_01.al_comeherehelpme03" = "<font color=\"rgb(255,212,255)\">GORDON!"
		"ep_01.al_control_heresyourelevator" = "<font color=\"rgb(255,212,255)\">Eh bien..."
		"ep_01.al_core_couldbeit" = "<font color=\"rgb(255,212,255)\">Je crois que ça y est, Gordon."
