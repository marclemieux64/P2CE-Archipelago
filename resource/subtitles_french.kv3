		"ep_01.al_bridge_nicethinking" = "<font color=\"rgb(255,212,255)\">Bien vu."
		"ep_01.al_bridge_noidea" = "<font color=\"rgb(255,212,255)\">Ces gars n'ont aucune idée de ce qui les attend."
		"ep_01.al_bridge_pupil01" = "<font color=\"rgb(255,212,255)\">Ouais, c'était une bonne idée."
		"ep_01.al_bridge_pupil02" = "<font color=\"rgb(255,212,255)\">Après tout, vous étiez l'un des meilleurs étudiants du Dr Kleiner."
		"ep_01.al_bridge_sneak" = "<font color=\"rgb(255,212,255)\">Pour la discrétion, c'est raté."
