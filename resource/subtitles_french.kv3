		"ep_02.al_launch_inhere03" = "<font color=\"rgb(255,212,255)\">On vous attend"
		"ep_02.al_launch_judith01" = "<font color=\"rgb(255,212,255)\">Ne t'inquiète pas..."
		"ep_02.al_launch_judith02" = "<font color=\"rgb(255,212,255)\">On ne reviendra pas sans elle."
		"ep_02.al_launch_lethimgo01" = "<font color=\"rgb(255,212,255)\">Non... Non! Lâchez-le! "
		"ep_02.al_launch_lethimgo02" = "<font color=\"rgb(255,212,255)\">Lâchez-le!"
		"ep_02.al_launch_lift01" = "<font color=\"rgb(255,212,255)\">Bon... Nous y revoilà."
		"ep_02.al_launch_lift02" = "<font color=\"rgb(255,212,255)\">On dirait qu'on passe le plus clair de nos vies dans les ascenseurs..."
