		"ep_02.sheckley_onedge02" = "<font color=\"rgb(251,218,194)\">On est à cran parce qu'on est envahis de fourmis-lions ici."
		"ep_02.sheckley_onelight" = "<font color=\"rgb(251,218,194)\">Un feu!"
		"ep_02.sheckley_onenoproblem" = "<font color=\"rgb(251,218,194)\">Pas de problème."
		"ep_02.sheckley_pickturretup" = "<font color=\"rgb(251,218,194)\">Ramassez votre tourelle!"
		"ep_02.sheckley_protectvort" = "<font color=\"rgb(251,218,194)\">Protégez le Vort!"
		"ep_02.sheckley_quietyou" = "<font color=\"rgb(251,218,194)\">Du calme, toi."
		"ep_02.sheckley_rightturret" = "<font color=\"rgb(251,218,194)\">Redressez cette tourelle!"
		"ep_02.sheckley_somesupplies" = "<font color=\"rgb(251,218,194)\">On a des réserves si vous en avez besoin. Des trousses de secours, des munitions. Des trucs du genre."
		"ep_02.sheckley_swarmatbreach" = "<font color=\"rgb(251,218,194)\">Invasion! Invasion à la brèche!"
		"ep_02.sheckley_theory01" = "<font color=\"rgb(251,218,194)\">Ouais, c'est une théorie que je préfère ne pas tester. "
		"ep_02.sheckley_theory02" = "<font color=\"rgb(251,218,194)\">Il ne nous reste plus que deux tourelles, "
		"ep_02.sheckley_theory03" = "<font color=\"rgb(251,218,194)\">Et encore, elles tiennent debout grâce à du fil de fer et du sparadrap. "
		"ep_02.sheckley_theory04" = "<font color=\"rgb(251,218,194)\">Remarquez, heureusement qu'on les a, "
		"ep_02.sheckley_theory05" = "<font color=\"rgb(251,218,194)\">mais je ne remettrais pas ma vie entre leurs mains."
		"ep_02.sheckley_thosevortswant" = "<font color=\"rgb(251,218,194)\">Me regardez pas, je sais pas ce qu'ils veulent ces Vorts."
		"ep_02.sheckley_threelights" = "<font color=\"rgb(251,218,194)\">Trois feux! On a trois feux!"
		"ep_02.sheckley_threeomg" = "<font color=\"rgb(251,218,194)\">Oh mon Dieu!"
		"ep_02.sheckley_threeswarm" = "<font color=\"rgb(251,218,194)\">Invasion!"
		"ep_02.sheckley_thrubreach" = "<font color=\"rgb(251,218,194)\">Ils viennent par la brèche!"
		"ep_02.sheckley_toomany" = "<font color=\"rgb(251,218,194)\">Y en a trop!"
		"ep_02.sheckley_training01" = "<font color=\"rgb(251,218,194)\">Ce capteur s'allume si une fourmi-lion pénètre dans ce tunnel."
		"ep_02.sheckley_training02" = "<font color=\"rgb(251,218,194)\">Plus de feux: plus de fourmis-lions."
		"ep_02.sheckley_training03" = "<font color=\"rgb(251,218,194)\">Quand le feu s'allume, on place quelques tourelles devant le tunnel. "
		"ep_02.sheckley_training04" = "<font color=\"rgb(251,218,194)\">Pas compliqué, hein, Doc?"
		"ep_02.sheckley_trainingnags01" = "<font color=\"rgb(251,218,194)\">Hé, Freeman, venez par ici."
		"ep_02.sheckley_trainingnags02" = "<font color=\"rgb(251,218,194)\">Hé, Doc! Venez ici."
		"ep_02.sheckley_trainingnags03" = "<font color=\"rgb(251,218,194)\">Vous avez fini de zieuter? Il faut vraiment qu'on se prépare."
		"ep_02.sheckley_trainingnags04" = "<font color=\"rgb(251,218,194)\">Je suis sérieux, Doc. Je dois vous montrer comment fonctionne le système défensif avant la prochaine attaque."
		"ep_02.sheckley_trainingnags05" = "<font color=\"rgb(251,218,194)\">Hé Griggs, tu pourrais montrer au Dr Freeman là où on stocke les munitions?"
		"ep_02.sheckley_tunnelpanic_01" = "<font color=\"rgb(251,218,194)\">Oh, merde. Tout est allumé. Prenez un tunnel!"
		"ep_02.sheckley_tunnelpanic_02" = "<font color=\"rgb(251,218,194)\">Tout est allumé. Prenez un tunnel!"
		"ep_02.sheckley_turretbroke" = "<font color=\"rgb(251,218,194)\">Ahh! La dernière tourelle vient de lâcher!"
		"ep_02.sheckley_turretdown01" = "<font color=\"rgb(251,218,194)\">Tourelle en panne!"
		"ep_02.sheckley_turretdown02" = "<font color=\"rgb(251,218,194)\">Une des tourelles s'est faite dégommer."
		"ep_02.sheckley_turretfeet" = "<font color=\"rgb(251,218,194)\">Il faut redresser ces tourelles!"
		"ep_02.sheckley_turretsturrets" = "<font color=\"rgb(251,218,194)\">Des tourelles! Des tourelles!"
		"ep_02.sheckley_twolights" = "<font color=\"rgb(251,218,194)\">Deux feux."
		"ep_02.sheckley_twothatmeans" = "<font color=\"rgb(251,218,194)\">Ça veut dire deux ou trois, hein?"
		"ep_02.sheckley_underest" = "<font color=\"rgb(251,218,194)\">Je crois qu'on s'est trompés."
		"ep_02.sheckley_vortintrouble" = "<font color=\"rgb(251,218,194)\">Il faut aider le Vort!"
		"ep_02.sheckley_vortsaidonway01" = "<font color=\"rgb(251,218,194)\">Le Vortigaunt a dit qu'il allait venir. "
		"ep_02.sheckley_vortsaidonway02" = "<font color=\"rgb(251,218,194)\">Dr Freeman, Alyx Vance est là-bas."
		"ep_02.sheckley_vortsaidonway03" = "<font color=\"rgb(251,218,194)\">Le Vort essaye de la retaper."
		"ep_02.sheckley_vortscalling" = "<font color=\"rgb(251,218,194)\">Les Vorts vous appellent."
		"ep_02.sheckley_vortswantyou" = "<font color=\"rgb(251,218,194)\">Ah, je crois que les Vorts vous réclament."
		"ep_02.sheckley_watchall" = "<font color=\"rgb(251,218,194)\">Il faut surveiller tous les tunnels, Freeman!"
		"ep_02.sheckley_watchvorts_01" = "<font color=\"rgb(251,218,194)\">Heureusement qu'ils sont avec nous."
		"ep_02.sheckley_watchvorts_02" = "<font color=\"rgb(251,218,194)\">Comme ils foncent!"
		"ep_02.sheckley_watchvorts_03" = "<font color=\"rgb(251,218,194)\">Griggsy, ne t'approche pas de l'éclair vert."
		"ep_02.sheckley_watchvorts_04" = "<font color=\"rgb(251,218,194)\">Bouffez la vortessence, bande de sales fourmis!"
		"ep_02.sheckley_wecandothis" = "<font color=\"rgb(251,218,194)\">Encore des feux, on peut le faire."
		"ep_02.sheckley_wegot_12_01" = "<font color=\"rgb(251,218,194)\">On a le 12!"
		"ep_02.sheckley_wegot_12_02" = "<font color=\"rgb(251,218,194)\">On va prendre le 12!"
		"ep_02.sheckley_wegot_24_01" = "<font color=\"rgb(251,218,194)\">On a le 24!"
		"ep_02.sheckley_wegot_24_02" = "<font color=\"rgb(251,218,194)\">On va prendre le 24!"
		"ep_02.sheckley_wegot_36_01" = "<font color=\"rgb(251,218,194)\">On a le 36!"
		"ep_02.sheckley_wegot_36_02" = "<font color=\"rgb(251,218,194)\">On va prendre le 36!"
		"ep_02.sheckley_wegot_breach_01" = "<font color=\"rgb(251,218,194)\">On a la brèche!"
		"ep_02.sheckley_wegot_breach_02" = "<font color=\"rgb(251,218,194)\">On va prendre la brèche!"
		"ep_02.sheckley_whysomany" = "<font color=\"rgb(251,218,194)\">Pourquoi y en a-t-il tant?"
		"ep_02.sheckley_youtake_12_01" = "<font color=\"rgb(251,218,194)\">Hé Doc, couvrez le 12!"
		"ep_02.sheckley_youtake_12_02" = "<font color=\"rgb(251,218,194)\">Vous gérez le 12, Doc!"
		"ep_02.sheckley_youtake_24_01" = "<font color=\"rgb(251,218,194)\">Hé Doc, couvrez le 24!"
		"ep_02.sheckley_youtake_24_02" = "<font color=\"rgb(251,218,194)\">Vous gérez le 24, Doc!"
		"ep_02.sheckley_youtake_36_01" = "<font color=\"rgb(251,218,194)\">Hé Doc, couvrez le 36!"
		"ep_02.sheckley_youtake_36_02" = "<font color=\"rgb(251,218,194)\">Vous gérez le 36, Doc!"
		"ep_02.sheckley_youtake_breach_01" = "<font color=\"rgb(251,218,194)\">Hé Doc, couvrez la brèche!"
		"ep_02.sheckley_youtake_breach_02" = "<font color=\"rgb(251,218,194)\">Vous gérez la brèche, Doc!"
		"ep_02.sheckley_youturrets" = "<font color=\"rgb(251,218,194)\">Dr Freeman, vous vous occupez de ces tourelles."
		"ep_02.rebc_chop_bootsmysize4" = "Vous croyez que ces bottes vont m'aller?"
		"ep_02.rebc_chop_hit01" = "Retour à l'envoyeur."
		"ep_02.rebc_chop_hit02" = "Ça, ça va laisser des traces."
		"ep_02.rebc_chop_hit03" = "Doc, vous montez une clinique."
		"ep_02.rebc_chop_hit04" = "Et si vous y goûtiez un petit peu aussi."
		"ep_02.rebc_chop_shipdown01" = "C'est fini mais ça continue de crier!"
		"ep_02.rebc_chop_shipdown02" = "Il faut reconnaître que le Cartel est fortiche, quand même. Ce sont des adversaires coriaces, la grande classe."
		"ep_02.reb_tvwatching_01" = "Hé, j'étais en train de regarder!"
		"ep_02.reb_tvwatching_02" = "Merci, Freeman."
		"ep_02.reb_tvwatching_03" = "[soupir]"
		"ep_02.reb_tvwatching_04" = "Je déteste ma vie."
		"ep_02.vort_03_urgent_idle_01" = "<font color=\"rgb(188,241,174)\">Le fil qui retient l'Alyx Vance à la vie se fait plus ténu. "
		"ep_02.vort_03_urgent_idle_02" = "<font color=\"rgb(188,241,174)\">Faisons vite, Freeman. "
		"ep_02.vort_03_urgent_idle_03" = "<font color=\"rgb(188,241,174)\">Il faut nous presser."
		"ep_02.vort_03_urgent_idle_04" = "<font color=\"rgb(188,241,174)\">La vie de l'Alyx Vance dépend de notre réussite."
		"ep_02.vort_03_urgent_idle_05" = "<font color=\"rgb(188,241,174)\">Je sens qu'elle nous échappe."
		"ep_02.vort_03_urgent_idle_06" = "<font color=\"rgb(188,241,174)\">En avant, Freeman!"
		"ep_02.vort_03_urgent_idle_07" = "<font color=\"rgb(188,241,174)\">L'Alyx Vance ne peut pas rester charnelle beaucoup plus longtemps."
		"ep_02.vort_03_urgent_idle_08" = "<font color=\"rgb(188,241,174)\">Il faut nous hâter. "
		"ep_02.vort_04_elevator_descend_01" = "<font color=\"rgb(188,241,174)\">Je descends!"
		"ep_02.vort_04_elevator_descend_02" = "<font color=\"rgb(188,241,174)\">Attendez un instant, Freeman, que nous continuions ensemble!"
		"ep_02.vort_04_enter_elevator_01" = "<font color=\"rgb(188,241,174)\">Freeman!"
		"ep_02.vort_04_enter_elevator_02" = "<font color=\"rgb(188,241,174)\">Là!"
		"ep_02.vort_04_enter_elevator_03" = "<font color=\"rgb(188,241,174)\">Appelez l'ascenseur!"
		"ep_02.vort_acid_01" = "<font color=\"rgb(188,241,174)\">Attention, Freeman, de l'acide!"
		"ep_02.vort_acid_02" = "<font color=\"rgb(188,241,174)\">Ils brûlent la chair!"
		"ep_02.vort_antlions_arrive_01" = "<font color=\"rgb(188,241,174)\">Des fourmis-lions!"
		"ep_02.vort_antlions_arrive_02" = "<font color=\"rgb(188,241,174)\">Les fourmis-lions approchent!"
		"ep_02.vort_basket_puzzle_01" = "<font color=\"rgb(188,241,174)\">Il semblerait que cela ait eu de l'effet."
		"ep_02.vort_basket_puzzle_02" = "<font color=\"rgb(188,241,174)\">Le plan de Freeman fonctionne!"
		"ep_02.vort_basket_puzzle_03" = "<font color=\"rgb(188,241,174)\">Continuez de la sorte, Freeman."
		"ep_02.vort_basket_success_01" = "<font color=\"rgb(188,241,174)\">Bien joué. "
		"ep_02.vort_basket_success_02" = "<font color=\"rgb(188,241,174)\">La voie est libre. "
		"ep_02.vort_basket_success_03" = "<font color=\"rgb(188,241,174)\">Il faut nous dépêcher! "
		"ep_02.vort_breakweb01" = "<font color=\"rgb(188,241,174)\">D'autres moins chanceux de votre espèce ont dû s'abriter ici."
		"ep_02.vort_breakweb02" = "<font color=\"rgb(188,241,174)\">Le malheur de ceux-là fait notre bonheur."
		"ep_02.vort_breakweb03" = "<font color=\"rgb(188,241,174)\">Triste loterie..."
		"ep_02.vort_bridge_attempt" = "<font color=\"rgb(188,241,174)\">On dirait qu'ils ont essayé de s'enfuir, mais ne sont allés plus loin que l'abysse."
		"ep_02.vort_bridge_depleted01" = "<font color=\"rgb(188,241,174)\">Sa batterie est déchargée."
		"ep_02.vort_bridge_depleted02" = "<font color=\"rgb(188,241,174)\">L'arme est déchargée."
		"ep_02.vort_bridge_farewell" = "<font color=\"rgb(188,241,174)\">Vous de même! Et adieu,  ce fut un honneur!"
		"ep_02.vort_bridge_gofm01" = "<font color=\"rgb(188,241,174)\">Allez Freeman."
		"ep_02.vort_bridge_gofm02" = "<font color=\"rgb(188,241,174)\">Je prendrai soin de l'Alyx Vance."
		"ep_02.vort_bridge_gunlacks" = "<font color=\"rgb(188,241,174)\">Il est possible que je puisse alimenter cette arme."
		"ep_02.vort_bridge_honored" = "<font color=\"rgb(188,241,174)\">Nos liens sont naturels et n'exigent aucune sorte de gratitude."
		"ep_02.vort_bridge_host01" = "<font color=\"rgb(188,241,174)\">Je détecte de nombreux parasites dans les profondeurs."
		"ep_02.vort_bridge_host02" = "<font color=\"rgb(188,241,174)\">Les récents réfugiés n'avaient aucune expérience pour repousser les prédateurs communs."
		"ep_02.vort_bridge_hunt01" = "<font color=\"rgb(188,241,174)\">Je crains que des affaires plus urgentes requièrent notre attention: "
		"ep_02.vort_bridge_hunt02" = "<font color=\"rgb(188,241,174)\">des conseillers qui n'ont pas encore éclos. "
		"ep_02.vort_bridge_hunt03" = "<font color=\"rgb(188,241,174)\">Il faut veiller à ce que cela reste ainsi."
		"ep_02.vort_bridge_nogoodend01" = "<font color=\"rgb(188,241,174)\">Mais ils ne s'en sont pas sortis non plus."
		"ep_02.vort_bridge_nogoodend02" = "<font color=\"rgb(188,241,174)\">Les crabes de tête ont fait du tort aux deux groupes."
		"ep_02.vort_bridge_recommend" = "<font color=\"rgb(188,241,174)\">Nous recommandons le Freeman pour cette tâche."
		"ep_02.vort_bridge_takeupaim01" = "<font color=\"rgb(188,241,174)\">Cette condition ne durera pas si vous plongez dans les toxines en dessous. "
		"ep_02.vort_bridge_takeupaim02" = "<font color=\"rgb(188,241,174)\">Nous ferions bien de lui assurer une protection d'ici, pendant que le Freeman se frotte aux dangers de la fosse."
		"ep_02.vort_bridge_thismountgun" = "<font color=\"rgb(188,241,174)\">Cette arme peut se révéler fort utile."
		"ep_02.vort_bridge_thisroad" = "<font color=\"rgb(188,241,174)\">Cette route vous emmènera près de White Forest, mais n'oubliez pas que vous ne serez pas seuls."
		"ep_02.vort_canyon_advisor01" = "<font color=\"rgb(188,241,174)\">Ah oui, il s'agit d'un conseiller."
		"ep_02.vort_canyon_advisor02" = "<font color=\"rgb(188,241,174)\">Beaucoup ont été disséminés lors de la destruction de la Citadelle."
		"ep_02.vort_canyon_advisor03" = "<font color=\"rgb(188,241,174)\">Sans leur exécutif, ils vont mobiliser les forces locales jusqu'à ce que les liens soient rétablis avec le royaume des commandes."
		"ep_02.vort_canyon_enclavesentries01" = "<font color=\"rgb(188,241,174)\">Les humains ont une enclave sur les bords de ce canyon. "
		"ep_02.vort_canyon_enclavesentries02" = "<font color=\"rgb(188,241,174)\">Je ne vois pas leurs patrouilles."
		"ep_02.vort_canyon_farfetch" = "<font color=\"rgb(188,241,174)\">Une telle théorie est à peine exagérée."
		"ep_02.vort_canyon_guardianrage01" = "<font color=\"rgb(188,241,174)\">Le gardien est furieux, car nous avons volé l'extrait."
		"ep_02.vort_canyon_guardianrage02" = "<font color=\"rgb(188,241,174)\">S'il entrave notre progression, nous devrons le tuer."
		"ep_02.vort_canyon_podparade01" = "<font color=\"rgb(188,241,174)\">Oui et ils portent des Shu'ulathoi. Des conseillers, encore en incubateur."
		"ep_02.vort_canyon_podparade02" = "<font color=\"rgb(188,241,174)\">Ils rassemblent et unifient les forces éparpillées du Cartel."
		"ep_02.vort_canyon_podparade03" = "<font color=\"rgb(188,241,174)\">C'est pourquoi il faut les chasser et les tuer avant qu'ils n'éclosent et gagnent en puissance."
		"ep_02.vort_canyon_purpose" = "<font color=\"rgb(188,241,174)\">Ils avancent vers le nord avec force entrain."
		"ep_02.vort_canyon_puzzling" = "<font color=\"rgb(188,241,174)\">Etrange. Les patrouilles auraient dû nous détecter à présent."
		"ep_02.vort_canyon_reside01" = "<font color=\"rgb(188,241,174)\">Je connais des humains ayant un véhicule, non loin d'ici."
		"ep_02.vort_canyon_reside02" = "<font color=\"rgb(188,241,174)\">Ils comprendront l'urgence de notre requête."
		"ep_02.vort_canyon_towf" = "<font color=\"rgb(188,241,174)\">Je crains, à priori, vers White Forest."
		"ep_02.vort_combat_combined01" = "<font color=\"rgb(188,241,174)\">Dommage que la combi du Freeman ne le protège pas des dommages externes."
		"ep_02.vort_combat_combined02" = "<font color=\"rgb(188,241,174)\">Votre combi montre des signes de faiblesse, Freeman!"
		"ep_02.vort_extract_accompany" = "<font color=\"rgb(188,241,174)\">Maintenant, Freeman. Arrivez!"
		"ep_02.vort_extract_aciddamage01" = "<font color=\"rgb(188,241,174)\">Nous avons appris à exterminer les acides-lions à distance."
		"ep_02.vort_extract_aciddamage02" = "<font color=\"rgb(188,241,174)\">Méfiez-vous de leur jet caustique!"
		"ep_02.vort_extract_aciddamage03" = "<font color=\"rgb(188,241,174)\">Evitez tout contact, Freeman!"
		"ep_02.vort_extract_aciddamage04" = "<font color=\"rgb(188,241,174)\">Un nuisible explosif!"
		"ep_02.vort_extract_aciddamage05" = "<font color=\"rgb(188,241,174)\">Vous seriez mal avisé d'approcher de trop près un tel ennemi."
		"ep_02.vort_extract_aciddamage06" = "<font color=\"rgb(188,241,174)\">Gardez vos talents de mêlée pour des ennemis moins explosifs."
		"ep_02.vort_extract_acidinfo01" = "<font color=\"rgb(188,241,174)\">Attention, les acides-lions crachent à distance!"
		"ep_02.vort_extract_acidinfo02" = "<font color=\"rgb(188,241,174)\">Evitez leur jet corrosif!"
		"ep_02.vort_extract_acidinfo03" = "<font color=\"rgb(188,241,174)\">Une bave si corrosive qu'elle brûle."
		"ep_02.vort_extract_acidinfo04" = "<font color=\"rgb(188,241,174)\">Ils crachent leur acide de loin!"
		"ep_02.vort_extract_acidinfo05" = "<font color=\"rgb(188,241,174)\">Attention aux acides-lions. Leur jet corrosif permet de percer des voies dans la roche, mais il sert aussi à faire fuir les voleurs d'extrait comme nous."
		"ep_02.vort_extract_agreed" = "<font color=\"rgb(188,241,174)\">D'accord!"
		"ep_02.vort_extract_agreed02" = "<font color=\"rgb(188,241,174)\">D'accord!"
		"ep_02.vort_extract_ahyes" = "<font color=\"rgb(188,241,174)\">Ah oui!"
		"ep_02.vort_extract_almosthere" = "<font color=\"rgb(188,241,174)\">L'ascenseur, Freeman! Il est presque là!"
		"ep_02.vort_extract_amusing" = "<font color=\"rgb(188,241,174)\">Tout ceci est fort amusant. Néanmoins, n'oublions pas la gravité de notre tâche: guérir l'Alyx Vance."
		"ep_02.vort_extract_ancientguard" = "<font color=\"rgb(188,241,174)\">Ah. Le vieux gardien! Récupérer l'extrait ne va pas être une partie de plaisir."
		"ep_02.vort_extract_antsahead01" = "<font color=\"rgb(188,241,174)\">Attention, Freeman, quoique peu malignes, les fourmis-lions tendront une embuscade dès que possible."
		"ep_02.vort_extract_antsahead02" = "<font color=\"rgb(188,241,174)\">Elles sont tapies un peu plus loin!"
		"ep_02.vort_extract_antsahead03" = "<font color=\"rgb(188,241,174)\">Méfiez-vous à chaque tournant!"
		"ep_02.vort_extract_bond01" = "<font color=\"rgb(188,241,174)\">Vraiment, Freeman, bravo. "
		"ep_02.vort_extract_bond02" = "<font color=\"rgb(188,241,174)\">Vous possédez certains traits que l'on croyait exclusivement vortaux. "
		"ep_02.vort_extract_bond03" = "<font color=\"rgb(188,241,174)\">L'élevage de fourmis-lions était autrefois une pratique courante pour nous."
		"ep_02.vort_extract_bond04" = "<font color=\"rgb(188,241,174)\">Il s'exsude de ces créatures bien des composants précieux, mais c'est l'extrait qui est, de loin, le plus prisé."
		"ep_02.vort_extract_bond05" = "<font color=\"rgb(188,241,174)\">Il dissout les faux voiles qui divisent la vortessence."
		"ep_02.vort_extract_bond06" = "<font color=\"rgb(188,241,174)\">Vous verrez tout cela quand ---"
		"ep_02.vort_extract_bounty01" = "<font color=\"rgb(188,241,174)\">Ah, excellent. Une abondance d'extrait larvaire. "
		"ep_02.vort_extract_bounty02" = "<font color=\"rgb(188,241,174)\">Cela ne devrait prendre qu'un moment."
		"ep_02.vort_extract_bravely" = "<font color=\"rgb(188,241,174)\">Quel courage, Freeman! Quand vous atteindrez la salle inférieure, trouvez un moyen de me faire venir!"
		"ep_02.vort_extract_chairman" = "<font color=\"rgb(188,241,174)\">Une scène poignante. Un repos éternel. Voilà qui procure de paisibles pensées, n'est-ce pas?"
		"ep_02.vort_extract_constantobst" = "<font color=\"rgb(188,241,174)\">Quel est le prochain obstacle sur notre liste interminable?"
		"ep_02.vort_extract_counterintuitive" = "<font color=\"rgb(188,241,174)\">Contrairement à ce que notre intuition préconiserait, nous devrons monter pour atteindre le nectarium."
		"ep_02.vort_extract_covert" = "<font color=\"rgb(188,241,174)\">Ceci requiert une progression à couvert plutôt qu'une confrontation."
		"ep_02.vort_extract_densrundeep01" = "<font color=\"rgb(188,241,174)\">Freeman, attention. "
		"ep_02.vort_extract_densrundeep02" = "<font color=\"rgb(188,241,174)\">Les repaires des fourmis-lions sont profonds. "
		"ep_02.vort_extract_densrundeep03" = "<font color=\"rgb(188,241,174)\">Dans chaque nid, il y a un grand nectarium où les créatures stockent leur précieux extrait glandulaire.   "
		"ep_02.vort_extract_densrundeep04" = "<font color=\"rgb(188,241,174)\">L'espèce vort dispose d'une affinité antique avec cette sécrétion particulière et nous savons comment transmuter ses propriétés."
		"ep_02.vort_extract_densrundeep05" = "<font color=\"rgb(188,241,174)\">Mais la route est par essence périlleuse."
		"ep_02.vort_extract_densrundeep06" = "<font color=\"rgb(188,241,174)\">Votre aide est très appréciée."
		"ep_02.vort_extract_dire" = "<font color=\"rgb(188,241,174)\">Sublimité extrême!"
		"ep_02.vort_extract_donotkill" = "<font color=\"rgb(188,241,174)\">N'oubliez pas: ne tuez pas le gardien sinon l'extrait serait gâté!"
		"ep_02.vort_extract_dreamsdonotfollow01" = "<font color=\"rgb(188,241,174)\">Tant de caisses dans l'abysse."
		"ep_02.vort_extract_dreamsdonotfollow02" = "<font color=\"rgb(188,241,174)\">J'espère que nos rêves ne les suivent pas."
		"ep_02.vort_extract_elude" = "<font color=\"rgb(188,241,174)\">Le Freeman ne doit pas tuer le gardien! Ses hurlements gâteraient l'extrait!"
		"ep_02.vort_extract_emergency" = "<font color=\"rgb(188,241,174)\">-Attendez! L'Alyx Vance s'éteint... Il faut faire vite!"
		"ep_02.vort_extract_fallingtrap01" = "<font color=\"rgb(188,241,174)\">À quoi s'attendait le Freeman en allant là-bas?"
		"ep_02.vort_extract_fallingtrap02" = "<font color=\"rgb(188,241,174)\">Vraiment, le Freeman ne laisse rien au hasard."
		"ep_02.vort_extract_findaway01" = "<font color=\"rgb(188,241,174)\">Le Freeman va sûrement trouver un moyen d'activer cet ascenseur. "
		"ep_02.vort_extract_findaway02" = "<font color=\"rgb(188,241,174)\">La vie de l'Alyx Vance dépend de nous."
		"ep_02.vort_extract_findnectarium01" = "<font color=\"rgb(188,241,174)\">Vite, au nectarium!"
		"ep_02.vort_extract_findnectarium02" = "<font color=\"rgb(188,241,174)\">Je sens que l'extrait est tout près. Vite!"
		"ep_02.vort_extract_findnectarium03" = "<font color=\"rgb(188,241,174)\">Nous sommes sur le bon chemin pour arriver au nectarium."
		"ep_02.vort_extract_findnectarium04" = "<font color=\"rgb(188,241,174)\">Vous le sentez, Freeman? L'extrait? Le nectarium n'est pas loin."
		"ep_02.vort_extract_findnectarium05" = "<font color=\"rgb(188,241,174)\">Chaque pas nous rapproche du nectarium. Ne tardons pas."
		"ep_02.vort_extract_findnectarium06" = "<font color=\"rgb(188,241,174)\">En avant, Freeman! Vers le nectarium!"
		"ep_02.vort_extract_findnectarium07" = "<font color=\"rgb(188,241,174)\">Le chemin est sinueux mais nous sommes sûrs d'arriver au nectarium."
		"ep_02.vort_extract_finequality01" = "<font color=\"rgb(188,241,174)\">Des sécrétions de la meilleure qualité. "
		"ep_02.vort_extract_finequality02" = "<font color=\"rgb(188,241,174)\">Retournons auprès de l'Alyx Vance."
		"ep_02.vort_extract_flipants01" = "<font color=\"rgb(188,241,174)\">Nous formons une équipe admirable avec le Freeman."
		"ep_02.vort_extract_flipants02" = "<font color=\"rgb(188,241,174)\">Le Freeman est un compagnon estimable."
		"ep_02.vort_extract_flipants03" = "<font color=\"rgb(188,241,174)\">Nous travaillons bien ensemble!"
		"ep_02.vort_extract_flipants04" = "<font color=\"rgb(188,241,174)\">Habile manoeuvre!!"
		"ep_02.vort_extract_flipants05" = "<font color=\"rgb(188,241,174)\">Quel talent!"
		"ep_02.vort_extract_fmhurry" = "<font color=\"rgb(188,241,174)\">Le Freeman doit se hâter."
		"ep_02.vort_extract_fmitistime" = "<font color=\"rgb(188,241,174)\">Freeman, il est temps!"
		"ep_02.vort_extract_fmnotime" = "<font color=\"rgb(188,241,174)\">Pas de temps à perdre!"
		"ep_02.vort_extract_fortunately" = "<font color=\"rgb(188,241,174)\">Heureusement que nous avons le Freeman..."
		"ep_02.vort_extract_haltattend" = "<font color=\"rgb(188,241,174)\">Halte, Freeman! Et attention!"
		"ep_02.vort_extract_hardwork01" = "<font color=\"rgb(188,241,174)\">Le parfum de la mûre perfection se répand. "
		"ep_02.vort_extract_hardwork02" = "<font color=\"rgb(188,241,174)\">Suivez-moi, Freeman, pendant que je retrouve la source. "
		"ep_02.vort_extract_hardwork03" = "<font color=\"rgb(188,241,174)\">Vous avez fait le plus gros du travail en ouvrant l'accès à cette salle. "
		"ep_02.vort_extract_hardwork04" = "<font color=\"rgb(188,241,174)\">Vraiment, la vie de l'Alyx Vance est entre des mains expertes."
		"ep_02.vort_extract_hence" = "<font color=\"rgb(188,241,174)\">Alors, Freeman!"
		"ep_02.vort_extract_howdescend" = "<font color=\"rgb(188,241,174)\">Mais comment... allons-nous descendre?"
		"ep_02.vort_extract_humanmark" = "<font color=\"rgb(188,241,174)\">Il nous faut un humain..."
		"ep_02.vort_extract_imbibe" = "<font color=\"rgb(188,241,174)\">Rejoignez-nous pendant que nous absorbons l'extrait."
		"ep_02.vort_extract_injuriesdeep01" = "<font color=\"rgb(188,241,174)\">Ses blessures sont graves. "
		"ep_02.vort_extract_injuriesdeep02" = "<font color=\"rgb(188,241,174)\">Il va falloir s'immerger totalement dans la vortessence."
		"ep_02.vort_extract_joinmefm01" = "<font color=\"rgb(188,241,174)\">S'il vous plaît, Freeman. "
		"ep_02.vort_extract_joinmefm02" = "<font color=\"rgb(188,241,174)\">Rejoignez-moi."
		"ep_02.vort_extract_joinusfree" = "<font color=\"rgb(188,241,174)\">Rejoignez-nous, Freeman!"
		"ep_02.vort_extract_journeydeep01" = "<font color=\"rgb(188,241,174)\">Je vais faire le voyage pour aller chercher l'extrait au plus profond du nid, dans le nectarium sacré. "
		"ep_02.vort_extract_journeydeep02" = "<font color=\"rgb(188,241,174)\">Mais je ne pourrai jamais le ramener seul."
		"ep_02.vort_extract_keen01" = "<font color=\"rgb(188,241,174)\">Les fourmis-lions détectent notre présence. "
		"ep_02.vort_extract_keen02" = "<font color=\"rgb(188,241,174)\">Plus on avancera et plus elles seront agressives."
		"ep_02.vort_extract_laddertop" = "<font color=\"rgb(188,241,174)\">Ah! Aucune fosse n'est digne de ce nom sans un Freeman qui en ressort."
		"ep_02.vort_extract_larvalaroma" = "<font color=\"rgb(188,241,174)\">Ah. Une telle quantité de larves... un tel arôme enivrant."
		"ep_02.vort_extract_liftalone" = "<font color=\"rgb(188,241,174)\">Cet ascenseur est trop petit pour nous deux. Continuez seul. Je vous rejoindrai!"
		"ep_02.vort_extract_liftarrived" = "<font color=\"rgb(188,241,174)\">L'ascenseur est là! Allez vite!"
		"ep_02.vort_extract_liftmovesnot01" = "<font color=\"rgb(188,241,174)\">Le courant a été rétabli, mais l'ascenseur ne bouge toujours pas. "
		"ep_02.vort_extract_liftmovesnot02" = "<font color=\"rgb(188,241,174)\">Le Freeman doit pouvoir faire quelque chose d'autre!"
		"ep_02.vort_extract_liftnags01" = "<font color=\"rgb(188,241,174)\">L'ascenseur, Freeman!"
		"ep_02.vort_extract_liftnags02" = "<font color=\"rgb(188,241,174)\">L'ascenseur est là!"
		"ep_02.vort_extract_liftnags03" = "<font color=\"rgb(188,241,174)\">L'ascenseur vous attend, Freeman!"
		"ep_02.vort_extract_liftnags04" = "<font color=\"rgb(188,241,174)\">Vite, Freeman, faites monter l'ascenseur!"
		"ep_02.vort_extract_liftnags05" = "<font color=\"rgb(188,241,174)\">Vers l'ascenseur, Freeman! Ne m'attendez pas!"
		"ep_02.vort_extract_logic" = "<font color=\"rgb(188,241,174)\">Je décèle une lueur de logique dans les yeux du Freeman!"
		"ep_02.vort_extract_magnificently" = "<font color=\"rgb(188,241,174)\">Le Freeman a mené sa tâche admirablement!"
		"ep_02.vort_extract_makehaste" = "<font color=\"rgb(188,241,174)\">Dépêchez-vous!"
		"ep_02.vort_extract_merge" = "<font color=\"rgb(188,241,174)\">Fusionnez avec la vortessence!"
		"ep_02.vort_extract_nearness" = "<font color=\"rgb(188,241,174)\">La présence du gardien signale la proximité des rayons larvaires. Ils se trouvent près des jeunes."
		"ep_02.vort_extract_nocrates" = "<font color=\"rgb(188,241,174)\">Ces caisses étaient certainement sans valeur."
		"ep_02.vort_extract_notwise" = "<font color=\"rgb(188,241,174)\">Voilà qui n'était pas la décision la plus futée du Freeman."
		"ep_02.vort_extract_observefight" = "<font color=\"rgb(188,241,174)\">Voyez comme elles continuent le combat, sans se rendre compte de notre échappée."
		"ep_02.vort_extract_pharynx" = "<font color=\"rgb(188,241,174)\">Sécrétion miraculeuse!"
		"ep_02.vort_extract_pitythegen" = "<font color=\"rgb(188,241,174)\">Triste est le générateur qui a besoin d'un Vortigaunt pour fonctionner."
		"ep_02.vort_extract_promising" = "<font color=\"rgb(188,241,174)\">Le grand nombre de fourmis-lions est de bon augure. Cela signifie que nous trouverons l'extrait larvaire dans les profondeurs."
		"ep_02.vort_extract_puzzling01" = "<font color=\"rgb(188,241,174)\">Ah, une situation épineuse et énigmatique comme le Freeman aime à les résoudre. "
		"ep_02.vort_extract_puzzling02" = "<font color=\"rgb(188,241,174)\">Je vais observer avec impatience!"
		"ep_02.vort_extract_recalcitrance01" = "<font color=\"rgb(188,241,174)\">Freeman, il serait bon de dompter cet ascenseur récalcitrant pour pouvoir continuer."
		"ep_02.vort_extract_recalcitrance02" = "<font color=\"rgb(188,241,174)\">La vie de l'Alyx Vance est entre nos mains!"
		"ep_02.vort_extract_rejoinplayer01" = "<font color=\"rgb(188,241,174)\">Je suis avec vous, Freeman!"
		"ep_02.vort_extract_rejoinplayer02" = "<font color=\"rgb(188,241,174)\">N'ayez crainte, Freeman, je vous suis!"
		"ep_02.vort_extract_rejoinplayer03" = "<font color=\"rgb(188,241,174)\">Je suis le Freeman."
		"ep_02.vort_extract_reunite01" = "<font color=\"rgb(188,241,174)\">Ah, Freeman!"
		"ep_02.vort_extract_reunite02" = "<font color=\"rgb(188,241,174)\">Hé, Freeman."
		"ep_02.vort_extract_reunite03" = "<font color=\"rgb(188,241,174)\">Enchanté, Freeman."
		"ep_02.vort_extract_reunite04" = "<font color=\"rgb(188,241,174)\">Le Freeman nous a manqué."
		"ep_02.vort_extract_reunite05" = "<font color=\"rgb(188,241,174)\">Vraiment, Freeman. Notre séparation a été trop longue."
		"ep_02.vort_extract_savedcrates01" = "<font color=\"rgb(188,241,174)\">Le Freeman a l'esprit vif et agit avec célérité. "
		"ep_02.vort_extract_savedcrates02" = "<font color=\"rgb(188,241,174)\">Vous n'allez pas regretter d'avoir épargné ces caisses."
		"ep_02.vort_extract_secure" = "<font color=\"rgb(188,241,174)\">Continuons, confiants, dans l'espoir qu'un nid si grand nous procure une copieuse récolte d'extrait larvaire."
		"ep_02.vort_extract_sendup01" = "<font color=\"rgb(188,241,174)\">Freeman! Faites monter l'ascenseur!"
		"ep_02.vort_extract_sendup02" = "<font color=\"rgb(188,241,174)\">Je sens le Freeman, en bas!"
		"ep_02.vort_extract_sendup03" = "<font color=\"rgb(188,241,174)\">Activez l'ascenseur, que l'on se retrouve!"
		"ep_02.vort_extract_sendup04" = "<font color=\"rgb(188,241,174)\">Activez l'ascenseur!"
		"ep_02.vort_extract_sensor" = "<font color=\"rgb(188,241,174)\">Si ce capteur est réglé comme les autres, il est programmé pour détecter les fourmis-lions."
		"ep_02.vort_extract_shaft01" = "<font color=\"rgb(188,241,174)\">Ce puits rejoint la salle ci-dessus, où les miens maintiennent l'Alyx Vance en vie. "
		"ep_02.vort_extract_shaft02" = "<font color=\"rgb(188,241,174)\">Une fois qu'on aura l'extrait, nous les rejoindrons rapidement, du moins si l'on parvient à réparer l'ascenseur."
		"ep_02.vort_extract_sheerbulk01" = "<font color=\"rgb(188,241,174)\">La massivité de cet engin appelle à une solution de force brutale. "
		"ep_02.vort_extract_sheerbulk02" = "<font color=\"rgb(188,241,174)\">Mais ne négligez pas les détails petits et évidents."
		"ep_02.vort_extract_slipperyslope" = "<font color=\"rgb(188,241,174)\">Attention, Freeman! L'imprudence est une voie périlleuse!"
		"ep_02.vort_extract_strikeforth" = "<font color=\"rgb(188,241,174)\">Freeman, nous devons frapper fort!"
		"ep_02.vort_extract_summoned" = "<font color=\"rgb(188,241,174)\">Donc vous avez appelé l'ascenseur."
		"ep_02.vort_extract_theextract" = "<font color=\"rgb(188,241,174)\">L'extrait!"
		"ep_02.vort_extract_theextract02" = "<font color=\"rgb(188,241,174)\">L'extrait!"
		"ep_02.vort_extract_theextract03" = "<font color=\"rgb(188,241,174)\">L'extrait!"
		"ep_02.vort_extract_tothelift" = "<font color=\"rgb(188,241,174)\">Vers l'ascenseur, Freeman!"
		"ep_02.vort_extract_tothelift01" = "<font color=\"rgb(188,241,174)\">Vers l'ascenseur, Freeman!"
		"ep_02.vort_extract_tothelift02" = "<font color=\"rgb(188,241,174)\">Sauvez-vous!"
		"ep_02.vort_extract_tothelift03" = "<font color=\"rgb(188,241,174)\">J'ai la situation bien en main!"
		"ep_02.vort_extract_traces" = "<font color=\"rgb(188,241,174)\">De telles traces d'habitations anciennes m'attristent quelque part."
		"ep_02.vort_extract_vastnectarium" = "<font color=\"rgb(188,241,174)\">Ahhh! Je n'ai jamais vu de nectarium aussi vaste! L'extrait de ce nid sera de la plus grande qualité!"
		"ep_02.vort_extract_vibchasm01" = "<font color=\"rgb(188,241,174)\">Attention! De l'autre côté du gouffre! "
		"ep_02.vort_extract_vibchasm02" = "<font color=\"rgb(188,241,174)\">Cet énorme appareil répulsif va mettre fin aux incessantes attaques de fourmis-lions!"
		"ep_02.vort_extract_vibchasm03" = "<font color=\"rgb(188,241,174)\">Si le Freeman est d'accord, mettons-nous en quête de ce refuge."
		"ep_02.vort_extract_vibdevice" = "<font color=\"rgb(188,241,174)\">Un appareil vibratoire! Ils sont des plus efficaces pour repousser les fourmis-lions, comme doit s'en souvenir le Freeman."
		"ep_02.vort_extract_vibrespite" = "<font color=\"rgb(188,241,174)\">Grâce à cet appareil vibratoire, nos ennemis vont nous laisser un peu de répit."
		"ep_02.vort_extract_weapons01" = "<font color=\"rgb(188,241,174)\">Les armes du Freeman, quoique inférieures, devraient suffire pour la tâche. "
		"ep_02.vort_extract_weapons02" = "<font color=\"rgb(188,241,174)\">Si seulement elles étaient innées et inépuisables."
		"ep_02.vort_extract_weightlift" = "<font color=\"rgb(188,241,174)\">J'ai confiance: le Freeman va trouver le moyen d'ouvrir cette porte et nous pourrons continuer ensemble."
		"ep_02.vort_extract_weighty" = "<font color=\"rgb(188,241,174)\">C'est une grave question, bien adaptée à un physicien de votre trempe."
		"ep_02.vort_extract_wemustremain" = "<font color=\"rgb(188,241,174)\">Il faut survivre pour garder l'Alyx Vance en vie!"
		"ep_02.vort_extract_werequire" = "<font color=\"rgb(188,241,174)\">Il nous faut... de l'extrait larvaire."
		"ep_02.vort_extract_willfollow" = "<font color=\"rgb(188,241,174)\">Je suivrai le Freeman le mieux possible."
		"ep_02.vort_extract_wind" = "<font color=\"rgb(188,241,174)\">Le vent qui vient d'en bas émane un parfum d'extrait. Ce que nous recherchons se trouve au fond de cette fosse."
		"ep_02.vort_extract_wrongway01" = "<font color=\"rgb(188,241,174)\">Nous errons, Freeman!"
		"ep_02.vort_extract_wrongway02" = "<font color=\"rgb(188,241,174)\">Nous nous sommes trompés de route,  le nectarium est ailleurs."
		"ep_02.vort_extract_wrongway03" = "<font color=\"rgb(188,241,174)\">Le parfum d'extrait se dissipe!"
		"ep_02.vort_extract_wrongway04" = "<font color=\"rgb(188,241,174)\">Nous nous éloignons du nectarium. Prenons un autre chemin."
		"ep_02.vort_extract_wrongway05" = "<font color=\"rgb(188,241,174)\">Prenons un autre chemin... L'arôme est moins puissant ici."
		"ep_02.vort_extract_wrongway06" = "<font color=\"rgb(188,241,174)\">Ce n'est pas le chemin du nectarium."
		"ep_02.vort_extract_wrongway07" = "<font color=\"rgb(188,241,174)\">Il faut retourner sur nos pas et prendre un autre chemin."
		"ep_02.vort_extract_yescompanion01" = "<font color=\"rgb(188,241,174)\">Oui, prenez le Freeman! "
		"ep_02.vort_extract_yescompanion02" = "<font color=\"rgb(188,241,174)\">C'est un incomparable compagnon!"
		"ep_02.vort_extract_yesthefm01" = "<font color=\"rgb(188,241,174)\">Prenez le Freeman, oui!"
		"ep_02.vort_extract_yesthefm02" = "<font color=\"rgb(188,241,174)\">Oui, prenez le Freeman, ah oui!"
		"ep_02.vort_extract_youareonto" = "<font color=\"rgb(188,241,174)\">Oui, oui, je vois que vous avez une idée en tête!"
		"ep_02.vort_followvortnag_conver2_01" = "<font color=\"rgb(188,241,174)\">Non! Le fil de sa vie se dénoue, mais ne s'est pas encore rompu."
		"ep_02.vort_grp_agree01" = "<font color=\"rgb(188,241,174)\">C'est cela."
		"ep_02.vort_grp_agree02" = "<font color=\"rgb(188,241,174)\">D'accord!"
		"ep_02.vort_grp_agree03" = "<font color=\"rgb(188,241,174)\">Mmmm"
		"ep_02.vort_grp_agree04" = "<font color=\"rgb(188,241,174)\">Ah..."
		"ep_02.vort_grp_agree05" = "<font color=\"rgb(188,241,174)\">Oui."
		"ep_02.vort_grp_agree06" = "<font color=\"rgb(188,241,174)\">Certainement."
		"ep_02.vort_grp_agree07" = "<font color=\"rgb(188,241,174)\">Bien dit."
		"ep_02.vort_grp_agree08" = "<font color=\"rgb(188,241,174)\">Nous nous accordons sur ce point."
		"ep_02.vort_grp_greetings01" = "<font color=\"rgb(188,241,174)\">Salutations  "
		"ep_02.vort_grp_greetings02" = "<font color=\"rgb(188,241,174)\">C'est bien."
		"ep_02.vort_grp_greetings03" = "<font color=\"rgb(188,241,174)\">Mmmm..."
		"ep_02.vort_grp_greetings04" = "<font color=\"rgb(188,241,174)\">Ah..."
		"ep_02.vort_grp_greetings05" = "<font color=\"rgb(188,241,174)\">Oui..."
		"ep_02.vort_grubhealth01" = "<font color=\"rgb(188,241,174)\">Les petits sont assez appétissants."
		"ep_02.vort_grubhealth02" = "<font color=\"rgb(188,241,174)\">Les larves produisent les sphères vortales."
		"ep_02.vort_grubhealth03" = "<font color=\"rgb(188,241,174)\">Ne sous-estimez pas les sphères vortales."
		"ep_02.vort_grubs4health01" = "<font color=\"rgb(188,241,174)\">Ne négligez pas les sphères larvaires!"
		"ep_02.vort_grubs4health02" = "<font color=\"rgb(188,241,174)\">Un remède prêt à l'emploi est à portée de main, Freeman! Profitons des bienfaits de ces larves!"
		"ep_02.vort_grubs4health03" = "<font color=\"rgb(188,241,174)\">Freeman, vous avez l'air mal en point. Utilisez donc des sphères larvaires!"
		"ep_02.vort_guard_alyxshelter01" = "<font color=\"rgb(188,241,174)\">Abritez-vous près de l'appareil répulsif!"
		"ep_02.vort_guard_alyxshelter02" = "<font color=\"rgb(188,241,174)\">L'Alyx Vance sera en sécurité là où les vibrations sont les plus fortes."
		"ep_02.vort_guard_alyxshelter03" = "<font color=\"rgb(188,241,174)\">Une oasis vibratoire!"
		"ep_02.vort_guard_killit" = "<font color=\"rgb(188,241,174)\">Cette fois, vous pouvez le tuer sans crainte!"
		"ep_02.vort_guard_killit_nag01" = "<font color=\"rgb(188,241,174)\">Les cris de ce gardien ne menacent plus notre extrait. Tuez-le, Freeman!"
		"ep_02.vort_guard_killit_nag02" = "<font color=\"rgb(188,241,174)\">Freeman, nous ne pouvons poursuivre tant que ce gardien est en vie."
		"ep_02.vort_guard_killit_nag03" = "<font color=\"rgb(188,241,174)\">Le gardien nous barre la route, mais nous pouvons désormais le détruire."
		"ep_02.vort_guard_killit_nag04" = "<font color=\"rgb(188,241,174)\">Nous ne pourrons appeler l'ascenseur qu'une fois le gardien mort."
		"ep_02.vort_guard_killit_nag05" = "<font color=\"rgb(188,241,174)\">Si nous voulons aller de l'avant, il faut que le gardien meure."
		"ep_02.vort_guard_killit_nag06" = "<font color=\"rgb(188,241,174)\">Si nous voulons survivre, il faut que le gardien meure maintenant."
		"ep_02.vort_guard_killit_nag07" = "<font color=\"rgb(188,241,174)\">Tuez-le, Freeman!"
		"ep_02.vort_guard_killit_nag08" = "<font color=\"rgb(188,241,174)\">Tuez le gardien maintenant!"
		"ep_02.vort_guard_killit_nag09" = "<font color=\"rgb(188,241,174)\">Le gardien!"
		"ep_02.vort_guard_movetolift01" = "<font color=\"rgb(188,241,174)\">Venez. Le véhicule que nous voulons est dans le campement au dessus."
		"ep_02.vort_guard_movetolift02" = "<font color=\"rgb(188,241,174)\">Cet ascenseur nous mènera jusqu'au véhicule."
		"ep_02.vort_guard_surfacesighting" = "<font color=\"rgb(188,241,174)\">Le gardien!"
		"ep_02.vort_guard_welldone01" = "<font color=\"rgb(188,241,174)\">Bien joué, Freeman!"
		"ep_02.vort_guard_welldone02" = "<font color=\"rgb(188,241,174)\">Freeman! Vous achevez ces gardes avec force célérité!"
		"ep_02.vort_guard_welldone03" = "<font color=\"rgb(188,241,174)\">Ah, quel dommage que ce ne soit pas la saison des gardiens. Il n'y aura pas de phéropodes."
		"ep_02.vort_junc_ahfreeman" = "<font color=\"rgb(188,241,174)\">Ah. Freeman. C'est bien. "
		"ep_02.vort_junc_ahfreeman02" = "<font color=\"rgb(188,241,174)\">Ah, le Freeman. "
		"ep_02.vort_junc_almostvortal" = "<font color=\"rgb(188,241,174)\">Presque vortal, ce lien entre vous..."
		"ep_02.vort_junc_assistance01" = "<font color=\"rgb(188,241,174)\">L'Alyx Vance est entre la vie et la mort. "
		"ep_02.vort_junc_assistance02" = "<font color=\"rgb(188,241,174)\">Les miens sont encore loin. "
		"ep_02.vort_junc_assistance03" = "<font color=\"rgb(188,241,174)\">Pour l'heure, il ne faut pas nous déranger. "
		"ep_02.vort_junc_attendtoalyx" = "<font color=\"rgb(188,241,174)\">Il faut s'occuper de l'Alyx Vance. "
		"ep_02.vort_junc_badlyinjured01" = "<font color=\"rgb(188,241,174)\">Pendant un moment, vous l'avez été. "
		"ep_02.vort_junc_badlyinjured02" = "<font color=\"rgb(188,241,174)\">Un chasseur du Cartel vous a blessée gravement..."
		"ep_02.vort_junc_behold" = "<font color=\"rgb(188,241,174)\">Attention!"
		"ep_02.vort_junc_bye01" = "<font color=\"rgb(188,241,174)\">Adieu!"
		"ep_02.vort_junc_bye02" = "<font color=\"rgb(188,241,174)\">Soyez prudents!"
		"ep_02.vort_junc_bye03" = "<font color=\"rgb(188,241,174)\">Bon voyage!"
		"ep_02.vort_junc_closerfm" = "<font color=\"rgb(188,241,174)\">Plus près, Freeman!"
		"ep_02.vort_junc_donotmove" = "<font color=\"rgb(188,241,174)\">Pas un geste."
		"ep_02.vort_junc_ebbs" = "<font color=\"rgb(188,241,174)\">Elle s'éteint..."
		"ep_02.vort_junc_exhausted" = "<font color=\"rgb(188,241,174)\">Nous les avons éliminées pour l'instant."
		"ep_02.vort_junc_fmcomecloser01" = "<font color=\"rgb(188,241,174)\">Plus près, Freeman! "
		"ep_02.vort_junc_fmcomecloser02" = "<font color=\"rgb(188,241,174)\">L'Alyx Vance doit se raccrocher au train de la vie humaine."
		"ep_02.vort_junc_fmsignature01" = "<font color=\"rgb(188,241,174)\">Freeman..."
		"ep_02.vort_junc_fmsignature02" = "<font color=\"rgb(188,241,174)\">Approchez-vous..."
		"ep_02.vort_junc_fmsignature03" = "<font color=\"rgb(188,241,174)\">Vous faites partie de sa fréquence,"
		"ep_02.vort_junc_fmsignature04" = "<font color=\"rgb(188,241,174)\">il nous faut votre signature vortale."
		"ep_02.vort_junc_fmstandnear" = "<font color=\"rgb(188,241,174)\">Le Freeman doit être plus près."
		"ep_02.vort_junc_givemoretime" = "<font color=\"rgb(188,241,174)\">Cela vous donnera plus de temps. "
		"ep_02.vort_junc_immeasurable" = "<font color=\"rgb(188,241,174)\">Nous venons d'éviter une perte incommensurable."
		"ep_02.vort_junc_inamongus" = "<font color=\"rgb(188,241,174)\">Avec nous! Maintenant!"
		"ep_02.vort_junc_keephunting" = "<font color=\"rgb(188,241,174)\">Nous allons continuer de chasser les conseillers. "
		"ep_02.vort_junc_killedmanyyet01" = "<font color=\"rgb(188,241,174)\">Nous avons tué bien des fourmis-lions. "
		"ep_02.vort_junc_killedmanyyet02" = "<font color=\"rgb(188,241,174)\">Mais il en reste d'autres. "
		"ep_02.vort_junc_knit" = "<font color=\"rgb(188,241,174)\">Nous avons ressoudé les os broyés et restauré son circuit sanguin."
		"ep_02.vort_junc_liestill" = "<font color=\"rgb(188,241,174)\">Allongez-vous."
		"ep_02.vort_junc_loseherloseall" = "<font color=\"rgb(188,241,174)\">Si nous la perdons, nous perdons tout!"
		"ep_02.vort_junc_matterhours" = "<font color=\"rgb(188,241,174)\">Quelques heures."
		"ep_02.vort_junc_momentlonger" = "<font color=\"rgb(188,241,174)\">Une minute de plus..."
		"ep_02.vort_junc_momentlonger02" = "<font color=\"rgb(188,241,174)\">Encore un instant."
		"ep_02.vort_junc_myplace01" = "<font color=\"rgb(188,241,174)\">Ma place est ici. "
		"ep_02.vort_junc_myplace02" = "<font color=\"rgb(188,241,174)\">Il ne faut pas m'interrompre."
		"ep_02.vort_junc_nextmatter" = "<font color=\"rgb(188,241,174)\">Attaquons-nous à la prochaine urgence."
		"ep_02.vort_junc_nopulse01" = "<font color=\"rgb(188,241,174)\">Pas de pouls! "
		"ep_02.vort_junc_nopulse02" = "<font color=\"rgb(188,241,174)\">Son coeur s'est arrêté!"
		"ep_02.vort_junc_nothingchanged" = "<font color=\"rgb(188,241,174)\">A notre connaissance, il est encore à White Forest, à travailler au bouclier du portail."
		"ep_02.vort_junc_object" = "<font color=\"rgb(188,241,174)\">Il n'y a plus de temps. Les fourmis-lions approchent. "
		"ep_02.vort_junc_pathtowf" = "<font color=\"rgb(188,241,174)\">Venez, alors. Je vous indique la direction de White Forest."
		"ep_02.vort_junc_quicken" = "<font color=\"rgb(188,241,174)\">Oui... Il y a une excitation..."
		"ep_02.vort_junc_quietthem" = "<font color=\"rgb(188,241,174)\">Il faut les faire taire. "
		"ep_02.vort_junc_realms" = "<font color=\"rgb(188,241,174)\">Toutefois, c'est le Freeman qui a récupéré votre vortessence."
		"ep_02.vort_junc_rightroad" = "<font color=\"rgb(188,241,174)\">Soyez sans crainte. Nous vous mettrons sur la bonne voie."
		"ep_02.vort_junc_rise" = "<font color=\"rgb(188,241,174)\">Maintenant... essayez de vous lever doucement."
		"ep_02.vort_junc_stabilizing01" = "<font color=\"rgb(188,241,174)\">Elle se stabilise. "
		"ep_02.vort_junc_stabilizing02" = "<font color=\"rgb(188,241,174)\">Sa forme vortale a retrouvé son intégrité."
		"ep_02.vort_junc_stirs" = "<font color=\"rgb(188,241,174)\">Elle bouge!"
		"ep_02.vort_junc_strengthtoproceed" = "<font color=\"rgb(188,241,174)\">Si vous en avez la force, continuons."
		"ep_02.vort_junc_thealyxvance" = "<font color=\"rgb(188,241,174)\">L'Alyx Vance!"
		"ep_02.vort_junc_tosurface" = "<font color=\"rgb(188,241,174)\">Venez, Freeman. A la surface!"
		"ep_02.vort_junc_weavelife" = "<font color=\"rgb(188,241,174)\">Nous lions la vie du Freeman avec la sienne."
		"ep_02.vort_junc_weweredelayed" = "<font color=\"rgb(188,241,174)\">Notre retard est regrettable. "
		"ep_02.vort_mineshaft_warning01" = "<font color=\"rgb(188,241,174)\">Gare au faux pas."
		"ep_02.vort_mineshaft_warning02" = "<font color=\"rgb(188,241,174)\">Gare au faux pas."
		"ep_02.vort_mineshaft_warning03" = "<font color=\"rgb(188,241,174)\">Freeman, attention aux fosses."
		"ep_02.vort_playerahead01" = "<font color=\"rgb(188,241,174)\">Attendez un peu, Freeman! Jusqu'à ce que je tire rapidement!"
		"ep_02.vort_playerahead02" = "<font color=\"rgb(188,241,174)\">Freeman! "
		"ep_02.vort_prone_nag_01" = "<font color=\"rgb(188,241,174)\">Achevez-les, Freeman!"
		"ep_02.vort_prone_nag_02" = "<font color=\"rgb(188,241,174)\">Je les ai neutralisées."
		"ep_02.vort_prone_nag_03" = "<font color=\"rgb(188,241,174)\">Attaquez!"
		"ep_02.vort_rbed_altroute" = "<font color=\"rgb(188,241,174)\">Nos chemins se séparent, Freeman! Chassez les fourmis-lions!"
		"ep_02.vort_rbed_antlions" = "<font color=\"rgb(188,241,174)\">Ces fourmis-lions ne nous laisseront pas en paix."
		"ep_02.vort_rbed_awake" = "<font color=\"rgb(188,241,174)\">Debout! Levez-vous!"
		"ep_02.vort_rbed_byanotherpath" = "<font color=\"rgb(188,241,174)\">Vite, Freeman! Je l'emmènerai chez les miens par un autre chemin."
		"ep_02.vort_rbed_companions01" = "<font color=\"rgb(188,241,174)\">Les miens nous rencontreront dans un abri sous la surface."
		"ep_02.vort_rbed_companions02" = "<font color=\"rgb(188,241,174)\">Il faut vite l'y emmener. "
		"ep_02.vort_rbed_companions03" = "<font color=\"rgb(188,241,174)\">Je vais la stabiliser, si le Freeman nous offre sa protection."
		"ep_02.vort_rbed_distract" = "<font color=\"rgb(188,241,174)\">Le Freeman doit repousser les fourmis-lions. "
		"ep_02.vort_rbed_freeman" = "<font color=\"rgb(188,241,174)\">Freeman!"
		"ep_02.vort_rbed_freeman01" = "<font color=\"rgb(188,241,174)\">Ah, le Freeman! "
		"ep_02.vort_rbed_freeman02" = "<font color=\"rgb(188,241,174)\">Je suis heureux de vous voir indemne au moins!"
		"ep_02.vort_rbed_freeman03" = "<font color=\"rgb(188,241,174)\">Quant à l'Alyx Vance...son état est grave."
		"ep_02.vort_rbed_freeman04" = "<font color=\"rgb(188,241,174)\">Seul, je n'arriverai pas à la guérir."
		"ep_02.vort_rbed_freeman05" = "<font color=\"rgb(188,241,174)\">Je dois appeler les miens!"
		"ep_02.vort_rbed_intomines01" = "<font color=\"rgb(188,241,174)\">Faisons vite, Freeman. "
		"ep_02.vort_rbed_intomines02" = "<font color=\"rgb(188,241,174)\">De l'aide nous attend, dans les mines."
		"ep_02.vort_rbed_letsgo01a" = "<font color=\"rgb(188,241,174)\">Vite, Freeman. "
		"ep_02.vort_rbed_letsgo01b" = "<font color=\"rgb(188,241,174)\">Nos mains sont occupées."
		"ep_02.vort_rbed_letsgo01c" = "<font color=\"rgb(188,241,174)\">Détruisez tous les obstacles!"
		"ep_02.vort_rbed_letsgo02" = "<font color=\"rgb(188,241,174)\">Après vous, Freeman!"
		"ep_02.vort_rbed_letsgo03" = "<font color=\"rgb(188,241,174)\">En avant, Freeman. "
		"ep_02.vort_rbed_letsgo04a" = "<font color=\"rgb(188,241,174)\">Il faut nous hâter. "
		"ep_02.vort_rbed_letsgo04b" = "<font color=\"rgb(188,241,174)\">Son état est critique."
		"ep_02.vort_rbed_nomatter01" = "<font color=\"rgb(188,241,174)\">Peu importe!"
		"ep_02.vort_rbed_nomatter02" = "<font color=\"rgb(188,241,174)\">Nous prendrons un autre chemin!"
		"ep_02.vort_rbed_nomatter03" = "<font color=\"rgb(188,241,174)\">Nous comptons sur l'ingéniosité du Freeman pour nous rapprocher!"
		"ep_02.vort_rbed_presson" = "<font color=\"rgb(188,241,174)\">Vite, Freeman! Si vous le pouvez!"
		"ep_02.vort_rbed_stucklift" = "<font color=\"rgb(188,241,174)\">Le Freeman pourrait peut-être remettre en marche cet ascenseur."
		"ep_02.vort_rbed_thealyx" = "<font color=\"rgb(188,241,174)\">L'Alyx Vance!"
		"ep_02.vort_rbed_usecare" = "<font color=\"rgb(188,241,174)\">Soyez prudent, Freeman!"
		"ep_02.vort_rbed_vemotings01" = "<font color=\"rgb(188,241,174)\">[expression vortigèse de choc:]"
		"ep_02.vort_rbed_whatharm" = "<font color=\"rgb(188,241,174)\">Quel mal est survenu?"
		"ep_02.vort_separation_goodbye01" = "<font color=\"rgb(188,241,174)\">Freeman! Vous avez libéré notre voie, mais la vôtre est encombrée."
		"ep_02.vort_separation_goodbye02" = "<font color=\"rgb(188,241,174)\">Beaucoup de chemins mènent à ce carrefour ci-dessous, j'ai foi en votre capacité à nous y rejoindre."
		"ep_02.vort_separation_goodbye03" = "<font color=\"rgb(188,241,174)\">Sinon, votre sacrifice ne sera pas oublié."
		"ep_02.vort_separation_leave01" = "<font color=\"rgb(188,241,174)\">Freeman, l'entrée des mines est droit devant."
		"ep_02.vort_separation_leave02" = "<font color=\"rgb(188,241,174)\">Je ne peux pourfendre les fourmis-lions et maintenir l'Alyx en vie."
		"ep_02.vort_separation_leave03" = "<font color=\"rgb(188,241,174)\">Attirez leur colère pendant que je la mets à l'abri."
		"ep_02.vort_separation_nag01" = "<font color=\"rgb(188,241,174)\">Freeman, vous devez vous occuper des fourmis-lions."
		"ep_02.vort_separation_nag02" = "<font color=\"rgb(188,241,174)\">Freeman, allez à présent."
		"ep_02.vort_separation_success01" = "<font color=\"rgb(188,241,174)\">Bien joué, Freeman!"
		"ep_02.vort_separation_success02" = "<font color=\"rgb(188,241,174)\">Bravo!"
		"ep_02.vort_separation_success03" = "<font color=\"rgb(188,241,174)\">Continuez, Freeman!"
		"ep_02.vort_silo_admit" = "<font color=\"rgb(188,241,174)\">Le Magnusson m'a chargé de vous admettre dans le silo secondaire."
		"ep_02.vort_silo_ahalyx" = "<font color=\"rgb(188,241,174)\">Ah, l'Alyx Vance."
		"ep_02.vort_silo_freeman" = "<font color=\"rgb(188,241,174)\">Freeman!"
		"ep_02.vort_silo_honor" = "<font color=\"rgb(188,241,174)\">Si vous pouviez emmener le Freeman, je pourrais retourner à ma place d'honneur auprès du Magnusson."
		"ep_02.vort_silo_mag_brag01" = "<font color=\"rgb(188,241,174)\">Écoutez bien le Magnusson."
		"ep_02.vort_silo_mag_brag02" = "<font color=\"rgb(188,241,174)\">Le Magnusson dit vrai."
		"ep_02.vort_silo_mag_brag03" = "<font color=\"rgb(188,241,174)\">D'aussi sages propos n'ont jamais été tenus, à part peut-être par le Magnusson."
		"ep_02.vort_silo_mag_brag04" = "<font color=\"rgb(188,241,174)\">C'est une chance que de bénéficier des conseils du Magnusson à ce sujet."
		"ep_02.vort_silo_mag_brag05" = "<font color=\"rgb(188,241,174)\">Ce temps passé auprès du Magnusson représente certainement le plus bel instant de la vie du Freeman."
		"ep_02.vort_silo_mag_brag06" = "<font color=\"rgb(188,241,174)\">Bien dit. Le Magnusson a encore atteint le coeur du sujet."
		"ep_02.vort_silo_magbestsuited" = "<font color=\"rgb(188,241,174)\">Peut-être le Magnusson est-il le mieux à même de manier l'appareil Magnusson."
		"ep_02.vort_silo_magdidwell01" = "<font color=\"rgb(188,241,174)\">Freeman!"
		"ep_02.vort_silo_magdidwell02" = "<font color=\"rgb(188,241,174)\">Le Magnusson a bien fait de vous choisir pour cette tâche! "
		"ep_02.vort_silo_magdidwell03" = "<font color=\"rgb(188,241,174)\">Une fois de plus, son jugement s'avère irréprochable."
		"ep_02.vort_silo_maghonor01" = "<font color=\"rgb(188,241,174)\">C'est un honneur d'avoir été choisi par le Magnusson."
		"ep_02.vort_silo_maghonor02" = "<font color=\"rgb(188,241,174)\">Vraiment, l'esprit du Magnusson est une force de la nature."
		"ep_02.vort_silo_maghonor03" = "<font color=\"rgb(188,241,174)\">La vortessence est très présente chez le Magnusson."
		"ep_02.vort_silo_magrespected" = "<font color=\"rgb(188,241,174)\">Le Magnusson est très respecté."
		"ep_02.vort_silo_norefrigeration" = "<font color=\"rgb(188,241,174)\">L'appareil du Magnusson ne requiert aucune réfrigération."
		"ep_02.vort_silo_regrettablytrue" = "<font color=\"rgb(188,241,174)\">Malheureusement vrai."
		"ep_02.vort_silo_returntomag" = "<font color=\"rgb(188,241,174)\">Si vous pouviez emmener le Freeman, je pourrais retourner à ma place d'honneur auprès du Magnusson."
		"ep_02.vort_silo_thankstomag" = "<font color=\"rgb(188,241,174)\">Grâce au Magnusson."
		"ep_02.vort_silo_thisway01" = "<font color=\"rgb(188,241,174)\">Par ici et vite."
		"ep_02.vort_silo_thisway02" = "<font color=\"rgb(188,241,174)\">Vos pairs attendent."
		"ep_02.vort_silo_thisway03" = "<font color=\"rgb(188,241,174)\">Suivez, Freeman."
		"ep_02.vort_silo_thruhere" = "<font color=\"rgb(188,241,174)\">On peut atteindre le silo secondaire par ici."
		"ep_02.vort_squishgrub01" = "<font color=\"rgb(188,241,174)\">Ce n'est pas désagréable sous le pied, n'est-ce pas?"
		"ep_02.vort_squishgrub02" = "<font color=\"rgb(188,241,174)\">Ah, quel son et quelle sensation délectables."
		"ep_02.vort_squishgrub03" = "<font color=\"rgb(188,241,174)\">Les larves sont absolument... succulentes."
		"ep_02.vort_squishgrub04" = "<font color=\"rgb(188,241,174)\">Je vois que vous appréciez aussi les propriétés des sphères larvaires!"
		"ep_02.vort_turret_defendus" = "<font color=\"rgb(188,241,174)\">Défendez-nous!"
		"ep_02.vort_turret_helpcall01" = "<font color=\"rgb(188,241,174)\">Il nous faut de l'aide!"
		"ep_02.vort_turret_helpcall02" = "<font color=\"rgb(188,241,174)\">Défendez-moi!"
		"ep_02.vort_turret_helpcall03" = "<font color=\"rgb(188,241,174)\">Approchez!"
		"ep_02.vort_turret_helpcall04" = "<font color=\"rgb(188,241,174)\">On nous attaque!"
		"ep_02.vort_turret_helpcall05" = "<font color=\"rgb(188,241,174)\">Protégez-nous!"
		"ep_02.vort_turret_helpcall06" = "<font color=\"rgb(188,241,174)\">Il nous faut votre protection!"
		"ep_02.vort_turret_helpcall07" = "<font color=\"rgb(188,241,174)\">Eliminez ces fourmis-lions!"
		"ep_02.vort_turret_helpcall08" = "<font color=\"rgb(188,241,174)\">Si je meurs, l'Alyx Vance est perdue!"
		"ep_02.vort_turret_helpcall09" = "<font color=\"rgb(188,241,174)\">A moi, Freeman!"
		"ep_02.vort_turret_keepthemaway" = "<font color=\"rgb(188,241,174)\">Repoussez-les!"
		"ep_02.vort_turret_mustbestopped" = "<font color=\"rgb(188,241,174)\">Il faut les arrêter!"
		"ep_02.vort_turret_notinterrupt" = "<font color=\"rgb(188,241,174)\">Pas d'interruption!"
		"ep_02.vort_turret_protectalyx" = "<font color=\"rgb(188,241,174)\">Protégez l'Alyx Vance!"
		"ep_02.vort_turret_protectus" = "<font color=\"rgb(188,241,174)\">Protégez-nous!"
		"ep_02.vort_turret_use01" = "<font color=\"rgb(188,241,174)\">Ne nous dérangez pas!"
		"ep_02.vort_turret_use02" = "<font color=\"rgb(188,241,174)\">Pas d'interruption!"
		"ep_02.vort_turret_use03" = "<font color=\"rgb(188,241,174)\">Laissez-nous tranquille, nous maintenons en vie l'Alyx Vance."
		"ep_02.vort_tutor_custom01" = "<font color=\"rgb(188,241,174)\">Le Freeman ne sait-il pas frapper aux portes? "
		"ep_02.vort_tutor_custom02" = "<font color=\"rgb(188,241,174)\">Je pensais que c'était une coutume courante. "
		"ep_02.vort_tutor_deactive01" = "<font color=\"rgb(188,241,174)\">Pour la sécurité de la base, ces appareils sont désactivés."
		"ep_02.vort_tutor_deactive02" = "<font color=\"rgb(188,241,174)\">Ils ne peuvent pas exploser comme ceux que vous trouverez sur le terrain."
		"ep_02.vort_tutor_knock" = "<font color=\"rgb(188,241,174)\">Hm, je croyais que la coutume de frapper aux portes était universelle."
		"ep_02.vort_tutor_novelmethods" = "<font color=\"rgb(188,241,174)\">Puisque nous avons le temps, apprenez-moi vos méthodes de détection d'entrées."
		"npc_vortigaunt.above" = "<font color=\"rgb(188,241,174)\">Au-dessus."
		"npc_vortigaunt.abovefm" = "<font color=\"rgb(188,241,174)\">Au-dessus du Freeman."
		"npc_vortigaunt.acceptcharge" = "<font color=\"rgb(188,241,174)\">Acceptez une recharge. "
		"npc_vortigaunt.acceptenergy" = "<font color=\"rgb(188,241,174)\">Acceptez l'énergie. "
		"npc_vortigaunt.accompany" = "<font color=\"rgb(188,241,174)\">Avec joie nous vous suivons. "
		"npc_vortigaunt.advancefm" = "<font color=\"rgb(188,241,174)\">Avancez, Freeman."
		"npc_vortigaunt.alert" = "<font color=\"rgb(188,241,174)\">Alerte."
		"npc_vortigaunt.alert_soldiers" = "<font color=\"rgb(188,241,174)\">Des soldats!"
		"npc_vortigaunt.allfornow" = "<font color=\"rgb(188,241,174)\">C'est tout pour le moment. "
		"npc_vortigaunt.allinoneinall" = "<font color=\"rgb(188,241,174)\">Le Tout commun nous rassemble tous "
		"npc_vortigaunt.allowrecharge" = "<font color=\"rgb(188,241,174)\">Laissez-nous recharger vos cellules. "
		"npc_vortigaunt.allwecanspare" = "<font color=\"rgb(188,241,174)\">C'est tout ce que nous avons. "
		"npc_vortigaunt.allwehave" = "<font color=\"rgb(188,241,174)\">Toutes nos possessions sont vôtres. "
		"npc_vortigaunt.approaches" = "<font color=\"rgb(188,241,174)\">Quelque chose approche."
		"npc_vortigaunt.asound" = "<font color=\"rgb(188,241,174)\">Un bruit."
		"npc_vortigaunt.assent" = "<font color=\"rgb(188,241,174)\">Acceptez. "
		"npc_vortigaunt.behindfm" = "<font color=\"rgb(188,241,174)\">Derrière le Freeman."
		"npc_vortigaunt.behindyou" = "<font color=\"rgb(188,241,174)\">Derrière vous!"
		"npc_vortigaunt.below" = "<font color=\"rgb(188,241,174)\">En-dessous!"
		"npc_vortigaunt.belowfm" = "<font color=\"rgb(188,241,174)\">Sous le Freeman!"
		"npc_vortigaunt.beware" = "<font color=\"rgb(188,241,174)\">Prenez garde!"
		"npc_vortigaunt.bodyyours" = "<font color=\"rgb(188,241,174)\">Ce corps est à vos ordres. "
		"npc_vortigaunt.byvort" = "<font color=\"rgb(188,241,174)\">Par la vortessence!"
		"npc_vortigaunt.cannotfire" = "<font color=\"rgb(188,241,174)\">Nous ne pouvons tirer sans blesser le Freeman. "
		"npc_vortigaunt.caution" = "<font color=\"rgb(188,241,174)\">Attention! "
		"npc_vortigaunt.cautionfm" = "<font color=\"rgb(188,241,174)\">Attention, Freeman! "
		"npc_vortigaunt.cautionfm02" = "<font color=\"rgb(188,241,174)\">Prenez garde, Freeman!"
		"npc_vortigaunt.choicemade" = "<font color=\"rgb(188,241,174)\">Le choix est fait."
		"npc_vortigaunt.claimvort" = "<font color=\"rgb(188,241,174)\">Récupérons la vortessence!"
		"npc_vortigaunt.cordcut" = "<font color=\"rgb(188,241,174)\">Son cordon est coupé."
		"npc_vortigaunt.dedicate" = "<font color=\"rgb(188,241,174)\">Nous sommes dédiés à votre cause. "
		"npc_vortigaunt.done" = "<font color=\"rgb(188,241,174)\">Terminé "
		"npc_vortigaunt.downhere" = "<font color=\"rgb(188,241,174)\">N'hésitez pas."
		"npc_vortigaunt.downthere" = "<font color=\"rgb(188,241,174)\">Là-bas!"
		"npc_vortigaunt.dreamed" = "<font color=\"rgb(188,241,174)\">Nous rêvions de cet instant. "
		"npc_vortigaunt.empowerus" = "<font color=\"rgb(188,241,174)\">Donnez-nous la force! "
		"npc_vortigaunt.energyempower" = "<font color=\"rgb(188,241,174)\">Puisons son énergie. "
		"npc_vortigaunt.enough" = "<font color=\"rgb(188,241,174)\">Assez."
		"npc_vortigaunt.fearnotfm" = "<font color=\"rgb(188,241,174)\">N'ayez crainte, Freeman."
		"npc_vortigaunt.finished" = "<font color=\"rgb(188,241,174)\">Terminé."
		"npc_vortigaunt.fittingend" = "<font color=\"rgb(188,241,174)\">Cela finit bien."
		"npc_vortigaunt.fmaccompany" = "<font color=\"rgb(188,241,174)\">Que le Freeman veuille bien nous accompagner."
		"npc_vortigaunt.fmadvance" = "<font color=\"rgb(188,241,174)\">Le Freeman doit avancer."
		"npc_vortigaunt.fmbeware" = "<font color=\"rgb(188,241,174)\">Prudence!"
		"npc_vortigaunt.fmcanuse" = "<font color=\"rgb(188,241,174)\">Le Freeman peut utiliser ceci. "
		"npc_vortigaunt.fmdoesushonor" = "<font color=\"rgb(188,241,174)\">Le Freeman nous fait honneur. "
		"npc_vortigaunt.fmhonorsus" = "<font color=\"rgb(188,241,174)\">Le Freeman nous honore. "
		"npc_vortigaunt.fminway" = "<font color=\"rgb(188,241,174)\">Le Freeman nous fait obstacle. "
		"npc_vortigaunt.fmknowsbest" = "<font color=\"rgb(188,241,174)\">Le Freeman a toujours raison. "
		"npc_vortigaunt.fmmustbeware" = "<font color=\"rgb(188,241,174)\">Le Freeman doit prendre garde. "
		"npc_vortigaunt.fmmustcaution" = "<font color=\"rgb(188,241,174)\">Le Freeman doit être prudent."
		"npc_vortigaunt.fmmustfollow" = "<font color=\"rgb(188,241,174)\">Le Freeman doit nous suivre "
		"npc_vortigaunt.fmmustmove" = "<font color=\"rgb(188,241,174)\">Le Freeman doit bouger. "
		"npc_vortigaunt.fmmustnotfear" = "<font color=\"rgb(188,241,174)\">Que le Freeman n'aie crainte."
		"npc_vortigaunt.fmsilent" = "<font color=\"rgb(188,241,174)\">Le Freeman doit se taire."
		"npc_vortigaunt.fmstandstill" = "<font color=\"rgb(188,241,174)\">Que le Freeman reste immobile. "
		"npc_vortigaunt.followfm" = "<font color=\"rgb(188,241,174)\">Suivez, Freeman."
		"npc_vortigaunt.forbearfm" = "<font color=\"rgb(188,241,174)\">Attention, Freeman."
		"npc_vortigaunt.forcause" = "<font color=\"rgb(188,241,174)\">Pour le Tout-puissant."
		"npc_vortigaunt.forfreedom" = "<font color=\"rgb(188,241,174)\">Pour la liberté! "
		"npc_vortigaunt.forthefm" = "<font color=\"rgb(188,241,174)\">Pour le Freeman! "
		"npc_vortigaunt.forward" = "<font color=\"rgb(188,241,174)\">En avant! "
		"npc_vortigaunt.freeman" = "<font color=\"rgb(188,241,174)\">Freeman. "
		"npc_vortigaunt.giveover" = "<font color=\"rgb(188,241,174)\">Donnez-nous votre essence. "
		"npc_vortigaunt.gladly" = "<font color=\"rgb(188,241,174)\">Volontiers. "
		"npc_vortigaunt.gloriousend" = "<font color=\"rgb(188,241,174)\">A notre fin glorieuse. "
		"npc_vortigaunt.greetingsfm" = "<font color=\"rgb(188,241,174)\">Bienvenue au Freeman. "
		"npc_vortigaunt.halt" = "<font color=\"rgb(188,241,174)\">Halte. "
		"npc_vortigaunt.hark" = "<font color=\"rgb(188,241,174)\">Écoutez."
		"npc_vortigaunt.hastefm" = "<font color=\"rgb(188,241,174)\">Hâtez-vous, Freeman."
		"npc_vortigaunt.heal01" = "<font color=\"rgb(188,241,174)\">Vos blessures sollicitent notre aide, Freeman."
		"npc_vortigaunt.heal02" = "<font color=\"rgb(188,241,174)\">C'est un plaisir de soigner le Freeman."
		"npc_vortigaunt.heal03" = "<font color=\"rgb(188,241,174)\">Le Freeman a besoin de soins."
		"npc_vortigaunt.heal04" = "<font color=\"rgb(188,241,174)\">Laissez-nous soigner vos blessures."
		"npc_vortigaunt.heal05" = "<font color=\"rgb(188,241,174)\">Nous n'avons pas de trousse, mais cela devrait suffire."
		"npc_vortigaunt.healscanharm" = "<font color=\"rgb(188,241,174)\">Ce qui soigne peut aussi blesser."
		"npc_vortigaunt.here" = "<font color=\"rgb(188,241,174)\">Ici. "
		"npc_vortigaunt.herewestay" = "<font color=\"rgb(188,241,174)\">Nous restons ici. "
		"npc_vortigaunt.hold" = "<font color=\"rgb(188,241,174)\">Halte. "
		"npc_vortigaunt.holdorcantcharge" = "<font color=\"rgb(188,241,174)\">Pour être rechargé, restez immobile. "
		"npc_vortigaunt.holdstill" = "<font color=\"rgb(188,241,174)\">Ne bougez pas. "
		"npc_vortigaunt.honorfollow" = "<font color=\"rgb(188,241,174)\">C'est un honneur que de vous suivre. "
		"npc_vortigaunt.honorours" = "<font color=\"rgb(188,241,174)\">C'est un grand honneur. "
		"npc_vortigaunt.hurryonfm" = "<font color=\"rgb(188,241,174)\">Vite, Freeman."
		"npc_vortigaunt.ifyoumove" = "<font color=\"rgb(188,241,174)\">Si vous bougez, nous ne pouvons rien faire. "
		"npc_vortigaunt.isitthefm" = "<font color=\"rgb(188,241,174)\">Est-ce le Freeman? "
		"npc_vortigaunt.itisthefm" = "<font color=\"rgb(188,241,174)\">C'est le Freeman. "
		"npc_vortigaunt.keepfmsafe" = "<font color=\"rgb(188,241,174)\">Ainsi, le Freeman est protégé. "
		"npc_vortigaunt.leadon" = "<font color=\"rgb(188,241,174)\">Ouvrez la voie. "
		"npc_vortigaunt.leadus" = "<font color=\"rgb(188,241,174)\">Guidez-nous. "
		"npc_vortigaunt.lookwell" = "<font color=\"rgb(188,241,174)\">Observez."
		"npc_vortigaunt.losesight" = "<font color=\"rgb(188,241,174)\">Ne perdons jamais de vue que le Tout commun nous rassemble tous."
		"npc_vortigaunt.movingtarget" = "<font color=\"rgb(188,241,174)\">Nous ne pouvons soigner une cible mouvante. "
		"npc_vortigaunt.mutual" = "<font color=\"rgb(188,241,174)\">Notre objectif est le même. "
		"npc_vortigaunt.nodenexus" = "<font color=\"rgb(188,241,174)\">Noeud et Nexus, que cette vie vous nourrisse!"
		"npc_vortigaunt.obstruction" = "<font color=\"rgb(188,241,174)\">Voyons la vraie nature de cette obstruction."
		"npc_vortigaunt.onepasses" = "<font color=\"rgb(188,241,174)\">L'un de nous meurt mais nous survivons."
		"npc_vortigaunt.onesurvives" = "<font color=\"rgb(188,241,174)\">Si l'un survit, nous vivons tous."
		"npc_vortigaunt.onward" = "<font color=\"rgb(188,241,174)\">En avant! "
		"npc_vortigaunt.ourplacehere" = "<font color=\"rgb(188,241,174)\">C'est ici notre place. "
		"npc_vortigaunt.overthere" = "<font color=\"rgb(188,241,174)\">Là-bas. "
		"npc_vortigaunt.passon" = "<font color=\"rgb(188,241,174)\">Continuez! "
		"npc_vortigaunt.pleasure" = "<font color=\"rgb(188,241,174)\">Avec plaisir. "
		"npc_vortigaunt.prepare" = "<font color=\"rgb(188,241,174)\">Soyez prêt pour l'énergie. "
		"npc_vortigaunt.preparetomerge" = "<font color=\"rgb(188,241,174)\">Préparez-vous à fusionner avec le néant."
		"npc_vortigaunt.prevail" = "<font color=\"rgb(188,241,174)\">Nous l'emporterons. "
		"npc_vortigaunt.proceedfm" = "<font color=\"rgb(188,241,174)\">Allez-y, Freeman."
		"npc_vortigaunt.propitious" = "<font color=\"rgb(188,241,174)\">Alliance propice. "
		"npc_vortigaunt.reasondelay" = "<font color=\"rgb(188,241,174)\">Pourquoi ce retard?"
		"npc_vortigaunt.recsilence" = "<font color=\"rgb(188,241,174)\">Nous conseillons le silence."
		"npc_vortigaunt.regrettable" = "<font color=\"rgb(188,241,174)\">C'est regrettable. "
		"npc_vortigaunt.regrettable02" = "<font color=\"rgb(188,241,174)\">Regrettable."
		"npc_vortigaunt.rememberus" = "<font color=\"rgb(188,241,174)\">Ne nous oubliez pas."
		"npc_vortigaunt.returntoall" = "<font color=\"rgb(188,241,174)\">Retournez au Tout commun. "
		"npc_vortigaunt.returnvoid" = "<font color=\"rgb(188,241,174)\">Retournez au néant. "
		"npc_vortigaunt.satisfaction" = "<font color=\"rgb(188,241,174)\">Satisfaction. "
		"npc_vortigaunt.seenworse" = "<font color=\"rgb(188,241,174)\">Nous avons vu pire à travers les âges. "
		"npc_vortigaunt.silence" = "<font color=\"rgb(188,241,174)\">Silence"
		"npc_vortigaunt.standclear" = "<font color=\"rgb(188,241,174)\">Ecartez-vous. "
		"npc_vortigaunt.surge" = "<font color=\"rgb(188,241,174)\">A l'attaque. "
		"npc_vortigaunt.tethercut" = "<font color=\"rgb(188,241,174)\">Le lien est brisé. "
		"npc_vortigaunt.thatisall" = "<font color=\"rgb(188,241,174)\">C'est tout. "
		"npc_vortigaunt.thatsound" = "<font color=\"rgb(188,241,174)\">Ce bruit."
		"npc_vortigaunt.thefreeman" = "<font color=\"rgb(188,241,174)\">Le Freeman. "
		"npc_vortigaunt.there" = "<font color=\"rgb(188,241,174)\">Là!"
		"npc_vortigaunt.tothevoid" = "<font color=\"rgb(188,241,174)\">Retournez au néant. "
		"npc_vortigaunt.troubleus" = "<font color=\"rgb(188,241,174)\">Celui-là ne nous ennuiera plus. "
		"npc_vortigaunt.trulyitis" = "<font color=\"rgb(188,241,174)\">C'est bien le Freeman. "
		"npc_vortigaunt.undeserving" = "<font color=\"rgb(188,241,174)\">Indigne de conscience. "
		"npc_vortigaunt.untethered" = "<font color=\"rgb(188,241,174)\">Celui-ci est détaché."
		"npc_vortigaunt.upthere" = "<font color=\"rgb(188,241,174)\">Là-haut"
		"npc_vortigaunt.utmostprotect" = "<font color=\"rgb(188,241,174)\">Nous ferons notre possible pour défendre le Freeman."
		"npc_vortigaunt.veillifted" = "<font color=\"rgb(188,241,174)\">Que le voile soit enfin levé, ou bien alors déchiré."
		"npc_vortigaunt.vmourn01" = "<font color=\"rgb(188,241,174)\">Cet esprit périt."
		"npc_vortigaunt.vmourn02" = "<font color=\"rgb(188,241,174)\">Le chemin de l'éclaireur se ferme."
		"npc_vortigaunt.vmourn03" = "<font color=\"rgb(188,241,174)\">Le Freeman ne doit pas craindre, mais fusionner."
		"npc_vortigaunt.vmourn04" = "<font color=\"rgb(188,241,174)\">La vortessence est infinie."
		"npc_vortigaunt.vmourn05" = "<font color=\"rgb(188,241,174)\">De telles postures sont fugaces."
		"npc_vortigaunt.vmourn06" = "<font color=\"rgb(188,241,174)\">Ce n'est qu'un passage éphémère."
		"npc_vortigaunt.vmourn07" = "<font color=\"rgb(188,241,174)\">Ce n'est pas la fin."
		"npc_vortigaunt.vmourn08" = "<font color=\"rgb(188,241,174)\">Le Freeman survit en nous."
		"npc_vortigaunt.vmourn09" = "<font color=\"rgb(188,241,174)\">Le cordon du Freeman est coupé."
		"npc_vortigaunt.vmourn10" = "<font color=\"rgb(188,241,174)\">Le cordon du Freeman est coupé."
		"npc_vortigaunt.vmourn11" = "<font color=\"rgb(188,241,174)\">Le Freeman n'est plus."
		"npc_vortigaunt.vmourn12" = "<font color=\"rgb(188,241,174)\">Ainsi va la vie."
		"npc_vortigaunt.voidlaysclaim" = "<font color=\"rgb(188,241,174)\">Le néant réclame ce qui est sien."
