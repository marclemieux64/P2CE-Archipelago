		"ep_02.al_ambush_turretnag03" = "<font color=\"rgb(255,212,255)\">Désactivez cette tourelle, après je pourrai éteindre le champ de force."
		"ep_02.al_ambush_uphere" = "<font color=\"rgb(255,212,255)\">Là-haut, Gordon!"
		"ep_02.al_ambush_upstairs" = "<font color=\"rgb(255,212,255)\">En haut!"
		"ep_02.al_ambush_uptosomething" = "<font color=\"rgb(255,212,255)\">Hmmm... Ils mijotent quelque chose."
		"ep_02.al_ambush_watchwindows" = "<font color=\"rgb(255,212,255)\">Attention aux fenêtres!"
		"ep_02.al_ambush_weresurrounded" = "<font color=\"rgb(255,212,255)\">On est cernés!"
		"ep_02.al_ambush_whatnow" = "<font color=\"rgb(255,212,255)\">Quoi encore?"
		"ep_02.al_ambush_whatwasthat" = "<font color=\"rgb(255,212,255)\">C'est quoi ça ?"
		"ep_02.al_ambush_wirebuilding" = "<font color=\"rgb(255,212,255)\">Le câble vient de ce bâtiment, Gordon."
		"ep_02.al_ambush_wirestarts" = "<font color=\"rgb(255,212,255)\">Ouais, le câble commence là."
		"ep_02.al_ambush_wireuphill01" = "<font color=\"rgb(255,212,255)\">Le câble va jusqu'en haut de la colline vers ces bâtiments. "
		"ep_02.al_ambush_wireuphill02" = "<font color=\"rgb(255,212,255)\">Voyons d'où ça vient."
		"ep_02.al_ambush_youhearthat" = "<font color=\"rgb(255,212,255)\">Vous avez entendu?"
		"ep_02.al_ambush_youokayinthere" = "<font color=\"rgb(255,212,255)\">Ça va là-dedans?"
		"ep_02.al_barn_adv_ah" = "<font color=\"rgb(255,212,255)\">Ah !"
		"ep_02.al_barn_adv_didyouseeituhoh01" = "<font color=\"rgb(255,212,255)\">Ce truc était blessé. Vous l'avez vu?"
		"ep_02.al_barn_adv_didyouseeituhoh02" = "<font color=\"rgb(255,212,255)\">Je n'ose pas imaginer ce qu'il aurait fait si..."
		"ep_02.al_barn_adv_didyouseeituhoh03" = "<font color=\"rgb(255,212,255)\">Oh oh."
		"ep_02.al_barn_adv_hangong" = "<font color=\"rgb(255,212,255)\">Tenez bon, Gordon!"
