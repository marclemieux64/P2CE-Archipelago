		"ep_02.al_ambush_thatwasit01" = "<font color=\"rgb(255,212,255)\">Et voilà! Le champ de force est désactivé!"
		"ep_02.al_ambush_thatwasit02" = "<font color=\"rgb(255,212,255)\">En route!"
		"ep_02.al_ambush_theyreinhouse" = "<font color=\"rgb(255,212,255)\">Ils sont dans la maison!"
		"ep_02.al_ambush_theyreinside" = "<font color=\"rgb(255,212,255)\">Ils sont à l'intérieur!"
