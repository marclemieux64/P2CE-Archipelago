		"ep_01.al_fight10" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight11" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight12" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight13" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight14" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight15" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight16" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight17" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight18" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight19" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight20" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight21" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight22" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_fight23" = "<font color=\"rgb(255,212,255)\">[bruits de lutte]"
		"ep_01.al_figureaway" = "<font color=\"rgb(255,212,255)\">On trouvera un moyen de sortir... je sais pas, on montera dans un train."
		"ep_01.al_figureouthow" = "<font color=\"rgb(255,212,255)\">Il faut trouver un moyen d'aller à la Citadelle."
		"ep_01.al_findanotherway" = "<font color=\"rgb(255,212,255)\">Faut trouver un autre chemin."
		"ep_01.al_findterminal" = "<font color=\"rgb(255,212,255)\">Je vais pirater un terminal pour trouver un chemin vers le noyau."
		"ep_01.al_firstbarnacle" = "<font color=\"rgb(255,212,255)\">Aaargh ! Des bernacles."
		"ep_01.al_firststage" = "<font color=\"rgb(255,212,255)\">OK... première phase stabilisée... Ils amènent d'autres stalkers... Je peux rien faire de plus avant la fermeture de la prochaine phase."
		"ep_01.al_flares_first" = "<font color=\"rgb(255,212,255)\">Des fusées éclairantes! On pourrait les utiliser!"
		"ep_01.al_flares_goingout" = "<font color=\"rgb(255,212,255)\">Cette fusée va partir!"
		"ep_01.al_flares01" = "<font color=\"rgb(255,212,255)\">Des fusées éclairantes! Ça doit éclairer plus longtemps que votre lampe torche."
		"ep_01.al_flares02" = "<font color=\"rgb(255,212,255)\">Prenez-en une."
		"ep_01.al_flares03" = "<font color=\"rgb(255,212,255)\">Ces fusées peuvent être utiles."
		"ep_01.al_follow01" = "<font color=\"rgb(255,212,255)\">Je vous suis."
		"ep_01.al_follow02" = "<font color=\"rgb(255,212,255)\">Je vous suis, Gordon."
		"ep_01.al_follow03" = "<font color=\"rgb(255,212,255)\">Après vous."
		"ep_01.al_follow04" = "<font color=\"rgb(255,212,255)\">Allez-y."
		"ep_01.al_follow05" = "<font color=\"rgb(255,212,255)\">Allez-y, je vous suis."
		"ep_01.al_follow06" = "<font color=\"rgb(255,212,255)\">Je vous suis."
		"ep_01.al_gate_anyluckyet" = "<font color=\"rgb(255,212,255)\">Vous avez trouvé?"
		"ep_01.al_gate_cantbelieve" = "<font color=\"rgb(255,212,255)\">J'arrive pas à y croire."
		"ep_01.al_gate_canthearus" = "<font color=\"rgb(255,212,255)\">Ils doivent pas nous entendre."
		"ep_01.al_gate_checkside" = "<font color=\"rgb(255,212,255)\">Je vais voir par là."
		"ep_01.al_gate_doestrick" = "<font color=\"rgb(255,212,255)\">OK. On va voir si ça marche."
		"ep_01.al_gate_goodletsgo" = "<font color=\"rgb(255,212,255)\">Dieu merci. Sortons d'ici."
		"ep_01.al_gate_heyupthere" = "<font color=\"rgb(255,212,255)\">Hé, là-haut? Hé! Quelqu'un peut nous aider à sortir?"
		"ep_01.al_gate_lookaround" = "<font color=\"rgb(255,212,255)\">Ce qui sert à ouvrir la porte est peut-être dans le coin."
		"ep_01.al_gate_noitslocked" = "<font color=\"rgb(255,212,255)\">Non, non... C'est verrouillé."
		"ep_01.al_gate_ohgodno" = "<font color=\"rgb(255,212,255)\">Oh, non..."
		"ep_01.al_gate_seeanyway" = "<font color=\"rgb(255,212,255)\">Vous avez une idée pour ouvrir ça?"
		"ep_01.al_gate_slotforcrank" = "<font color=\"rgb(255,212,255)\">Il devait y avoir une manivelle ou une poignée."
		"ep_01.al_gate_spotwheel" = "<font color=\"rgb(255,212,255)\">Ça marchera peut-être avec ce volant. Essayez de l'enlever, Gordon."
		"ep_01.al_gate_stillday" = "<font color=\"rgb(255,212,255)\">Dieu merci, il fait encore jour! Sortons d'ici."
		"ep_01.al_getacrosshow" = "<font color=\"rgb(255,212,255)\">Il faut qu'on passe, mais comment?"
		"ep_01.al_getbarrier" = "<font color=\"rgb(255,212,255)\">Je désactive ce champ et on s'occupe de lui."
		"ep_01.al_getbusy" = "<font color=\"rgb(255,212,255)\">Mais euh, c'est vraiment le Dr Kleiner qui dit à tout le monde... de s'activer?"
		"ep_01.al_getinvan_nag01" = "<font color=\"rgb(255,212,255)\">Gordon, montez."
		"ep_01.al_getinvan_nag02" = "<font color=\"rgb(255,212,255)\">Montez du côté passager."
		"ep_01.al_getinvan_nag03" = "<font color=\"rgb(255,212,255)\">Allez, je perds patience."
		"ep_01.al_getinvan_nag04" = "<font color=\"rgb(255,212,255)\">Je peux pas y aller toute seule."
		"ep_01.al_getstarted" = "<font color=\"rgb(255,212,255)\">Allez-y, Gordon. Ça ira ici."
		"ep_01.al_getthemmoving" = "<font color=\"rgb(255,212,255)\">S'il reste encore des gens à évacuer, nous devons les aider."
		"ep_01.al_getthruhere01" = "<font color=\"rgb(255,212,255)\">Je crois qu'on peut passer..."
		"ep_01.al_getthruhere02" = "<font color=\"rgb(255,212,255)\">Là..."
		"ep_01.al_givemeroller" = "<font color=\"rgb(255,212,255)\">Je dois pirater un autre lamineur."
		"ep_01.al_gointocore" = "<font color=\"rgb(255,212,255)\">Vous devez entrer et stabiliser le noyau vous-même, Gordon... Ne laissez pas les stalkers vous en empêcher... Nous n'avons plus beaucoup de temps."
		"ep_01.al_goodboy" = "<font color=\"rgb(255,212,255)\">Bon chien!"
		"ep_01.al_gooddog01" = "<font color=\"rgb(255,212,255)\">Bien."
		"ep_01.al_goodluck" = "<font color=\"rgb(255,212,255)\">Eh bien... Bonne chance."
		"ep_01.al_goodthink" = "<font color=\"rgb(255,212,255)\">Bien vu."
		"ep_01.al_goodthinking01" = "<font color=\"rgb(255,212,255)\">Bien vu!"
		"ep_01.al_goodthrow" = "<font color=\"rgb(255,212,255)\">Ah, bien lancé, Chien."
		"ep_01.al_goonbarney" = "<font color=\"rgb(255,212,255)\">Allez-y sans nous, Barney. Ces gens n'y arriveront pas sans vous."
		"ep_01.al_goonboy" = "<font color=\"rgb(255,212,255)\">Allez Chien, donne à Gordon."
		"ep_01.al_goovertheredog" = "<font color=\"rgb(255,212,255)\">Par là, Chien! On se retrouve après."
		"ep_01.al_gordon" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_01.al_gordonallright" = "<font color=\"rgb(255,212,255)\">Oh, Gordon, vous allez bien!"
		"ep_01.al_gottahurrydog" = "<font color=\"rgb(255,212,255)\">Il faut se dépêcher, on n'a plus le temps."
		"ep_01.al_gottogettocore" = "<font color=\"rgb(255,212,255)\">Il faut accéder au noyau."
		"ep_01.al_gotwhatineeded" = "<font color=\"rgb(255,212,255)\">Bon..."
		"ep_01.al_gotwhatineeded01" = "<font color=\"rgb(255,212,255)\">J'ai ce qu'il me faut."
		"ep_01.al_gotwhatineeded02" = "<font color=\"rgb(255,212,255)\">On continue."
		"ep_01.al_gravgunholdonto" = "<font color=\"rgb(255,212,255)\">Hé, le pistolet! Donne-le à Gordon."
		"ep_01.al_gravgunholdonto01" = "<font color=\"rgb(255,212,255)\">Hé, le pistolet."
		"ep_01.al_gravgunholdonto02" = "<font color=\"rgb(255,212,255)\">Allez, mon chien."
		"ep_01.al_gravgunholdonto03" = "<font color=\"rgb(255,212,255)\">Donne-le à Gordon."
		"ep_01.al_gravgunlosingpower" = "<font color=\"rgb(255,212,255)\">Il perd de l'énergie. Mince. Il aurait fallu le charger un peu plus longtemps. Il tirait certainement son énergie du noyau."
		"ep_01.al_gravgunpowerdown" = "<font color=\"rgb(255,212,255)\">Oulà... Regardez. On dirait que le pistolet n'a plus d'énergie."
		"ep_01.al_greet_cit01" = "<font color=\"rgb(255,212,255)\">D'accord."
		"ep_01.al_greet_cit02" = "<font color=\"rgb(255,212,255)\">OK. On peut continuer, maintenant?"
		"ep_01.al_greet_cit03" = "<font color=\"rgb(255,212,255)\">Vous ne me défendez pas, Gordon?"
		"ep_01.al_greet_cit04" = "<font color=\"rgb(255,212,255)\">Pas si on bouge pas d'ici... allez!"
		"ep_01.al_greet_cit05" = "<font color=\"rgb(255,212,255)\">Ça se présente pas très bien, mais Gordon a déjà fait des miracles."
		"ep_01.al_greet_cit06" = "<font color=\"rgb(255,212,255)\">Euh, j'aime pas interrompre les réunions mais là, il faut vraiment y aller."
		"ep_01.al_greet_cit07" = "<font color=\"rgb(255,212,255)\">Pas si on ne sort pas d'ici."
		"ep_01.al_greet_cit08" = "<font color=\"rgb(255,212,255)\">Bien sûr. Allons-y!"
		"ep_01.al_greet_cit09" = "<font color=\"rgb(255,212,255)\">Oui. Et dans la combi, c'est le Docteur Freeman."
		"ep_01.al_greet_cit10" = "<font color=\"rgb(255,212,255)\">Alors, vous devez savoir qu'on doit y aller."
		"ep_01.al_greet_cit11" = "<font color=\"rgb(255,212,255)\">Mes problèmes me suivent."
		"ep_01.al_greet_cit12" = "<font color=\"rgb(255,212,255)\">On fera tout pour vous aider."
		"ep_01.al_greet_cit13" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_01.al_greet_cit14" = "<font color=\"rgb(255,212,255)\">On est restés derrière pour vous presser un peu."
		"ep_01.al_greet_cit15" = "<font color=\"rgb(255,212,255)\">Et moi, je vous dis d'avancer."
		"ep_01.al_greet_cit16" = "<font color=\"rgb(255,212,255)\">Euh, non. Mon père est Odessa Cubbage."
		"ep_01.al_greet_cit17" = "<font color=\"rgb(255,212,255)\">Oui, euh, OK. Allons-y!"
		"ep_01.al_greet_cit18" = "<font color=\"rgb(255,212,255)\">Il arrivera plus tard."
		"ep_01.al_greet_cit19" = "<font color=\"rgb(255,212,255)\">J'ai une meilleure question: pourquoi n'êtes-vous pas encore à la gare? Allez, en route !"
		"ep_01.al_greet_cit20" = "<font color=\"rgb(255,212,255)\">On n'y est pas encore, là."
		"ep_01.al_greet_cit21" = "<font color=\"rgb(255,212,255)\">Gordon n'est pas très bavard."
		"ep_01.al_greet_cit22" = "<font color=\"rgb(255,212,255)\">Gordon est libre de dire ce qu'il veut. Hein, Gordon?"
		"ep_01.al_greet_cit23" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que vous dites? C'est pas grave. Allez, on y va!"
		"ep_01.al_hack_done01" = "<font color=\"rgb(255,212,255)\">Maintenant, il est des nôtres!"
		"ep_01.al_hack_done02" = "<font color=\"rgb(255,212,255)\">Celui-là est bon."
		"ep_01.al_hack_done03" = "<font color=\"rgb(255,212,255)\">On va le faire marcher."
		"ep_01.al_hack_fail01" = "<font color=\"rgb(255,212,255)\">OK... Peut-être plus tard."
		"ep_01.al_hack_fail02" = "<font color=\"rgb(255,212,255)\">Vous êtes sûr de vouloir faire ça?"
		"ep_01.al_hack_train01" = "<font color=\"rgb(255,212,255)\">Rapprochez-moi ça."
		"ep_01.al_hack_train02" = "<font color=\"rgb(255,212,255)\">Plus près."
		"ep_01.al_hack_train03" = "<font color=\"rgb(255,212,255)\">Tenez-le bien."
		"ep_01.al_hack_train04" = "<font color=\"rgb(255,212,255)\">Je peux pas l'atteindre."
		"ep_01.al_hack_train05" = "<font color=\"rgb(255,212,255)\">Amenez-le moi, je vais le convertir."
		"ep_01.al_harness" = "<font color=\"rgb(255,212,255)\">Il est rechargé... comme dans le réacteur de Breen... Ça nous aidera, là où on va..."
		"ep_01.al_harness01" = "<font color=\"rgb(255,212,255)\">Il est rechargé, Gordon..."
		"ep_01.al_harness02" = "<font color=\"rgb(255,212,255)\">Comme dans le réacteur de Breen."
		"ep_01.al_harness03" = "<font color=\"rgb(255,212,255)\">Super. On aura besoin de toute l'aide possible."
		"ep_01.al_hastobearoundhere" = "<font color=\"rgb(255,212,255)\">Il doit être là, tout proche. Je suis sûre que nous sommes tout près."
		"ep_01.al_hastobeawayacross01" = "<font color=\"rgb(255,212,255)\">Il doit y avoir un moyen de passer."
		"ep_01.al_hastobeawayacross02" = "<font color=\"rgb(255,212,255)\">Mais comment?"
		"ep_01.al_hatetothink" = "<font color=\"rgb(255,212,255)\">Argh. Je veux même pas savoir ce qui a vécu là-dedans."
		"ep_01.al_headcrabsurprise01" = "<font color=\"rgb(255,212,255)\">Ah!"
		"ep_01.al_headcrabsurprise02" = "<font color=\"rgb(255,212,255)\">Ouaouh!"
		"ep_01.al_headcrabsurprise03" = "<font color=\"rgb(255,212,255)\">Aaaaaah!"
		"ep_01.al_headingoutnow" = "<font color=\"rgb(255,212,255)\">On n'est pas encore sortis de la Citadelle."
		"ep_01.al_healplayer01" = "<font color=\"rgb(255,212,255)\">Tenez, soignez-vous."
		"ep_01.al_healplayer02" = "<font color=\"rgb(255,212,255)\">Prenez une trousse de secours."
		"ep_01.al_heatupsoon" = "<font color=\"rgb(255,212,255)\">Le Dr Kleiner a dit que ça réchaufferait tout."
		"ep_01.al_helpmedog" = "<font color=\"rgb(255,212,255)\">Aide-moi, Chien."
		"ep_01.al_hereslift" = "<font color=\"rgb(255,212,255)\">Voilà l'ascenseur. Allez-y."
		"ep_01.al_hesalive" = "<font color=\"rgb(255,212,255)\">Il est vivant!"
		"ep_01.al_hesalivegethimout" = "<font color=\"rgb(255,212,255)\">Il est vivant! Chien, sors-le de là."
		"ep_01.al_hiding01" = "<font color=\"rgb(255,212,255)\">Les gens ont dû se cacher ici."
		"ep_01.al_hiding02" = "<font color=\"rgb(255,212,255)\">Il y avait pas d'endroit sûr."
		"ep_01.al_hiding03" = "<font color=\"rgb(255,212,255)\">Je me demande comment ça va hors de la ville."
		"ep_01.al_holdasec" = "<font color=\"rgb(255,212,255)\">Attends... Il y a des interférences."
		"ep_01.al_holdingback" = "<font color=\"rgb(255,212,255)\">Ah... C'était la seule chose qui retenait les fourmis-lions."
		"ep_01.al_holdingotherside" = "<font color=\"rgb(255,212,255)\">Il l'active de l'autre côté."
		"ep_01.al_holdon" = "<font color=\"rgb(255,212,255)\">Une seconde."
		"ep_01.al_hopelessnoaccess" = "<font color=\"rgb(255,212,255)\">C'est sans espoir... Il y a pas d'accès. Pas moyen de..."
		"ep_01.al_hopelessnoaccess01" = "<font color=\"rgb(255,212,255)\">C'est sans espoir... Il y a pas d'accès. Pas moyen de..."
		"ep_01.al_hopelessnoaccess02" = "<font color=\"rgb(255,212,255)\">Hein?"
		"ep_01.al_hoponlift" = "<font color=\"rgb(255,212,255)\">Grimpez dans l'ascenseur, Gordon. Je vous ferai descendre dans le noyau."
		"ep_01.al_howcouldanyonelive" = "<font color=\"rgb(255,212,255)\">Mais qui pourrait survivre ici?"
		"ep_01.al_howgetacross" = "<font color=\"rgb(255,212,255)\">Comment allons-nous passer?"
		"ep_01.al_hurrydog" = "<font color=\"rgb(255,212,255)\">Dépêche-toi, Chien."
		"ep_01.al_hurrygord01" = "<font color=\"rgb(255,212,255)\">Allez, Gordon."
		"ep_01.al_hurrygordon01" = "<font color=\"rgb(255,212,255)\">Vite, on doit continuer."
		"ep_01.al_idontgetit" = "<font color=\"rgb(255,212,255)\">Je ne comprends pas. Pourquoi est-ce qu'ils traînent par ici?"
		"ep_01.al_ifonlybridgepower" = "<font color=\"rgb(255,212,255)\">Si seulement on pouvait mettre le pont sous tension..."
		"ep_01.al_ifwedont" = "<font color=\"rgb(255,212,255)\">Si on n'abat pas ce strider, personne ne sort vivant d'ici."
		"ep_01.al_ifwefoundaway01" = "<font color=\"rgb(255,212,255)\">Ben, vous avez la combi CEH."
		"ep_01.al_ifwefoundaway02" = "<font color=\"rgb(255,212,255)\">Si on arrivait à rentrer dans la Citadelle, on pourrait..."
		"ep_01.al_illfigurethisout" = "<font color=\"rgb(255,212,255)\">Occupez-vous du noyau. J'essaie de trouver une solution."
		"ep_01.al_ipromise" = "<font color=\"rgb(255,212,255)\">Je te le promets."
		"ep_01.al_ishe" = "<font color=\"rgb(255,212,255)\">Il est..."
		"ep_01.al_isthisit" = "<font color=\"rgb(255,212,255)\">Hé? Tu entends?"
		"ep_01.al_itoldyoudad" = "<font color=\"rgb(255,212,255)\">Je t'avais dit qu'il était là, quelque part... On a capté le signal de la combi CEH, et on a creusé."
		"ep_01.al_itoldyoudad01" = "<font color=\"rgb(255,212,255)\">Je t'avais dit qu'il était là, quelque part."
		"ep_01.al_itoldyoudad02" = "<font color=\"rgb(255,212,255)\">Heureusement, on a capté le signal de la combi CEH, et puis on a creusé."
		"ep_01.al_itsgone" = "<font color=\"rgb(255,212,255)\">Vous avez eu le temps de le voir?"
		"ep_01.al_itsjudith" = "<font color=\"rgb(255,212,255)\">Hé, c'est Judith. On dirait que le Cartel a intercepté un message. Je vais prendre ça et tout ce que je peux."
		"ep_01.al_itsus" = "<font color=\"rgb(255,212,255)\">Regardez! C'est nous!"
		"ep_01.al_itsworking" = "<font color=\"rgb(255,212,255)\">Je ne sais pas ce que vous faites, mais ca marche."
		"ep_01.al_judithgotaway" = "<font color=\"rgb(255,212,255)\">Papa et Judith sont partis dans l'une des cellules de secours du Dr Breen. Ils sont arrivés dans un camp Vortigaunt, hors de la ville. J'espère qu'on aura le temps d'y arriver."
		"ep_01.al_keytounlock" = "<font color=\"rgb(255,212,255)\">Il y a tellement de données... C'est impressionnant."
		"ep_01.al_kickintohall" = "<font color=\"rgb(255,212,255)\">Balancez-ça dans le couloir."
		"ep_01.al_kleinercast" = "<font color=\"rgb(255,212,255)\">Je suis si contente de revoir le Dr Kleiner."
		"ep_01.al_lasttrains" = "<font color=\"rgb(255,212,255)\">Les derniers trains partent... Faites monter les gens, on retient le Cartel. "
		"ep_01.al_lead_catchup01" = "<font color=\"rgb(255,212,255)\">Allez!"
		"ep_01.al_lead_catchup02" = "<font color=\"rgb(255,212,255)\">Par là!"
		"ep_01.al_lead_catchup03" = "<font color=\"rgb(255,212,255)\">Allez!"
		"ep_01.al_lead_catchup04" = "<font color=\"rgb(255,212,255)\">Vous êtes où?"
		"ep_01.al_lead_catchup05" = "<font color=\"rgb(255,212,255)\">Gordon, où êtes-vous?"
		"ep_01.al_lead_catchup06" = "<font color=\"rgb(255,212,255)\">Ca ne va pas?"
		"ep_01.al_lead_catchup07" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'il y a?"
		"ep_01.al_lead_catchup08" = "<font color=\"rgb(255,212,255)\">Vous venez?"
		"ep_01.al_lead_comingback01" = "<font color=\"rgb(255,212,255)\">J'arrive."
		"ep_01.al_lead_comingback02" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que vous faites?"
		"ep_01.al_lead_comingback03" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qui vous retient?"
		"ep_01.al_lead_comingback04" = "<font color=\"rgb(255,212,255)\">Vous venez?"
		"ep_01.al_lead_comingback05" = "<font color=\"rgb(255,212,255)\">Ca va?"
		"ep_01.al_lead_comingback06" = "<font color=\"rgb(255,212,255)\">On doit vraiment y aller."
		"ep_01.al_lead_comingback07" = "<font color=\"rgb(255,212,255)\">Mais qu'est-ce qui vous retient?"
		"ep_01.al_lead_retrieve01" = "<font color=\"rgb(255,212,255)\">Venez."
		"ep_01.al_lead_retrieve02" = "<font color=\"rgb(255,212,255)\">Vous me suivez, OK?"
		"ep_01.al_lead_retrieve03" = "<font color=\"rgb(255,212,255)\">Restez avec moi."
		"ep_01.al_lead_start01" = "<font color=\"rgb(255,212,255)\">Allez."
		"ep_01.al_lead_start02" = "<font color=\"rgb(255,212,255)\">Allons-y!"
		"ep_01.al_lead_start03" = "<font color=\"rgb(255,212,255)\">On y va."
		"ep_01.al_lead_start04" = "<font color=\"rgb(255,212,255)\">On continue."
		"ep_01.al_lead_start05" = "<font color=\"rgb(255,212,255)\">Hé, vous venez?"
		"ep_01.al_lead_start06" = "<font color=\"rgb(255,212,255)\">Vous êtes prêt?"
		"ep_01.al_lead_start07" = "<font color=\"rgb(255,212,255)\">On y va?"
		"ep_01.al_lemmethink" = "<font color=\"rgb(255,212,255)\">Attendez, je réfléchis... Hmmm..."
		"ep_01.al_letmegetaccess" = "<font color=\"rgb(255,212,255)\">OK, je vais vous faire passer."
