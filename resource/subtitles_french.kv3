		"ep_02.sheckley_atbreach" = "<font color=\"rgb(251,218,194)\">Elles sont à la brèche!"
		"ep_02.sheckley_awayfromvort" = "<font color=\"rgb(251,218,194)\">Eloignez-les du Vort!"
		"ep_02.sheckley_badturret" = "<font color=\"rgb(251,218,194)\">C'est celle qu'on appelle la Grande diablesse."
		"ep_02.sheckley_badturret_alt" = "<font color=\"rgb(251,218,194)\">C'est celle qu'on aime bien appeler la Grande diablesse."
		"ep_02.sheckley_betweenwave_01" = "<font color=\"rgb(251,218,194)\">D'accord, Doc!"
		"ep_02.sheckley_betweenwave_02" = "<font color=\"rgb(251,218,194)\">Doc, vous avez déjà vu une fourmi-lion?"
		"ep_02.sheckley_betweenwave_03" = "<font color=\"rgb(251,218,194)\">Ouais!"
		"ep_02.sheckley_betweenwave_04" = "<font color=\"rgb(251,218,194)\">D'accord!"
		"ep_02.sheckley_betweenwave_05" = "<font color=\"rgb(251,218,194)\">J'espère que c'était la dernière vague."
		"ep_02.sheckley_betweenwave_06" = "<font color=\"rgb(251,218,194)\">On se débrouille pas mal."
		"ep_02.sheckley_betweenwave_conver1_01" = "<font color=\"rgb(251,218,194)\">On en a tous eu 10, il y en a des centaines."
		"ep_02.sheckley_betweenwave_conver2_01" = "<font color=\"rgb(251,218,194)\">Quoi?"
		"ep_02.sheckley_betweenwave_conver2_02" = "<font color=\"rgb(251,218,194)\">Quoi?"
		"ep_02.sheckley_betweenwave_conver3_01" = "<font color=\"rgb(251,218,194)\">Qu'est-ce qui vous fait penser ça?"
		"ep_02.sheckley_betweenwave_conver4_01" = "<font color=\"rgb(251,218,194)\">Si vous voyez une bestiole sur moi, faites-la déguerpir la prochaine fois."
		"ep_02.sheckley_betweenwave_conver4_02" = "<font color=\"rgb(251,218,194)\">Ouais. Non. C'est sûr. Elles ne font jamais qu'un mètre cinquante. "
		"ep_02.sheckley_breachagain" = "<font color=\"rgb(251,218,194)\">Encore la brèche!"
		"ep_02.sheckley_bye01" = "<font color=\"rgb(251,218,194)\">A plus! "
		"ep_02.sheckley_bye02" = "<font color=\"rgb(251,218,194)\">Bonne chance pour là-bas."
		"ep_02.sheckley_cantholdout" = "<font color=\"rgb(251,218,194)\">On va pas pouvoir tenir beaucoup plus longtemps."
		"ep_02.sheckley_cavalry" = "<font color=\"rgb(251,218,194)\">Vous voulez dire la cavalerie."
		"ep_02.sheckley_comingfrom24" = "<font color=\"rgb(251,218,194)\">Elles viennent encore du 24!"
		"ep_02.sheckley_cover12" = "<font color=\"rgb(251,218,194)\">Couvrez le 12!"
		"ep_02.sheckley_cover24" = "<font color=\"rgb(251,218,194)\">Couvrez le 24!"
		"ep_02.sheckley_cover36" = "<font color=\"rgb(251,218,194)\">Couvrez le 36!"
		"ep_02.sheckley_covervort" = "<font color=\"rgb(251,218,194)\">Couvrez le Vort!"
		"ep_02.sheckley_dochelpvort" = "<font color=\"rgb(251,218,194)\">Doc, aidez le Vort!"
		"ep_02.sheckley_dontcount01" = "<font color=\"rgb(251,218,194)\">On bouge! "
		"ep_02.sheckley_dontcount02" = "<font color=\"rgb(251,218,194)\">Il faut défendre le Vort."
		"ep_02.sheckley_downhere01" = "<font color=\"rgb(251,218,194)\">Puisque vous êtes là, Freeman, donnez-nous un coup de main. "
		"ep_02.sheckley_downhere02" = "<font color=\"rgb(251,218,194)\">Je vais vous montrer les capteurs de fourmis-lions."
		"ep_02.sheckley_everywhere" = "<font color=\"rgb(251,218,194)\">Oh mon Dieu, elles viennent de partout!"
		"ep_02.sheckley_fightlion_01" = "<font color=\"rgb(251,218,194)\">Hé Griggs, t'as vu ça?"
		"ep_02.sheckley_fightlion_02" = "<font color=\"rgb(251,218,194)\">Griggs, là-bas!"
		"ep_02.sheckley_following01" = "<font color=\"rgb(251,218,194)\">J'arrive."
		"ep_02.sheckley_following02" = "<font color=\"rgb(251,218,194)\">Ouais, ouais."
		"ep_02.sheckley_followme01" = "<font color=\"rgb(251,218,194)\">Allez, Griggsy, bouge-toi."
		"ep_02.sheckley_followme02" = "<font color=\"rgb(251,218,194)\">On y va, Griggs."
		"ep_02.sheckley_followme03" = "<font color=\"rgb(251,218,194)\">Ici, Griggs. Grouille-toi."
		"ep_02.sheckley_followme04" = "<font color=\"rgb(251,218,194)\">Allez, allez, on y va."
		"ep_02.sheckley_followme05" = "<font color=\"rgb(251,218,194)\">Allez, gardez le rythme."
		"ep_02.sheckley_followme06" = "<font color=\"rgb(251,218,194)\">Vous venez ou quoi?"
		"ep_02.sheckley_gogriggs" = "<font color=\"rgb(251,218,194)\">D'accord, Griggs!"
		"ep_02.sheckley_gohelpvort" = "<font color=\"rgb(251,218,194)\">Freeman, allez aider le Vort!"
		"ep_02.sheckley_helldoesthatmean" = "<font color=\"rgb(251,218,194)\">Bon sang, qu'est-ce que ça veut dire?"
		"ep_02.sheckley_idiot02" = "<font color=\"rgb(251,218,194)\">Andouille, "
		"ep_02.sheckley_idiot03" = "<font color=\"rgb(251,218,194)\">C'est Gordon Freeman"
		"ep_02.sheckley_incom36" = "<font color=\"rgb(251,218,194)\">Elles arrivent au 36! "
		"ep_02.sheckley_junc_followvortnag01" = "<font color=\"rgb(251,218,194)\">Faut se bouger, Doc. Suivez le Vort."
		"ep_02.sheckley_junc_followvortnag02" = "<font color=\"rgb(251,218,194)\">Sérieusement, Freeman, il faut y aller."
		"ep_02.sheckley_junc_followvortnag03" = "<font color=\"rgb(251,218,194)\">Mademoiselle Vance est mal en point, Doc. Dépêchez-vous de suivre le Vort."
		"ep_02.sheckley_junc_followvortnag04" = "<font color=\"rgb(251,218,194)\">On est tous crevés, Freeman, mais vous ne pouvez pas rester sans rien faire. Suivez le Vort!"
		"ep_02.sheckley_junc_yousaidthat" = "<font color=\"rgb(251,218,194)\">Je n'en crois pas mes oreilles."
		"ep_02.sheckley_keepeye" = "<font color=\"rgb(251,218,194)\">Freeman! Regardez bien les feux!"
		"ep_02.sheckley_keepmoving" = "<font color=\"rgb(251,218,194)\">Tais-toi donc et avance."
		"ep_02.sheckley_keepsupplies" = "<font color=\"rgb(251,218,194)\">Hé Griggs, tu pourrais montrer au Dr Freeman là où on stocke les munitions?"
		"ep_02.sheckley_killlion_01" = "<font color=\"rgb(251,218,194)\">Ah ah."
		"ep_02.sheckley_killlion_02" = "<font color=\"rgb(251,218,194)\">Je t'en laisse un peu Griggs, hein?"
		"ep_02.sheckley_killlion_03" = "<font color=\"rgb(251,218,194)\">Ouais. Ouais!"
