		"ep_02.al_barn_adv_thankallright02" = "<font color=\"rgb(255,212,255)\">Dieu merci, vous allez bien..."
		"ep_02.al_barn_adv_thinkhurt" = "<font color=\"rgb(255,212,255)\">Je crois qu'il est blessé!"
