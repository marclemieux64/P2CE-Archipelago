		"ep_02.al_junc_beenout03" = "<font color=\"rgb(255,212,255)\">Ça fait combien de temps?"
		"ep_02.al_junc_expectingus01" = "<font color=\"rgb(255,212,255)\">Il faut se rendre à White Forest. "
		"ep_02.al_junc_expectingus02" = "<font color=\"rgb(255,212,255)\">C'est crucial."
		"ep_02.al_junc_gettowhiteforest01" = "<font color=\"rgb(255,212,255)\">Vite, Gordon. "
		"ep_02.al_junc_gettowhiteforest02" = "<font color=\"rgb(255,212,255)\">On doit se rendre à White Forest."
		"ep_02.al_junc_ineedto01" = "<font color=\"rgb(255,212,255)\">Mais..."
		"ep_02.al_junc_ineedto02" = "<font color=\"rgb(255,212,255)\">Je dois..."
