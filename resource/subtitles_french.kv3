		"ep_01.ba_gettingaboard02" = "<font color=\"rgb(215,255,255)\">Ils y sont!"
		"ep_01.ba_gettingaboard03" = "<font color=\"rgb(215,255,255)\">Ça y est!"
		"ep_01.ba_gettingaboard04" = "<font color=\"rgb(215,255,255)\">Tous à bord!"
		"ep_01.ba_goacross" = "<font color=\"rgb(215,255,255)\">Traversez, Gordon."
		"ep_01.ba_goodjob" = "<font color=\"rgb(215,255,255)\">Bien joué, Gordon!"
		"ep_01.ba_gordoniknow" = "<font color=\"rgb(215,255,255)\">Ça c'est le Gordon Freeman que je connais!"
		"ep_01.ba_greeting01" = "<font color=\"rgb(215,255,255)\">Gordon?  "
		"ep_01.ba_greeting02" = "<font color=\"rgb(215,255,255)\">Alyx!"
		"ep_01.ba_greeting03" = "<font color=\"rgb(215,255,255)\">C'est incroyable!"
		"ep_01.ba_greeting04" = "<font color=\"rgb(215,255,255)\">Mais comment êtes-vous sortis de la Citadelle?"
		"ep_01.ba_groupready01" = "<font color=\"rgb(215,255,255)\">Ok, emmenez ce groupe de citoyens jusqu'au train."
		"ep_01.ba_groupready02" = "<font color=\"rgb(215,255,255)\">Le prochain groupe est prêt à vous suivre!"
		"ep_01.ba_groupready03" = "<font color=\"rgb(215,255,255)\">Emmenez-les au train!"
		"ep_01.ba_groupready04" = "<font color=\"rgb(215,255,255)\">Emmenez-les jusqu'au train et protégez-les!"
		"ep_01.ba_guardpoint" = "<font color=\"rgb(215,255,255)\">Je vais sécuriser le secteur pour qu'ils puissent avancer vers les trains."
		"ep_01.ba_gunshipkill" = "<font color=\"rgb(215,255,255)\">Et un hélico de moins sur Terre!"
		"ep_01.ba_head4trains" = "<font color=\"rgb(215,255,255)\">Avancez vers les trains, citoyens! Je vais vous confier à mon vieil ami Gordon Freeman."
		"ep_01.ba_headfornext" = "<font color=\"rgb(215,255,255)\">Allons jusqu'au trainsuivant ! Vous, vous allez en avant, et je ramène le prochain groupe de citoyens!"
		"ep_01.ba_hellyeah" = "<font color=\"rgb(215,255,255)\">Ah ça, oui!"
		"ep_01.ba_herewego" = "<font color=\"rgb(215,255,255)\">On y va."
		"ep_01.ba_hightailstrider" = "<font color=\"rgb(215,255,255)\">Bon sang, d'où pouvait bien venir ce strider? Je croyais qu'ils avaient déjà tous quitté la ville. "
		"ep_01.ba_hurrytrain" = "<font color=\"rgb(215,255,255)\">Dépêchez-vous, ce train s'en va!"
		"ep_01.ba_ifyousayso" = "<font color=\"rgb(215,255,255)\">Vraiment? Si vous le dites."
		"ep_01.ba_justaboutfull" = "<font color=\"rgb(215,255,255)\">Le train est presque plein."
		"ep_01.ba_kiddingstrider" = "<font color=\"rgb(215,255,255)\">Oh, vous plaisantez. Un strider, ici?"
		"ep_01.ba_killapc01" = "<font color=\"rgb(215,255,255)\">Quelqu'un doit se débarrasser de ce véhicule blindé."
		"ep_01.ba_killapc02" = "<font color=\"rgb(215,255,255)\">Détruisez ce véhicule blindé."
		"ep_01.ba_killapc03" = "<font color=\"rgb(215,255,255)\">Débarrassez-vous des véhicules blindés."
		"ep_01.ba_killgunship01" = "<font color=\"rgb(215,255,255)\">Il faut s'occuper de cet hélico avant que quelqu'un d'autre essaie de passer."
		"ep_01.ba_killgunship02" = "<font color=\"rgb(215,255,255)\">Abattez l'hélico."
		"ep_01.ba_killgunship03" = "<font color=\"rgb(215,255,255)\">Descendez cet hélico, Doc!"
		"ep_01.ba_killgunship04" = "<font color=\"rgb(215,255,255)\">Doc, visez l'hélico!"
		"ep_01.ba_killrpgsoldier01" = "<font color=\"rgb(215,255,255)\">Attendez, il faut d'abord s'occuper du lance-roquettes."
		"ep_01.ba_killrpgsoldier02" = "<font color=\"rgb(215,255,255)\">Visez le soldat avec le lance-roquettes!"
		"ep_01.ba_killrpgsoldier03" = "<font color=\"rgb(215,255,255)\">On ne passera pas tant que ce soldat sera là."
		"ep_01.ba_kneecapping" = "<font color=\"rgb(215,255,255)\">Bien vu pour les rotules du strider!"
		"ep_01.ba_knowevac" = "<font color=\"rgb(215,255,255)\">Vous connaissez les trains d'évacuation, pas vrai?"
		"ep_01.ba_laterseeyou" = "<font color=\"rgb(215,255,255)\">Ok, vous deux! Je vous vois là-bas!"
		"ep_01.ba_luckydog" = "<font color=\"rgb(215,255,255)\">Quel veinard, hein!"
		"ep_01.ba_makeapush01" = "<font color=\"rgb(215,255,255)\">Eh bien, on avait prévu de faire une percée jusqu'à la gare."
		"ep_01.ba_makeapush02" = "<font color=\"rgb(215,255,255)\">J'ai la nette impression qu'on va devoir se tailler un passage au milieu de tous ces abrutis de métroflics qui tiennent absolument à défendre Cité 17."
		"ep_01.ba_moveemout" = "<font color=\"rgb(215,255,255)\">Faites-les sortir!"
		"ep_01.ba_nextyard" = "<font color=\"rgb(215,255,255)\">Ok, allons vers la prochaine cour!"
		"ep_01.ba_nicework" = "<font color=\"rgb(215,255,255)\">Bon travail."
		"ep_01.ba_notrophy" = "<font color=\"rgb(215,255,255)\">Oh, bon... je n'ai pas d'armoire à médailles de toute façon."
		"ep_01.ba_ohmanapc" = "<font color=\"rgb(215,255,255)\">Oh non... des blindés!"
		"ep_01.ba_ohyeah01" = "<font color=\"rgb(215,255,255)\">Ouais!"
		"ep_01.ba_pressure" = "<font color=\"rgb(215,255,255)\">Eh bien, ça met la pression. Il faut avancer maintenant."
		"ep_01.ba_runfortrains" = "<font color=\"rgb(215,255,255)\">Allez vers les trains! Le Dr Freeman va s'assurer qu'il ne vous arrivera rien!"
		"ep_01.ba_safepath01" = "<font color=\"rgb(215,255,255)\">Le moyen le plus sûr pour aller à la gare est de passer par ce pont, puis par les toits."
		"ep_01.ba_safepath02" = "<font color=\"rgb(215,255,255)\">Vous deux, allez par-là."
		"ep_01.ba_safepath03" = "<font color=\"rgb(215,255,255)\">Je vais parcourir les rues pour voir si quelqu'un nous attend."
		"ep_01.ba_safepath04" = "<font color=\"rgb(215,255,255)\">On vous retrouve là-bas."
		"ep_01.ba_seeya" = "<font color=\"rgb(215,255,255)\">On se revoit quand on se revoit!"
		"ep_01.ba_seeyouatstation" = "<font color=\"rgb(215,255,255)\">On se voit à la gare!"
		"ep_01.ba_seeyououtthere" = "<font color=\"rgb(215,255,255)\">D'accord. Prenez soin de vous. Je vous rejoins là-bas."
		"ep_01.ba_sheswaiting" = "<font color=\"rgb(215,255,255)\">Elle vous attend."
		"ep_01.ba_soldierrpg" = "<font color=\"rgb(215,255,255)\">Oh merde, je crois bien que ce soldat s'est trouvé un lance-roquettes."
		"ep_01.ba_sorryguys" = "<font color=\"rgb(215,255,255)\">Désolé les gars! À bientôt!"
		"ep_01.ba_stayandpoint" = "<font color=\"rgb(215,255,255)\">Je reste ici pour indiquer le chemin vers les trains."
		"ep_01.ba_striderknees" = "<font color=\"rgb(215,255,255)\">Bon, voyons voir si vous pouvez descendre ce strider."
		"ep_01.ba_takedownstrider" = "<font color=\"rgb(215,255,255)\">Descendez le strider."
		"ep_01.ba_takeitdown" = "<font color=\"rgb(215,255,255)\">Allez-y, descendez-le, Gordon."
		"ep_01.ba_takeoutapc" = "<font color=\"rgb(215,255,255)\">Il faut détruire ce blindé transporteur de troupes, sinon personne ne pourra passer."
		"ep_01.ba_tellemdoc" = "<font color=\"rgb(215,255,255)\">Montrez-leur, Doc!"
		"ep_01.ba_thereyouare01" = "<font color=\"rgb(215,255,255)\">Ah, vous voilà!"
		"ep_01.ba_thereyouare02" = "<font color=\"rgb(215,255,255)\">Je me demandais si vous arriveriez à temps. "
		"ep_01.ba_tothetrains" = "<font color=\"rgb(215,255,255)\">Vers les trains, citoyens! Nous allons assurer votre sécurité jusque là-bas."
		"ep_01.ba_trainaboutfull" = "<font color=\"rgb(215,255,255)\">Le train est presque plein. On remplit celui-là et on fait monter les gens dans un autre!"
		"ep_01.ba_trynottolose" = "<font color=\"rgb(215,255,255)\">Écoutez, j'en ai pas beaucoup, alors essayez de ne pas le perdre, ok?"
		"ep_01.ba_woo" = "<font color=\"rgb(215,255,255)\">Ouais!"
		"ep_01.ba_wrinkleship" = "<font color=\"rgb(215,255,255)\">Un hélico! On avait vraiment pas besoin de ça."
		"ep_01.ba_yeah01" = "<font color=\"rgb(215,255,255)\">Ah, ah, ah, ouais!"
		"ep_01.ba_yougothim" = "<font color=\"rgb(215,255,255)\">Vous l'avez eu!"
		"ep_01.ba_youguyscoming" = "<font color=\"rgb(215,255,255)\">Vous venez?"
		"ep_01.eli_alyxno" = "<font color=\"rgb(255,208,172)\"><i>Alyx, non!"
		"ep_01.eli_andgordon01" = "<font color=\"rgb(255,208,172)\"><i>Gordon...."
		"ep_01.eli_andgordon02" = "<font color=\"rgb(255,208,172)\"><i>Prenez bien soin de ma fille... je compte sur vous."
		"ep_01.eli_checkin01" = "<font color=\"rgb(255,208,172)\"><i>Alyx, où es-tu?"
		"ep_01.eli_checkin02" = "<font color=\"rgb(255,208,172)\"><i>Oh, mon Dieu, dis-moi que tu es hors de la ville!"
		"ep_01.eli_comeinalyx01" = "<font color=\"rgb(255,208,172)\"><i>Alyx?"
		"ep_01.eli_comeinalyx02" = "<font color=\"rgb(255,208,172)\"><i>Alyx, es-tu là?"
		"ep_01.eli_comeinalyx03" = "<font color=\"rgb(255,208,172)\"><i>Alyx, entre!"
		"ep_01.eli_comeinalyx04" = "<font color=\"rgb(255,208,172)\"><i>Alyx?"
		"ep_01.eli_comeinalyx05" = "<font color=\"rgb(255,208,172)\"><i>Entre, ma chérie!"
		"ep_01.eli_dowhatyoumust01" = "<font color=\"rgb(255,208,172)\"><i>Ok, Alyx, ok, ok... promets-moi juste..."
		"ep_01.eli_dowhatyoumust02" = "<font color=\"rgb(255,208,172)\"><i>Promets-moi seulement que tu ne prendras aucun risque inutile."
		"ep_01.eli_isaacplease" = "<font color=\"rgb(255,208,172)\"><i>Isaac, s'il te plaît."
		"ep_01.eli_izzytalk" = "<font color=\"rgb(255,208,172)\"><i>Izzy, essaie un peu de la raisonner!"
		"ep_01.eli_kleiner" = "<font color=\"rgb(255,208,172)\"><i>Kleiner."
		"ep_01.eli_kleinerstop" = "<font color=\"rgb(255,208,172)\"><i>Kleiner! Non!"
		"ep_01.eli_loveyoutoo01" = "<font color=\"rgb(255,208,172)\"><i>Je t'aime aussi, ma chérie."
		"ep_01.eli_loveyoutoo02" = "<font color=\"rgb(255,208,172)\"><i>Je prierai pour toi."
		"ep_01.eli_loveyoutoo03" = "<font color=\"rgb(255,208,172)\"><i>Nous avons beaucoup à faire ici, et je ne peux rien faire sans toi."
		"ep_01.eli_shefoundyou01" = "<font color=\"rgb(255,208,172)\"><i>Tu as trouvé Gordon?"
		"ep_01.eli_shefoundyou02" = "<font color=\"rgb(255,208,172)\"><i>Je n'y crois pas."
		"ep_01.eli_shefoundyou03" = "<font color=\"rgb(255,208,172)\"><i>C'est... c'est impossible!"
		"ep_01.eli_shefoundyou04" = "<font color=\"rgb(255,208,172)\"><i>Écoute, vous devez tous les deux quitter la ville."
		"ep_01.eli_shefoundyou05" = "<font color=\"rgb(255,208,172)\"><i>La Citadelle peut exploser n'importe quand!"
		"ep_01.eli_uhizzy" = "<font color=\"rgb(255,208,172)\"><i>Izzy..."
		"ep_01.eli_uhizzy01" = "<font color=\"rgb(255,208,172)\"><i>Izzy..."
		"ep_01.eli_uhizzy02" = "<font color=\"rgb(255,208,172)\"><i>Izzy!"
		"ep_01.eli_uhizzy03" = "<font color=\"rgb(255,208,172)\"><i>Izzy?"
		"ep_01.eli_uhizzy04" = "<font color=\"rgb(255,208,172)\"><i>Izzy?"
		"ep_01.eli_uhizzy05" = "<font color=\"rgb(255,208,172)\"><i>Izzy?"
		"ep_01.eli_what01" = "<font color=\"rgb(255,208,172)\"><i>Quoi?!"
		"ep_01.kl_carefullamarr01" = "<font color=\"rgb(255,255,200)\"><i>Attention, Lamarr!"
		"ep_01.kl_carefullamarr02" = "<font color=\"rgb(255,255,200)\"><i>Ces lampes sont brûlantes!"
		"ep_01.kl_citadelabove01" = "<font color=\"rgb(255,255,200)\"><i>Oh mon Dieu, je suis désolé Eli mais... nul besoin de s'alarmer, n'est-ce pas?"
		"ep_01.kl_citadelabove02" = "<font color=\"rgb(255,255,200)\"><i>Alyx est totalement hors de danger maintenant."
		"ep_01.kl_damage" = "<font color=\"rgb(255,255,200)\"><i>La manière dont ces effets quantiques incroyablement rares se répandent vers le macroniveau de matière sera fascinante à observer, mais à distance. Les ravages sur le matériau cellulaire sont inimaginables."
		"ep_01.kl_damage01" = "<font color=\"rgb(255,255,200)\"><i>La manière dont ces effets quantiques incroyablement rares se répandent vers le macroniveau de matière sera fascinante à observer."
		"ep_01.kl_damage02" = "<font color=\"rgb(255,255,200)\"><i>Mais à distance."
		"ep_01.kl_damage03" = "<font color=\"rgb(255,255,200)\"><i>Les ravages sur le matériau cellulaire sont inimaginables."
		"ep_01.kl_damage04" = "<font color=\"rgb(255,255,200)\"><i>Néanmoins, je pense qu'il faudrait vraiment organiser une expédition pour récolter quelques échantillons après la fusion."
		"ep_01.kl_fellowcitizens01" = "<font color=\"rgb(255,255,200)\"><i>Chers concitoyens... habitants de Cité17 et des environs... j'entends par-là des habitants sensibles, évidemment, humains et autres, bien que je pense qu'il est inutile d'expliquer les faits récents survenus avec nos alliés Vortigaunts..."
		"ep_01.kl_fellowcitizens02" = "<font color=\"rgb(255,255,200)\"><i>Bref... Tout d'abord, la situation est urgente, si vous êtes toujours dans les limites de Cité17, nous vous conseillons vivement de quitter la ville immédiatement par le moyen le plus rapide à votre disposition. Nous avons remis en service la plupart des systèmes de transport par navette pour conduire les citoyens hors de la ville le plus rapidement possible. Nous avons également établi des camps et des zones de triage dans les environs."
		"ep_01.kl_fellowcitizens03" = "<font color=\"rgb(255,255,200)\"><i>Je répète, il faut évacuer la ville immédiatement."
		"ep_01.kl_fellowcitizens04" = "<font color=\"rgb(255,255,200)\"><i>Même s'il était certainement nécessaire de détruire le noyau du téléporteur de la Citadelle, nous avons détecté un effet secondaire plutôt fâcheux."
		"ep_01.kl_fellowcitizens05" = "<font color=\"rgb(255,255,200)\"><i>Il semble malheureusement inévitable que très bientôt, la Citadelle sera consumée par un évènement destructeur dont je ne peux estimer actuellement la magnitude avec précision, si ce n'est pour dire qu'il irradiera certainement un périmètre d'un rayon de plusieurs kilomètres."
		"ep_01.kl_fellowcitizens06" = "<font color=\"rgb(255,255,200)\"><i>Donc, je le répète, évacuez Cité17 tout de suite si ce n'est plus tôt! Je ne peux qu'insister fortement sur l'urgence de la situation!"
		"ep_01.kl_fellowcitizens07" = "<font color=\"rgb(255,255,200)\"><i>Heureusement, si vous êtes déjà dans une de nos zones de sécurité désignées, je me permets de souligner qu'un des effets secondaires bénéfiques de la destruction du réacteur est la disparition totale du champ de suppression reproductif du Cartel..."
		"ep_01.kl_fellowcitizens08" = "<font color=\"rgb(255,255,200)\"><i>Auparavant, la formation de certaines chaînes de protéines nécessaires au développement embryonnaire était sélectivement évitée... Ce n'est plus le cas... Pour ceux qui sont tentés, c'est un excellent moment pour procréer... Ce qui veut dire, pour être plus clair, que vous devriez songer sérieusement à participer au renouvellement de l'espèce... Nous devons tirer parti du temps dont nous disposons, car nous ignorons combien de temps encore nous serons en sécurité avant que le Cartel n'essaie de nous dominer à nouveau, ce qu'ils vont sûrement essayer de faire. "
		"ep_01.kl_fellowcitizens09" = "<font color=\"rgb(255,255,200)\"><i>Puisque c'est la première fois que nous avons l'occasion de parler ouvertement de l'influence maléfique du Cartel, il y a beaucoup à dire... et, en fait, j'espère instituer une série de bulletins utiles dans les jours qui viennent... Néanmoins, pour l'instant, nous allons malheureusement devoir nous contenter d'exposés relativement maigres."
		"ep_01.kl_fellowcitizens10" = "<font color=\"rgb(255,255,200)\"><i>La déstabilisation du réacteur de Cité17 a eu des répercussions qui n'étaient pas entièrement inattendues, bien que nous n'ayons pas osé en parler à l'avance. Le souffle destructeur a touché le réseau entier de réacteurs interdépendants de la Citadelle. Donc, pour l'instant, je crois que tous les portails du Cartel sont complètement en panne, ainsi que tous les systèmes de communication basés sur cette technologie. "
		"ep_01.kl_fellowcitizens11" = "<font color=\"rgb(255,255,200)\"><i>Bref, le Cartel est complètement isolé... les unités du Cartel actuellement stationnées sur Terre sont désormais isolées... Coincées!"
		"ep_01.kl_fellowcitizens12" = "<font color=\"rgb(255,255,200)\"><i>Cependant, cet état de fait n'est probablement que temporaire... comme nous l'avons déjà expérimenté à nos dépends, même la faille relativement étroite produite à Black Mesa a généré une ouverture pour nos ennemis, qu'ils ont été capables d'agrandir en s'engouffrant dedans en nombre toujours croissant..."
		"ep_01.kl_fellowcitizens13" = "<font color=\"rgb(255,255,200)\"><i>Outre les espèces complètement xénothériques, il reste sur Terre beaucoup d'alliés post-humains modifiés, qui feront tout leur possible pour rétablir les lignes de communication et d'approvisionnement avec les forces plus importantes. "
		"ep_01.kl_fellowcitizens14" = "<font color=\"rgb(255,255,200)\"><i>Quoiqu'il en soit, il y a plus d'espoir maintenant que durant ces dix dernières années."
		"ep_01.kl_fellowcitizens15" = "<font color=\"rgb(255,255,200)\"><i>Nous avons développé, en secret, plusieurs avancées technologiques et nous tenterons tout pour les déployer avant le retour du Cartel."
		"ep_01.kl_fellowcitizens16" = "<font color=\"rgb(255,255,200)\"><i>Nous continuons de rassembler et de former une nouvelle génération de scientifiques et de techniciens."
		"ep_01.kl_fellowcitizens17" = "<font color=\"rgb(255,255,200)\"><i>Car, ce que le Cartel craint le plus n'est pas une arme matérielle humaine, mais notre volonté, notre intelligence, notre capacité à répondre sélectivement et rationnellement à chacune de leurs vagues de terreur."
		"ep_01.kl_fellowcitizens18" = "<font color=\"rgb(255,255,200)\"><i>Nous avons le plus grand espoir dans l'esprit humain, même si nous savons avec quelle facilité il peut être anéanti. Nous avons vu familles et amis détruits par le Cartel. Certains de nos voisins ont accepté d'être cooptés et nettoyés de leur humanité, par la machine militaire..."
		"ep_01.kl_fellowcitizens19" = "<font color=\"rgb(255,255,200)\"><i>Et ceux qui ont résisté ont eu un destin plus terrible encore...."
		"ep_01.kl_fellowcitizens20" = "<font color=\"rgb(255,255,200)\"><i>Pourtant, je ne peux qu'insister sur l'importance de conserver notre humanité. Seul cela nous permettra d'être solidaires en prévision de leur inévitable retour... et de ce qui sera certainement une revanche inimaginable. "
		"ep_01.kl_fellowcitizens21" = "<font color=\"rgb(255,255,200)\"><i>Et... ah oui, si vous avez manqué une partie de ce message, il se répétera automatiquement jusqu'à que cela ne soit plus nécessaire.  "
		"ep_01.kl_fellowcitizens22" = "<font color=\"rgb(255,255,200)\"><i>Excusez-moi pour les erreurs ou omissions involontaires... Comme vous vous en doutez, nous avions peu de temps pour l'enregistrement, et aucun pour les répétitions. "
		"ep_01.kl_fellowcitizens23" = "<font color=\"rgb(255,255,200)\"><i>Qu'est-ce qu'il y a, Eli? Oh, OK..."
		"ep_01.kl_fellowcitizens24" = "<font color=\"rgb(255,255,200)\"><i>C'était le Dr Isaac Kleiner, autrefois membre de Black Mesa, aujourd'hui humble citoyen de la Terre, comme vous tous..."
		"ep_01.kl_fellowcitizens25" = "<font color=\"rgb(255,255,200)\"><i>J'ajouterai, pour ceux qui peuvent m'entendre, tandis que nous luttons contre les ténèbres de nos ennemis malfaisants, bienvenue à la lumière. "
		"ep_01.kl_fellowcitizens26" = "<font color=\"rgb(255,255,200)\"><i>Où ai-je mis cette calculatrice?"
		"ep_01.kl_hopeyoufar" = "<font color=\"rgb(255,255,200)\"><i>Oh Alyx, ma chère, j'espère que vous, au moins, vous êtes loin, très loin de la Citadelle."
		"ep_01.kl_imsorryeli01" = "<font color=\"rgb(255,255,200)\"><i>Désolé Eli, mais je ne vois pas d'autre moyen."
		"ep_01.kl_imsorryeli02" = "<font color=\"rgb(255,255,200)\"><i>On pourrait évacuer plus de citoyens...."
		"ep_01.kl_insufficient" = "<font color=\"rgb(255,255,200)\"><i>Comment? Mon Dieu! Nous n'avons plus le temps! Le noyau va bientôt fondre... Impossible de s'éloigner suffisamment sans d'abord... eh bien... seule une intervention directe dans le noyau pourrait peut-être retarder la réaction."
		"ep_01.kl_intothecore" = "<font color=\"rgb(255,255,200)\"><i>Dans le noyau, oui... Mais c'est bien trop dangereux... La chambre va être inondée de radiations...."
		"ep_01.kl_isthison" = "<font color=\"rgb(255,255,200)\"><i>Hmm... ça marche, là? Oui? Très bien, je... je ne suis pas vraiment un grand orateur mais... je... je ferai de mon mieux."
		"ep_01.kl_noquestion01" = "<font color=\"rgb(255,255,200)\"><i>Elle va effectivement exploser, j'en ai bien peur..."
		"ep_01.kl_noquestion02" = "<font color=\"rgb(255,255,200)\"><i>Nos capteurs à distance indiquent que le processus s'accélère vers un feu d'énergie vide."
		"ep_01.kl_noquestion03" = "<font color=\"rgb(255,255,200)\"><i>Nous approchons rapidement du point de non-retour...."
		"ep_01.kl_vicinity" = "<font color=\"rgb(255,255,200)\"><i>Toutes les personnes restées dans les environs subiront des événements énergétiques dont les effets sont hors de mes pouvoirs de spéculation."
		"ep_01.mo_intercept01" = "<font color=\"rgb(220,255,198)\"><i>Je suis presque sûre d'avoir trouvé l'emplacement du Projet."
		"ep_01.mo_intercept02" = "<font color=\"rgb(220,255,198)\"><i>C'est difficile d'estimer ce qui a survécu ou s'il reste quelque chose qui pourrait compromettre notre travail..."
		"ep_01.mo_intercept03" = "<font color=\"rgb(220,255,198)\"><i>... si le Cartel le découvrait."
		"ep_01.mo_intercept04" = "<font color=\"rgb(220,255,198)\"><i>Il faudra regarder cela de plus près, bien sûr, mais je serai capable de vous en dire plus d'ici quelques heures."
		"ep_01.mo_intercept05" = "<font color=\"rgb(220,255,198)\"><i>Si le site est là où nous le pensons, il doit se trouver à peu près..."
		"ep_01.mo_intercept06" = "<font color=\"rgb(220,255,198)\"><i>Qu'est-ce que c'est?"
		"ep_01.mo_intercept07" = "<font color=\"rgb(220,255,198)\"><i>Je vais abréger. On nous a peut-être repérés."
		"ep_01.gman_wellseeaboutthat" = "On verra ça."
		"ep1_citizen.cit_alert_antlions01_female" = "Bloquez les terriers!"
		"ep1_citizen.cit_alert_antlions02_female" = "Bloquez  les ouvertures!"
		"ep1_citizen.cit_alert_antlions03_female" = "D'où viennent toutes ces choses?"
		"ep1_citizen.cit_alert_antlions04_female" = "Mais comment rentrent-elles dans la ville?"
		"ep1_citizen.cit_alert_antlions05_female" = "Saletés d'insectes!"
		"ep1_citizen.cit_alert_antlions06_female" = "Au secours!"
		"ep1_citizen.cit_alert_antlions07_female" = "Comme si on en avait pas assez comme ça!"
		"ep1_citizen.cit_alert_antlions08_female" = "Elles arrivent!"
		"ep1_citizen.cit_alert_antlions09_female" = "Je les entends!"
		"ep1_citizen.cit_alert_antlions10_female" = "Ces fourmis-lions doivent venir par les souterrains."
		"ep1_citizen.cit_alert_antlions11_female" = "Vous les entendez... en dessous?"
		"ep1_citizen.cit_alert_antlions12_female" = "Défenses combinées pour les tenir à distance."
		"ep1_citizen.cit_alert_antlions13_female" = "Les fourmis-lions n'entraient jamais dans la ville avant... enfin, la semaine dernière."
		"ep1_citizen.cit_alert_antlions14_female" = "Au moins, les fourmis-lions nous détestent autant que le Cartel."
		"ep1_citizen.cit_alert_antlions15_female" = "D'abord le Cartel... puis ça!"
		"ep1_citizen.cit_alert_antlions16_female" = "Bouchez-moi ces trous!"
		"ep1_citizen.cit_alert_antlions17_female" = "Elles sortent par ces trous!"
		"ep1_citizen.cit_alert_antlions18_female" = "Sales bestioles!"
		"ep1_citizen.cit_alert_gunship01_female" = "Attention, il va tirer!"
		"ep1_citizen.cit_alert_gunship02_female" = "Il vient vers nous!"
		"ep1_citizen.cit_alert_gunship03_female" = "Abattez-le!"
		"ep1_citizen.cit_alert_gunship04_female" = "Il faut le descendre!"
		"ep1_citizen.cit_alert_gunship05_female" = "Détruisez-le avant qu'il ne revienne!"
		"ep1_citizen.cit_alert_gunship06_female" = "Il va nous déchiqueter!"
		"ep1_citizen.cit_alert_gunship07_female" = "Cette chose va nous dévorer!"
		"ep1_citizen.cit_alert_gunship08_female" = "On en vient presque à regretter les crabes de têtes."
		"ep1_citizen.cit_alert_head01_female" = "Des crabes de têtes!"
		"ep1_citizen.cit_alert_head02_female" = "C'est ça, un crabe de tête... pffah"
		"ep1_citizen.cit_alert_head03_female" = "Enlevez-moi ça! Enlevez-le!"
		"ep1_citizen.cit_alert_head04_female" = "Enlevez-le-moi!"
		"ep1_citizen.cit_alert_head05_female" = "Bweuh!"
		"ep1_citizen.cit_alert_head06_female" = "Merde!"
		"ep1_citizen.cit_alert_head07_female" = "C'est quoi, ça?"
		"ep1_citizen.cit_alert_head08_female" = "Ne le laissez pas vous sauter à la tête!"
		"ep1_citizen.cit_alert_rollers01_female" = "Des lamineurs!"
		"ep1_citizen.cit_alert_rollers02_female" = "Les laissez pas s'approcher!"
		"ep1_citizen.cit_alert_rollers03_female" = "Restez éloignés!"
		"ep1_citizen.cit_alert_soldier_above_female" = "Ils viennent d'en haut!"
		"ep1_citizen.cit_alert_soldier01_female" = "On est que des cibles maintenant pour eux."
		"ep1_citizen.cit_alert_soldier02_female" = "Mais pourquoi sont-ils encore là?"
		"ep1_citizen.cit_alert_soldier03_female" = "Leur leader est parti! Mais pourquoi est-ce qu'ils restent?"
		"ep1_citizen.cit_alert_soldier04_female" = "Des soldats!"
		"ep1_citizen.cit_alert_soldier05_female" = "C'est la milice!"
		"ep1_citizen.cit_alert_soldier06_female" = "Pourquoi ils sont pas partis avec le reste du Cartel?"
		"ep1_citizen.cit_alert_soldier07_female" = "Traîtres!"
		"ep1_citizen.cit_alert_zombie01_female" = "Des zombies!"
		"ep1_citizen.cit_alert_zombie02_female" = "C'est quoi... un zombie?"
		"ep1_citizen.cit_alert_zombie03_female" = "C'est quoi ça?"
		"ep1_citizen.cit_alert_zombie04_female" = "Tuez-le!"
		"ep1_citizen.cit_alert_zombie05_female" = "Mon Dieu, qu'est-ce que c'est que ça?"
		"ep1_citizen.cit_alert_zombie06_female" = "Tuez-les!"
		"ep1_citizen.cit_alert_zombie07_female" = "Visez la tête!"
		"ep1_citizen.cit_alert_zombie08_female" = "Merde! Je connais ce gars!"
		"ep1_citizen.cit_buddykilled01_female" = "Ça va?"
		"ep1_citizen.cit_buddykilled02_female" = "Mon Dieu... je vais y passer... j'en suis sûre..."
		"ep1_citizen.cit_buddykilled03_female" = "Non!"
		"ep1_citizen.cit_buddykilled04_female" = "Mon Dieu!"
		"ep1_citizen.cit_buddykilled05_female" = "Debout!"
		"ep1_citizen.cit_buddykilled06_female" = "Avancez!"
		"ep1_citizen.cit_buddykilled07_female" = "Oh merde!"
		"ep1_citizen.cit_buddykilled08_female" = "Homme à terre!"
		"ep1_citizen.cit_buddykilled09_female" = "Pourquoi?"
		"ep1_citizen.cit_buddykilled10_female" = "On a fait une terrible erreur..."
		"ep1_citizen.cit_buddykilled11_female" = "On va tous mourir!"
		"ep1_citizen.cit_buddykilled12_female" = "Ça y est... je suis énervée!"
		"ep1_citizen.cit_buddykilled13_female" = "Ils ont tué le nouveau!"
		"ep1_citizen.cit_buddykilled14_female" = "Continuez!"
		"ep1_citizen.cit_buddykilled15_female" = "Avancez!"
		"ep1_citizen.cit_comehere_female" = "Par ici!"
		"ep1_citizen.cit_denytrain01_female" = "Pas vous Freeman! Vous avez du travail."
		"ep1_citizen.cit_denytrain02_female" = "En arrière, Doc... Je suis sûre que vous voulez aider les autres à embarquer d'abord."
		"ep1_citizen.cit_denytrain03_female" = "Vous êtes supposé attendre que tout le monde soit à bord."
		"ep1_citizen.cit_denytrain04_female" = "Hé, Freeman.  Allez donc aider les autres."
		"ep1_citizen.cit_evac_casualty01_female" = "Vous pouvez faire mieux que ça!"
		"ep1_citizen.cit_evac_casualty02_female" = "Ils sont tous en train de mourir."
		"ep1_citizen.cit_evac_casualty03_female" = "On en a perdu un autre!"
		"ep1_citizen.cit_evac_casualty04_female" = "N'en perdez pas un autre, Freeman!"
		"ep1_citizen.cit_evac_casualty05_female" = "On n'y arrivera jamais comme ça!"
		"ep1_citizen.cit_evac_casualty06_female" = "Ouh, c'est pas passé loin!"
		"ep1_citizen.cit_evac_casualty07_female" = "Je croyais que vous deviez nous aider!"
		"ep1_citizen.cit_evac_casualty08_female" = "À l'aaaiiide!"
		"ep1_citizen.cit_evac_casualty09_female" = "C'est sans espoir!"
		"ep1_citizen.cit_evac_casualty10_female" = "Autant abandonner..."
		"ep1_citizen.cit_evac_casualty11_female" = "Nom de Dieu. Au secours!"
		"ep1_citizen.cit_evac_defendus01_female" = "Vous êtes supposé nous protéger!"
		"ep1_citizen.cit_evac_defendus02_female" = "Défendez-nous, Freeman!"
		"ep1_citizen.cit_evac_defendus03_female" = "Mais couvrez-nous, Freeman!"
		"ep1_citizen.cit_evac_defendus04_female" = "Nous dépendons de vous, Freeman!"
		"ep1_citizen.cit_evac_defendus05_female" = "Où est-ce qu'on doit aller, déjà?"
		"ep1_citizen.cit_evac_defendus06_female" = "Faut sortir d'ici!"
		"ep1_citizen.cit_evac_defendus07_female" = "Vers les trains!"
		"ep1_citizen.cit_evac_defendus08_female" = "J'aurais jamais cru être aussi heureuse de revoir ces trains."
		"ep1_citizen.cit_evac_defendus09_female" = "On a besoin d'aide ici, Freeman."
		"ep1_citizen.cit_evac_defendusvance_female" = "On a besoin d'aide ici, Vance."
		"ep1_citizen.cit_evac_enemies01_female" = "Ils arrivent!"
		"ep1_citizen.cit_evac_enemies02_female" = "Ils sont partout!"
		"ep1_citizen.cit_evac_no01_female" = "On suivra dès qu'on pourra."
		"ep1_citizen.cit_evac_no02_female" = "On reste pour voir si on peut aider quelqu'un à partir."
		"ep1_citizen.cit_evac_no03_female" = "S'il reste des gens dans la ville, on va essayer de les sauver."
		"ep1_citizen.cit_evac_no04_female" = "Partez sans nous. On a du boulot."
		"ep1_citizen.cit_evac_ok01_female" = "Bien sûr qu'on est avec vous!"
		"ep1_citizen.cit_evac_ok02_female" = "Nous venons avec vous."
		"ep1_citizen.cit_evac_ok03_female" = "Nous sortons le plus vite possible!"
		"ep1_citizen.cit_evac_ok04_female" = "Faut pas me le demander deux fois. Partons. "
		"ep1_citizen.cit_evac_thanks01_female" = "Merci, Freeman!"
		"ep1_citizen.cit_evac_thanks02_female" = "On a réussi, grâce à vous!"
		"ep1_citizen.cit_evac_thanks03_female" = "C'est pas passé loin."
		"ep1_citizen.cit_evac_thanks04_female" = "J'ai pensé qu'on n'y arriverait pas."
		"ep1_citizen.cit_evac_thanks05_female" = "Ouh, j'ai bien cru qu'on s'en sortirait pas."
		"ep1_citizen.cit_evac_thanksalyx_female" = "Merci, Alyx."
		"ep1_citizen.cit_getaboard01_female" = "Venez citoyens."
		"ep1_citizen.cit_getaboard02_female" = "Embarquez!"
		"ep1_citizen.cit_getaboard03_female" = "Foutons le camp!"
		"ep1_citizen.cit_getaboard04_female" = "Montez par ici!"
		"ep1_citizen.cit_getaboard05_female" = "À l'intérieur, vite!"
		"ep1_citizen.cit_getoffstreet_female" = "Vite! Partez d'ici! Le Cartel arrive dans cette zone."
		"ep1_citizen.cit_greatshot_female" = "Bien joué, Doc!"
		"ep1_citizen.cit_greet_alyx01_female" = "Hé! Vous êtes Alyx Vance!"
		"ep1_citizen.cit_greet_alyx02_female" = "Je vous connais!"
		"ep1_citizen.cit_greet_alyx03_female" = "Alyx Vance et Gordon Freeman! Vous êtes restés derrière pour nous protéger, c'est ça?"
		"ep1_citizen.cit_greet_alyx04_female" = "Qui êtes-vous, déjà?"
		"ep1_citizen.cit_greet_alyx05_female" = "J'espère que vous allez nous aider."
		"ep1_citizen.cit_greet_alyx06_female" = "Vous êtes la fille de Kleiner?"
		"ep1_citizen.cit_greet_alyx07_female" = "Oui, oui, ravie de vous voir. Où est Chien?"
		"ep1_citizen.cit_greet_alyx08_female" = "Alyx, mon Dieu, où est Freeman? Ah, il est ici..."
		"ep1_citizen.cit_greet_alyx09_female" = "Bonjour, Freeman. Et voici Madame, je suppose?"
		"ep1_citizen.cit_greet_alyx10_female" = "Alyx, Gordon, vous y êtes arrivés!"
		"ep1_citizen.cit_greet_alyx11_female" = "Alyx, franchement, vous croyez qu'on a une chance?"
		"ep1_citizen.cit_greet_alyx12_female" = "Bla, bla, bla... Pourquoi vous laissez pas parler Freeman pour une fois?"
		"ep1_citizen.cit_gunship_female" = "Oh non, un hélico! Courez!"
		"ep1_citizen.cit_heyoverhere_female" = "Hé! Par ici!"
		"ep1_citizen.cit_hurryup_female" = "Dépêchez-vous!"
		"ep1_citizen.cit_itsaraid_female" = "C'est un raid!"
		"ep1_citizen.cit_jump_female" = "Sautez!"
		"ep1_citizen.cit_kill01_female" = "Ouais!"
		"ep1_citizen.cit_kill02_female" = "Et un de moins."
		"ep1_citizen.cit_kill03_female" = "Et encore un."
		"ep1_citizen.cit_kill04_female" = "Ça, c'est du bon travail."
		"ep1_citizen.cit_kill05_female" = "Quelqu'un connaît une prière?"
		"ep1_citizen.cit_kill06_female" = "Vous avez vu ça?"
		"ep1_citizen.cit_kill07_female" = "De mieux en mieux."
		"ep1_citizen.cit_kill08_female" = "Bingo!"
		"ep1_citizen.cit_kill09_female" = "Prends ça!"
		"ep1_citizen.cit_kill10_female" = "Prends ça!"
		"ep1_citizen.cit_kill11_female" = "Ouais."
		"ep1_citizen.cit_kill12_female" = "Ouais."
		"ep1_citizen.cit_kill13_female" = "Bouffe ça!"
		"ep1_citizen.cit_kill14_female" = "Crève!"
		"ep1_citizen.cit_kill15_female" = "Un pour la résistance!"
		"ep1_citizen.cit_kill16_female" = "Brûlez en Enfer! Enfin, si vous y croyez."
		"ep1_citizen.cit_kill17_female" = "Crève en Enfer!"
		"ep1_citizen.cit_kill18_female" = "C'est comme ça que vous faites, hein Freeman?"
		"ep1_citizen.cit_letyouthru_female" = "Ok, on vous laisse passer."
		"ep1_citizen.cit_notice_gravgunkill01_female" = "Ouah! Bien joué, Dr Freeman."
		"ep1_citizen.cit_notice_gravgunkill02_female" = "Ça c'était quelque chose, Doc!"
		"ep1_citizen.cit_notice_gravgunkill03_female" = "Qu'est-ce que vous avez fait, là?"
		"ep1_citizen.cit_notice_gravgunkill04_female" = "Un jour vous me montrerez comment vous faites."
		"ep1_citizen.cit_pain01_female" = "[cri de douleur]"
		"ep1_citizen.cit_pain02_female" = "[cri de douleur]"
		"ep1_citizen.cit_pain03_female" = "[cri de douleur]"
