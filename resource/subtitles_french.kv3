		"ep_01.al_onlywayiknow01" = "<font color=\"rgb(255,212,255)\">On doit passer par ici."
		"ep_01.al_onlywayiknow02" = "<font color=\"rgb(255,212,255)\">Je ne connais que ce chemin pour arriver au noyau."
		"ep_01.al_podpull_01" = "<font color=\"rgb(255,212,255)\">Ça bouge."
		"ep_01.al_podpull_02" = "<font color=\"rgb(255,212,255)\">C'est ça. Tirez."
