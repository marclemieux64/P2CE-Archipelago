		"ep_01.al_idontgetit01" = "<font color=\"rgb(255,212,255)\">Je ne comprends pas."
		"ep_01.al_idontgetit02" = "<font color=\"rgb(255,212,255)\">Pourquoi est-ce qu'ils traînent par ici?"
		"ep_01.al_ihearturrets" = "<font color=\"rgb(255,212,255)\">Attention. J'entends les tourelles."
		"ep_01.al_itsthisway" = "<font color=\"rgb(255,212,255)\">Par ici."
		"ep_01.al_itsthiswaygordon" = "<font color=\"rgb(255,212,255)\">Par ici, Gordon."
		"ep_01.al_letsfigureout" = "<font color=\"rgb(255,212,255)\">Voyons voir."
		"ep_01.al_lift_stalkertough" = "<font color=\"rgb(255,212,255)\">Ce stalker complique les choses."
		"ep_01.al_lookatsize" = "<font color=\"rgb(255,212,255)\">Regardez la taille de cet endroit."
		"ep_01.al_notimetodealwiththis01" = "<font color=\"rgb(255,212,255)\">Pas le temps de s'occuper de ça."
