		"ep_02.al_junc_whattheywere02" = "<font color=\"rgb(255,212,255)\">C'était donc ça!"
		"ep_02.al_launch_allyours" = "<font color=\"rgb(255,212,255)\">A vous de jouer, Gordon."
		"ep_02.al_launch_attackstart01" = "<font color=\"rgb(255,212,255)\">Gordon!"
		"ep_02.al_launch_attackstart02" = "<font color=\"rgb(255,212,255)\">À l'aide!"
		"ep_02.al_launch_aw" = "<font color=\"rgb(255,212,255)\">Papa..."
		"ep_02.al_launch_barrier01" = "<font color=\"rgb(255,212,255)\">C'est tout alors?"
		"ep_02.al_launch_barrier02" = "<font color=\"rgb(255,212,255)\">La barrière fonctionne?"
		"ep_02.al_launch_beallright" = "<font color=\"rgb(255,212,255)\">T'inquiète pas papa. Ça va aller."
		"ep_02.al_launch_briefed01" = "<font color=\"rgb(255,212,255)\">Le Dr Kleiner m'a briefée sur tout ce qu'il a appris du paquet de données."
		"ep_02.al_launch_briefed02" = "<font color=\"rgb(255,212,255)\">J'expliquerai à Gordon en chemin."
		"ep_02.al_launch_briefed03" = "<font color=\"rgb(255,212,255)\">Dieu sait qu'on aura largement le temps."
		"ep_02.al_launch_bringherback01" = "<font color=\"rgb(255,212,255)\">C'est bon, papa. "
		"ep_02.al_launch_bringherback02" = "<font color=\"rgb(255,212,255)\">On va retrouver Judith et la ramener."
		"ep_02.al_launch_bringherback03" = "<font color=\"rgb(255,212,255)\">Allez, Gordon,"
		"ep_02.al_launch_bringherback04" = "<font color=\"rgb(255,212,255)\">l'hélico nous attend."
		"ep_02.al_launch_bringherback05" = "<font color=\"rgb(255,212,255)\">Allez, Gordon, l'hélico nous attend."
		"ep_02.al_launch_byedad01" = "<font color=\"rgb(255,212,255)\">Oui.   "
		"ep_02.al_launch_byedad02" = "<font color=\"rgb(255,212,255)\">Au revoir, Papa."
		"ep_02.al_launch_comeon" = "<font color=\"rgb(255,212,255)\">Allez, Gordon."
		"ep_02.al_launch_comeong" = "<font color=\"rgb(255,212,255)\">Allez, Gordon!"
		"ep_02.al_launch_comeonin" = "<font color=\"rgb(255,212,255)\">Montez, Gordon."
		"ep_02.al_launch_comeonportal" = "<font color=\"rgb(255,212,255)\">Allez!"
		"ep_02.al_launch_copterworking01" = "<font color=\"rgb(255,212,255)\">Pendant que vous vous amusiez, j'ai trouvé un vieil hélico que j'ai réussi à faire marcher."
		"ep_02.al_launch_copterworking02" = "<font color=\"rgb(255,212,255)\">Il est chargé, prêt à partir. "
		"ep_02.al_launch_copterworking03" = "<font color=\"rgb(255,212,255)\">Nous devrons partir pour le Borealis juste après le lancement."
		"ep_02.al_launch_copterworking04" = "<font color=\"rgb(255,212,255)\">On ne s'ennuie pas, hein?"
		"ep_02.al_launch_countingdog01" = "<font color=\"rgb(255,212,255)\">OK Chien!"
		"ep_02.al_launch_countingdog02" = "<font color=\"rgb(255,212,255)\">N'oublie pas, je compte sur toi."
