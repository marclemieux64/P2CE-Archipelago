		"ep_01.al_postcore_hardpartover" = "<font color=\"rgb(255,212,255)\">Eh bien. Le plus dur est fait."
		"ep_01.al_postcore_route" = "<font color=\"rgb(255,212,255)\">Je sais comment nous échapper."
		"ep_01.al_postcore_trainrunning01" = "<font color=\"rgb(255,212,255)\">Si les trains de la Citadelle marchent encore, on pourra peut-être sortir de la ville."
		"ep_01.al_postcore_trainrunning02" = "<font color=\"rgb(255,212,255)\">Je doute qu'il faille les suivre jusqu'au bout de la ligne, mieux vaut mettre de la distance entre nous et..."
		"ep_01.al_remindsmeofnp01" = "<font color=\"rgb(255,212,255)\">On dirait le téléporteur de Nova Prospekt."
