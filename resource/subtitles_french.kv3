		"ep_02.al_launch_pieta01j" = "<font color=\"rgb(255,212,255)\">Non..."
		"ep_02.al_launch_pieta01k" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta01l" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta01m" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta01n" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta01o" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta01p" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta01q" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu!"
		"ep_02.al_launch_pieta01r" = "<font color=\"rgb(255,212,255)\">Non."
		"ep_02.al_launch_pieta01s" = "<font color=\"rgb(255,212,255)\">Non... Ne me laisse pas."
		"ep_02.al_launch_pieta01t" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta01u" = "<font color=\"rgb(255,212,255)\">Papa."
		"ep_02.al_launch_pieta01v" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02a" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02b" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02c" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02d" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02e" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02f" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02g" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02h" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02i" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02j" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02k" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02l" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_pieta02m" = "<font color=\"rgb(255,212,255)\">[sanglot]"
		"ep_02.al_launch_portalclose" = "<font color=\"rgb(255,212,255)\">Le portail va s'ouvrir, mais le Dr Magnusson pense qu'on arrivera à temps pour l'en empêcher. "
		"ep_02.al_launch_portalwhoa01" = "<font color=\"rgb(255,212,255)\">Wow!   "
		"ep_02.al_launch_portalwhoa02" = "<font color=\"rgb(255,212,255)\">Oui! Oui!"
		"ep_02.al_launch_portalwhoa03" = "<font color=\"rgb(255,212,255)\">Oh!"
		"ep_02.al_launch_portalwhoa04" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu!"
		"ep_02.al_launch_praise01" = "<font color=\"rgb(255,212,255)\">Beau boulot."
		"ep_02.al_launch_praise02" = "<font color=\"rgb(255,212,255)\">Ouah, bien joué, Gordon."
		"ep_02.al_launch_praise03" = "<font color=\"rgb(255,212,255)\">Vous êtes vraiment mon héros."
		"ep_02.al_launch_push" = "<font color=\"rgb(255,212,255)\">Appuyez sur le bouton, Gordon."
		"ep_02.al_launch_readywaiting" = "<font color=\"rgb(255,212,255)\">L'hélico est prêt à décoller."
		"ep_02.al_launch_rightthisway" = "<font color=\"rgb(255,212,255)\">Par ici."
		"ep_02.al_launch_rushoff01" = "<font color=\"rgb(255,212,255)\">Dès que je reviens, je m'occupe de Chien et de ces mises à niveau."
		"ep_02.al_launch_seeusoff" = "<font color=\"rgb(255,212,255)\">Vous ne venez pas voir notre décollage?"
		"ep_02.al_launch_sigh01" = "<font color=\"rgb(255,212,255)\">[soupir]"
		"ep_02.al_launch_sigh02" = "<font color=\"rgb(255,212,255)\">[soupir]"
		"ep_02.al_launch_theredog" = "<font color=\"rgb(255,212,255)\">Chien! Te voilà!"
		"ep_02.al_launch_theymean" = "<font color=\"rgb(255,212,255)\">Ils veulent que vous appuyiez sur le bouton, Gordon."
		"ep_02.al_launch_thing01" = "<font color=\"rgb(255,212,255)\">A vous de jouer."
		"ep_02.al_launch_thing02" = "<font color=\"rgb(255,212,255)\">Lancez ce truc."
		"ep_02.al_launch_toohappy" = "<font color=\"rgb(255,212,255)\">Je parie que le Cartel est un peu vert maintenant."
		"ep_02.al_launch_upsetnut01" = "<font color=\"rgb(255,212,255)\">Qu'est-ce qu'il est bête... "
		"ep_02.al_launch_upsetnut02" = "<font color=\"rgb(255,212,255)\">Ne t'éloigne pas trop!"
		"ep_02.al_launch_wedidit01" = "<font color=\"rgb(255,212,255)\">Ça y est, Gordon! "
		"ep_02.al_launch_wedidit02" = "<font color=\"rgb(255,212,255)\">On a réussi!"
		"ep_02.al_launch_wedidit03" = "<font color=\"rgb(255,212,255)\">On a fermé le portail!"
		"ep_02.al_launch_wereback" = "<font color=\"rgb(255,212,255)\">Nous sommes là!"
		"ep_02.al_launch_whatdoing" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu !"
		"ep_02.al_launch_wow" = "<font color=\"rgb(255,212,255)\">Ouah..."
		"ep_02.al_launch_wowgord" = "<font color=\"rgb(255,212,255)\">Ouah... Gordon. Vous avez été fantastique."
		"ep_02.al_launch_wowgord_alt" = "<font color=\"rgb(255,212,255)\">Ouah... Gordon. Vous avez été fantastique. Je ne sais pas comment vous faites."
		"ep_02.al_rad_1stpowernowtrans01" = "<font color=\"rgb(255,212,255)\">Allons voir ce qu'on a chargé. J'espère que c'est un émetteur."
		"ep_02.al_rad_1stpowernowtrans02" = "<font color=\"rgb(255,212,255)\">Cherchons la salle de radio avant que d'autres chasseurs nous trouvent."
		"ep_02.al_rad_1stpowernowtrans03" = "<font color=\"rgb(255,212,255)\">À mon avis, la salle de radio doit être par ici."
		"ep_02.al_rad_allofem01" = "<font color=\"rgb(255,212,255)\">Je crois que c'est tout. "
		"ep_02.al_rad_allofem02" = "<font color=\"rgb(255,212,255)\">En tous cas, j'espère. "
		"ep_02.al_rad_another" = "<font color=\"rgb(255,212,255)\">En voilà un autre. "
		"ep_02.al_rad_atdoor" = "<font color=\"rgb(255,212,255)\">A la porte."
		"ep_02.al_rad_awayfromdoor01" = "<font color=\"rgb(255,212,255)\">La porte! "
		"ep_02.al_rad_awayfromdoor02" = "<font color=\"rgb(255,212,255)\">Eloignez-vous de la porte!"
		"ep_02.al_rad_backtocar" = "<font color=\"rgb(255,212,255)\">Retournons à la voiture."
		"ep_02.al_rad_bullets" = "<font color=\"rgb(255,212,255)\">Les balles n'ont aucun effet."
		"ep_02.al_rad_carefulok" = "<font color=\"rgb(255,212,255)\">Attention, OK?"
		"ep_02.al_rad_caught01" = "<font color=\"rgb(255,212,255)\">Bon, allez."
		"ep_02.al_rad_caught02" = "<font color=\"rgb(255,212,255)\">Je ne voudrais pas que mon père pense qu'on s'est fait avoir quand ça a sauté."
		"ep_02.al_rad_combing" = "<font color=\"rgb(255,212,255)\">Ils doivent être en train de passer les collines au peigne fin!"
		"ep_02.al_rad_comingthrough" = "<font color=\"rgb(255,212,255)\">Attention, il arrive!"
		"ep_02.al_rad_coverdoor" = "<font color=\"rgb(255,212,255)\">La porte! Couvrez la porte, Gordon!"
		"ep_02.al_rad_coverdoor01" = "<font color=\"rgb(255,212,255)\">La porte! "
		"ep_02.al_rad_coverdoor02" = "<font color=\"rgb(255,212,255)\">Couvrez la porte, Gordon! "
		"ep_02.al_rad_crap" = "<font color=\"rgb(255,212,255)\">Bon sang."
		"ep_02.al_rad_datauseless01" = "<font color=\"rgb(255,212,255)\">Ces données ne serviront à rien si le Cartel arrive avant nous à White Forest. "
		"ep_02.al_rad_datauseless02" = "<font color=\"rgb(255,212,255)\">Le portail va s'ouvrir en grand et ensuite..."
		"ep_02.al_rad_datauseless03" = "<font color=\"rgb(255,212,255)\">Il faut y aller..."
		"ep_02.al_rad_detour01" = "<font color=\"rgb(255,212,255)\">Euh... C'est pas par-là qu'on retourne au pont? "
		"ep_02.al_rad_detour02" = "<font color=\"rgb(255,212,255)\">On devrait retourner au complexe et voir où mène la route."
		"ep_02.al_rad_didyouhear" = "<font color=\"rgb(255,212,255)\">Vous avez entendu?"
		"ep_02.al_rad_didyousee" = "<font color=\"rgb(255,212,255)\">Vous avez vu?"
		"ep_02.al_rad_doorlock01" = "<font color=\"rgb(255,212,255)\">Bon, voilà."
		"ep_02.al_rad_doorlock02" = "<font color=\"rgb(255,212,255)\">Plus de courant."
		"ep_02.al_rad_doyouread01" = "<font color=\"rgb(255,212,255)\">Eh"
		"ep_02.al_rad_doyouread02" = "<font color=\"rgb(255,212,255)\">Allô?"
		"ep_02.al_rad_doyouread03" = "<font color=\"rgb(255,212,255)\">Répondez."
		"ep_02.al_rad_doyouread04" = "<font color=\"rgb(255,212,255)\">Allô?"
		"ep_02.al_rad_doyouread05" = "<font color=\"rgb(255,212,255)\">tu es là?"
		"ep_02.al_rad_doyouread06" = "<font color=\"rgb(255,212,255)\">White Forest, vous m'entendez?"
		"ep_02.al_rad_dreamed" = "<font color=\"rgb(255,212,255)\">Je ne pensais pas voir ce jour."
		"ep_02.al_rad_findradroom" = "<font color=\"rgb(255,212,255)\">Bon, cherchons la salle de radio."
		"ep_02.al_rad_findway" = "<font color=\"rgb(255,212,255)\">Vous pouvez trouver un chemin là-haut?"
		"ep_02.al_rad_foundcontrols01" = "<font color=\"rgb(255,212,255)\">J'ai trouvé les commandes de la porte! "
		"ep_02.al_rad_foundcontrols02" = "<font color=\"rgb(255,212,255)\">C'est parti!"
		"ep_02.al_rad_gateclosed01" = "<font color=\"rgb(255,212,255)\">Je dois ouvrir la porte pour qu'on puisse sortir. "
		"ep_02.al_rad_gateclosed02" = "<font color=\"rgb(255,212,255)\">Minute..."
		"ep_02.al_rad_gateclosed03" = "<font color=\"rgb(255,212,255)\">À mon avis, les commandes doivent se trouver par là."
		"ep_02.al_rad_gener" = "<font color=\"rgb(255,212,255)\">Des générateurs... du courant... On a tout ce qu'il faut?"
		"ep_02.al_rad_getouthere" = "<font color=\"rgb(255,212,255)\">Allons-y."
		"ep_02.al_rad_getpoweron01" = "<font color=\"rgb(255,212,255)\">Il faudrait rallumer le courant."
		"ep_02.al_rad_getpoweron02" = "<font color=\"rgb(255,212,255)\">Il faut acheminer du courant vers l'émetteur, Gordon."
		"ep_02.al_rad_getready" = "<font color=\"rgb(255,212,255)\">Non, pas nous. Le Cartel! Tenez-vous prêts!"
		"ep_02.al_rad_good" = "<font color=\"rgb(255,212,255)\">Bien."
		"ep_02.al_rad_goodpoweron" = "<font color=\"rgb(255,212,255)\">Bien... Le courant fonctionne."
		"ep_02.al_rad_headingyourway" = "<font color=\"rgb(255,212,255)\">Oui, je sais! Mais le Cartel se dirige vers vous!"
		"ep_02.al_rad_hellodoc01" = "<font color=\"rgb(255,212,255)\">Allô. Dr Magnusson?"
		"ep_02.al_rad_hellodoc02" = "<font color=\"rgb(255,212,255)\">Allô?"
		"ep_02.al_rad_hellodoc03" = "<font color=\"rgb(255,212,255)\">tu es là?"
		"ep_02.al_rad_hellout" = "<font color=\"rgb(255,212,255)\">Partons vite d'ici."
		"ep_02.al_rad_help" = "<font color=\"rgb(255,212,255)\">À l'aide, Gordon!"
		"ep_02.al_rad_herecomes" = "<font color=\"rgb(255,212,255)\">Le voilà."
		"ep_02.al_rad_hereitis01" = "<font color=\"rgb(255,212,255)\">C'est bon."
		"ep_02.al_rad_hereitis02" = "<font color=\"rgb(255,212,255)\">OK..."
		"ep_02.al_rad_hereitis03" = "<font color=\"rgb(255,212,255)\">Ça devrait aller..."
		"ep_02.al_rad_hereletme" = "<font color=\"rgb(255,212,255)\">Là, je vais ouvrir la porte."
		"ep_02.al_rad_hideinhere" = "<font color=\"rgb(255,212,255)\">Gordon, cachez-vous. "
		"ep_02.al_rad_hideinhere01" = "<font color=\"rgb(255,212,255)\">Gordon..."
		"ep_02.al_rad_hideinhere02" = "<font color=\"rgb(255,212,255)\">Cachez-vous!"
		"ep_02.al_rad_hopehold" = "<font color=\"rgb(255,212,255)\">Pourvu que ça tienne suffisamment pour charger l'émetteur."
		"ep_02.al_rad_inheresomewhere" = "<font color=\"rgb(255,212,255)\">Il doit y avoir un émetteur par ici. Il faut le trouver."
		"ep_02.al_rad_killedit" = "<font color=\"rgb(255,212,255)\">On l'a tué! On l'a tué! "
		"ep_02.al_rad_killedyeah" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_rad_location01" = "<font color=\"rgb(255,212,255)\">Non, le Cartel se dirige vers vous."
		"ep_02.al_rad_location02" = "<font color=\"rgb(255,212,255)\">Ils vont arriver!"
		"ep_02.al_rad_lookforradio01" = "<font color=\"rgb(255,212,255)\">Il doit y avoir un émetteur par ici, Gordon."
		"ep_02.al_rad_lookforradio02" = "<font color=\"rgb(255,212,255)\">Cherchons un émetteur par ici."
		"ep_02.al_rad_lookforradio03" = "<font color=\"rgb(255,212,255)\">Il faut trouver une salle de radio."
		"ep_02.al_rad_lookout" = "<font color=\"rgb(255,212,255)\">Je fais le guet pendant que vous fouillez dedans."
		"ep_02.al_rad_lookup" = "<font color=\"rgb(255,212,255)\">Eh, là-haut! Un pylône radio."
		"ep_02.al_rad_message" = "<font color=\"rgb(255,212,255)\">C'est un de ces trucs qu'on a vus dans le message de Judith."
		"ep_02.al_rad_musthavetrans" = "<font color=\"rgb(255,212,255)\">Il doit y avoir un émetteur dans un de ces bâtiments."
		"ep_02.al_rad_needdad" = "<font color=\"rgb(255,212,255)\">Je dois parler à mon père."
		"ep_02.al_rad_needwarn01" = "<font color=\"rgb(255,212,255)\">Nous devons alerter White Forest."
		"ep_02.al_rad_neverpower01" = "<font color=\"rgb(255,212,255)\">J'ai l'impression que le courant ne veut plus se rétablir."
		"ep_02.al_rad_neverpower02" = "<font color=\"rgb(255,212,255)\">Il faut reprendre la route."
		"ep_02.al_rad_nobody01" = "<font color=\"rgb(255,212,255)\">Il n'y a personne. "
		"ep_02.al_rad_nobody02" = "<font color=\"rgb(255,212,255)\">Depuis combien de temps est-ce désert?"
		"ep_02.al_rad_notthistime" = "<font color=\"rgb(255,212,255)\">Pas cette fois. "
		"ep_02.al_rad_notthistime_loud" = "<font color=\"rgb(255,212,255)\">Pas cette fois! "
		"ep_02.al_rad_nottough" = "<font color=\"rgb(255,212,255)\">Ils ne sont pas si coriaces que ça!"
		"ep_02.al_rad_notwastetime" = "<font color=\"rgb(255,212,255)\">Ne perdons pas de temps. Il faut appeler White Forest. "
		"ep_02.al_rad_now" = "<font color=\"rgb(255,212,255)\">Maintenant! "
		"ep_02.al_rad_offagain" = "<font color=\"rgb(255,212,255)\">Hé! Ça a coupé! Qu'est-ce que vous avez fait?"
		"ep_02.al_rad_offguard" = "<font color=\"rgb(255,212,255)\">Ils ne m'auront plus par surprise. "
		"ep_02.al_rad_oldblue" = "<font color=\"rgb(255,212,255)\">Bien joué avec le chasseur."
		"ep_02.al_rad_omgc17" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu."
		"ep_02.al_rad_omgc17a" = "<font color=\"rgb(255,212,255)\">Le portail s'agrandit. "
		"ep_02.al_rad_omgc17b" = "<font color=\"rgb(255,212,255)\">Pourvu qu'on ait le temps de l'éteindre."
		"ep_02.al_rad_onedown" = "<font color=\"rgb(255,212,255)\">Un de moins!"
		"ep_02.al_rad_onemoredown" = "<font color=\"rgb(255,212,255)\">Encore un de moins!"
		"ep_02.al_rad_onlyonemore" = "<font color=\"rgb(255,212,255)\">Plus qu'un!"
		"ep_02.al_rad_onroof" = "<font color=\"rgb(255,212,255)\">Écoutez, c'est sur le toit!"
		"ep_02.al_rad_onroof01" = "<font color=\"rgb(255,212,255)\">Écoutez."
		"ep_02.al_rad_onroof02" = "<font color=\"rgb(255,212,255)\">C'est sur le toit. "
		"ep_02.al_rad_onuphere" = "<font color=\"rgb(255,212,255)\">OK! Il y a du courant ici!"
		"ep_02.al_rad_pickuproad" = "<font color=\"rgb(255,212,255)\">Continuons, on verra si on peut récupérer la route plus loin."
		"ep_02.al_rad_posthunters01" = "<font color=\"rgb(255,212,255)\">Essayons l'émetteur avant qu'il n'en arrive d'autres."
		"ep_02.al_rad_posthunters02" = "<font color=\"rgb(255,212,255)\">Essayons l'émetteur avant qu'il n'en arrive d'autres."
		"ep_02.al_rad_postkill01" = "<font color=\"rgb(255,212,255)\">C'est bon!On les a tous eus! Ouais! "
		"ep_02.al_rad_postkill02" = "<font color=\"rgb(255,212,255)\">Ils réfléchiront avant de s'en prendre encore à nous."
		"ep_02.al_rad_postkill03" = "<font color=\"rgb(255,212,255)\">Pas vrai?"
		"ep_02.al_rad_postkill04" = "<font color=\"rgb(255,212,255)\">Plus jamais ça."
		"ep_02.al_rad_postkill05" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_rad_postkill06" = "<font color=\"rgb(255,212,255)\">Bon, ce n'est pas tout, mais..."
		"ep_02.al_rad_postkill07" = "<font color=\"rgb(255,212,255)\">Nous devons envoyer notre alerte et continuer. "
		"ep_02.al_rad_powerboxagain01" = "<font color=\"rgb(255,212,255)\">Vérifions ce générateur une nouvelle fois."
		"ep_02.al_rad_powerboxagain02" = "<font color=\"rgb(255,212,255)\">C'est peut-être juste instable."
		"ep_02.al_rad_powerlines" = "<font color=\"rgb(255,212,255)\">Eh, ces lignes électriques viennent de ce bâtiment."
		"ep_02.al_rad_powerout01" = "<font color=\"rgb(255,212,255)\">Bien, voilà l'émetteur. "
		"ep_02.al_rad_powerout02" = "<font color=\"rgb(255,212,255)\">Mm... Pas de courant. "
		"ep_02.al_rad_powerout03" = "<font color=\"rgb(255,212,255)\">Essayons de rétablir l'électricité. "
		"ep_02.al_rad_ready" = "<font color=\"rgb(255,212,255)\">Je suis prête! "
		"ep_02.al_rad_readyforyou" = "<font color=\"rgb(255,212,255)\">Je suis prête. "
		"ep_02.al_rad_readythistime" = "<font color=\"rgb(255,212,255)\">Je les attends cette fois."
		"ep_02.al_rad_roadblock" = "<font color=\"rgb(255,212,255)\">Il va falloir trouver un détour."
		"ep_02.al_rad_roadpast01" = "<font color=\"rgb(255,212,255)\">On dirait que la route va nous emmener au-delà."
		"ep_02.al_rad_roadpast02" = "<font color=\"rgb(255,212,255)\">Allons-y."
		"ep_02.al_rad_roadsout" = "<font color=\"rgb(255,212,255)\">On aurait dû se douter que ça n'allait pas être une simple promenade. On va devoir faire un détour. "
		"ep_02.al_rad_seeifworking" = "<font color=\"rgb(255,212,255)\">Allez, Gordon. Voyons si l'émetteur fonctionne."
		"ep_02.al_rad_seestower01" = "<font color=\"rgb(255,212,255)\">Un pylône de radio. "
		"ep_02.al_rad_seestower02" = "<font color=\"rgb(255,212,255)\">Si ça marche, il faudra alerter White Forest. "
		"ep_02.al_rad_seestower03" = "<font color=\"rgb(255,212,255)\">Ils ne savent pas que le Cartel se dirige vers eux. "
		"ep_02.al_rad_setback" = "<font color=\"rgb(255,212,255)\">On a eu un contretemps."
		"ep_02.al_rad_sh" = "<font color=\"rgb(255,212,255)\">Chut. "
		"ep_02.al_rad_shit" = "<font color=\"rgb(255,212,255)\">Oh, chiotte."
		"ep_02.al_rad_signweak01" = "<font color=\"rgb(255,212,255)\">Oh, le signal est vraiment faible."
		"ep_02.al_rad_signweak02" = "<font color=\"rgb(255,212,255)\">Bon, essayons."
		"ep_02.al_rad_stickby01" = "<font color=\"rgb(255,212,255)\">Retournez au générateur, OK?"
		"ep_02.al_rad_stickby02" = "<font color=\"rgb(255,212,255)\">Je reste à la radio au cas où ils reviendraient en ligne."
		"ep_02.al_rad_stickby03" = "<font color=\"rgb(255,212,255)\">On ne pourra pas parler très longtemps, même si vous rétablissez le courant."
		"ep_02.al_rad_stunned" = "<font color=\"rgb(255,212,255)\">Vous l'avez paralysé."
		"ep_02.al_rad_takedown" = "<font color=\"rgb(255,212,255)\">Détruisez-le!"
		"ep_02.al_rad_takethat01" = "<font color=\"rgb(255,212,255)\">Prends ça!"
		"ep_02.al_rad_takethese" = "<font color=\"rgb(255,212,255)\">Gordon, on prend ça."
		"ep_02.al_rad_thatsit" = "<font color=\"rgb(255,212,255)\">Voilà."
		"ep_02.al_rad_theyreback" = "<font color=\"rgb(255,212,255)\">Ce qui nous a attaqués dans les mines... des chasseurs, ils sont là."
		"ep_02.al_rad_theyreback01" = "<font color=\"rgb(255,212,255)\">Ce qui nous a attaqués dans les mines..."
		"ep_02.al_rad_theyreback02" = "<font color=\"rgb(255,212,255)\">les chasseurs..."
		"ep_02.al_rad_theyreback03" = "<font color=\"rgb(255,212,255)\">Ils sont là. "
		"ep_02.al_rad_thick01" = "<font color=\"rgb(255,212,255)\">Ça devait être un groupe d'éclaireurs. "
		"ep_02.al_rad_thick02" = "<font color=\"rgb(255,212,255)\">Envoyons notre alerte et déguerpissons."
		"ep_02.al_rad_thisis" = "<font color=\"rgb(255,212,255)\">Ici... Aly... [interruption]"
		"ep_02.al_rad_thisisav01" = "<font color=\"rgb(255,212,255)\">Non, ici Alyx Vance."
		"ep_02.al_rad_thisisav02" = "<font color=\"rgb(255,212,255)\">Le Dr Magnusson, c'est vous?"
		"ep_02.al_rad_threedown01" = "<font color=\"rgb(255,212,255)\">On a réussi!"
		"ep_02.al_rad_throw" = "<font color=\"rgb(255,212,255)\">Jetez-lui quelque chose!"
		"ep_02.al_rad_timetogo01" = "<font color=\"rgb(255,212,255)\">Allons à White Forest, ils ont besoin de nous."
		"ep_02.al_rad_timetogo02" = "<font color=\"rgb(255,212,255)\">En route, Gordon."
		"ep_02.al_rad_tough" = "<font color=\"rgb(255,212,255)\">Bon sang, ils sont coriaces."
		"ep_02.al_rad_trypowerbox" = "<font color=\"rgb(255,212,255)\">Essayez ce générateur, Gordon."
		"ep_02.al_rad_trysignal" = "<font color=\"rgb(255,212,255)\">Ça va être difficile, mais il faut qu'on essaie d'avoir un signal."
		"ep_02.al_rad_twomore" = "<font color=\"rgb(255,212,255)\">Bon sang. Encore d'autres?"
		"ep_02.al_rad_use_findtrans01" = "<font color=\"rgb(255,212,255)\">Il faut trouver la salle de radio, comme ça on pourra avertir White Forest de l'arrivée imminente du Cartel."
		"ep_02.al_rad_use_findtrans02" = "<font color=\"rgb(255,212,255)\">Personne ne sait à White Forest que le Cartel arrive. Il faut les avertir."
		"ep_02.al_rad_use_powertotrans01" = "<font color=\"rgb(255,212,255)\">Il faut restaurer le courant pour l'émetteur."
		"ep_02.al_rad_use_powertotrans02" = "<font color=\"rgb(255,212,255)\">Il faut alimenter l'émetteur."
		"ep_02.al_rad_usecar" = "<font color=\"rgb(255,212,255)\">Il nous faut la voiture pour arriver à White Forest avant le Cartel."
		"ep_02.al_rad_useless" = "<font color=\"rgb(255,212,255)\">Les balles ne font rien!"
		"ep_02.al_rad_usetrans" = "<font color=\"rgb(255,212,255)\">Allez, voyons si leur émetteur fonctionne."
		"ep_02.al_rad_warn" = "<font color=\"rgb(255,212,255)\">Pourvu qu'ils aient reçu mon alerte."
		"ep_02.al_rad_wecandothis" = "<font color=\"rgb(255,212,255)\">On peut le faire! "
		"ep_02.al_rad_wfcomein01" = "<font color=\"rgb(255,212,255)\">White Forest, répondez."
		"ep_02.al_rad_wfcomein02" = "<font color=\"rgb(255,212,255)\">White Forest, vous m'entendez?"
		"ep_02.al_rad_wfcomein03" = "<font color=\"rgb(255,212,255)\">White Forest, vous m'entendez?"
		"ep_02.al_rad_whatwasthat" = "<font color=\"rgb(255,212,255)\">C'était quoi, ça?"
		"ep_02.al_rad_wonder_alt01" = "<font color=\"rgb(255,212,255)\">Je me demande s'il a reçu le message. "
		"ep_02.al_rad_wonder_alt02" = "<font color=\"rgb(255,212,255)\">Bon, il vaut mieux reprendre la route."
		"ep_02.al_rad_wonder01" = "<font color=\"rgb(255,212,255)\">Je me demande s'il a reçu le message. "
		"ep_02.al_rad_wonder02" = "<font color=\"rgb(255,212,255)\">On devrait reprendre la route."
		"ep_02.al_radar_blip01" = "<font color=\"rgb(255,212,255)\">Blip."
		"ep_02.al_radar_blip02" = "<font color=\"rgb(255,212,255)\">Blip."
		"ep_02.al_radar_blip03" = "<font color=\"rgb(255,212,255)\">[rire]"
		"ep_02.al_radar_blip04" = "<font color=\"rgb(255,212,255)\">Blip blip."
		"ep_02.al_radar_building01" = "<font color=\"rgb(255,212,255)\">D'après le radar, il y a une radiobalise dans ce bâtiment."
		"ep_02.al_radar_building02" = "<font color=\"rgb(255,212,255)\">La cache doit être dans ce bâtiment."
		"ep_02.al_radar_building03" = "<font color=\"rgb(255,212,255)\">Je vais surveiller ici pendant que vous cherchez la cache."
		"ep_02.al_radar_colder01" = "<font color=\"rgb(255,212,255)\">Ça refroidit."
		"ep_02.al_radar_colder02" = "<font color=\"rgb(255,212,255)\">C'est plus à l'écran."
		"ep_02.al_radar_colder03" = "<font color=\"rgb(255,212,255)\">Fini."
		"ep_02.al_radar_colder04" = "<font color=\"rgb(255,212,255)\">Perdu."
		"ep_02.al_radar_followup01" = "<font color=\"rgb(255,212,255)\">Vous voulez vérifier?"
		"ep_02.al_radar_followup02" = "<font color=\"rgb(255,212,255)\">Vous voulez jeter un oeil?"
		"ep_02.al_radar_followup03" = "<font color=\"rgb(255,212,255)\">On devrait vérifier."
		"ep_02.al_radar_followup04" = "<font color=\"rgb(255,212,255)\">Vous voulez jeter un oeil?"
		"ep_02.al_radar_getgoing01" = "<font color=\"rgb(255,212,255)\">Gordon, il faut y aller."
		"ep_02.al_radar_getgoing02" = "<font color=\"rgb(255,212,255)\">On devrait peut-être filer. "
		"ep_02.al_radar_getgoing03" = "<font color=\"rgb(255,212,255)\">Ça va là-dedans?"
		"ep_02.al_radar_hiddencache01" = "<font color=\"rgb(255,212,255)\">Hmm... On reçoit bien un signal mais on ne voit rien."
		"ep_02.al_radar_hiddencache02" = "<font color=\"rgb(255,212,255)\">Qu'en pensez-vous, Gordon?"
		"ep_02.al_radar_launcherhandy" = "<font color=\"rgb(255,212,255)\">Oh, un lance-roquettes! Ça pourra servir!"
		"ep_02.al_radar_multi" = "<font color=\"rgb(255,212,255)\">Ouah, le radar s'affole!"
		"ep_02.al_radar_newdetect01" = "<font color=\"rgb(255,212,255)\">Eh, le radar capte un truc."
		"ep_02.al_radar_newdetect02" = "<font color=\"rgb(255,212,255)\">J'ai quelque chose sur le radar."
		"ep_02.al_radar_newdetect03" = "<font color=\"rgb(255,212,255)\">Le radar s'est éteint, Gordon."
		"ep_02.al_radar_newdetect04" = "<font color=\"rgb(255,212,255)\">Revoilà le radar."
		"ep_02.al_radar_newdetect05" = "<font color=\"rgb(255,212,255)\">C'est quoi ce truc  sur le radar?"
		"ep_02.al_radar_newpanel01" = "<font color=\"rgb(255,212,255)\">Le nouveau panneau se met en route."
		"ep_02.al_radar_newpanel02" = "<font color=\"rgb(255,212,255)\">On m'a dit que les caches rebelles y sont cryptées... Ça peut servir."
		"ep_02.al_radar_newpanel03" = "<font color=\"rgb(255,212,255)\">Voyons ce que le radar repère."
		"ep_02.al_radar_nicejob" = "<font color=\"rgb(255,212,255)\">Bien joué. Ça pourra servir."
		"ep_02.al_radar_plususe01" = "<font color=\"rgb(255,212,255)\">On devrait peut-être filer. Il faut qu'on rejoigne White Forest."
		"ep_02.al_radar_plususe02" = "<font color=\"rgb(255,212,255)\">Je n'en sais pas. C'est plutôt de votre domaine, non?"
		"ep_02.al_radar_regain01" = "<font color=\"rgb(255,212,255)\">C'est reparti."
		"ep_02.al_radar_regain02" = "<font color=\"rgb(255,212,255)\">Il le repère encore."
		"ep_02.al_radar_regain03" = "<font color=\"rgb(255,212,255)\">Il a encore reçu un signal."
		"ep_02.al_radar_warmer01" = "<font color=\"rgb(255,212,255)\">On se rapproche."
		"ep_02.al_radar_warmer02" = "<font color=\"rgb(255,212,255)\">Ça se réchauffe."
		"ep_02.al_radar_warmer03" = "<font color=\"rgb(255,212,255)\">On est pile dessus."
		"ep_02.al_radar_warmer04" = "<font color=\"rgb(255,212,255)\">C'est quelque part par ici."
		"ep_02.al_radar_withoutbeacon" = "<font color=\"rgb(255,212,255)\">Sans la balise, on n'aurait jamais su que c'était ici."
		"ep_02.al_radar_worthtrouble" = "<font color=\"rgb(255,212,255)\">Pffff... Ça n'en valait sûrement pas la peine. Allons-y."
		"ep_02.al_radar_youfoundcache" = "<font color=\"rgb(255,212,255)\">Ah, vous l'avez trouvée. "
		"ep_02.al_radar_zombiestuff" = "<font color=\"rgb(255,212,255)\">Oh, oh! Les zombies veulent reprendre leurs affaires."
		"ep_02.al_rbed_aportalstorm" = "<font color=\"rgb(255,212,255)\">Un ouragan de portail! "
		"ep_02.al_rbed_areyouok" = "<font color=\"rgb(255,212,255)\">Ça va? "
		"ep_02.al_rbed_backuptracks" = "<font color=\"rgb(255,212,255)\">Il va falloir reprendre notre itinéraire initial vers les rails mais, en attendant, on peut peut-être chercher ces Vortigaunts."
		"ep_02.al_rbed_bridge" = "<font color=\"rgb(255,212,255)\">Attention! Le pont!"
		"ep_02.al_rbed_callinggordon01" = "<font color=\"rgb(255,212,255)\">Gordon! "
		"ep_02.al_rbed_callinggordon02" = "<font color=\"rgb(255,212,255)\">Gordon! "
		"ep_02.al_rbed_callinggordon03" = "<font color=\"rgb(255,212,255)\">Gordon! "
		"ep_02.al_rbed_callinggordon04" = "<font color=\"rgb(255,212,255)\">Gordon! "
		"ep_02.al_rbed_checkin" = "<font color=\"rgb(255,212,255)\">Bon vérifions. "
		"ep_02.al_rbed_commctr01" = "<font color=\"rgb(255,212,255)\">OK. Un centre de communication. "
		"ep_02.al_rbed_commctr02" = "<font color=\"rgb(255,212,255)\">Voyons si on peut envoyer un message à mon père. "
		"ep_02.al_rbed_cover" = "<font color=\"rgb(255,212,255)\">Mieux vaut en profiter pour se mettre à couvert pour l'instant, pour échapper aux survols. "
		"ep_02.al_rbed_didntseeyou01" = "<font color=\"rgb(255,212,255)\">Comme je ne vous trouvais pas, j'ai cru... "
		"ep_02.al_rbed_didntseeyou02" = "<font color=\"rgb(255,212,255)\">Je sais, je sais. Je n'aurais pas dû m'inquiéter. "
		"ep_02.al_rbed_didtrick" = "<font color=\"rgb(255,212,255)\">Ça a marché. Merci. "
		"ep_02.al_rbed_didtrick02" = "<font color=\"rgb(255,212,255)\">Ça a marché. Merci. "
		"ep_02.al_rbed_didyouhear" = "<font color=\"rgb(255,212,255)\">Vous avez entendu? "
		"ep_02.al_rbed_expectmore01" = "<font color=\"rgb(255,212,255)\">À mon avis, il y en aura d'autres..."
		"ep_02.al_rbed_expectmore02" = "<font color=\"rgb(255,212,255)\">Ça recommence comme aux premiers jours."
		"ep_02.al_rbed_findcover" = "<font color=\"rgb(255,212,255)\">Il faut se mettre à couvert. "
		"ep_02.al_rbed_firstdays01" = "<font color=\"rgb(255,212,255)\">Un ouragan de portails! "
		"ep_02.al_rbed_firstdays02" = "<font color=\"rgb(255,212,255)\">Ça recommence comme aux premiers jours."
		"ep_02.al_rbed_gatenags01" = "<font color=\"rgb(255,212,255)\">Allez, Gordon  Ouvrez la porte."
		"ep_02.al_rbed_gatenags02" = "<font color=\"rgb(255,212,255)\">Tant qu'ils font des balayages aériens, il faut qu'on passe par les mines."
		"ep_02.al_rbed_gatenags03" = "<font color=\"rgb(255,212,255)\">Vous pourriez peut-être essayer d'ouvrir cette porte. "
		"ep_02.al_rbed_gatenags04" = "<font color=\"rgb(255,212,255)\">On dirait qu'on peut entrer dans les mines par ici. Si seulement on pouvait ouvrir cette porte."
		"ep_02.al_rbed_gatenags05" = "<font color=\"rgb(255,212,255)\">Vous voyez une commande pour la porte, Gordon?"
		"ep_02.al_rbed_gatenags06" = "<font color=\"rgb(255,212,255)\">Ouvrez la porte, Gordon!"
		"ep_02.al_rbed_giveupnow01" = "<font color=\"rgb(255,212,255)\">Bon, il faut continuer. "
		"ep_02.al_rbed_giveupnow02" = "<font color=\"rgb(255,212,255)\">Je parie que le Cartel ne nous a pas oubliés. "
		"ep_02.al_rbed_gladtosee" = "<font color=\"rgb(255,212,255)\">Vous ne pouvez pas savoir comme j'étais contente de vous voir là."
		"ep_02.al_rbed_gordon" = "<font color=\"rgb(255,212,255)\">Gordon?"
		"ep_02.al_rbed_gravgunkick" = "<font color=\"rgb(255,212,255)\">Ouah. J'avais oublié comme ce truc avait la pêche. "
		"ep_02.al_rbed_gravgunstillworks" = "<font color=\"rgb(255,212,255)\">Pourvu qu'il marche encore. "
		"ep_02.al_rbed_haven" = "<font color=\"rgb(255,212,255)\">Bon, c'est pas un abri très sûr... "
		"ep_02.al_rbed_heardvorts01" = "<font color=\"rgb(255,212,255)\">J'ai entendu des Vortigaunts tout à l'heure. Ils sont peut-être encore là. "
		"ep_02.al_rbed_heardvorts02" = "<font color=\"rgb(255,212,255)\">On a encore beaucoup de chemin à faire avant de retrouver mon père. On aurait bien besoin de renforts. "
		"ep_02.al_rbed_help" = "<font color=\"rgb(255,212,255)\">À l'aide!"
		"ep_02.al_rbed_heregoes" = "<font color=\"rgb(255,212,255)\">C'est parti. "
		"ep_02.al_rbed_holdonsec" = "<font color=\"rgb(255,212,255)\">Une minute. Je vais vous sortir de là. "
		"ep_02.al_rbed_holdonsec_alt" = "<font color=\"rgb(255,212,255)\">Ah.Une minute, je vais vous tirer de là. "
		"ep_02.al_rbed_hopewedont01" = "<font color=\"rgb(255,212,255)\">Ça recommence comme aux premiers jours. "
		"ep_02.al_rbed_hopewedont02" = "<font color=\"rgb(255,212,255)\">J'espère qu'il n'en reste plus beaucoup. "
		"ep_02.al_rbed_hunter_breathing01" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing02" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing03" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing04" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing05" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing06" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing07" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing08" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing09" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing10" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing11" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing12" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_breathing13" = "<font color=\"rgb(255,212,255)\">[respiration difficile]"
		"ep_02.al_rbed_hunter_collapse01" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_collapse02" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_collapse03" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_collapse04" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_collapse05" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_collapse06" = "<font color=\"rgb(255,212,255)\">[cris de douleur] Aidez-moi!"
		"ep_02.al_rbed_hunter_collapse07" = "<font color=\"rgb(255,212,255)\">[cris de douleur] À l'aide..."
		"ep_02.al_rbed_hunter_collapse08" = "<font color=\"rgb(255,212,255)\">[cris de douleur] Aidez-moi!"
		"ep_02.al_rbed_hunter_collapse09" = "<font color=\"rgb(255,212,255)\">[cris de douleur] Gordon..."
		"ep_02.al_rbed_hunter_collapse10" = "<font color=\"rgb(255,212,255)\">[cris de douleur] À l'aide..."
		"ep_02.al_rbed_hunter_gordon" = "<font color=\"rgb(255,212,255)\">[cris de douleur] Gordon!"
		"ep_02.al_rbed_hunter_pain01" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_pain02" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_pain03" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_pain04" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_pain05" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_pain06" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_pain07" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hunter_pain08" = "<font color=\"rgb(255,212,255)\">[cris de douleur]"
		"ep_02.al_rbed_hurrynags01" = "<font color=\"rgb(255,212,255)\">Gordon, il y a du monde!"
		"ep_02.al_rbed_hurrynags02" = "<font color=\"rgb(255,212,255)\">Vite!"
		"ep_02.al_rbed_hurrynags03" = "<font color=\"rgb(255,212,255)\">Vite, dépêchons-nous!"
		"ep_02.al_rbed_insight" = "<font color=\"rgb(255,212,255)\">Eh, si vous savez comment réparer ça, surtout, n'hésitez pas. "
		"ep_02.al_rbed_lookbridge" = "<font color=\"rgb(255,212,255)\">Regardez. Le pont! "
		"ep_02.al_rbed_lookdoingbridge" = "<font color=\"rgb(255,212,255)\">Regardez ce que ça fait au pont!"
		"ep_02.al_rbed_lookrocks" = "<font color=\"rgb(255,212,255)\">Regardez. L'onde de choc a dû faire bouger les rochers. "
		"ep_02.al_rbed_mess" = "<font color=\"rgb(255,212,255)\">Quel souk. Ça risque de prendre du temps. "
		"ep_02.al_rbed_mindplug" = "<font color=\"rgb(255,212,255)\">Vous pouvez le brancher?"
		"ep_02.al_rbed_mineshaft01" = "<font color=\"rgb(255,212,255)\">Un puits de mine! "
		"ep_02.al_rbed_mineshaft02" = "<font color=\"rgb(255,212,255)\">Entrons par ici."
		"ep_02.al_rbed_notalone" = "<font color=\"rgb(255,212,255)\">Chut. Silence! Il y a du monde."
		"ep_02.al_rbed_notsurehow" = "<font color=\"rgb(255,212,255)\">Je ne sais pas ce que j'ai fait... mais ça marche. "
		"ep_02.al_rbed_omg" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu!"
		"ep_02.al_rbed_omgcitadel01" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu. La Citadelle! "
		"ep_02.al_rbed_omgcitadel02" = "<font color=\"rgb(255,212,255)\">Mais qu'est-ce qui se passe? "
		"ep_02.al_rbed_plugitin" = "<font color=\"rgb(255,212,255)\">Vous voyez le cordon, Gordon? Vous pourriez le brancher?"
		"ep_02.al_rbed_plususe01" = "<font color=\"rgb(255,212,255)\">Contente de vous voir aussi."
		"ep_02.al_rbed_plususe02" = "<font color=\"rgb(255,212,255)\">OK, Gordon... On continue."
		"ep_02.al_rbed_plususe03" = "<font color=\"rgb(255,212,255)\">Mm-hm, on devrait partir."
		"ep_02.al_rbed_plususe04" = "<font color=\"rgb(255,212,255)\">C'est incroyable qu'on ait survécu."
		"ep_02.al_rbed_powercord" = "<font color=\"rgb(255,212,255)\">Eh... Un cordon électrique. Qu'est-ce qu'il fait là?"
		"ep_02.al_rbed_rebel" = "<font color=\"rgb(255,212,255)\">Je parie que cet endroit été utilisé par les rebelles. "
		"ep_02.al_rbed_refugees_alt" = "<font color=\"rgb(255,212,255)\">Des réfugiés! Si seulement quelqu'un les avait prévenus pour les crabes de tête."
		"ep_02.al_rbed_refugees01" = "<font color=\"rgb(255,212,255)\">Des réfugiés.."
		"ep_02.al_rbed_refugees02" = "<font color=\"rgb(255,212,255)\">Une formation de survie en milieu hostile leur aurait été utile."
		"ep_02.al_rbed_refugees03" = "<font color=\"rgb(255,212,255)\">Si seulement quelqu'un les avait prévenus pour les crabes de tête."
		"ep_02.al_rbed_rocksshifted" = "<font color=\"rgb(255,212,255)\">Je n'avais pas remarqué ça: l'onde de choc a déplacé les rochers. "
		"ep_02.al_rbed_rocksshifted01" = "<font color=\"rgb(255,212,255)\">Je viens de le remarquer;"
		"ep_02.al_rbed_rocksshifted02" = "<font color=\"rgb(255,212,255)\">L'onde de choc a dû faire bouger les rochers. "
		"ep_02.al_rbed_seeanyway" = "<font color=\"rgb(255,212,255)\">Si vous pouviez donner un coup de main, j'apprécierais, Gordon."
		"ep_02.al_rbed_seesgravgun01" = "<font color=\"rgb(255,212,255)\">Ah."
		"ep_02.al_rbed_seesgravgun02" = "<font color=\"rgb(255,212,255)\">Le pistolet anti-gravité."
		"ep_02.al_rbed_shifted01" = "<font color=\"rgb(255,212,255)\">Quelque chose a changé..."
		"ep_02.al_rbed_shifted02" = "<font color=\"rgb(255,212,255)\">Il y a une ouverture."
		"ep_02.al_rbed_snooping" = "<font color=\"rgb(255,212,255)\">Gordon. Quelque chose se balade par ici. "
		"ep_02.al_rbed_standback" = "<font color=\"rgb(255,212,255)\">Reculez. "
		"ep_02.al_rbed_takegravgun01" = "<font color=\"rgb(255,212,255)\">Tenez. Prenez le pistolet anti-gravité. "
		"ep_02.al_rbed_takegravgun02" = "<font color=\"rgb(255,212,255)\">Vous le maniez mieux que moi. "
		"ep_02.al_rbed_toovuln" = "<font color=\"rgb(255,212,255)\">Venez. On est trop exposés ici."
		"ep_02.al_rbed_wannaplugitin" = "<font color=\"rgb(255,212,255)\">Eh Gordon? Vous pouvez le brancher?"
		"ep_02.al_rbed_whatnow01" = "<font color=\"rgb(255,212,255)\">Oh, zut. "
		"ep_02.al_rbed_whatnow02" = "<font color=\"rgb(255,212,255)\">Quoi encore. "
		"ep_02.al_rbed_whatsthat" = "<font color=\"rgb(255,212,255)\">C'est quoi? "
		"ep_02.al_rbed_whatthat" = "<font color=\"rgb(255,212,255)\">Allô? "
		"ep_02.al_rbed_whoa" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_rbed_workingagain" = "<font color=\"rgb(255,212,255)\">Voyons si je peux le faire marcher. "
		"ep_02.al_rbed_yourokay" = "<font color=\"rgb(255,212,255)\">Oh Gordon, Dieu merci vous allez bien. "
		"ep_02.al_rbed_zombies01" = "<font color=\"rgb(255,212,255)\">Des zombies! Paré pour l'attaque!"
		"ep_02.al_rbed_zombies02" = "<font color=\"rgb(255,212,255)\">Des zombies! Je m'en charge!"
		"ep_02.al_rbed_zombies03" = "<font color=\"rgb(255,212,255)\">Ou alors, c'est vous..."
		"ep_02.al_rbed_zombies04" = "<font color=\"rgb(255,212,255)\">Ou vous vous en chargez..."
		"ep_02.al_rdblk_field01" = "<font color=\"rgb(255,212,255)\">Pour aller plus loin en voiture, il va falloir désactiver ce champ de force."
		"ep_02.al_rdblk_field02" = "<font color=\"rgb(255,212,255)\">Et si je restais ici pour contrôler la population zombie pendant que vous essayez d'éteindre ce truc."
		"ep_02.al_rdblk_needboth01" = "<font color=\"rgb(255,212,255)\">Inutile d'être à deux pour défendre la voiture."
		"ep_02.al_rdblk_needboth02" = "<font color=\"rgb(255,212,255)\">Essayez de désactiver le champ de force."
		"ep_02.al_rdblk_podhid01" = "<font color=\"rgb(255,212,255)\">Donc il y avait un incubateur de conseiller ici."
		"ep_02.al_rdblk_podhid02" = "<font color=\"rgb(255,212,255)\">Et il a éclos."
		"ep_02.al_rdblk_podhid03" = "<font color=\"rgb(255,212,255)\">Va falloir foncer."
		"ep_02.al_silo_anotheralarm" = "<font color=\"rgb(255,212,255)\">Une autre alerte?"
		"ep_02.al_silo_anysooner01" = "<font color=\"rgb(255,212,255)\">Désolée, on n'a pas pu arriver plus tôt, Papa. "
		"ep_02.al_silo_anysooner02" = "<font color=\"rgb(255,212,255)\">On a fait le plus vite possible."
		"ep_02.al_silo_areyouok" = "<font color=\"rgb(255,212,255)\">Papa? Ça va?"
		"ep_02.al_silo_array01" = "<font color=\"rgb(255,212,255)\">Donc, le vieux réseau du satellite du portail marchait finalement."
		"ep_02.al_silo_basesecure01" = "<font color=\"rgb(255,212,255)\">Oui, il va bien."
		"ep_02.al_silo_basesecure02" = "<font color=\"rgb(255,212,255)\">Et grâce à lui la base est sécurisée. "
		"ep_02.al_silo_besttime01" = "<font color=\"rgb(255,212,255)\">Papa..."
		"ep_02.al_silo_besttime02" = "<font color=\"rgb(255,212,255)\">Hum, je sais que ce n'est pas le moment pour demander ça mais,"
		"ep_02.al_silo_besttime03" = "<font color=\"rgb(255,212,255)\">avec tout ce qu'elle nous a fait subir,"
		"ep_02.al_silo_besttime04" = "<font color=\"rgb(255,212,255)\">la trahison et Nova Prospekt"
		"ep_02.al_silo_bigger" = "<font color=\"rgb(255,212,255)\">Comment avance le projet?"
		"ep_02.al_silo_borealisreal01" = "<font color=\"rgb(255,212,255)\">Quoi?"
		"ep_02.al_silo_borealisreal02" = "<font color=\"rgb(255,212,255)\">Le Borealis existe... vraiment?"
		"ep_02.al_silo_breath01" = "<norepeat:10><font color=\"rgb(255,212,255)\">[respiration]"
		"ep_02.al_silo_breath02" = "<norepeat:10><font color=\"rgb(255,212,255)\">[respiration]"
		"ep_02.al_silo_bunker" = "<font color=\"rgb(255,212,255)\">On dirait l'entrée d'un bunker là devant."
		"ep_02.al_silo_bunkerentrance" = "<font color=\"rgb(255,212,255)\">Voilà l'entrée! "
		"ep_02.al_silo_cantcome01" = "<font color=\"rgb(255,212,255)\">Désolée, Gordon, mais je ne peux pas venir. "
		"ep_02.al_silo_cantcome02" = "<font color=\"rgb(255,212,255)\">Je dois aider le Dr Kleiner."
		"ep_02.al_silo_captured01" = "<font color=\"rgb(255,212,255)\">Nous avons capté des données brutes émanant de la Citadelle quand elle a explosé."
		"ep_02.al_silo_captured02" = "<font color=\"rgb(255,212,255)\">Ils ont vraiment tout fait pour les envoyer."
		"ep_02.al_silo_captured03" = "<font color=\"rgb(255,212,255)\">et ils sont sur nos talons depuis."
		"ep_02.al_silo_catchup" = "<font color=\"rgb(255,212,255)\">Rattrapez-nous quand vous aurez fini."
		"ep_02.al_silo_comefindyou" = "<font color=\"rgb(255,212,255)\">Je viendrai vous chercher tout à l'heure."
		"ep_02.al_silo_comeonin" = "<font color=\"rgb(255,212,255)\">Allez, Gordon."
		"ep_02.al_silo_coming_far" = "<font color=\"rgb(255,212,255)\">Eh Gordon, vous venez?"
		"ep_02.al_silo_coming_near" = "<font color=\"rgb(255,212,255)\">Gordon, vous venez?"
		"ep_02.al_silo_copied01" = "<font color=\"rgb(255,212,255)\">Ouais, j'ai copié tout le paquet."
		"ep_02.al_silo_copied02" = "<font color=\"rgb(255,212,255)\">Avec la transmission de Judith."
		"ep_02.al_silo_dad" = "<font color=\"rgb(255,212,255)\">Papa!"
		"ep_02.al_silo_dadshock01" = "<font color=\"rgb(255,212,255)\">Papa!"
		"ep_02.al_silo_dadshock02" = "<font color=\"rgb(255,212,255)\">Papa!"
		"ep_02.al_silo_dadtransmission" = "<font color=\"rgb(255,212,255)\">Papa."
		"ep_02.al_silo_dadtransmissionno" = "<font color=\"rgb(255,212,255)\">Papa, non!"
		"ep_02.al_silo_dogslowpoke" = "<font color=\"rgb(255,212,255)\">Ce sera pour une autre fois, lambin."
		"ep_02.al_silo_dogwins" = "<font color=\"rgb(255,212,255)\">T'as gagné ce coup-ci, Chien. "
		"ep_02.al_silo_dontgiveup01" = "<font color=\"rgb(255,212,255)\">Tenez bon, Gordon. "
		"ep_02.al_silo_dontgiveup02" = "<font color=\"rgb(255,212,255)\">Allons-y."
		"ep_02.al_silo_doyouneed01" = "<font color=\"rgb(255,212,255)\">OK."
		"ep_02.al_silo_doyouneed02" = "<font color=\"rgb(255,212,255)\">Il vous faut quelque chose?"
		"ep_02.al_silo_everythingok" = "<font color=\"rgb(255,212,255)\">Est-ce que tout va bien?"
		"ep_02.al_silo_finehere01" = "<font color=\"rgb(255,212,255)\">On sera bien ici, Gordon."
		"ep_02.al_silo_finehere02" = "<font color=\"rgb(255,212,255)\">Le Dr Kleiner a besoin de vous."
		"ep_02.al_silo_fixyouup" = "<font color=\"rgb(255,212,255)\">On dirait qu'ils vont te réparer ici."
		"ep_02.al_silo_gladtobeback" = "<font color=\"rgb(255,212,255)\">Contente d'être de retour."
		"ep_02.al_silo_gladtobehere01" = "<font color=\"rgb(255,212,255)\">Salut!"
		"ep_02.al_silo_gladtobehere02" = "<font color=\"rgb(255,212,255)\">Eh bien, on n'est pas mécontents d'être ici."
		"ep_02.al_silo_goingtobe" = "<font color=\"rgb(255,212,255)\">Tout va bien se passer."
		"ep_02.al_silo_goodteam01" = "<font color=\"rgb(255,212,255)\">Ouais."
		"ep_02.al_silo_goodteam02" = "<font color=\"rgb(255,212,255)\">On forme une bonne équipe."
		"ep_02.al_silo_gordonthankgoodness01" = "<font color=\"rgb(255,212,255)\">Gordon..."
		"ep_02.al_silo_gordonthankgoodness02" = "<font color=\"rgb(255,212,255)\">Dieu merci, vous allez bien."
		"ep_02.al_silo_gordonthankgoodness03" = "<font color=\"rgb(255,212,255)\">On a fait aussi vite que possible. "
		"ep_02.al_silo_gordonthankgoodness04" = "<font color=\"rgb(255,212,255)\">On a pu entrer qu'une fois le silo bouclé et les portes ouvertes. "
		"ep_02.al_silo_gothruhere01" = "<font color=\"rgb(255,212,255)\">Par ici, Gordon."
		"ep_02.al_silo_gothruhere02" = "<font color=\"rgb(255,212,255)\">Par ici."
		"ep_02.al_silo_gothruhere03" = "<font color=\"rgb(255,212,255)\">Après vous, Gordon."
		"ep_02.al_silo_gotthru" = "<font color=\"rgb(255,212,255)\">Ils ont reçu notre message en fin de compte."
		"ep_02.al_silo_greetrebs01" = "<font color=\"rgb(255,212,255)\">Merci. Contente d'être ici."
		"ep_02.al_silo_greetrebs02" = "<font color=\"rgb(255,212,255)\">C'est fou comme je suis contente d'être ici."
		"ep_02.al_silo_greetrebs03" = "<font color=\"rgb(255,212,255)\">Enfin en sécurité!"
		"ep_02.al_silo_greetrebs04" = "<font color=\"rgb(255,212,255)\">Laissez-nous entrer!"
		"ep_02.al_silo_hellomag" = "<font color=\"rgb(255,212,255)\">Bonjour Dr Magnusson."
		"ep_02.al_silo_hereyougo01" = "<font color=\"rgb(255,212,255)\">Et voilà. "
		"ep_02.al_silo_hereyougo02" = "<font color=\"rgb(255,212,255)\">L'eau était déjà chaude."
		"ep_02.al_silo_hereyougo03" = "<font color=\"rgb(255,212,255)\">Ça va mieux, maintenant?"
		"ep_02.al_silo_hopegothere01" = "<font color=\"rgb(255,212,255)\">Et le Cartel? "
		"ep_02.al_silo_hopegothere02" = "<font color=\"rgb(255,212,255)\">On pourra effectuer le lancement avant leur attaque?"
		"ep_02.al_silo_howlongactive01" = "<font color=\"rgb(255,212,255)\">On sait dans combien de temps le superportail sera actif?"
		"ep_02.al_silo_illcatchup" = "<font color=\"rgb(255,212,255)\">Je vous rejoins dans une minute."
		"ep_02.al_silo_imfine01" = "<font color=\"rgb(255,212,255)\">C'est moins grave qu'il n'y paraît. Ça va."
		"ep_02.al_silo_imfine02" = "<font color=\"rgb(255,212,255)\">Si, si, ça va."
		"ep_02.al_silo_imherenow01" = "<font color=\"rgb(255,212,255)\">Chut... Papa."
		"ep_02.al_silo_imherenow02" = "<font color=\"rgb(255,212,255)\">Je suis là."
		"ep_02.al_silo_imherenow03" = "<font color=\"rgb(255,212,255)\">Il ne va rien m'arriver."
		"ep_02.al_silo_inhere" = "<font color=\"rgb(255,212,255)\">Ici."
		"ep_02.al_silo_inseparable" = "<font color=\"rgb(255,212,255)\">Ils sont inséparables."
		"ep_02.al_silo_install01" = "<font color=\"rgb(255,212,255)\">Elle a parlé d'une espèce d'installation."
		"ep_02.al_silo_install02" = "<font color=\"rgb(255,212,255)\">Depuis quand n'avez-vous plus de nouvelles?"
		"ep_02.al_silo_intercomdad" = "<font color=\"rgb(255,212,255)\">Papa?"
		"ep_02.al_silo_judithnorth" = "<font color=\"rgb(255,212,255)\">Le Dr Kleiner m'a dit que Judith est partie vers le nord en hélico juste après leur arrivée, mais ne m'a pas dit pourquoi."
		"ep_02.al_silo_justhaveto01" = "<font color=\"rgb(255,212,255)\">Bon ben, il va falloir que..."
		"ep_02.al_silo_justhaveto02" = "<font color=\"rgb(255,212,255)\">Il faut juste qu'on..."
		"ep_02.al_silo_justwhat" = "<font color=\"rgb(255,212,255)\">J'ai peut-être ce que vous cherchez."
		"ep_02.al_silo_keepeye01" = "<font color=\"rgb(255,212,255)\">Je reviens tout de suite."
		"ep_02.al_silo_keepeye02" = "<font color=\"rgb(255,212,255)\">Gordon, vous le surveillez?"
		"ep_02.al_silo_leanintome01" = "<font color=\"rgb(255,212,255)\">OK..."
		"ep_02.al_silo_leanintome02" = "<font color=\"rgb(255,212,255)\">C'est bon, c'est..."
		"ep_02.al_silo_leanintome03" = "<font color=\"rgb(255,212,255)\">Prends appui sur moi."
		"ep_02.al_silo_leanintome04" = "<font color=\"rgb(255,212,255)\">Voilà."
		"ep_02.al_silo_leanintome05" = "<font color=\"rgb(255,212,255)\">Tu vas te reposer."
		"ep_02.al_silo_leanintome06" = "<font color=\"rgb(255,212,255)\">Allonge-toi."
		"ep_02.al_silo_leanintome07" = "<font color=\"rgb(255,212,255)\">Et voilà."
		"ep_02.al_silo_letdadknow" = "<font color=\"rgb(255,212,255)\">Je préviens mon père que vous allez bien."
		"ep_02.al_silo_letsgetin" = "<font color=\"rgb(255,212,255)\">Entrons."
		"ep_02.al_silo_letsgetinside" = "<font color=\"rgb(255,212,255)\">Entrons."
		"ep_02.al_silo_listentokleiner01" = "<font color=\"rgb(255,212,255)\">Écoute le Dr Kleiner, Papa."
		"ep_02.al_silo_listentokleiner02" = "<font color=\"rgb(255,212,255)\">Gordon et moi, on est tout à fait capables de faire ça. "
		"ep_02.al_silo_listentokleiner03" = "<font color=\"rgb(255,212,255)\">On va la ramener."
		"ep_02.al_silo_looklater03" = "<font color=\"rgb(255,212,255)\">C'est bon d'être enfin ici."
		"ep_02.al_silo_meetincontrolroom" = "<font color=\"rgb(255,212,255)\">On sera dans la salle de contrôle, quand vous aurez terminé."
		"ep_02.al_silo_message" = "<font color=\"rgb(255,212,255)\">Le message ne serait donc pas passé?"
		"ep_02.al_silo_neverget" = "<font color=\"rgb(255,212,255)\">Je croyais qu'on n'y arriverait jamais."
		"ep_02.al_silo_neversoglad01" = "<font color=\"rgb(255,212,255)\">Sincèrement, je n'ai jamais été si contente de le voir. "
		"ep_02.al_silo_neversoglad02" = "<font color=\"rgb(255,212,255)\">Pas vrai, mon vieux?"
		"ep_02.al_silo_nohiding01" = "<font color=\"rgb(255,212,255)\">Donc..."
		"ep_02.al_silo_nohiding02" = "<font color=\"rgb(255,212,255)\">On ne se cache plus."
		"ep_02.al_silo_noidea01" = "<font color=\"rgb(255,212,255)\">Désolée."
		"ep_02.al_silo_noidea02" = "<font color=\"rgb(255,212,255)\">Je ne savais pas."
		"ep_02.al_silo_notatall01" = "<font color=\"rgb(255,212,255)\">Pas du tout."
		"ep_02.al_silo_notatall02" = "<font color=\"rgb(255,212,255)\">Tu as entendu, Chien."
		"ep_02.al_silo_notatall03" = "<font color=\"rgb(255,212,255)\">Je vais voir papa."
		"ep_02.al_silo_notatall04" = "<font color=\"rgb(255,212,255)\">Je te retrouve après."
		"ep_02.al_silo_notatall05" = "<font color=\"rgb(255,212,255)\">Fais attention."
		"ep_02.al_silo_ohyou" = "<font color=\"rgb(255,212,255)\">[exaspération muette]"
		"ep_02.al_silo_omgdad" = "<font color=\"rgb(255,212,255)\">Papa..."
		"ep_02.al_silo_ourfight" = "<font color=\"rgb(255,212,255)\">Papa, c'est notre lutte à tous."
		"ep_02.al_silo_prepare" = "<font color=\"rgb(255,212,255)\">Prépare-toi à des conséquences imprévues."
		"ep_02.al_silo_prepare01" = "<font color=\"rgb(255,212,255)\">Papa... "
		"ep_02.al_silo_prepare02" = "<font color=\"rgb(255,212,255)\">Prépare-toi à des conséquences imprévues."
		"ep_02.al_silo_rightheredoc01" = "<font color=\"rgb(255,212,255)\">C'est ici, Dr Kleiner. "
		"ep_02.al_silo_rightheredoc02" = "<font color=\"rgb(255,212,255)\">On a des tonnes de données."
		"ep_02.al_silo_rightheredoc03" = "<font color=\"rgb(255,212,255)\">Ce qui est bizarre, c'est qu'elles étaient jointes à une transmission de Judith."
		"ep_02.al_silo_safeatlastg01" = "<font color=\"rgb(255,212,255)\">OK. Gordon  "
		"ep_02.al_silo_safeatlastg02" = "<font color=\"rgb(255,212,255)\">White Forest."
		"ep_02.al_silo_safeatlastg03" = "<font color=\"rgb(255,212,255)\">Mission accomplie. Enfin en sécurité."
		"ep_02.al_silo_sameold" = "<font color=\"rgb(255,212,255)\">Je vois qu'il n'a pas changé."
		"ep_02.al_silo_sameold01" = "<font color=\"rgb(255,212,255)\">Je vois que le Dr Magnusson n'a pas changé."
		"ep_02.al_silo_seedad01" = "<font color=\"rgb(255,212,255)\">Venez, "
		"ep_02.al_silo_seedad02" = "<font color=\"rgb(255,212,255)\">J'ai hâte de voir mon père!"
		"ep_02.al_silo_seemag" = "<font color=\"rgb(255,212,255)\">Dépêchons-nous,  Magnusson va péter un plomb s'il voit qu'on traîne."
		"ep_02.al_silo_sheok01" = "<font color=\"rgb(255,212,255)\">Elle...elle va bien?"
		"ep_02.al_silo_sheok02" = "<font color=\"rgb(255,212,255)\">Elle en avait l'air, oui..."
		"ep_02.al_silo_soafraid" = "<font color=\"rgb(255,212,255)\">J'avais si peur de ne plus te revoir."
		"ep_02.al_silo_somethings" = "<font color=\"rgb(255,212,255)\">Ils ne changeront jamais..."
		"ep_02.al_silo_starting" = "<font color=\"rgb(255,212,255)\">Oh non, c'est quoi?"
		"ep_02.al_silo_surething01" = "<font color=\"rgb(255,212,255)\">Bien sûr."
		"ep_02.al_silo_surething02" = "<font color=\"rgb(255,212,255)\">Ça va mieux maintenant! "
		"ep_02.al_silo_takegoodcare" = "<font color=\"rgb(255,212,255)\">Prenez soin de lui, OK?"
		"ep_02.al_silo_thankreb" = "<font color=\"rgb(255,212,255)\">Merci."
		"ep_02.al_silo_thanksdog" = "<font color=\"rgb(255,212,255)\">Chien, c'est bien, tu as réussi."
		"ep_02.al_silo_thereitis01" = "<font color=\"rgb(255,212,255)\">[inspiration]  "
		"ep_02.al_silo_thereitis02" = "<font color=\"rgb(255,212,255)\">Ouah."
		"ep_02.al_silo_thereitis03" = "<font color=\"rgb(255,212,255)\">La voilà."
		"ep_02.al_silo_tired01" = "<font color=\"rgb(255,212,255)\">Wow!"
		"ep_02.al_silo_tired02" = "<font color=\"rgb(255,212,255)\">Désolée."
		"ep_02.al_silo_tired03" = "<font color=\"rgb(255,212,255)\">Ça doit être la fatigue."
		"ep_02.al_silo_wait" = "<font color=\"rgb(255,212,255)\">Une minute."
		"ep_02.al_silo_waithere_far" = "<font color=\"rgb(255,212,255)\">On vous attend ici, Gordon."
		"ep_02.al_silo_waithere_near" = "<font color=\"rgb(255,212,255)\">On vous attend ici, Gordon."
		"ep_02.al_silo_wellheadover01" = "<font color=\"rgb(255,212,255)\">On arrive dès que possible."
		"ep_02.al_silo_wemadeit01" = "<font color=\"rgb(255,212,255)\">Ça y est!"
		"ep_02.al_silo_wemadeit02" = "<font color=\"rgb(255,212,255)\">On a réussi!"
		"ep_02.al_silo_whatif" = "<font color=\"rgb(255,212,255)\">Vous l'avez dé... [interruption]"
		"ep_02.al_silo_whereskleiner01" = "<font color=\"rgb(255,212,255)\">Hum, où est le Dr Kleiner?"
		"ep_02.al_silo_whereskleiner02" = "<font color=\"rgb(255,212,255)\">Il faut lui apporter ces données tout de suite."
		"ep_02.al_silo_wonder01" = "<font color=\"rgb(255,212,255)\">Au moins on arrive avant le Cartel."
		"ep_02.al_silo_wonder02" = "<font color=\"rgb(255,212,255)\">J'espère qu'ils sont prêts pour ce qui les attend."
		"ep_02.al_silo_wow" = "<font color=\"rgb(255,212,255)\">Ouah."
		"ep_02.al_silo_yougo01" = "<font color=\"rgb(255,212,255)\">Passez devant, Gordon. Je ne veux pas le laisser seul si tôt."
		"ep_02.al_silo_yougo02" = "<font color=\"rgb(255,212,255)\">Je vous rejoindrai après."
		"ep_02.al_silo_youshouldhelp" = "<font color=\"rgb(255,212,255)\">Gordon, vous devriez aider le Dr Magnusson."
		"ep_02.al_str_almosthadme" = "<font color=\"rgb(255,212,255)\">J'ai eu peur sur ce coup-là."
		"ep_02.al_str_base01" = "<font color=\"rgb(255,212,255)\">La base est quelque part par ici. "
		"ep_02.al_str_base02" = "<font color=\"rgb(255,212,255)\">Je n'y suis jamais arrivée par-là."
		"ep_02.al_str_careful" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_02.al_str_carnag01" = "<font color=\"rgb(255,212,255)\">Venez Gordon, prenez la voiture et on va faire la course avec Chien."
		"ep_02.al_str_carnag02" = "<font color=\"rgb(255,212,255)\">Il faut prendre la voiture, Gordon."
		"ep_02.al_str_carnag03" = "<font color=\"rgb(255,212,255)\">Vous pourriez amener la voiture, Gordon?"
		"ep_02.al_str_catchingup" = "<font color=\"rgb(255,212,255)\">On récupère!"
		"ep_02.al_str_closethankgod" = "<font color=\"rgb(255,212,255)\">On est enfin tout près."
		"ep_02.al_str_detour" = "<font color=\"rgb(255,212,255)\">On est bon pour un détour."
		"ep_02.al_str_dogfallen01" = "<font color=\"rgb(255,212,255)\">Chien!"
		"ep_02.al_str_dogfallen02" = "<font color=\"rgb(255,212,255)\">Chien!"
		"ep_02.al_str_dogfallen03" = "<font color=\"rgb(255,212,255)\">Ça va?"
		"ep_02.al_str_dogokay" = "<font color=\"rgb(255,212,255)\">Chien..."
		"ep_02.al_str_dograce01" = "<font color=\"rgb(255,212,255)\">Allez Gordon, allez!"
		"ep_02.al_str_dograce02" = "<font color=\"rgb(255,212,255)\">Montez, Gordon!"
		"ep_02.al_str_dograce03" = "<font color=\"rgb(255,212,255)\">On va gagner, Chien!"
		"ep_02.al_str_dograce04" = "<font color=\"rgb(255,212,255)\">On te rattrape, mon vieux!"
		"ep_02.al_str_dograce05" = "<font color=\"rgb(255,212,255)\">Non, Chien! Tu dois nous laisser gagner!"
		"ep_02.al_str_dropship01" = "<font color=\"rgb(255,212,255)\">Wow! "
		"ep_02.al_str_dropship02" = "<font color=\"rgb(255,212,255)\">Un vaisseau!"
		"ep_02.al_str_dropship03" = "<font color=\"rgb(255,212,255)\">Alors, c'est ça, le crash qu'on a entendu. "
		"ep_02.al_str_dropship04" = "<font color=\"rgb(255,212,255)\">Les guetteurs de White Forest font leur boulot."
		"ep_02.al_str_ew" = "<font color=\"rgb(255,212,255)\">Beurk..."
		"ep_02.al_str_fine01" = "<font color=\"rgb(255,212,255)\">Ça va!"
		"ep_02.al_str_fine02" = "<font color=\"rgb(255,212,255)\">Merci du coup de main!"
		"ep_02.al_str_gasp" = "<font color=\"rgb(255,212,255)\">[halètement]"
		"ep_02.al_str_getclear" = "<font color=\"rgb(255,212,255)\">Dégagez!"
		"ep_02.al_str_gettingclose01" = "<font color=\"rgb(255,212,255)\">Ça me dit quelque chose. "
		"ep_02.al_str_gettingclose02" = "<font color=\"rgb(255,212,255)\">On se rapproche."
		"ep_02.al_str_gettobase" = "<font color=\"rgb(255,212,255)\">OK, on y va."
		"ep_02.al_str_getup" = "<font color=\"rgb(255,212,255)\">Debout!"
		"ep_02.al_str_good" = "<font color=\"rgb(255,212,255)\">Bien."
		"ep_02.al_str_goodboy" = "<font color=\"rgb(255,212,255)\">Bon chien."
		"ep_02.al_str_gooddoggie" = "<font color=\"rgb(255,212,255)\">Bon chien chien..."
		"ep_02.al_str_gordonoverhere" = "<font color=\"rgb(255,212,255)\">Gordon, par ici!"
		"ep_02.al_str_great" = "<font color=\"rgb(255,212,255)\">Supeeer."
		"ep_02.al_str_hangon" = "<font color=\"rgb(255,212,255)\">Une minute!"
		"ep_02.al_str_helpagain" = "<font color=\"rgb(255,212,255)\">On va encore avoir besoin de toi."
		"ep_02.al_str_holdon" = "<font color=\"rgb(255,212,255)\">Attends!"
		"ep_02.al_str_lookoutdog" = "<font color=\"rgb(255,212,255)\">Attention, Chien!"
		"ep_02.al_str_no" = "<font color=\"rgb(255,212,255)\">Non!"
		"ep_02.al_str_ohnodog" = "<font color=\"rgb(255,212,255)\">Oh non!"
		"ep_02.al_str_ohnodog02" = "<font color=\"rgb(255,212,255)\">Oh non!"
		"ep_02.al_str_ohshistrid" = "<font color=\"rgb(255,212,255)\">Un strider!"
		"ep_02.al_str_omg" = "<font color=\"rgb(255,212,255)\">Oh mon Dieu !"
		"ep_02.al_str_onfoot" = "<font color=\"rgb(255,212,255)\">Bon, on est assez près pour éventuellement finir à pied."
		"ep_02.al_str_onourside" = "<font color=\"rgb(255,212,255)\">Heureusement que tu es là."
		"ep_02.al_str_opengate01" = "<font color=\"rgb(255,212,255)\">Eh, une minute."
		"ep_02.al_str_opengate02" = "<font color=\"rgb(255,212,255)\">Chien, ouvre cette porte!"
		"ep_02.al_str_outoftheway" = "<font color=\"rgb(255,212,255)\">Bougez de là!"
		"ep_02.al_str_overhere" = "<font color=\"rgb(255,212,255)\">Par ici, Gordon."
		"ep_02.al_str_overheregordon" = "<font color=\"rgb(255,212,255)\">Par ici, Gordon!"
		"ep_02.al_str_raceyou01" = "<font color=\"rgb(255,212,255)\">OK, Chien."
		"ep_02.al_str_raceyou02" = "<font color=\"rgb(255,212,255)\">Le premier à la base!"
		"ep_02.al_str_seeantenna01" = "<font color=\"rgb(255,212,255)\">Là-bas. "
		"ep_02.al_str_seeantenna02" = "<font color=\"rgb(255,212,255)\">Je vois une antenne!"
		"ep_02.al_str_seeantenna03" = "<font color=\"rgb(255,212,255)\">C'est sûrement White Forest!"
		"ep_02.al_str_selfserve" = "<font color=\"rgb(255,212,255)\">C'est self-service, je suppose."
		"ep_02.al_str_sentrypost" = "<font color=\"rgb(255,212,255)\">Là. Une grille. "
		"ep_02.al_str_soldiers01" = "<font color=\"rgb(255,212,255)\">Vous entendez? "
		"ep_02.al_str_soldiers02" = "<font color=\"rgb(255,212,255)\">Ça doit être des soldats de White Forest. "
		"ep_02.al_str_soldiers03" = "<font color=\"rgb(255,212,255)\">Rattrapons-les."
		"ep_02.al_str_soundgood" = "<font color=\"rgb(255,212,255)\">Ah... Ce n'est pas bon signe."
		"ep_02.al_str_soundlikecrash01" = "<font color=\"rgb(255,212,255)\">C'est quoi? "
		"ep_02.al_str_soundlikecrash02" = "<font color=\"rgb(255,212,255)\">On dirait un crash!"
		"ep_02.al_str_soundslikedog01" = "<font color=\"rgb(255,212,255)\">Mais,"
		"ep_02.al_str_soundslikedog02" = "<font color=\"rgb(255,212,255)\">On dirait..."
		"ep_02.al_str_soundslikedog03" = "<font color=\"rgb(255,212,255)\">Chien!"
		"ep_02.al_str_steponit" = "<font color=\"rgb(255,212,255)\">Montez, Gordon!"
		"ep_02.al_str_thanksagain01" = "<font color=\"rgb(255,212,255)\">C'est bon,"
		"ep_02.al_str_thanksagain02" = "<font color=\"rgb(255,212,255)\">Merci!"
		"ep_02.al_str_thatsoneway" = "<font color=\"rgb(255,212,255)\">Bon, c'est une possibilité."
		"ep_02.al_str_uhoh" = "<font color=\"rgb(255,212,255)\">Oh oh."
		"ep_02.al_str_wakeupdog01" = "<font color=\"rgb(255,212,255)\">Debout, Chien."
		"ep_02.al_str_wakeupdog02" = "<font color=\"rgb(255,212,255)\">Allez..."
		"ep_02.al_str_watchoutsoldiers01" = "<font color=\"rgb(255,212,255)\">Attention!"
		"ep_02.al_str_watchoutsoldiers02" = "<font color=\"rgb(255,212,255)\">Des soldats!"
		"ep_02.al_str_waypast01" = "<font color=\"rgb(255,212,255)\">Si on pouvait contourner ça..."
		"ep_02.al_str_waypast02" = "<font color=\"rgb(255,212,255)\">White Forest est juste après cette crête."
		"ep_02.al_str_waytogo" = "<font color=\"rgb(255,212,255)\">Voilà, c'est bien!"
		"ep_02.al_str_waytogoboy" = "<font color=\"rgb(255,212,255)\">Voilà, c'est bien!"
		"ep_02.al_str_welcome" = "<font color=\"rgb(255,212,255)\">On est près de White Forest, mais il va falloir laisser la voiture, à moins de trouver comment ouvrir cette porte."
		"ep_02.al_str_whatthehell" = "<font color=\"rgb(255,212,255)\">Qu'est-ce que?"
		"ep_02.al_str_working" = "<font color=\"rgb(255,212,255)\">Tout marche comme il faut?"
		"ep_02.al_str_wouldyoumind" = "<font color=\"rgb(255,212,255)\">S'il vous plaît..."
		"ep_02.al_str_yeah01" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_str_yeah02" = "<font color=\"rgb(255,212,255)\">Ouais!"
		"ep_02.al_str_youareok01" = "<font color=\"rgb(255,212,255)\">[Rire]"
		"ep_02.al_str_youareok02" = "<font color=\"rgb(255,212,255)\">Ça va bien!"
		"ep_02.al_str_yougothim" = "<font color=\"rgb(255,212,255)\">Bien joué!"
		"ep_02.al_throwmed01" = "<font color=\"rgb(255,212,255)\">Gordon, tenez!"
		"ep_02.al_throwmed02" = "<font color=\"rgb(255,212,255)\">Attrapez ça, Gordon!"
		"ep_02.al_throwmed03" = "<font color=\"rgb(255,212,255)\">Trousse de secours!"
		"ep_02.al_throwmed04" = "<font color=\"rgb(255,212,255)\">Gordon, voilà une trousse de secours!"
		"ep_02.al_throwmed05" = "<font color=\"rgb(255,212,255)\">Tenez, Gordon, ça peut vous servir!"
		"ep_02.al_transmit_ahno" = "<font color=\"rgb(255,212,255)\">Ah non! "
		"ep_02.al_transmit_bearings" = "<font color=\"rgb(255,212,255)\">Il faut qu'on se repère d'abord, mais on peut sûrement... "
		"ep_02.al_transmit_bldgs01" = "<font color=\"rgb(255,212,255)\">On dirait que ces bâtiments étaient encore occupés récemment. "
		"ep_02.al_transmit_bldgs02" = "<font color=\"rgb(255,212,255)\">On devrait y trouver une issue. "
		"ep_02.al_transmit_breakingup01" = "<font color=\"rgb(255,212,255)\">Papa? "
		"ep_02.al_transmit_breakingup02" = "<font color=\"rgb(255,212,255)\">Papa! "
		"ep_02.al_transmit_breakingup03" = "<font color=\"rgb(255,212,255)\">Papa! "
		"ep_02.al_transmit_breakingup04" = "<font color=\"rgb(255,212,255)\">Papa?"
		"ep_02.al_transmit_breakingup05" = "<font color=\"rgb(255,212,255)\">Je ne t'entends plus. Réponds. "
		"ep_02.al_transmit_breakingup06" = "<font color=\"rgb(255,212,255)\">Papa. Tu es là? "
		"ep_02.al_transmit_breakingup07" = "<font color=\"rgb(255,212,255)\">Papa! "
		"ep_02.al_transmit_breakthrough" = "<font color=\"rgb(255,212,255)\">Gordon. Vous avez trouvé!"
		"ep_02.al_transmit_carefulupthere01" = "<font color=\"rgb(255,212,255)\">Excellent, Gordon! "
		"ep_02.al_transmit_carefulupthere02" = "<font color=\"rgb(255,212,255)\">Attention là-haut. "
		"ep_02.al_transmit_carefulupthere03" = "<font color=\"rgb(255,212,255)\">Je vais faire le guet ici. "
		"ep_02.al_transmit_comein01" = "<font color=\"rgb(255,212,255)\">White Forest... "
		"ep_02.al_transmit_comein02" = "<font color=\"rgb(255,212,255)\">White Forest, ici Alyx Vance. Vous m'entendez? "
		"ep_02.al_transmit_comein03" = "<font color=\"rgb(255,212,255)\">White Forest, répondez. "
		"ep_02.al_transmit_comein04" = "<font color=\"rgb(255,212,255)\">White Forest, vous êtes là? "
		"ep_02.al_transmit_comein05" = "<font color=\"rgb(255,212,255)\">White Forest, répondez. Ici Alyx Vance. Vous m'entendez?"
		"ep_02.al_transmit_comeon01" = "<font color=\"rgb(255,212,255)\">Allez, par ici. "
		"ep_02.al_transmit_download01" = "<font color=\"rgb(255,212,255)\">J'ai téléchargé tout le paquet. "
		"ep_02.al_transmit_download02" = "<font color=\"rgb(255,212,255)\">Depuis, ils sont à nos trousses. "
		"ep_02.al_transmit_feedingdata01" = "<font color=\"rgb(255,212,255)\">Dans la salle de contrôle..."
		"ep_02.al_transmit_feedingdata02" = "<font color=\"rgb(255,212,255)\">Ils chargeaient de gros volumes de données directement dans la séquence de destruction centrale. "
		"ep_02.al_transmit_gordontoo" = "<font color=\"rgb(255,212,255)\">Oui, je suis avec Gordon. Ça va, on a réussi à sortir de Cité 17. "
		"ep_02.al_transmit_grabbed01" = "<font color=\"rgb(255,212,255)\">Mon Dieu. "
		"ep_02.al_transmit_grabbed02" = "<font color=\"rgb(255,212,255)\">Gordon... "
		"ep_02.al_transmit_grabbed03" = "<font color=\"rgb(255,212,255)\">Et si c'était pour ça qu'ils envoyaient tant de données de la Citadelle?"
		"ep_02.al_transmit_grabbed04" = "<font color=\"rgb(255,212,255)\">Pour que..."
		"ep_02.al_transmit_hmm01" = "<font color=\"rgb(255,212,255)\">Hmmm... "
		"ep_02.al_transmit_howgetthru" = "<font color=\"rgb(255,212,255)\">Comment on va passer? "
		"ep_02.al_transmit_huh" = "<font color=\"rgb(255,212,255)\">Hum. "
		"ep_02.al_transmit_ifiwereto" = "<font color=\"rgb(255,212,255)\">Si je devais... hm. "
		"ep_02.al_transmit_ithinkthat" = "<font color=\"rgb(255,212,255)\">Je crois que... "
		"ep_02.al_transmit_lemmefigure" = "<font color=\"rgb(255,212,255)\">Laissez-moi réfléchir. "
		"ep_02.al_transmit_lemmesee01" = "<font color=\"rgb(255,212,255)\">Hmmm... Voyons voir... "
		"ep_02.al_transmit_lemmesee02" = "<font color=\"rgb(255,212,255)\">Attendez voir... "
		"ep_02.al_transmit_letmesee01" = "<font color=\"rgb(255,212,255)\">Mmm... Voyons voir. "
		"ep_02.al_transmit_oldrocket01" = "<font color=\"rgb(255,212,255)\">Le Dr Magnusson a une vieille fusée à White Forest. "
		"ep_02.al_transmit_oldrocket02" = "<font color=\"rgb(255,212,255)\">Il espérait qu'un jour il pourrait lancer un satellite qui accéderait à l'ancien réseau établi à Black Mesa. "
		"ep_02.al_transmit_oldrocket03" = "<font color=\"rgb(255,212,255)\">Mais effectuer un lancement tant que le Cartel était intact, c'était impossible. "
		"ep_02.al_transmit_oldrocket04" = "<font color=\"rgb(255,212,255)\">Je ne sais pas trop comment le satellite pourrait fermer le portail, mais... "
		"ep_02.al_transmit_oldrocket05" = "<font color=\"rgb(255,212,255)\">On verra bien une fois sur place. "
		"ep_02.al_transmit_oldrocket06" = "<font color=\"rgb(255,212,255)\">J'y suis déjà allée, on devrait trouver facilement. "
		"ep_02.al_transmit_opengate" = "<font color=\"rgb(255,212,255)\">Eh, vous pouvez trouver un moyen d'ouvrir cette porte? "
		"ep_02.al_transmit_pickup" = "<font color=\"rgb(255,212,255)\">J'espère qu'ils n'ont pas capté ça. "
		"ep_02.al_transmit_railcar" = "<font color=\"rgb(255,212,255)\">Ouah. "
		"ep_02.al_transmit_strangecore01" = "<font color=\"rgb(255,212,255)\">T'inquiète, papa. Ça va. "
		"ep_02.al_transmit_strangecore02" = "<font color=\"rgb(255,212,255)\">Mais il se passe quelque chose de bizarre à la Citadelle. "
		"ep_02.al_transmit_thatdidtrick" = "<font color=\"rgb(255,212,255)\">Bravo, ça marche. "
		"ep_02.al_transmit_thatworked" = "<font color=\"rgb(255,212,255)\">Ça a marché. "
		"ep_02.al_transmit_tracking01" = "<font color=\"rgb(255,212,255)\">Ils sont encore sur nos traces. "
		"ep_02.al_transmit_tracking02" = "<font color=\"rgb(255,212,255)\">Il faut continuer. "
		"ep_02.al_transmit_upnorth01" = "<font color=\"rgb(255,212,255)\">Le docteur Kleiner et mon père sont au Nord dans une vieille base de missiles."
		"ep_02.al_transmit_upnorth02" = "<font color=\"rgb(255,212,255)\">J'espère qu'ils utilisent encore cette fréquence. "
		"ep_02.al_transmit_upnorth03" = "<font color=\"rgb(255,212,255)\">Ils essayent de lancer une..."
		"ep_02.al_transmit_upnorth04" = "<font color=\"rgb(255,212,255)\">Ah. Ça y est. "
		"ep_02.al_transmit_waythrough" = "<font color=\"rgb(255,212,255)\">Je peux toujours compter sur vous pour trouver une solution. "
		"ep_02.al_transmit_well01" = "<font color=\"rgb(255,212,255)\">Bon... "
		"ep_02.reb_silo_reb_art10" = "Eh bien, on n'utilisait pas d'armes. On combattait les Chasseurs à mains nues. J'en tuais environ dix, vingt par jour, juste avec mes poings."
		"ep_02.reb_silo_reb_art12" = "Sur le terrain? Non, je ne vais pas sur le terrain, moi. Je suis un opérateur radio."
		"ep_02.reb_silo_reb_art14" = "Ah non, je reste ici."
		"ep_02.reb_silo_reb_art2" = "Un AR2? Noooon... Mais un AR3, oui. Plein de fois."
		"ep_02.reb_silo_reb_art4" = "Vous êtes de la ville?"
		"ep_02.reb_silo_reb_art6" = "Eh bien, en ville... il y avait plein d'AR3."
		"ep_02.reb_silo_reb_art8" = "Pas du tout."
		"ep_02.reb_silo_reb_art1" = "Bon vous avez déjà vu un AR2?"
		"ep_02.reb_silo_reb_art11" = "Donc, sur le terrain, vous allez dégommer des chasseurs?"
		"ep_02.reb_silo_reb_art13" = "(Rouspète) Ça suffit. Partez. On n'a pas besoin de vous ici et je ne continuerai pas tant que vous serez là."
		"ep_02.reb_silo_reb_art15" = "Je ne plaisante pas, partez."
		"ep_02.reb_silo_reb_art16" = "Je ne continuerai que quand vous serez parti."
		"ep_02.reb_silo_reb_art3" = "Un AR3, ça n'existe pas."
		"ep_02.reb_silo_reb_art5" = "Non."
		"ep_02.reb_silo_reb_art7" = "Non, c'est pas vrai."
		"ep_02.reb_silo_reb_cpl1" = "Bon qu'est-ce qu'on peut faire de lui? Il ne s'occupe pas vraiment de la radio, je lui ai demandé de ne laisser personne toucher aux boutons."
		"ep_02.reb_silo_reb_cpl3" = "Peut-être qu'on pourrait enlever les boutons de la radio?"
		"ep_02.al_chop_backinsidenag01" = "<font color=\"rgb(255,212,255)\">Gordon! La voiture est prête! Revenez et on y va!"
		"ep_02.al_chop_backinsidenag02" = "<font color=\"rgb(255,212,255)\">Entrez Gordon!"
		"ep_02.al_chop_backinsidenag03" = "<font color=\"rgb(255,212,255)\">Gordon, la voiture est prête! Allons-y!"
		"ep_02.al_chop_chanceoutrun" = "<font color=\"rgb(255,212,255)\">Est-ce que c'est possible de le semer?"
		"ep_02.al_chop_didweloseit" = "<font color=\"rgb(255,212,255)\">Là! On l'a semé?"
		"ep_02.al_chop_ditch" = "<font color=\"rgb(255,212,255)\">Il ne va pas nous laisser comme ça. Voyons si on trouve un moyen de le semer."
		"ep_02.al_chop_helloutrun" = "<font color=\"rgb(255,212,255)\">Bon sang comment on va lâcher ce truc?"
		"ep_02.al_chop_itsback01" = "<font color=\"rgb(255,212,255)\">Oh non, le revoilà!"
		"ep_02.al_chop_itsback02" = "<font color=\"rgb(255,212,255)\">Il ne va pas nous laisser tranquille."
		"ep_02.al_chop_shakethisthing" = "<font color=\"rgb(255,212,255)\">Comment on va bien pouvoir de se débarrasser de ce machin?"
		"ep_02.al_chop_trytooutrun" = "<font color=\"rgb(255,212,255)\">Essayez de le semer!"
		"ep_02.al_chop_vannag01" = "<font color=\"rgb(255,212,255)\">C'est sûrement à cause de ces balises dans le fourgon."
		"ep_02.al_chop_vannag02" = "<font color=\"rgb(255,212,255)\">Le radar pointe directement sur ce fourgon."
		"ep_02.al_chop_vannag03" = "<font color=\"rgb(255,212,255)\">Comment est-ce qu'on va rentrer là-dedans?"
		"ep_02.reb_chop_autogun01" = "Ben ça pourrait être un problème."
		"ep_02.reb_chop_autogun02" = "Vous entendez la mitrailleuse là-bas?"
		"ep_02.reb_chop_autogun03" = "On réapprovisionne généralement la base de White Forest, mais depuis quelques jours, le Cartel a coupé l'accès."
		"ep_02.reb_chop_boyfriend" = "Bon, alors... c'est votre petit ami?"
		"ep_02.reb_chop_favor01" = "Hé! Par ici!"
		"ep_02.reb_chop_favor02" = "Puisque c'est vous qui nous avez ramené cet hélicoptère, vous allez nous aider à le dégommer?"
		"ep_02.reb_chop_goodluck" = "Bonne chance pour détruire cette mitrailleuse!"
		"ep_02.reb_chop_nagdoor" = "La porte est là-haut."
		"ep_02.reb_chop_nothankyou" = "Ne me remerciez pas."
		"ep_02.reb_chop_radarintro01" = "C'est une offre spéciale."
		"ep_02.reb_chop_radarintro02" = "C'est comme un radar de bord pour vous les gars. Il repère les balises comme celle-ci."
		"ep_02.reb_chop_radarintro03" = "On en a caché quelques-unes sur le terrain pour signaler des caches de secours."
		"ep_02.reb_chop_radarintro04" = "Donc, soyez à l'affût!"
		"ep_02.reb_chop_radarintro05" = "Quand le tableau de bord s'allume, il faut s'arrêter et chercher."
		"ep_02.reb_chop_shipdown03" = "La ferme!"
		"ep_02.reb_chop_shop" = "Des outils? On a un atelier là-bas. Venez, on va régler ça."
		"ep_02.reb_chop_showgun01" = "Venez voir. Je vais vous montrer."
		"ep_02.reb_chop_showgun02" = "Qu'en dites-vous?"
		"ep_02.reb_chop_showgun03" = "Vous pourrez jamais passer."
		"ep_02.reb_chop_trapdoor01" = "J'ai une porte dérobée ici pour vous faire passer de l'autre côté. "
		"ep_02.reb_chop_trapdoor02" = "Comme ça vous verrez l'arme avant qu'elle ne vous voie."
		"ep_02.reb_chop_useadrink01" = "Waouh. Incroyable comment vous leur avez renvoyé leurs mines à la figure. "
		"ep_02.reb_chop_useadrink02" = "Ah, je boirais bien un coup. Pas vous?"
		"ep_02.reb_chop_zombies01" = "Les nouveaux zombies de Cité 17 les ont retenus, mais c'est une question de temps avant que les troupes n'arrivent par ici. "
		"ep_02.reb_chop_zombies02" = "Si vous vous croyez à la hauteur, je vous laisse y aller."
		"ep_02.cpt_battle_comecloser01" = "Par ici!"
		"ep_02.cpt_battle_comecloser02" = "Approchez-vous!"
		"ep_02.cpt_battle_entrust01" = "Donc, ils nous ont envoyé Freeman? Brave homme."
		"ep_02.cpt_battle_positions01" = "Voilà, c'est tout!"
		"ep_02.cpt_battle_positions02" = "Positions de défense! Allez!"
		"ep_02.cpt_battle_sawmillhere01" = "Bon, approchez-vous."
		"ep_02.cpt_battle_sawmillhere02" = "Il y a une douzaine de striders juste au nord de nous. "
		"ep_02.cpt_battle_sawmillhere03" = "Nous devons les empêcher d'atteindre la base par le sud. "
		"ep_02.cpt_battle_sawmillhere04" = "S'ils arrivent à portée de tir du silo,"
		"ep_02.cpt_battle_sawmillhere05" = "le lancement est fichu. "
		"ep_02.cpt_battle_sawmillhere06" = "Et comme si on n'en avait pas assez avec les striders, ils sont escortés par des meutes de chasseurs. "
		"ep_02.cpt_battle_sawmillhere07" = "Avec ces saloperies, Freeman va avoir du mal à tirer avec le Magnusson. "
		"ep_02.cpt_battle_sawmillhere08" = "Maintenant je voudrais que vous... "
		"ep_02.eli_launch_adv_alyx" = "<font color=\"rgb(255,208,172)\">Alyx!"
		"ep_02.eli_launch_affirm01" = "<font color=\"rgb(255,208,172)\">Hmmm..."
		"ep_02.eli_launch_affirm02" = "<font color=\"rgb(255,208,172)\">Ouais."
		"ep_02.eli_launch_affirm03" = "<font color=\"rgb(255,208,172)\">Hmmm..."
		"ep_02.eli_launch_affirm04" = "<font color=\"rgb(255,208,172)\">Je comprends."
		"ep_02.eli_launch_ahgordon" = "<font color=\"rgb(255,208,172)\">Ah, Gordon."
		"ep_02.eli_launch_anotherattempt01" = "<font color=\"rgb(255,208,172)\">Bonne idée."
		"ep_02.eli_launch_anotherattempt02" = "<font color=\"rgb(255,208,172)\">Il est possible qu'elle essaie à nouveau."
		"ep_02.eli_launch_awe01" = "<font color=\"rgb(255,208,172)\">Oui! "
		"ep_02.eli_launch_awe02" = "<font color=\"rgb(255,208,172)\">Fantastique."
		"ep_02.eli_launch_bigpain01" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_bigpain02" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_bigpain03" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_bigpain04" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_bigpain05" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_bigpain06" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_breath01" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_breath02" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_breath03" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_breath04" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_breath05" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_breath06" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_breath07" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_brt" = "<font color=\"rgb(255,208,172)\">J'arrive, Alyx. "
		"ep_02.eli_launch_catchup" = "<font color=\"rgb(255,208,172)\">On te rejoint tout de suite, ma chérie."
		"ep_02.eli_launch_check11" = "<font color=\"rgb(255,208,172)\">Allons..."
		"ep_02.eli_launch_closeeyes" = "<font color=\"rgb(255,208,172)\">Ferme les yeux."
		"ep_02.eli_launch_constant01" = "<font color=\"rgb(255,208,172)\">Reste en contact en permanence."
		"ep_02.eli_launch_constant02" = "<font color=\"rgb(255,208,172)\">Nous n'avons aucune idée de ce qui nous attend."
		"ep_02.eli_launch_didit" = "<font color=\"rgb(255,208,172)\">On a réussi!"
		"ep_02.eli_launch_dontlook" = "<font color=\"rgb(255,208,172)\">Ne regarde pas."
		"ep_02.eli_launch_ehh" = "<font color=\"rgb(255,208,172)\">Ah oui!"
		"ep_02.eli_launch_fireworks01" = "<font color=\"rgb(255,208,172)\">Bon, sortons. "
		"ep_02.eli_launch_fireworks02" = "<font color=\"rgb(255,208,172)\">Nous verrons mieux le feu d'artifice."
		"ep_02.eli_launch_getstheidea01" = "<font color=\"rgb(255,208,172)\">Oui, oui, je crois que Gordon a compris."
		"ep_02.eli_launch_getstheidea02" = "<font color=\"rgb(255,208,172)\">On doit vraiment y aller."
		"ep_02.eli_launch_gimme01" = "<font color=\"rgb(255,208,172)\">On a réussi!"
		"ep_02.eli_launch_gimme02" = "<font color=\"rgb(255,208,172)\">Ça,"
		"ep_02.eli_launch_gimme03" = "<font color=\"rgb(255,208,172)\">Allez, allez, topez là!"
		"ep_02.eli_launch_gimme04" = "<font color=\"rgb(255,208,172)\">Allez-y!"
		"ep_02.eli_launch_gimme05" = "<font color=\"rgb(255,208,172)\">Allez!"
		"ep_02.eli_launch_givinghonor" = "<font color=\"rgb(255,208,172)\">Cet honneur devrait revenir à Gordon."
		"ep_02.eli_launch_goodluck01" = "<font color=\"rgb(255,208,172)\">Bonne chance à vous deux."
		"ep_02.eli_launch_goodluck02" = "<font color=\"rgb(255,208,172)\">Prenez soin l'un de l'autre."
		"ep_02.eli_launch_goodman01" = "<font color=\"rgb(255,208,172)\">Bien joué, Gordon."
		"ep_02.eli_launch_goodman02" = "<font color=\"rgb(255,208,172)\">Ça n'a pas dû être facile."
		"ep_02.eli_launch_gotcha" = "<font color=\"rgb(255,208,172)\">Ah, ah!"
		"ep_02.eli_launch_gotthatright01" = "<font color=\"rgb(255,208,172)\">Ça c'est sûr, ma chérie."
		"ep_02.eli_launch_gotthatright02" = "<font color=\"rgb(255,208,172)\">Nous avons plein de choses à fêter."
		"ep_02.eli_launch_gurgle01" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_gurgle02" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_gurgle03" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_gurgle04" = "<font color=\"rgb(255,208,172)\">[cri de douleur]"
		"ep_02.eli_launch_happening01" = "<font color=\"rgb(255,208,172)\">Ça marche! "
		"ep_02.eli_launch_happening02" = "<font color=\"rgb(255,208,172)\">Dieu merci."
		"ep_02.eli_launch_hastowork" = "<font color=\"rgb(255,208,172)\">Bon sang... Il faut que ça marche..."
		"ep_02.eli_launch_haveeverything" = "<font color=\"rgb(255,208,172)\">Vous avez bien tout ce qu'il vous faut?"
		"ep_02.eli_launch_hellofajob" = "<font color=\"rgb(255,208,172)\">Vous avez fait du bon boulot, mon vieux!"
		"ep_02.eli_launch_holdup" = "<font color=\"rgb(255,208,172)\">Gordon, attendez."
		"ep_02.eli_launch_holysh" = "<font color=\"rgb(255,208,172)\">C'est pas vrai!"
		"ep_02.eli_launch_iloveyou" = "<font color=\"rgb(255,208,172)\">Je t'aime."
		"ep_02.eli_launch_iloveyou_alt" = "<font color=\"rgb(255,208,172)\">Je t'aime."
		"ep_02.eli_launch_iloveyousweet" = "<font color=\"rgb(255,208,172)\">Je t'aime, ma chérie."
		"ep_02.eli_launch_info01" = "<font color=\"rgb(255,208,172)\">Bon."
		"ep_02.eli_launch_info02" = "<font color=\"rgb(255,208,172)\">Alyx, tu as toutes les informations qu'il te faut?"
		"ep_02.eli_launch_ithasto" = "<font color=\"rgb(255,208,172)\">Il le faut."
		"ep_02.eli_launch_leavesosoon01" = "<font color=\"rgb(255,208,172)\">J'aurais préféré que vous ne repartiez pas si vite."
		"ep_02.eli_launch_leavesosoon02" = "<font color=\"rgb(255,208,172)\">Si la situation n'était pas ce qu'elle est ..."
		"ep_02.eli_launch_listentome01" = "<font color=\"rgb(255,208,172)\">Alyx!"
		"ep_02.eli_launch_listentome02" = "<font color=\"rgb(255,208,172)\">Écoute-moi!"
